---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import TeacherPickerIsland from '@/components/TeacherPickerIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Classroom Random Picker — Free Student Name Selector for Teachers";
const description = "The random student picker built for classrooms. Save class rosters, ensure every student participates, add answer timers. No student data collected. Free forever.";
const canonical = "/teacher-picker";

const faqItems = [
  {
    question: "Are student names stored on your server?",
    answer: "No. Class rosters are saved only in your browser's local storage. Nothing is ever sent to our servers. The privacy badge on the tool is there because we take this seriously — especially given FERPA and COPPA requirements.",
  },
  {
    question: "How does the 'everyone gets called' mode work?",
    answer: "After each spin, the selected student is marked as called (crossed off the list). The wheel only includes uncalled students. Once everyone has been called, you see a completion message. Click 'Reset round' to start a fresh round with all students back in the pool.",
  },
  {
    question: "How does the answer timer work?",
    answer: "Set the timer length in the Pick Student tab (0 to 120 seconds, in 5-second increments). After a student is picked, the countdown starts automatically. A red color indicates the last 5 seconds. Set to 0 to disable the timer.",
  },
  {
    question: "Can I manage multiple classes?",
    answer: "Yes. Click '+ New class' to create additional class rosters. Switch between them with the class tabs at the top. Each class is stored separately in your browser. You can add, edit, and delete students in the Manage Class tab.",
  },
  {
    question: "Does this work on a smartboard or projector?",
    answer: "Yes. The interface is designed to be readable at a distance. The picked student's name appears large in the center. Works in any browser including Chromebook-native browsers used in many K-12 schools.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/teacher-picker",
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Teacher Picker", url: "https://realwheelpicker.com/teacher-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Teacher Picker</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Classroom Random Picker for Teachers
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Save your class rosters. Pick students fairly. Track who's been called.
          Add a countdown timer for answers. No student data ever leaves your browser.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 text-sm text-muted-foreground">
          <span>✅ Save multiple classes</span>
          <span>·</span>
          <span>✅ Everyone gets called</span>
          <span>·</span>
          <span>✅ Answer timer</span>
          <span>·</span>
          <span>🔒 FERPA-aware</span>
        </div>
        <p class="text-sm text-muted-foreground">Free • No account • Works on Chromebook & Smartboard</p>
      </section>

      <TeacherPickerIsland client:load />

      <section class="space-y-8 text-muted-foreground">
        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Why Random Cold Calling Improves Classroom Engagement</h2>
          <p class="leading-relaxed">
            Research published in the Journal of Educational Psychology found that random, unpredictable
            student selection increases overall classroom attention. When students know they might be called
            at any moment, they stay more focused on the lesson — not just in the minute before they think
            it's their turn.
          </p>
          <p class="leading-relaxed">
            Predictable patterns (alphabetical order, seating order, same students volunteering repeatedly)
            create "safe zones" for students who know they won't be called. Random selection eliminates
            these zones and creates equity — every student has an equal chance, every round.
          </p>
          <p class="leading-relaxed">
            The "everyone gets called" feature ensures that over a class period, no student is overlooked.
            Once the round is complete (all students have been called), you reset and start fresh. This
            balances engagement without the overhead of manually tracking who's been called.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Setup Guide — First Use in 5 Minutes</h2>
          <ol class="space-y-3">
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0">1.</span>
              <span>Open the <strong class="text-foreground">Manage Class</strong> tab and replace the demo names with your actual student roster. Type one name and press Enter to add quickly.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0">2.</span>
              <span>Add more classes using the <strong class="text-foreground">+ New class</strong> button. Each class is stored separately. Your rosters persist across sessions — you only need to enter them once.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0">3.</span>
              <span>In the <strong class="text-foreground">Pick Student</strong> tab, configure the answer timer (0 = off, or set 30–60 seconds for most question types). Display the page on your smartboard or projector.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0">4.</span>
              <span>Spin. The selected student's name appears prominently. The progress bar tracks how many students have been called this round. When everyone's been called, reset and continue.</span>
            </li>
          </ol>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Strategies for Effective Random Calling</h2>
          <ul class="space-y-2">
            <li class="flex gap-3"><span class="text-primary font-bold shrink-0">→</span><span><strong class="text-foreground">Warm call first:</strong> Give students 30 seconds to think before spinning, so they're not caught completely off guard. Random selection + preparation time reduces anxiety.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold shrink-0">→</span><span><strong class="text-foreground">Phone a friend:</strong> If the selected student doesn't know the answer, let them nominate someone from the remaining pool for help before spinning again.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold shrink-0">→</span><span><strong class="text-foreground">Remove and reset:</strong> After a complete round (everyone called), reset and spin again. This guarantees distribution without the boredom of a fixed order.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold shrink-0">→</span><span><strong class="text-foreground">Team mode:</strong> Use the <a href="/team-generator" class="text-primary hover:underline">team generator</a> at the start of class to split students into groups, then use the teacher picker within each group.</span></li>
          </ul>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4 text-sm">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Privacy & Data Notice</h2>
          <p class="leading-relaxed">
            Student names you enter are stored exclusively in your browser's localStorage — a storage
            mechanism that keeps data on your device and never transmits it to any server. We have no
            access to your class lists. Clearing your browser data removes the saved rosters.
          </p>
          <p class="leading-relaxed">
            This tool is designed with FERPA (Family Educational Rights and Privacy Act) and COPPA
            (Children's Online Privacy Protection Act) in mind. We collect no personally identifiable
            information about students. The tool functions entirely client-side.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/classroom-picker", label: "Classroom Picker", desc: "Simple random student picker, no class management needed." },
            { href: "/team-generator", label: "Team Generator", desc: "Split students into random balanced groups." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "General purpose name picker for any list." },
            { href: "/blog/classroom-random-picker", label: "Random Picker for Teachers — Guide", desc: "How to use random calling effectively in class." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:load />
  </div>
</Layout>
