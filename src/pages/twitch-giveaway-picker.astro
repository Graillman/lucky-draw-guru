---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Twitch Giveaway Picker — Live Stream Winner Selector | Real Wheel Picker";
const description = "Pick Twitch giveaway winners live on stream. Load subscriber or chat names into the wheel, spin as an OBS overlay. Cryptographically fair, no bot needed.";

const faqItems = [
  {
    question: "Can I use this as an OBS overlay?",
    answer: "Yes. Add RealWheelPicker as a Browser Source in OBS or Streamlabs. The wheel renders in the browser and can be captured, resized, and overlaid on your stream.",
  },
  {
    question: "Is this better than StreamElements or Nightbot giveaway commands?",
    answer: "Bot giveaways are fast but invisible — chat just sees 'Winner: username.' The wheel gives you a visual, hype-building moment that creates better content and more trust.",
  },
  {
    question: "Can I limit entries to subscribers?",
    answer: "We don't integrate directly with Twitch. But you can export your subscriber list from the Twitch dashboard and only load those names into the picker.",
  },
  {
    question: "How do I export Twitch chat participants?",
    answer: "Most Twitch bots (StreamElements, Nightbot) log chat. You can also use chat logging tools or the Twitch API to get a list of users who sent messages during a specific time window.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Twitch Giveaway Picker — Real Wheel Picker",
  "url": "https://realwheelpicker.com/twitch-giveaway-picker",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<Layout
  title={title}
  description={description}
  canonical="/twitch-giveaway-picker"
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Twitch Giveaway Picker", url: "https://realwheelpicker.com/twitch-giveaway-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Twitch Giveaway Picker</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Twitch Giveaway Picker — Live Draws Your Chat Will Love
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Load viewer names, spin the wheel on stream, let chat watch the draw happen in real-time. Works as an OBS overlay.
        </p>
      </section>

      <!-- How it works -->
      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How Does the Twitch Giveaway Picker Work?</h2>
        <p class="text-muted-foreground leading-relaxed">
          Collect viewer names from your Twitch chat, subscriber list, or channel points redemptions. Paste them into the wheel, share your screen, and spin to draw a winner live while your audience watches.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Twitch giveaways are best when they're live. Your viewers are already watching — they want to see the draw happen in real-time, not read a 'congratulations' message after the fact. The visual wheel spin creates a hype moment that chat goes wild for.
        </p>
      </section>

      <!-- Interactive tool -->
      <SEOPageIsland slug="twitch-giveaway-picker" client:load />

      <!-- Step-by-step guide -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Run a Twitch Giveaway Live</h2>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Setup Before Going Live</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Plan your giveaway trigger: subscriber-only, follower-only, chat command, or channel points. Open RealWheelPicker in a browser tab. In OBS/Streamlabs, add a Browser Source pointing to your picker tab, OR simply screen-share the tab when it's time to draw.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Collecting Entries During Stream</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Chat-based: Ask viewers to type a keyword like !enter in chat. Copy unique usernames from chat (most Twitch bots can export chat participants). Subscriber/follower lists: Export from Twitch Creator Dashboard &gt; Analytics &gt; Subscribers. Channel Points redemption: Create a Channel Points reward called 'Enter Giveaway' and export the redemption list.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">The Draw — Making It a Moment</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Build hype: 'We're drawing the winner in 60 seconds!' Show the loaded wheel on stream. Let chat see all the names. Count down: '3... 2... 1... SPIN!' The wheel animation creates natural suspense as it slows. React to the result — your genuine reaction is content.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">OBS/Streamlabs Integration</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Browser Source: Add a new Browser Source with the URL of your picker page. Resize to fit your layout. Window Capture: Alternatively, capture the browser window directly. Scene switching: Create a dedicated 'Giveaway' scene with the wheel prominently displayed.
          </p>
        </div>
      </section>

      <!-- Use Cases -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">Use Cases</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { emoji: "🎥", title: "Live Stream Draws", desc: "Spin on screen for chat to watch" },
            { emoji: "👥", title: "Sub Giveaways", desc: "Reward subscribers with random prizes" },
            { emoji: "🎁", title: "Chat Contests", desc: "Pick from chat command participants" },
            { emoji: "🏆", title: "Sub Milestones", desc: "Celebrate sub counts with prizes" },
            { emoji: "✨", title: "Viewer Rewards", desc: "Random rewards for active viewers" },
            { emoji: "📺", title: "OBS Overlay", desc: "Use as a visual overlay in your stream" },
          ].map((c) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center hover:scale-105 transition-all hover:border-primary/50">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-3 bg-primary/10 text-2xl">{c.emoji}</div>
              <h3 class="font-semibold text-foreground text-sm mb-1">{c.title}</h3>
              <p class="text-xs text-muted-foreground">{c.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- SEO bottom -->
      <section class="py-8 px-6 rounded-xl border bg-primary/5 border-primary/20 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Free Twitch Giveaway Picker — Live Draws Your Chat Will Love</h2>
        <p class="text-muted-foreground leading-relaxed">
          Our Twitch giveaway picker creates visual, hype-worthy live draws that are better content than any bot command. Load viewer names, spin the wheel on stream, and let chat explode when the winner is revealed. Works with OBS and Streamlabs as a browser source. For off-stream draws, see our Discord (<a href="/discord-giveaway-picker" class="text-primary hover:underline">/discord-giveaway-picker</a>) and YouTube (<a href="/youtube-giveaway-picker" class="text-primary hover:underline">/youtube-giveaway-picker</a>) pickers.
        </p>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/discord-giveaway-picker", label: "Discord Giveaway Picker", desc: "Pick winners from Discord server members or reactions." },
            { href: "/youtube-giveaway-picker", label: "YouTube Giveaway Picker", desc: "Select random winners from YouTube video comments." },
            { href: "/giveaway-picker", label: "Giveaway Picker", desc: "Run transparent prize draws for contests and promotions." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
