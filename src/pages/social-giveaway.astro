---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SocialGiveawayIsland from '@/components/SocialGiveawayIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Social Media Giveaway Picker — Import Comments & Pick Winners";
const description = "Import comments from Instagram, TikTok, YouTube, Whatnot, Discord & more. Filter by keyword, tags, duplicates. Pick a random winner with our visual spinner wheel.";
const canonical = "/social-giveaway";

const faqItems = [
  {
    question: "Which social media platforms are supported?",
    answer: "Instagram, TikTok, YouTube, Twitter/X, Facebook, Twitch, Discord, and Whatnot. Any platform where you can copy-paste comments or usernames works — just paste them in the text box.",
  },
  {
    question: "Do you connect to my social media account?",
    answer: "No. We never access your accounts or request any permissions. You paste comments manually from your platform. Everything runs in your browser — no data is sent to any server.",
  },
  {
    question: "How do I filter by tagged friends?",
    answer: "Set the 'Minimum @ tags' filter. If your giveaway rules require tagging 2 friends, set it to 2. Comments with fewer @ mentions are automatically excluded from the draw.",
  },
  {
    question: "Can I allow multiple entries per person?",
    answer: "Yes. Enable 'Allow multiple entries' and set a maximum per user. Each comment from the same person counts as a separate entry, up to your limit.",
  },
  {
    question: "Is the winner selection truly random?",
    answer: "Yes. The wheel uses crypto.getRandomValues(), a cryptographically secure random number generator. The result is impossible to predict or manipulate before the spin.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/social-giveaway",
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Social Giveaway Picker", url: "https://realwheelpicker.com/social-giveaway" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-5xl mx-auto px-4 py-8 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Social Giveaway Picker</span>
      </nav>

      <section class="text-center space-y-4">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Social Media Giveaway Picker
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Import comments from any platform. Filter by keywords, tags, and duplicate rules.
          Pick a winner with a visual, screen-recordable wheel spin.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 text-sm text-muted-foreground">
          <span>📸 Instagram</span>
          <span>·</span>
          <span>🎵 TikTok</span>
          <span>·</span>
          <span>▶️ YouTube</span>
          <span>·</span>
          <span>🛍️ Whatnot</span>
          <span>·</span>
          <span>💬 Discord</span>
          <span>·</span>
          <span>+ more</span>
        </div>
        <p class="text-sm text-muted-foreground">Free • No account • No API connection • Data stays in browser</p>
      </section>

      <SocialGiveawayIsland client:load />

      <!-- SEO content -->
      <section class="space-y-8 text-muted-foreground">
        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">The Only Free Giveaway Picker That Filters Comments</h2>
          <p class="leading-relaxed">
            Most giveaway pickers make you do the hard work first: export comments, clean the list manually,
            remove bots, check who tagged friends — and only then load the names into a wheel. Our social
            giveaway picker does all of this in one page.
          </p>
          <p class="leading-relaxed">
            Paste your raw comments — messy, unformatted, straight from the platform — and our parser
            extracts usernames automatically. Apply filters: require a specific keyword, set a minimum
            number of friend tags, remove duplicates, exclude bot patterns. The filtered list loads directly
            into the spinner wheel. Screen-record the spin, post the clip, and prove to your audience the
            draw was fair.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">How the Filters Work</h2>
          <ul class="space-y-3">
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0">→</span>
              <span><strong class="text-foreground">Required keyword:</strong> Only participants whose comment contains a specific word or phrase are included. Useful when your rules say "comment ENTER to participate" or require a specific hashtag.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0">→</span>
              <span><strong class="text-foreground">Minimum tags:</strong> Set a minimum number of @mentions. If your rules say "tag 2 friends," set this to 2 and anyone who didn't tag enough friends is excluded automatically.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0">→</span>
              <span><strong class="text-foreground">Bot filtering:</strong> Excludes accounts with suspicious username patterns — excessive numbers, no vowels, or other common bot signatures.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-primary font-bold shrink-0">→</span>
              <span><strong class="text-foreground">Duplicate handling:</strong> By default, each person gets one entry. Enable "multiple entries" for contests where commenting multiple times gives additional chances, with a configurable cap per user.</span>
            </li>
          </ul>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Privacy — Your Data Never Leaves Your Browser</h2>
          <p class="leading-relaxed">
            We don't connect to Instagram, TikTok, YouTube, or any other platform. We don't request API
            keys, OAuth tokens, or any account access. You paste the comments manually — the tool processes
            them entirely inside your browser using JavaScript. Nothing is sent to our servers. When you
            close the tab, everything disappears.
          </p>
          <p class="leading-relaxed">
            This also means the tool works with <em>any</em> platform, including niche platforms we've
            never heard of. If you can copy-paste names or comments from it, this picker handles them.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/instagram-giveaway-picker", label: "Instagram Giveaway Picker", desc: "Dedicated picker for Instagram comments." },
            { href: "/giveaway-picker", label: "Giveaway Picker", desc: "Simple giveaway wheel for any list of names." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random name from any list." },
            { href: "/templates", label: "All Templates", desc: "50 pre-loaded wheel templates for every occasion." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:load />
  </div>
</Layout>
