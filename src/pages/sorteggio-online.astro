---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import AdPlaceholder from '@/components/AdPlaceholder';
import { ArrowRight, Check } from 'lucide-react';

const title = "Sorteggio Online Gratis — Ruota della Fortuna per Estrazioni | Real Wheel Picker";
const description = "Fai estrazioni online giuste e trasparenti. Aggiungi i partecipanti, gira la ruota e scegli il vincitore casualmente. Gratis, senza registrazione, casuale crittografico.";
const canonical = "/sorteggio-online";
const locale = "it_IT";
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Sorteggio Online — Real Wheel Picker",
      "url": "https://realwheelpicker.com/sorteggio-online",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "description": "Effettua sorteggi online gratis con casualità crittografica. Aggiungi partecipanti, gira la ruota e scegli il vincitore.",
      "inLanguage": "it",
    },,
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Questo sorteggio online è davvero casuale e giusto?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì. Real Wheel Picker usa window.crypto.getRandomValues(), lo standard crittografico dei browser moderni. È lo stesso livello di casualità usato nell'online banking. Nessun partecipante ha più probabilità degli altri." },
        },
        {
          "@type": "Question",
          "name": "Quanti partecipanti posso aggiungere?",
          "acceptedAnswer": { "@type": "Answer", "text": "Puoi aggiungere quanti partecipanti vuoi. Clicca su qualsiasi nome per modificarlo e aggiungine altri. La ruota si adatta automaticamente." },
        },
        {
          "@type": "Question",
          "name": "Posso usarlo per sorteggi su Instagram o TikTok?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sì. Copia i nomi dai commenti, aggiungili alla ruota e registra lo schermo mentre giri. È trasparente e verificabile per il tuo pubblico." },
        },
      ],
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Sorteggio Online" },
      ],
    },
  ],
};

const defaultParticipants = [
  { pseudo: "Partecipante 1", weight: 1 },
  { pseudo: "Partecipante 2", weight: 1 },
  { pseudo: "Partecipante 3", weight: 1 },
  { pseudo: "Partecipante 4", weight: 1 },
];

const USI = [
  "Estrazioni su Instagram — commenti e like",
  "Lotterie e raccolte fondi",
  "Sorteggi in diretta su YouTube o TikTok",
  "Selezione vincitori nei concorsi",
  "Scegliere compiti o turni in classe",
  "Qualsiasi concorso online o di persona",
];
---

<Layout title={title} description={description} canonical={canonical} locale={locale} jsonLd={jsonLd}
  hreflangLinks={[
    { hreflang: 'en',       href: 'https://realwheelpicker.com/' },
    { hreflang: 'fr',       href: 'https://realwheelpicker.com/tirage-au-sort' },
    { hreflang: 'es',       href: 'https://realwheelpicker.com/sorteo-online' },
    { hreflang: 'pt',       href: 'https://realwheelpicker.com/sorteio-online' },
    { hreflang: 'it',       href: 'https://realwheelpicker.com/sorteggio-online' },
    { hreflang: 'de',       href: 'https://realwheelpicker.com/zufallsgenerator' },
    { hreflang: 'x-default', href: 'https://realwheelpicker.com/' },
  ]}
>
  <div class="relative min-h-screen overflow-hidden" style="background: var(--gradient-bg)">
    <div aria-hidden class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div class="aurora-orb aurora-orb-gold"></div>
      <div class="aurora-orb aurora-orb-purple"></div>
      <div class="aurora-orb aurora-orb-blue"></div>
    </div>
    <div class="relative z-10">
      <HeaderIsland client:load />
      <main class="max-w-5xl mx-auto px-4 py-8 space-y-10">

        <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span>/</span>
          <span class="text-foreground">Sorteggio Online</span>
        </nav>

        <section class="text-center space-y-4 py-2">
          <h1 class="text-2xl md:text-4xl font-bold text-foreground leading-tight">
            Sorteggio Online Gratis — Ruota per Scegliere il Vincitore
          </h1>
          <p class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto">
            Fai sorteggi giusti e trasparenti in pochi secondi. Aggiungi i partecipanti, gira la ruota e scegli il vincitore con casualità crittografica. Senza registrazione, completamente gratis.
          </p>
        </section>

        <section class="bg-card border border-border rounded-xl p-5 text-sm text-muted-foreground leading-relaxed">
          <p>
            <strong class="text-foreground">Sorteggio online:</strong> Aggiungi i nomi dei partecipanti, clicca su Gira la Ruota e il sistema sceglie un vincitore casualmente usando <code>window.crypto.getRandomValues()</code>. Ogni partecipante ha esattamente la stessa probabilità di vincere. Trasparente, verificabile, gratuito.
          </p>
        </section>

        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />

        <section class="space-y-4">
          <h2 class="text-xl font-bold text-foreground">A cosa serve questo strumento</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {USI.map((uso, i) => (
              <li class="flex items-start gap-3 bg-card border border-border rounded-xl p-4">
                <Check className="w-5 h-5 text-primary mt-0.5 shrink-0" />
                <span class="text-sm text-muted-foreground">{uso}</span>
              </li>
            ))}
          </ul>
        </section>

        <AdPlaceholder position="after-use-cases" client:visible />

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Domande frequenti</h2>
          <div class="space-y-3">
            {[
              ["Questo sorteggio online è davvero casuale e giusto?", "Sì. Usiamo window.crypto.getRandomValues(), lo standard crittografico dei browser moderni. Nessun partecipante ha più probabilità degli altri."],
              ["Quanti partecipanti posso aggiungere?", "Quanti ne vuoi. Clicca su qualsiasi nome per modificarlo e aggiungine altri. La ruota si adatta automaticamente."],
              ["Posso usarlo per sorteggi su Instagram o TikTok?", "Sì. Copia i nomi dai commenti, aggiungili alla ruota e registra lo schermo mentre giri. Trasparente e verificabile per il tuo pubblico."],
              ["È gratuito?", "Completamente gratuito. Senza registrazione, senza download, senza pagamenti."],
            ].map(([q, a], i) => (
              <div class="bg-card border border-border rounded-xl p-5">
                <p class="font-semibold text-foreground mb-2">{q}</p>
                <p class="text-muted-foreground">{a}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="text-center py-6">
          <a href="/" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition-opacity">
            Strumento completo <ArrowRight className="w-4 h-4" />
          </a>
        </section>

        <AdPlaceholder position="bottom" client:visible />
      </main>
      <GlobalFooterIsland client:idle />
    </div>
  </div>
</Layout>
