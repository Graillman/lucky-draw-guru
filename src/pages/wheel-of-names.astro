---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Wheel of Names — Free Random Name Picker | Spin Now";
const description = "Spin the wheel to pick a random name. Cryptographically fair, zero tracking, works on any device. Used by teachers, streamers, and teams worldwide.";

const faqItems = [
  {
    question: "Is this wheel of names really random?",
    answer: "Yes. We use crypto.getRandomValues(), a cryptographically secure random number generator built into every modern browser. This is the same technology used in SSL encryption, password generation, and online banking. Each spin is independent — previous results have zero influence on the next one.",
  },
  {
    question: "Can I rig or manipulate the result?",
    answer: "No. The randomness is generated by your device's hardware entropy pool, not by our code. Even we couldn't predict or manipulate the outcome. The entire application runs client-side — there's no server that could intervene.",
  },
  {
    question: "How many names can I add?",
    answer: "There's no hard limit. The wheel handles hundreds of names smoothly. For very large lists (500+), the text on each segment gets smaller but remains readable.",
  },
  {
    question: "Do you save or store my name list?",
    answer: "Never. Your data stays in your browser's memory and disappears when you close the tab. We don't use cookies to track your lists, and nothing is sent to any server.",
  },
  {
    question: "Can I use this for a legal giveaway or raffle?",
    answer: "Our tool provides verifiably random selection, which satisfies the fairness requirement of most giveaway rules. However, giveaway legality depends on your local laws — we recommend checking the contest regulations in your country or state. Screen-recording the spin is a good practice for transparency.",
  },
  {
    question: "Does it work on mobile?",
    answer: "Fully. The wheel is responsive and touch-optimized. Swipe or tap to spin on any smartphone or tablet.",
  },
  {
    question: "What's the difference between this and Wheel of Names?",
    answer: "RealWheelPicker is built on a modern stack (Astro + TypeScript) for faster load times and better mobile performance. We use the same cryptographic randomness standard but with a cleaner interface, no account required, and zero data collection.",
  },
  {
    question: "Can I share my wheel configuration with someone?",
    answer: "You can bookmark or share the page URL. Custom shareable wheel links with saved configurations are coming soon.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Wheel of Names — Real Wheel Picker",
  "url": "https://realwheelpicker.com/wheel-of-names",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<Layout
  title={title}
  description={description}
  canonical="/wheel-of-names"
  jsonLd={jsonLd}
  hreflangLinks={[
    { hreflang: 'en',       href: 'https://realwheelpicker.com/wheel-of-names' },
    { hreflang: 'fr',       href: 'https://realwheelpicker.com/roue-des-noms' },
    { hreflang: 'es',       href: 'https://realwheelpicker.com/rueda-de-la-suerte' },
    { hreflang: 'pt',       href: 'https://realwheelpicker.com/roleta-de-nomes' },
    { hreflang: 'it',       href: 'https://realwheelpicker.com/ruota-dei-nomi' },
    { hreflang: 'de',       href: 'https://realwheelpicker.com/namenrad' },
    { hreflang: 'x-default', href: 'https://realwheelpicker.com/wheel-of-names' },
  ]}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Wheel of Names", url: "https://realwheelpicker.com/wheel-of-names" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Wheel of Names</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Wheel of Names — Pick a Random Name Instantly
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Enter names, spin the wheel, and let fate decide. Cryptographically fair. No signup. Works on any device.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- How it works — rich version -->
      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How Does This Wheel of Names Work?</h2>
        <p class="text-muted-foreground leading-relaxed">
          Type or paste your list of names into the text box. Hit the spin button. The wheel accelerates,
          slows down with realistic physics, and stops on a randomly selected name.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          The selection is powered by <code class="bg-muted px-1 rounded text-sm font-mono">crypto.getRandomValues()</code> — the same cryptographic function
          used by password managers and banking apps. Unlike <code class="bg-muted px-1 rounded text-sm font-mono">Math.random()</code>, which follows
          predictable patterns, our method pulls entropy from your operating system's hardware
          (mouse movements, keystroke timing, CPU noise). The result: each name on the wheel has
          a mathematically equal probability of being selected.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Everything runs locally in your browser. No data is sent to any server. Your name list
          stays private — we never see it, store it, or share it.
        </p>
        <div class="space-y-2 pt-2">
          <p class="font-semibold text-foreground">Quick Start in 3 Steps</p>
          <ol class="space-y-2 text-muted-foreground">
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/20 text-primary font-bold text-sm flex items-center justify-center">1</span>
              <span><strong class="text-foreground">Add names</strong> — Type them manually, paste from a spreadsheet, or drag a CSV file</span>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/20 text-primary font-bold text-sm flex items-center justify-center">2</span>
              <span><strong class="text-foreground">Spin</strong> — Click the wheel or press the spacebar</span>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/20 text-primary font-bold text-sm flex items-center justify-center">3</span>
              <span><strong class="text-foreground">Get your result</strong> — The winner appears with an option to remove them and spin again</span>
            </li>
          </ol>
        </div>
      </section>

      <!-- Interactive tool -->
      <SEOPageIsland slug="wheel-of-names" client:load />

      <!-- Step-by-step guide -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Step-by-Step Guide</h2>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">For Teachers — Random Student Picker</h3>
          <p class="text-sm text-muted-foreground">Set up a fair classroom participation system in under 60 seconds:</p>
          <ol class="space-y-2 text-sm text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span><span>Open RealWheelPicker on your classroom projector or smartboard</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span><span>Paste your class roster (one name per line)</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span><span>Spin to select a student for the next question or activity</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">4.</span><span>Click "Remove winner" to avoid picking the same student twice</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">5.</span><span>Reset the wheel at the end of class for the next session</span></li>
          </ol>
          <p class="text-sm text-muted-foreground leading-relaxed pt-1">
            Teachers using random selection report higher engagement — students pay more attention
            when they know they might be called on at any moment. It also removes the perception
            of favoritism, which matters more than most teachers realize.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">For Streamers — Live Giveaway Picker</h3>
          <p class="text-sm text-muted-foreground">Run transparent giveaways your audience actually trusts:</p>
          <ol class="space-y-2 text-sm text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span><span>Collect participant names from chat (copy-paste or export)</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span><span>Load them into the wheel</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span><span>Share your screen so viewers watch the spin live</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">4.</span><span>The physics-based animation makes it obvious the result isn't pre-determined</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">5.</span><span>Announce the winner while the confetti flies</span></li>
          </ol>
          <p class="text-sm text-muted-foreground leading-relaxed pt-1">
            Works with Twitch, YouTube Live, TikTok Live, and Discord voice channels.
            No extension or bot required — just a browser tab.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">For Offices — Decision Maker</h3>
          <p class="text-sm text-muted-foreground">End the "who's doing what" debate:</p>
          <ol class="space-y-2 text-sm text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span><span>Add team member names</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span><span>Spin for task assignments, meeting facilitators, or presentation order</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span><span>Screenshot the result for accountability</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">4.</span><span>The fairness is built-in — no one can argue with cryptographic randomness</span></li>
          </ol>
        </div>
      </section>

      <!-- Use Cases -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">When Should You Use a Wheel of Names?</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
          {[
            { emoji: "🎁", title: "Contest Winners", desc: "Select giveaway winners transparently" },
            { emoji: "🎓", title: "Student Selection", desc: "Pick students for presentations or activities" },
            { emoji: "👥", title: "Meeting Facilitator", desc: "Choose who leads the next meeting" },
            { emoji: "🏆", title: "Raffle Draws", desc: "Run fair raffles and lotteries" },
            { emoji: "✨", title: "Secret Santa", desc: "Randomly assign gift recipients" },
          ].map((c) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center hover:scale-105 transition-all hover:border-primary/50">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-3 bg-primary/10 text-2xl">{c.emoji}</div>
              <h3 class="font-semibold text-foreground text-sm mb-1">{c.title}</h3>
              <p class="text-xs text-muted-foreground">{c.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- SEO bottom -->
      <section class="py-8 px-6 rounded-xl border bg-primary/5 border-primary/20 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Free Wheel of Names — Built for Speed and Fairness</h2>
        <p class="text-muted-foreground leading-relaxed">
          RealWheelPicker started as a simple question: why do all spinner wheels look like they
          were designed in 2010? We built a wheel of names that's fast, private, and genuinely
          random — not "pseudo-random" like most alternatives.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Every spin uses your device's cryptographic entropy. No accounts, no tracking, no server
          calls. The wheel loads in under a second, works offline after the first visit, and runs
          smoothly on old phones and Chromebooks alike.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          We built this for teachers who need a quick student picker between classes, for streamers
          who want their audience to trust the giveaway, and for teams who are tired of the same
          person always volunteering (or never volunteering).
        </p>
        <p class="text-muted-foreground leading-relaxed">
          All tools are free. No premium tier hiding the good features behind a paywall. If you
          find this useful, the best way to support us is to share it with someone who'd use it too.
        </p>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Same engine, different interface. Pick names from a list without the wheel animation." },
            { href: "/giveaway-picker", label: "Giveaway Picker", desc: "Run transparent prize draws for contests and promotions." },
            { href: "/team-generator", label: "Team Generator", desc: "Split a list of names into balanced random teams." },
            { href: "/roue-des-noms", label: "Roue des noms (FR)", desc: "La version française de la roue des noms, pour les enseignants et animateurs." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
