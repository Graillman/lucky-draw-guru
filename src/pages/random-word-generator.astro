---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Random Word Generator — Spin to Pick a Random Word";
const description = "Spin the wheel to generate a random word. Add any words you need — vocabulary lists, writing prompts, creative triggers, or game challenges. Free, cryptographically random.";
const canonical = "/random-word-generator";

const faqItems = [
  {
    question: "What is a random word generator?",
    answer: "A random word generator picks one word at random from a list you define. Unlike a simple random word list, this wheel lets you add your own words — vocabulary terms, writing prompts, names, themes, or anything you need. Spin and one word is selected with equal probability.",
  },
  {
    question: "How do I add my own words?",
    answer: "Click any word on the wheel to edit it. Use the + button to add more words. Each word becomes one equal segment of the wheel. You can add dozens of words — the wheel scales to fit them all.",
  },
  {
    question: "Is this good for vocabulary practice?",
    answer: "Yes. Load your vocabulary list into the wheel and spin during study sessions. The random element keeps practice unpredictable — you can't just memorize the order. Teachers use it to call on students with specific words to define.",
  },
  {
    question: "Can I use this for creative writing prompts?",
    answer: "Absolutely. Add abstract nouns, verbs, or themes — spin to pick your writing prompt for the day. The randomness forces you to write outside your comfort zone. Add 'regret', 'lighthouse', 'unexpected gift', 'lost letter' and spin for your next story opening.",
  },
  {
    question: "Can I use this for word games like charades or Taboo?",
    answer: "Yes. Add your game words and spin instead of drawing cards. One player spins while others can't see the result. Works for charades, Pictionary, Taboo, 20 questions, or any word-based game.",
  },
  {
    question: "How many words can I add?",
    answer: "There is no hard limit. The wheel handles hundreds of words. For word games and prompts, 10–30 words gives a satisfying spin. For large vocabulary lists, hundreds of entries all work correctly.",
  },
];

const defaultParticipants = [
  { pseudo: "Adventure", weight: 1 },
  { pseudo: "Silence", weight: 1 },
  { pseudo: "Mirror", weight: 1 },
  { pseudo: "Storm", weight: 1 },
  { pseudo: "Journey", weight: 1 },
  { pseudo: "Shadow", weight: 1 },
  { pseudo: "Bridge", weight: 1 },
  { pseudo: "Memory", weight: 1 },
  { pseudo: "Flame", weight: 1 },
  { pseudo: "Horizon", weight: 1 },
  { pseudo: "Puzzle", weight: 1 },
  { pseudo: "Wilderness", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Random Word Generator — Real Wheel Picker",
      "url": "https://realwheelpicker.com/random-word-generator",
      "description": description,
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "publisher": { "@type": "Organization", "name": "Real Wheel Picker", "url": "https://realwheelpicker.com" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Random Word Generator" },
      ],
    },
  ],
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Random Word Generator", url: "https://realwheelpicker.com/random-word-generator" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Random Word Generator</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Random Word Generator — Spin to Pick a Word
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Add any words to the wheel and spin for a random result. Vocabulary practice, creative writing prompts, word games, or study tools — fully customizable and cryptographically random.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Add any words</p>
      </section>

      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <section class="space-y-6">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Use the Random Word Generator</h2>
          <p class="text-muted-foreground leading-relaxed">
            The default wheel has 12 evocative words — perfect for creative writing prompts. To use it for your own purpose, click any word to replace it, use the + button to add more, and × to remove entries. The wheel adapts to any word list.
          </p>
          <div class="grid sm:grid-cols-2 gap-3 mt-2 text-sm">
            {[
              { tip: "Vocabulary practice", how: "Add your study vocabulary, spin before each flashcard session to randomize order." },
              { tip: "Writing prompts", how: "Add themes, objects, or emotions — spin for today's creative writing trigger." },
              { tip: "Word games", how: "Replace cards in charades, Pictionary, or Taboo with a wheel spin." },
              { tip: "Language learning", how: "Load target-language words and spin to quiz yourself on translations." },
            ].map((item) => (
              <div class="p-3 bg-primary/5 border border-primary/20 rounded-lg">
                <p class="font-semibold text-foreground text-xs mb-1">{item.tip}</p>
                <p class="text-xs text-muted-foreground">{item.how}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Word Lists You Can Load</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 text-sm">
            {[
              { category: "Creative writing", words: "Lighthouse, Betrayal, Last train, Storm at sea, Unopened letter, Old photograph" },
              { category: "English vocabulary", words: "Ephemeral, Serendipity, Melancholy, Lucid, Paradox, Resilience, Nostalgia" },
              { category: "Emotions", words: "Anticipation, Regret, Gratitude, Envy, Wonder, Relief, Dread, Elation" },
              { category: "Story elements", words: "The detective, A hidden map, At midnight, The last key, Wrong address, Missing page" },
              { category: "Debate topics", words: "Technology, Climate, Education, Democracy, Privacy, Wealth, Justice" },
              { category: "Poetry prompts", words: "The moon, Hands, Time, Distance, Rain, A door, What was left" },
            ].map((item) => (
              <div class="p-3 bg-card border border-border rounded-lg">
                <p class="font-semibold text-foreground text-xs mb-1">{item.category}</p>
                <p class="text-xs text-muted-foreground leading-relaxed">{item.words}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Random Word Generator for Teachers</h2>
          <p class="text-muted-foreground leading-relaxed">
            Load your weekly vocabulary list and spin during class. Students must use the selected word in a sentence, define it, or find its opposite. The spinning wheel removes the predictable "going around the room" order — every student is alert because any word could appear next.
          </p>
          <p class="text-muted-foreground text-sm leading-relaxed">
            For spelling bees, load challenge words and spin to select the next word for each contestant. Remove words after they've been used. The visual wheel is more engaging than reading from a list.
          </p>
        </div>

      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random name from any list — students, teams, or events." },
            { href: "/random-number-picker", label: "Random Number Picker", desc: "Pick any random number from a custom range." },
            { href: "/decision-wheel", label: "Decision Wheel", desc: "Add any options and spin to make a decision." },
            { href: "/", label: "Spin the Wheel", desc: "The main wheel — fully customizable for any use case." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:idle />
  </div>
</Layout>
