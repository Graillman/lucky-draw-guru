---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Yes or No Wheel — Spin for a Random Yes or No Decision";
const description = "Can't decide? Spin the yes or no wheel. Add your own options, adjust the odds, or just flip between yes and no. Free, instant, no signup.";

const faqItems = [
  {
    question: "How does the yes or no wheel work?",
    answer: "The wheel has two segments — Yes and No — with equal 50/50 odds by default. Spin the wheel and it randomly lands on one. You can customize it to add more options like Maybe, or adjust the sizes of each segment to change the odds.",
  },
  {
    question: "Can I change the odds — like 70% yes and 30% no?",
    answer: "Yes. Use the weighted picker to set Yes to 7 and No to 3. The wheel segments will reflect that ratio, giving Yes a 70% chance of winning each spin.",
  },
  {
    question: "Can I add more than just yes and no?",
    answer: "Yes. Add options like Maybe, Ask again later, Definitely not — or turn it into a full decision wheel with custom choices. Any list of options works.",
  },
  {
    question: "Is the result truly random?",
    answer: "Yes. Real Wheel Picker uses crypto.getRandomValues() — cryptographic randomness sourced from your device's hardware entropy. It's not predictable or repeatable.",
  },
  {
    question: "Can I use this as a coin flip?",
    answer: "Absolutely. A yes/no wheel with equal-sized segments is functionally equivalent to a coin flip — 50% chance of each result, each spin completely independent.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "@id": "https://realwheelpicker.com/yes-no-wheel#app",
  "name": "Yes or No Wheel — Real Wheel Picker",
  "url": "https://realwheelpicker.com/yes-no-wheel",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "publisher": {
    "@type": "Organization",
    "@id": "https://realwheelpicker.com/#organization",
    "name": "Real Wheel Picker",
    "url": "https://realwheelpicker.com"
  },
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "ratingCount": "2340",
    "bestRating": "5",
    "worstRating": "1"
  }
};
---

<Layout
  title={title}
  description={description}
  canonical="/yes-no-wheel"
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Yes or No Wheel", url: "https://realwheelpicker.com/yes-no-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Yes or No Wheel</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Yes or No Wheel — Let the Wheel Decide
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Stuck between yes and no? Spin the wheel and get a truly random answer. Adjust the odds, add more options, or keep it simple — 50/50.
        </p>
        <p class="text-sm text-muted-foreground">Free • Instant • No signup required</p>
      </section>

      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Use the Yes or No Wheel</h2>
        <div class="grid sm:grid-cols-3 gap-4 pt-2">
          {[
            { step: "1", title: "Open the wheel", desc: "Load the wheel with Yes and No already set up" },
            { step: "2", title: "Spin", desc: "Click the wheel or the Spin button for a random result" },
            { step: "3", title: "Customize (optional)", desc: "Adjust the odds or add more options like Maybe" },
          ].map(({ step, title, desc }) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center">
              <div class="w-8 h-8 rounded-full bg-primary/20 text-primary font-bold text-sm flex items-center justify-center mx-auto mb-2">{step}</div>
              <p class="font-semibold text-foreground text-sm">{title}</p>
              <p class="text-xs text-muted-foreground mt-1">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      <SEOPageIsland slug="yes-no-wheel" client:load />

      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">When to Use a Yes or No Wheel</h2>

        <div class="grid md:grid-cols-2 gap-4">
          {[
            { title: "Break a tie vote", desc: "Two people can't agree? Let the wheel cast the deciding vote. No debate, no bias — pure random." },
            { title: "Overcome decision paralysis", desc: "Sometimes you already know what you want, you just need permission. Spin the wheel and see how you feel about the result." },
            { title: "Quick coin flip without a coin", desc: "A 50/50 yes/no wheel is exactly equivalent to a coin flip. Use it when you need a fast, verifiable random choice." },
            { title: "Add randomness to games", desc: "Use it as a game mechanic — should the player get a bonus turn? Does the dice roll count? Let the wheel decide." },
            { title: "Kids' activities and chores", desc: "Who does the dishes? Does screen time get extended? Let the wheel settle it without negotiation." },
            { title: "Business decisions with a nudge", desc: "Not all decisions need a wheel — but when you're stuck between two genuinely equal options, random selection is a valid and defensible method." },
          ].map(({ title, desc }) => (
            <div class="p-5 rounded-xl border bg-card border-border space-y-2">
              <h3 class="font-bold text-foreground">{title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">The Decision Wheel: Beyond Yes and No</h2>
        <p class="text-muted-foreground leading-relaxed">
          A pure yes/no wheel is the simplest form of a decision wheel. But the same concept scales to any number of choices. Instead of "Yes" and "No," try "Option A," "Option B," and "Option C." Or add "Ask again later," "Definitely yes," and "Absolutely not" for a Magic 8-Ball style experience.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Real Wheel Picker lets you add as many options as you want. The wheel automatically adjusts segment sizes to keep proportional odds. You can also weight segments differently — for example, if you want "Yes" to have 2× the odds of "No," set Yes to weight 2 and No to weight 1.
        </p>
        <a href="/decision-wheel" class="inline-block mt-2 text-primary font-semibold hover:underline">See the Decision Wheel →</a>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/decision-wheel", label: "Decision Wheel", desc: "Spin to choose between any list of options." },
            { href: "/random-wheel", label: "Random Wheel", desc: "Fully customizable spinning wheel for any purpose." },
            { href: "/wheel-of-names", label: "Wheel of Names", desc: "The classic spinning wheel for random name selection." },
            { href: "/party-wheel", label: "Party Wheel", desc: "Fun party games and dares — spin the wheel at your next event." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
