---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import HomepageIsland from '@/components/HomepageIsland';

const title = "Spin the Wheel — Free Online Random Picker";
const description = "Spin the wheel & pick a random winner in seconds. 8 free tools: giveaways, classrooms, teams & more. Cryptographically fair, no signup required.";
const canonical = "/";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "@id": "https://realwheelpicker.com/#app",
      "name": "Real Wheel Picker",
      "url": "https://realwheelpicker.com",
      "description": "Free online spin the wheel and random picker. Cryptographically secure randomness for giveaways, classrooms, teams and more.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": [
        "Cryptographically secure random selection",
        "Weighted draws — custom probabilities per entry",
        "Multi-winner draws without replacement",
        "Giveaway mode for Instagram, TikTok, Discord",
        "Embed widget for any website",
        "50+ pre-built wheel presets",
        "No signup required",
        "Mobile and desktop"
      ],
    },
    {
      "@type": "HowTo",
      "name": "How to spin the wheel and pick a random winner",
      "description": "Use Real Wheel Picker to randomly select a winner or make a fair random decision in seconds.",
      "totalTime": "PT1M",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Add your entries", "text": "Type names or options one by one, paste a comma-separated list, or choose a pre-built template." },
        { "@type": "HowToStep", "position": 2, "name": "Click Spin the Wheel", "text": "Press the Spin button. The wheel rotates with a realistic animation and click sound powered by the Web Audio API." },
        { "@type": "HowToStep", "position": 3, "name": "Get your winner", "text": "The wheel stops on a cryptographically random winner. Copy the result, share it on social media, or spin again instantly." }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Is the random picker truly fair?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Real Wheel Picker uses the Web Crypto API (window.crypto.getRandomValues) for cryptographically secure randomness — the same standard used in online banking and encryption." } },
        { "@type": "Question", "name": "Do you store my data?", "acceptedAnswer": { "@type": "Answer", "text": "No data is sent to any server. Everything runs entirely in your browser." } },
        { "@type": "Question", "name": "Can I pick multiple winners?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Set the number of winners before spinning. Each winner is selected without replacement." } },
        { "@type": "Question", "name": "Is it free to use?", "acceptedAnswer": { "@type": "Answer", "text": "100% free with no limits on spins, entries, or winners. No account required." } }
      ]
    }
  ]
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  hreflangLinks={[
    { hreflang: 'en', href: 'https://realwheelpicker.com/' },
    { hreflang: 'fr', href: 'https://realwheelpicker.com/tirage-au-sort' },
    { hreflang: 'x-default', href: 'https://realwheelpicker.com/' },
  ]}
>
  <!-- Static h1 for SEO crawlers -->
  <h1 class="sr-only">Spin the Wheel — Free Online Random Picker</h1>
  <HeaderIsland client:load />
  <HomepageIsland client:load />

  <!-- ============================================================
       STATIC SEO CONTENT — rendered by Astro SSR, always in HTML.
       Always visible to Googlebot even when JS is disabled.
       ============================================================ -->
  <section class="max-w-4xl mx-auto px-4 py-14 space-y-14" aria-label="About Real Wheel Picker">

    <!-- Value propositions -->
    <div>
      <h2 class="text-2xl font-bold text-center mb-8">The Fairest Way to Pick a Random Winner</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center p-6 rounded-xl border border-border bg-card/60">
          <div class="text-3xl mb-3">🎯</div>
          <h3 class="font-semibold mb-2">Cryptographically Random</h3>
          <p class="text-sm text-muted-foreground">
            Every spin uses <code>crypto.getRandomValues()</code> — the same security standard
            behind banking apps and password managers. Not pseudo-random. Genuinely unpredictable.
          </p>
        </div>
        <div class="text-center p-6 rounded-xl border border-border bg-card/60">
          <div class="text-3xl mb-3">🔒</div>
          <h3 class="font-semibold mb-2">100% Private</h3>
          <p class="text-sm text-muted-foreground">
            Everything runs in your browser. No data is sent to any server.
            Your name list stays on your device and disappears when you close the tab.
          </p>
        </div>
        <div class="text-center p-6 rounded-xl border border-border bg-card/60">
          <div class="text-3xl mb-3">⚡</div>
          <h3 class="font-semibold mb-2">Instant &amp; Free</h3>
          <p class="text-sm text-muted-foreground">
            No account needed. No download. The wheel loads in under a second
            and works on any device — phones, tablets, laptops, and smartboards.
          </p>
        </div>
      </div>
    </div>

    <!-- What it's used for -->
    <div class="prose max-w-none text-muted-foreground">
      <h2 class="text-2xl font-bold text-foreground">What Can You Use This Spinner Wheel For?</h2>
      <p>
        <strong>Teachers &amp; educators:</strong> Pick which student answers next with our
        <a href="/classroom-picker" class="text-primary hover:underline">classroom picker</a>. Random selection
        increases engagement — students pay more attention when they know they could be called on.
        Use <a href="/teacher-picker" class="text-primary hover:underline">Teacher Picker</a> to manage class
        rosters, track participation, and run a countdown timer for answers.
      </p>
      <p>
        <strong>Streamers &amp; content creators:</strong> Run transparent giveaways your audience trusts.
        Spin the wheel on camera with our <a href="/giveaway-picker" class="text-primary hover:underline">giveaway picker</a>
        or import comments directly from <a href="/instagram-giveaway-picker" class="text-primary hover:underline">Instagram</a>,
        <a href="/tiktok-giveaway-picker" class="text-primary hover:underline">TikTok</a>,
        <a href="/youtube-giveaway-picker" class="text-primary hover:underline">YouTube</a>, or
        <a href="/twitch-giveaway-picker" class="text-primary hover:underline">Twitch</a>.
      </p>
      <p>
        <strong>Teams &amp; offices:</strong> Use the <a href="/team-generator" class="text-primary hover:underline">team generator</a>
        to split groups fairly, or spin to pick who leads the next standup. End the
        "who's doing what" debate with cryptographic fairness.
      </p>
      <p>
        <strong>Parties &amp; games:</strong> Can't decide what to eat? Try our
        <a href="/templates/what-to-eat-wheel" class="text-primary hover:underline">food spinner</a>.
        Party night? Load the <a href="/templates/truth-or-dare-wheel" class="text-primary hover:underline">truth or dare wheel</a>
        or <a href="/spin-the-bottle" class="text-primary hover:underline">spin the bottle</a>.
        Browse <a href="/templates" class="text-primary hover:underline">50+ pre-made templates</a> for every occasion.
      </p>
    </div>

    <!-- How it works -->
    <div class="prose max-w-none text-muted-foreground">
      <h2 class="text-2xl font-bold text-foreground">How It Works — 4 Simple Steps</h2>
      <ol>
        <li><strong>Add your entries</strong> — Type names one by one, paste from a spreadsheet, or load one of 50+ ready-made templates.</li>
        <li><strong>Customize</strong> — Pick a color theme, adjust the spin duration, enable confetti and sound effects.</li>
        <li><strong>Spin</strong> — Click the wheel or press Spacebar. Watch the physics-based animation slow down and land on a cryptographically random result.</li>
        <li><strong>Share</strong> — Copy the result, remove the winner and spin again, or share a pre-loaded wheel link with your audience.</li>
      </ol>
    </div>

    <!-- Tools grid -->
    <div>
      <h2 class="text-2xl font-bold mb-6">All Free Tools — No Signup Required</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
        <a href="/wheel-of-names" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">Wheel of Names</strong>
          <p class="text-xs text-muted-foreground mt-1">Pick a random name from your list with a spinning wheel animation</p>
        </a>
        <a href="/random-name-picker" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">Random Name Picker</strong>
          <p class="text-xs text-muted-foreground mt-1">Select names from a list without the spinning wheel animation</p>
        </a>
        <a href="/yes-or-no-wheel" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">Yes or No Wheel</strong>
          <p class="text-xs text-muted-foreground mt-1">Spin for quick binary decisions — add Maybe, Later, or custom options</p>
        </a>
        <a href="/team-generator" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">Team Generator</strong>
          <p class="text-xs text-muted-foreground mt-1">Randomly split a group of people into balanced teams</p>
        </a>
        <a href="/giveaway-picker" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">Giveaway Picker</strong>
          <p class="text-xs text-muted-foreground mt-1">Transparent winner selection for contests and giveaways</p>
        </a>
        <a href="/random-number-generator" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">Random Number Generator</strong>
          <p class="text-xs text-muted-foreground mt-1">Generate cryptographically random numbers between any range</p>
        </a>
        <a href="/weighted-random-picker" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">Weighted Random Picker</strong>
          <p class="text-xs text-muted-foreground mt-1">Assign different probabilities to each entry for custom odds</p>
        </a>
        <a href="/classroom-picker" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">Classroom Picker</strong>
          <p class="text-xs text-muted-foreground mt-1">Randomly select students for activities, questions, and projects</p>
        </a>
        <a href="/templates" class="p-4 rounded-xl border border-border bg-card/60 hover:border-primary/40 hover:shadow-md transition-all">
          <strong class="block text-foreground">50+ Templates →</strong>
          <p class="text-xs text-muted-foreground mt-1">Pre-made wheels: food, party, games, office, education, and more</p>
        </a>
      </div>
    </div>

    <!-- FAQ static -->
    <div class="space-y-4 prose max-w-none text-muted-foreground">
      <h2 class="text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
      <details class="border border-border rounded-xl p-4">
        <summary class="font-semibold text-foreground cursor-pointer">Is the random wheel truly fair?</summary>
        <p class="mt-3">Yes. Real Wheel Picker uses the Web Crypto API (<code>window.crypto.getRandomValues</code>) for cryptographically secure randomness — the same standard used in online banking and encryption. Results are genuinely unpredictable.</p>
      </details>
      <details class="border border-border rounded-xl p-4">
        <summary class="font-semibold text-foreground cursor-pointer">Do you store my data?</summary>
        <p class="mt-3">No. Everything runs entirely in your browser. No names, results, or configuration are ever sent to our servers. Your lists are saved only in your own browser's local storage, and you can clear them at any time.</p>
      </details>
      <details class="border border-border rounded-xl p-4">
        <summary class="font-semibold text-foreground cursor-pointer">Can I pick multiple winners at once?</summary>
        <p class="mt-3">Yes. Set the number of winners before spinning. Each winner is selected without replacement — the same person cannot win twice in one draw.</p>
      </details>
      <details class="border border-border rounded-xl p-4">
        <summary class="font-semibold text-foreground cursor-pointer">Does it work on mobile phones?</summary>
        <p class="mt-3">Yes. Real Wheel Picker is fully responsive and works on any modern browser — phones, tablets, Chromebooks, laptops, and smartboards. No app download required.</p>
      </details>
    </div>

  </section>

  <GlobalFooterIsland client:idle />
</Layout>
