---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import HomepageIsland from '@/components/HomepageIsland';

const title = "Spin the Wheel — Free Online Random Picker";
const description = "Spin the wheel & pick a random winner in seconds. 8 free tools: giveaways, classrooms, teams & more. Cryptographically fair, no signup required.";
const canonical = "/";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "@id": "https://realwheelpicker.com/#app",
      "name": "Real Wheel Picker",
      "url": "https://realwheelpicker.com",
      "description": "Free online spin the wheel and random picker. Cryptographically secure randomness for giveaways, classrooms, teams and more.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": [
        "Cryptographically secure random selection",
        "Weighted draws — custom probabilities per entry",
        "Multi-winner draws without replacement",
        "Giveaway mode for Instagram, TikTok, Discord",
        "Embed widget for any website",
        "50+ pre-built wheel presets",
        "No signup required",
        "Mobile and desktop"
      ],
    },
    {
      "@type": "HowTo",
      "name": "How to spin the wheel and pick a random winner",
      "description": "Use Real Wheel Picker to randomly select a winner or make a fair random decision in seconds.",
      "totalTime": "PT1M",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Add your entries", "text": "Type names or options one by one, paste a comma-separated list, or choose a pre-built template." },
        { "@type": "HowToStep", "position": 2, "name": "Click Spin the Wheel", "text": "Press the Spin button. The wheel rotates with a realistic animation and click sound powered by the Web Audio API." },
        { "@type": "HowToStep", "position": 3, "name": "Get your winner", "text": "The wheel stops on a cryptographically random winner. Copy the result, share it on social media, or spin again instantly." }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Is the random picker truly fair?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Real Wheel Picker uses the Web Crypto API (window.crypto.getRandomValues) for cryptographically secure randomness — the same standard used in online banking and encryption." } },
        { "@type": "Question", "name": "Do you store my data?", "acceptedAnswer": { "@type": "Answer", "text": "No data is sent to any server. Everything runs entirely in your browser." } },
        { "@type": "Question", "name": "Can I pick multiple winners?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Set the number of winners before spinning. Each winner is selected without replacement." } },
        { "@type": "Question", "name": "Is it free to use?", "acceptedAnswer": { "@type": "Answer", "text": "100% free with no limits on spins, entries, or winners. No account required." } }
      ]
    }
  ]
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  hreflangLinks={[
    { hreflang: 'en', href: 'https://realwheelpicker.com/' },
    { hreflang: 'fr', href: 'https://realwheelpicker.com/tirage-au-sort' },
    { hreflang: 'x-default', href: 'https://realwheelpicker.com/' },
  ]}
>
  <!-- Static h1 for SEO crawlers -->
  <h1 class="sr-only">Spin the Wheel — Free Online Random Picker</h1>
  <HeaderIsland client:load />
  <HomepageIsland client:load />

  <!-- ═══════════════════════════════════════════════════════════════
       STATIC SEO CONTENT — Rendered at build time, visible to Google
       without any JavaScript. These sections are extracted from the
       React island so Googlebot indexes them immediately.
  ══════════════════════════════════════════════════════════════════ -->
  <div style="background: var(--gradient-bg)">
    <div class="max-w-6xl mx-auto px-4 pb-12 space-y-12">

      <!-- VALUE PROPOSITION -->
      <section class="space-y-6 pt-4">
        <h2 class="text-2xl font-bold text-foreground text-center">The Fairest Way to Pick a Random Winner</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="text-center p-6 rounded-xl border border-border bg-card/60">
            <div class="text-3xl mb-3">🎯</div>
            <h3 class="font-semibold text-foreground mb-2">Cryptographically Random</h3>
            <p class="text-sm text-muted-foreground">Every spin uses crypto.getRandomValues() — the same security standard behind banking apps. Not pseudo-random. Genuinely unpredictable.</p>
          </div>
          <div class="text-center p-6 rounded-xl border border-border bg-card/60">
            <div class="text-3xl mb-3">🔒</div>
            <h3 class="font-semibold text-foreground mb-2">100% Private</h3>
            <p class="text-sm text-muted-foreground">Everything runs in your browser. No data is sent to any server. Your list stays on your device and disappears when you close the tab.</p>
          </div>
          <div class="text-center p-6 rounded-xl border border-border bg-card/60">
            <div class="text-3xl mb-3">⚡</div>
            <h3 class="font-semibold text-foreground mb-2">Instant &amp; Free</h3>
            <p class="text-sm text-muted-foreground">No account needed. No download. Works on any device — phones, tablets, laptops, and smartboards.</p>
          </div>
        </div>
      </section>

      <!-- USE CASES -->
      <section class="space-y-6 pt-4">
        <div class="text-center space-y-2">
          <h2 class="text-2xl font-bold text-foreground">When to use the spinning wheel?</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">From Instagram giveaways to classroom activities — the spinning wheel is the fairest way to make a random decision.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="p-4 rounded-xl bg-card border border-border hover:border-primary/40 transition-all">
            <p class="text-sm text-muted-foreground leading-relaxed">🎁 <strong class="text-foreground">Giveaways &amp; contests</strong> — Pick winners from Instagram, TikTok, or Discord comments fairly and transparently. Show your audience the live spin.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border hover:border-primary/40 transition-all">
            <p class="text-sm text-muted-foreground leading-relaxed">🎓 <strong class="text-foreground">Classrooms &amp; training</strong> — Select students randomly for questions, presentations, or team assignments. Fair for everyone.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border hover:border-primary/40 transition-all">
            <p class="text-sm text-muted-foreground leading-relaxed">🏢 <strong class="text-foreground">Standup meetings</strong> — Randomize who speaks first in daily standups. Keeps meetings fresh and fair.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border hover:border-primary/40 transition-all">
            <p class="text-sm text-muted-foreground leading-relaxed">🎉 <strong class="text-foreground">Party games</strong> — Truth or Dare, Never Have I Ever, random challenges. Add any options and spin.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border hover:border-primary/40 transition-all">
            <p class="text-sm text-muted-foreground leading-relaxed">🤔 <strong class="text-foreground">Dinner decisions</strong> — Can't decide where to eat? Add restaurant names and let the wheel decide.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border hover:border-primary/40 transition-all">
            <p class="text-sm text-muted-foreground leading-relaxed">📋 <strong class="text-foreground">Task delegation</strong> — Assign chores, tasks, or project responsibilities randomly. No arguments.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border hover:border-primary/40 transition-all md:col-span-2">
            <p class="text-sm text-muted-foreground leading-relaxed">🎮 <strong class="text-foreground">Presentations</strong> — Call on students, pick speakers, or decide the order of presentations.</p>
          </div>
        </div>
      </section>

      <!-- HOW TO -->
      <section class="space-y-6">
        <h2 class="text-2xl font-bold text-foreground">How to use the wheel</h2>
        <ol class="list-decimal pl-6 space-y-3 text-muted-foreground">
          <li><strong class="text-foreground">Add your entries:</strong> Type names one by one, paste a list, or use one of our pre-made templates.</li>
          <li><strong class="text-foreground">Click Spin:</strong> Hit the "Spin the Wheel" button and watch the colorful wheel rotate with smooth animation.</li>
          <li><strong class="text-foreground">Get your result:</strong> The wheel lands on a random winner. Copy the result, share it, or spin again.</li>
        </ol>
      </section>

      <!-- WHY US -->
      <section class="space-y-4">
        <h2 class="text-2xl font-bold text-foreground">Why use our random wheel?</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="p-4 rounded-xl bg-card border border-border">
            <p class="font-semibold text-foreground text-sm">100% Fair</p>
            <p class="text-xs text-muted-foreground mt-0.5">Web Crypto API — same tech as online banking.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border">
            <p class="font-semibold text-foreground text-sm">Completely Free</p>
            <p class="text-xs text-muted-foreground mt-0.5">No premium tiers, no fees, no limits on spins.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border">
            <p class="font-semibold text-foreground text-sm">No Signup</p>
            <p class="text-xs text-muted-foreground mt-0.5">Start instantly — no account, no email.</p>
          </div>
          <div class="p-4 rounded-xl bg-card border border-border">
            <p class="font-semibold text-foreground text-sm">Privacy First</p>
            <p class="text-xs text-muted-foreground mt-0.5">Everything runs in your browser. Zero data sent.</p>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          <details class="bg-card border border-border rounded-xl p-5 group">
            <summary class="font-semibold text-foreground cursor-pointer list-none flex items-center justify-between gap-2">
              Is this random picker truly fair and unbiased?
              <span class="text-muted-foreground shrink-0 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="text-muted-foreground text-sm leading-relaxed mt-3">Yes, absolutely. Our random picker uses the Web Crypto API (crypto.getRandomValues), which provides cryptographically secure random numbers. This is the same technology used by banks and security applications. Every participant has exactly equal chances in fair mode — no manipulation is possible.</p>
          </details>
          <details class="bg-card border border-border rounded-xl p-5 group">
            <summary class="font-semibold text-foreground cursor-pointer list-none flex items-center justify-between gap-2">
              Is my data safe? What do you store?
              <span class="text-muted-foreground shrink-0 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="text-muted-foreground text-sm leading-relaxed mt-3">We store absolutely nothing on our servers. Your participant list is saved only in your browser's local storage for convenience — you can clear it anytime. No cookies track you, no analytics collect personal data, and no information leaves your device. The draw runs 100% client-side.</p>
          </details>
          <details class="bg-card border border-border rounded-xl p-5 group">
            <summary class="font-semibold text-foreground cursor-pointer list-none flex items-center justify-between gap-2">
              Can I pick multiple winners at once?
              <span class="text-muted-foreground shrink-0 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="text-muted-foreground text-sm leading-relaxed mt-3">Yes! Set the number of winners before spinning. For multiple winners, we use our casino roulette visualization with numbered balls — each landing in a unique slot. Winners are selected without replacement, ensuring the same person can't win twice in a single draw.</p>
          </details>
          <details class="bg-card border border-border rounded-xl p-5 group">
            <summary class="font-semibold text-foreground cursor-pointer list-none flex items-center justify-between gap-2">
              Is it free? Are there hidden costs?
              <span class="text-muted-foreground shrink-0 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="text-muted-foreground text-sm leading-relaxed mt-3">100% free with no hidden costs, no premium tiers, no signup required. We're supported by non-intrusive ads that never interrupt your draws. Use it unlimited times with unlimited participants.</p>
          </details>
          <details class="bg-card border border-border rounded-xl p-5 group">
            <summary class="font-semibold text-foreground cursor-pointer list-none flex items-center justify-between gap-2">
              Does it work on mobile devices?
              <span class="text-muted-foreground shrink-0 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="text-muted-foreground text-sm leading-relaxed mt-3">Absolutely. Our tool is fully responsive and optimized for all devices — phones, tablets, and desktops. The wheel animations are smooth, touch-friendly, and work identically across all platforms. No app download required — just open the website.</p>
          </details>
        </div>
      </section>

      <!-- OUR TOOLS GRID -->
      <section class="space-y-6">
        <h2 class="text-2xl font-bold text-foreground text-center">Our Tools — All Free, No Signup</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/yes-or-no-wheel" class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-lg transition-all">
            <div class="text-3xl mb-2">🎲</div>
            <h3 class="font-semibold text-sm text-foreground">Yes or No Wheel</h3>
            <p class="text-xs text-muted-foreground mt-1">Quick binary decisions</p>
          </a>
          <a href="/random-number-generator" class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-lg transition-all">
            <div class="text-3xl mb-2">🔢</div>
            <h3 class="font-semibold text-sm text-foreground">Number Picker</h3>
            <p class="text-xs text-muted-foreground mt-1">Random number by spinning</p>
          </a>
          <a href="/giveaway-picker" class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-lg transition-all">
            <div class="text-3xl mb-2">🎁</div>
            <h3 class="font-semibold text-sm text-foreground">Giveaway Picker</h3>
            <p class="text-xs text-muted-foreground mt-1">Fair contest winners</p>
          </a>
          <a href="/instagram-giveaway-picker" class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-lg transition-all">
            <div class="text-3xl mb-2">📸</div>
            <h3 class="font-semibold text-sm text-foreground">Instagram Picker</h3>
            <p class="text-xs text-muted-foreground mt-1">Pick from comments</p>
          </a>
          <a href="/team-generator" class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-lg transition-all">
            <div class="text-3xl mb-2">👥</div>
            <h3 class="font-semibold text-sm text-foreground">Team Generator</h3>
            <p class="text-xs text-muted-foreground mt-1">Split into random groups</p>
          </a>
          <a href="/party-wheel" class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-lg transition-all">
            <div class="text-3xl mb-2">🎉</div>
            <h3 class="font-semibold text-sm text-foreground">Party Wheel</h3>
            <p class="text-xs text-muted-foreground mt-1">Truth or Dare &amp; more</p>
          </a>
          <a href="/classroom-picker" class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-lg transition-all">
            <div class="text-3xl mb-2">🎓</div>
            <h3 class="font-semibold text-sm text-foreground">Classroom Picker</h3>
            <p class="text-xs text-muted-foreground mt-1">Random student selector</p>
          </a>
          <a href="/weighted-random-picker" class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-lg transition-all">
            <div class="text-3xl mb-2">⚖️</div>
            <h3 class="font-semibold text-sm text-foreground">Weighted Picker</h3>
            <p class="text-xs text-muted-foreground mt-1">Custom probabilities</p>
          </a>
        </div>
      </section>

    </div>
  </div>

  <GlobalFooterIsland client:idle />
</Layout>
