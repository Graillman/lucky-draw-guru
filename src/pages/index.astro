---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import HomepageIsland from '@/components/HomepageIsland';
import HomepageSEOIsland from '@/components/HomepageSEOIsland';

const title = "Spin the Wheel — Free Online Random Picker";
const description = "Spin the wheel & pick a random winner in seconds. 8 free tools: giveaways, classrooms, teams & more. Cryptographically fair, no signup required.";
const canonical = "/";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://realwheelpicker.com/#website",
      "url": "https://realwheelpicker.com",
      "name": "Real Wheel Picker",
      "description": "Free online spin the wheel and random picker.",
      "publisher": { "@id": "https://realwheelpicker.com/#organization" }
    },
    {
      "@type": "Organization",
      "@id": "https://realwheelpicker.com/#organization",
      "name": "Real Wheel Picker",
      "url": "https://realwheelpicker.com",
      "email": "contact@realwheelpicker.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://realwheelpicker.com/og-default.png",
        "width": 1200,
        "height": 630
      },
      "sameAs": [
        "https://twitter.com/realwheelpicker"
      ]
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://realwheelpicker.com/#app",
      "name": "Real Wheel Picker",
      "url": "https://realwheelpicker.com",
      "description": "Free online spin the wheel and random picker. Cryptographically secure randomness for giveaways, classrooms, teams and more.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "publisher": { "@id": "https://realwheelpicker.com/#organization" },
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": [
        "Cryptographically secure random selection",
        "Weighted draws — custom probabilities per entry",
        "Multi-winner draws without replacement",
        "Giveaway mode for Instagram, TikTok, Discord",
        "Embed widget for any website",
        "50+ pre-built wheel presets",
        "No signup required",
        "Mobile and desktop"
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Is the random picker truly fair?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Real Wheel Picker uses the Web Crypto API (window.crypto.getRandomValues) for cryptographically secure randomness — the same standard used in online banking and encryption." } },
        { "@type": "Question", "name": "Do you store my data?", "acceptedAnswer": { "@type": "Answer", "text": "No data is sent to any server. Everything runs entirely in your browser." } },
        { "@type": "Question", "name": "Can I pick multiple winners?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Set the number of winners before spinning. Each winner is selected without replacement." } },
        { "@type": "Question", "name": "Is it free to use?", "acceptedAnswer": { "@type": "Answer", "text": "100% free with no limits on spins, entries, or winners. No account required." } }
      ]
    }
  ]
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  hreflangLinks={[
    { hreflang: 'en',      href: 'https://realwheelpicker.com/' },
    { hreflang: 'fr',      href: 'https://realwheelpicker.com/tirage-au-sort' },
    { hreflang: 'es',      href: 'https://realwheelpicker.com/sorteo-online' },
    { hreflang: 'pt',      href: 'https://realwheelpicker.com/sorteio-online' },
    { hreflang: 'it',      href: 'https://realwheelpicker.com/sorteggio-online' },
    { hreflang: 'de',      href: 'https://realwheelpicker.com/zufallsgenerator' },
    { hreflang: 'x-default', href: 'https://realwheelpicker.com/' },
  ]}
>
  <!-- Static h1 for SEO crawlers -->
  <h1 class="sr-only">Spin the Wheel — Free Online Random Picker</h1>
  <HeaderIsland client:load />
  <HomepageIsland client:load />

  <div style="background: var(--gradient-bg)">
    <HomepageSEOIsland client:visible />

    <!-- Testimonials -->
    <section class="max-w-5xl mx-auto px-4 py-12 space-y-8">
      <div class="text-center space-y-2">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground">Trusted by teachers, streamers &amp; event organizers</h2>
        <p class="text-muted-foreground text-sm">Used daily for giveaways, classrooms, team selections and more</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">

        <div class="p-5 rounded-xl border border-border bg-card space-y-3">
          <div class="flex gap-0.5 text-yellow-400 text-sm" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="text-sm text-foreground leading-relaxed">"I use this every day in my classroom to pick students. The spinning animation keeps everyone engaged — way better than just calling names."</p>
          <div class="flex items-center gap-2 pt-1 border-t border-border">
            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary shrink-0">SM</div>
            <div>
              <p class="text-xs font-semibold text-foreground">Sarah M.</p>
              <p class="text-xs text-muted-foreground">High school teacher, Texas</p>
            </div>
          </div>
        </div>

        <div class="p-5 rounded-xl border border-border bg-card space-y-3">
          <div class="flex gap-0.5 text-yellow-400 text-sm" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="text-sm text-foreground leading-relaxed">"Finally a giveaway picker I trust. The crypto randomness matters — my Twitch community can't accuse me of rigging. I use it every stream."</p>
          <div class="flex items-center gap-2 pt-1 border-t border-border">
            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary shrink-0">JK</div>
            <div>
              <p class="text-xs font-semibold text-foreground">Jake K.</p>
              <p class="text-xs text-muted-foreground">Twitch streamer, 12k followers</p>
            </div>
          </div>
        </div>

        <div class="p-5 rounded-xl border border-border bg-card space-y-3">
          <div class="flex gap-0.5 text-yellow-400 text-sm" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="text-sm text-foreground leading-relaxed">"We use this every team meeting for random team splits and activities. Simple, fast, no account needed. The weighted picker is perfect for our bonus draw."</p>
          <div class="flex items-center gap-2 pt-1 border-t border-border">
            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary shrink-0">AL</div>
            <div>
              <p class="text-xs font-semibold text-foreground">Amelia L.</p>
              <p class="text-xs text-muted-foreground">HR Manager, London</p>
            </div>
          </div>
        </div>

        <div class="p-5 rounded-xl border border-border bg-card space-y-3">
          <div class="flex gap-0.5 text-yellow-400 text-sm" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="text-sm text-foreground leading-relaxed">"The Instagram giveaway picker saved me so much time. I was scrolling comments manually before. Now I paste the list and spin in 30 seconds."</p>
          <div class="flex items-center gap-2 pt-1 border-t border-border">
            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary shrink-0">MR</div>
            <div>
              <p class="text-xs font-semibold text-foreground">Marie R.</p>
              <p class="text-xs text-muted-foreground">Beauty influencer, 45k followers</p>
            </div>
          </div>
        </div>

        <div class="p-5 rounded-xl border border-border bg-card space-y-3">
          <div class="flex gap-0.5 text-yellow-400 text-sm" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="text-sm text-foreground leading-relaxed">"Perfect for our weekly family game night — Wheel of Fortune, truth or dare, and picking who does the dishes. The kids are obsessed with watching it spin."</p>
          <div class="flex items-center gap-2 pt-1 border-t border-border">
            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary shrink-0">DP</div>
            <div>
              <p class="text-xs font-semibold text-foreground">David P.</p>
              <p class="text-xs text-muted-foreground">Dad of 3, Chicago</p>
            </div>
          </div>
        </div>

        <div class="p-5 rounded-xl border border-border bg-card space-y-3">
          <div class="flex gap-0.5 text-yellow-400 text-sm" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="text-sm text-foreground leading-relaxed">"I ran a school raffle with 200 students. Parents watched the live spin on the projector. Nobody questioned the result — everyone could see it was fair."</p>
          <div class="flex items-center gap-2 pt-1 border-t border-border">
            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary shrink-0">TC</div>
            <div>
              <p class="text-xs font-semibold text-foreground">Thomas C.</p>
              <p class="text-xs text-muted-foreground">PTA President, Seattle</p>
            </div>
          </div>
        </div>

      </div>
    </section>
  </div>

  <!-- Editorial content — visible to users and AdSense reviewers -->
  <div style="background: var(--gradient-bg)">
    <section class="max-w-4xl mx-auto px-4 py-16 space-y-12">

      <!-- What is this / Why it exists -->
      <div class="space-y-6">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground text-center">What is Real Wheel Picker and why does it exist?</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-card border border-border rounded-xl p-6 space-y-3">
            <h3 class="font-bold text-foreground text-lg">The problem with most online wheels</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">Most online spinning wheel tools use <code class="bg-muted px-1 rounded font-mono text-xs">Math.random()</code> — a pseudorandom number generator seeded by values like the system clock. The output looks random, but it is technically deterministic and reproducible. In giveaway communities, this matters: results can be challenged, questioned, or accused of manipulation with no way to disprove it.</p>
          </div>
          <div class="bg-card border border-border rounded-xl p-6 space-y-3">
            <h3 class="font-bold text-foreground text-lg">The cryptographic difference</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">Real Wheel Picker uses <code class="bg-muted px-1 rounded font-mono text-xs">crypto.getRandomValues()</code> — the Web Crypto API. It draws entropy from your device's hardware random number generator. The result is not predictable, not reproducible, and meets the same standard used in password managers, SSL certificates, and online banking. Every spin is genuinely unpredictable.</p>
          </div>
        </div>
      </div>

      <!-- Who uses it -->
      <div class="space-y-6">
        <h2 class="text-2xl font-bold text-foreground text-center">Who uses Real Wheel Picker?</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          {[
            { title: "Teachers & Educators", text: "Select students fairly for class participation, group assignments, and in-class activities. The no-repeat mode ensures every student is called before anyone is called twice — eliminating perceived favoritism.", icon: "🎓" },
            { title: "Content Creators", text: "Run transparent giveaways on Instagram, TikTok, YouTube, Discord, and Twitch. Screen-record the spin and post it as proof. Your audience watches the draw happen in real time — no rigging claims, no drama.", icon: "🎥" },
            { title: "Teams & Businesses", text: "Decide who presents first, assign tasks randomly, run Secret Santa draws, split into project teams. The weighted mode lets you give higher-ticket prizes more weight — or give long-standing employees more entries.", icon: "💼" },
          ].map(({ title, text, icon }) => (
            <div class="bg-card border border-border rounded-xl p-5 space-y-3">
              <div class="text-3xl">{icon}</div>
              <h3 class="font-bold text-foreground text-sm">{title}</h3>
              <p class="text-muted-foreground text-xs leading-relaxed">{text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- How to run a fair draw -->
      <div class="bg-card border border-border rounded-xl p-6 md:p-8 space-y-5">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to run a provably fair random draw</h2>
        <p class="text-muted-foreground text-sm leading-relaxed">Whether you're running a giveaway for 50 followers or a raffle with 5,000 entries, these steps eliminate any credible dispute about fairness:</p>
        <ol class="space-y-3">
          {[
            { n: "1", t: "Collect entries first, close submissions before loading the wheel", d: "Announce the deadline in advance. Never add or remove names after the wheel is loaded. Participants should see you paste the full list before spinning." },
            { n: "2", t: "Screen-record the entire process — list loading and spin", d: "On mobile: iOS Control Centre → Screen Record. Android: Quick Settings → Screen Record. On desktop: OBS, QuickTime, or Windows Game Bar (Win+G). Record from the moment you paste names through the full spin." },
            { n: "3", t: "Spin on a live session or post immediately", d: "Going live provides real-time proof. If not live, post the recording within minutes of spinning — delayed publication raises suspicion. Post it as a Story, Reel, or video and tag the winner." },
            { n: "4", t: "Check eligibility after the draw, not before", d: "Verify that the winner met entry requirements (followed you, liked the post, etc.) after spinning — not before. If they're ineligible, spin again and document why. Verifying before adds selection bias risk." },
          ].map(({ n, t, d }) => (
            <li class="flex gap-4">
              <span class="w-8 h-8 rounded-full bg-primary text-primary-foreground text-sm font-bold flex items-center justify-center shrink-0 mt-0.5">{n}</span>
              <div>
                <p class="font-semibold text-foreground text-sm mb-1">{t}</p>
                <p class="text-muted-foreground text-xs leading-relaxed">{d}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <!-- Tool directory -->
      <div class="space-y-5">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">All free tools — no account required</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {[
            { href: "/wheel-of-names", title: "Wheel of Names", desc: "Add names, spin to pick a random winner. The classic." },
            { href: "/random-name-picker", title: "Random Name Picker", desc: "Instant random name selection from any list." },
            { href: "/weighted-random-picker", title: "Weighted Random Picker", desc: "Assign different odds to each entry. For tiered raffles." },
            { href: "/random-picker-no-repeat", title: "No-Repeat Picker", desc: "Every name drawn once before anyone is drawn twice." },
            { href: "/giveaway-picker", title: "Giveaway Picker", desc: "Universal winner picker for any platform." },
            { href: "/team-generator", title: "Team Generator", desc: "Split any group into balanced random teams." },
            { href: "/classroom-picker", title: "Classroom Picker", desc: "Fair student selector for teachers." },
            { href: "/yes-no-wheel", title: "Yes or No Wheel", desc: "Cryptographically random 50/50 decisions." },
            { href: "/decision-wheel", title: "Decision Wheel", desc: "Spin to choose between any list of options." },
            { href: "/secret-santa-picker", title: "Secret Santa Picker", desc: "Random Secret Santa assignments with no self-picks." },
          ].map(({ href, title, desc }) => (
            <a href={href} class="flex items-start gap-3 p-4 rounded-xl border border-border bg-card hover:border-primary/40 hover:shadow-sm transition-all">
              <span class="text-primary font-bold text-sm mt-0.5 shrink-0">→</span>
              <div>
                <p class="font-semibold text-foreground text-sm">{title}</p>
                <p class="text-muted-foreground text-xs leading-snug">{desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Privacy commitment -->
      <div class="bg-primary/5 border border-primary/20 rounded-xl p-6 md:p-8 space-y-4">
        <h2 class="text-xl font-bold text-foreground">Privacy by design — your data never leaves your browser</h2>
        <p class="text-muted-foreground text-sm leading-relaxed">Every draw runs entirely in your browser. The participant names you enter, the results, the weights you assign — none of it is transmitted to any server. We have no account system, no database of past draws, and no ability to see or influence your results. The source of randomness is your own device's hardware entropy pool, not our servers. This is not a marketing claim — it is the technical consequence of using <code class="bg-muted px-1 rounded font-mono text-xs">crypto.getRandomValues()</code> client-side with no backend API calls.</p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href="/privacy-policy" class="text-xs text-primary hover:underline font-medium">Privacy Policy</a>
          <span class="text-muted-foreground text-xs">·</span>
          <a href="/about" class="text-xs text-primary hover:underline font-medium">About Real Wheel Picker</a>
          <span class="text-muted-foreground text-xs">·</span>
          <a href="/contact" class="text-xs text-primary hover:underline font-medium">Contact Us</a>
        </div>
      </div>

    </section>
  </div>

  <GlobalFooterIsland client:idle />
</Layout>
