---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Instagram Giveaway Picker — Free Comment Winner Selector";
const description = "Pick a random Instagram giveaway winner in seconds. Paste usernames, spin the wheel, screen-record the draw. 100% free, no app needed.";

const faqItems = [
  {
    question: "How do I export Instagram comments?",
    answer: "For small giveaways (under 100 comments), manually copy usernames. For larger ones, use tools like IGExport or Phantombuster to export all commenters as a list. Always deduplicate the list before loading it into the picker.",
  },
  {
    question: "Can I pick multiple winners from Instagram?",
    answer: "Yes. After the first winner is drawn, click Remove winner and spin again. Repeat for each additional winner. Each subsequent spin is equally random.",
  },
  {
    question: "Do I need to verify that entrants followed me?",
    answer: "If following is a requirement, yes. Check each winner's profile to confirm they follow you. If they don't, redraw. This is why you should screen-record: it shows you did due diligence.",
  },
  {
    question: "Is it legal to run giveaways on Instagram?",
    answer: "In most countries, free-to-enter giveaways (sweepstakes) are legal. Requiring a purchase makes it a lottery, which requires a license. Always include the Instagram disclaimer and check your local contest laws.",
  },
  {
    question: "Can I run the giveaway live on Instagram Live?",
    answer: "Absolutely — and it's the most transparent method. Open RealWheelPicker on a laptop, share your screen or point your camera at it, load the names, and spin live. Your audience watches the draw happen in real-time.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Instagram Giveaway Picker — Real Wheel Picker",
  "url": "https://realwheelpicker.com/instagram-giveaway-picker",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<Layout
  title={title}
  description={description}
  canonical="/instagram-giveaway-picker"
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Instagram Giveaway Picker", url: "https://realwheelpicker.com/instagram-giveaway-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Instagram Giveaway Picker</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Instagram Giveaway Picker — Choose Winners Your Followers Trust
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Paste Instagram usernames, spin the wheel, screen-record the draw. Cryptographic fairness your audience can see.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- How it works -->
      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How Does the Instagram Giveaway Picker Work?</h2>
        <p class="text-muted-foreground leading-relaxed">
          Collect your giveaway participants from Instagram comments, paste their usernames into the wheel, and spin to select a random winner. The selection uses cryptographic randomness — the same standard behind banking encryption — so the result is impossible to predict or manipulate.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Instagram giveaways live or die on trust. Your followers need to believe the winner wasn't pre-selected. Our picker solves this with visual proof: the wheel spins in real-time, slows down with realistic physics, and lands on a name everyone can see. Screen-record the spin and post it to your Story — that 15-second clip builds more credibility than any 'winner selected randomly' caption.
        </p>
      </section>

      <!-- Interactive tool -->
      <SEOPageIsland slug="instagram-giveaway-picker" client:load />

      <!-- Step-by-step guide -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Run an Instagram Giveaway (Step-by-Step)</h2>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 1: Set Up Your Giveaway Post</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Write clear rules in your caption: what the prize is (be specific), how to enter (like + comment, tag friends), entry deadline (date AND timezone), eligibility. Pro tip: Keep entry requirements simple. Every extra step cuts your participation rate in half. 'Like + comment your favorite [thing]' is the sweet spot.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 2: Collect Participant Names</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Manual method (under 100 comments): Open your post, tap View all comments, scroll through and copy each unique username, paste into a text file one per line. Export method (100+ comments): Use IGExport, Phantombuster, or Export Comments. Check each comment meets your rules before including.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 3: Load the Wheel and Spin</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Paste the cleaned username list into RealWheelPicker (one per line). Start a screen recording. Spin the wheel. Stop recording when the winner is revealed.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 4: Announce the Winner</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Post the screen recording to your Story. Tag the winner. DM them with claim instructions. Set a 48-hour claim deadline. If they don't respond, spin again and document the re-draw.</p>
        </div>
      </section>

      <!-- Use Cases -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">Instagram Giveaway Use Cases</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { emoji: "🎁", title: "Comment Giveaways", desc: "Pick winners from post comments" },
            { emoji: "👥", title: "Follower Contests", desc: "Select from eligible followers" },
            { emoji: "🎥", title: "Story Giveaways", desc: "Draw winners from story entries" },
            { emoji: "🏆", title: "Multiple Winners", desc: "Pick 1, 3, or 5+ winners at once" },
            { emoji: "✨", title: "Brand Campaigns", desc: "Professional giveaway execution" },
            { emoji: "📱", title: "Instagram Live", desc: "Draw winners in real-time on Live" },
          ].map((c) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center hover:scale-105 transition-all hover:border-primary/50">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-3 bg-primary/10 text-2xl">{c.emoji}</div>
              <h3 class="font-semibold text-foreground text-sm mb-1">{c.title}</h3>
              <p class="text-xs text-muted-foreground">{c.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- SEO bottom -->
      <section class="py-8 px-6 rounded-xl border bg-primary/5 border-primary/20 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Free Instagram Giveaway Picker — Draw Winners Your Followers Trust</h2>
        <p class="text-muted-foreground leading-relaxed">
          Our Instagram giveaway picker selects random winners from your comment section with cryptographic fairness. Screen-record the spin, post it to your Story, and prove to every follower that the draw was real. No app to install, no login required. Paste your participant usernames, spin the wheel, and announce your winner in under a minute.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          For giveaways on other platforms, we also have dedicated pickers for <a href="/tiktok-giveaway-picker" class="text-primary hover:underline">TikTok (/tiktok-giveaway-picker)</a>, <a href="/youtube-giveaway-picker" class="text-primary hover:underline">YouTube (/youtube-giveaway-picker)</a>, and <a href="/discord-giveaway-picker" class="text-primary hover:underline">Discord (/discord-giveaway-picker)</a>.
        </p>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/how-to-pick-a-random-winner", label: "How to Pick a Random Winner", desc: "Complete guide to selecting contest and giveaway winners fairly — methods, tools, and legal tips." },
            { href: "/tiktok-giveaway-picker", label: "TikTok Giveaway Picker", desc: "Pick random winners from TikTok comments and post the draw as your next video." },
            { href: "/giveaway-picker", label: "Giveaway Picker", desc: "Universal giveaway picker for any platform or contest format." },
            { href: "/raffle-picker", label: "Raffle Picker", desc: "Run fair raffles and ticket draws with cryptographic randomness." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
