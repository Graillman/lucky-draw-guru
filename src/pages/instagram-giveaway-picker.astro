---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Instagram Giveaway Picker — Pick a Random Winner Free";
const description = "Pick a random winner from Instagram comments fairly and transparently. Paste comment usernames, spin the wheel, record and post the draw to your Story.";

const faqItems = [
  {
    question: "How do I get a list of Instagram comment usernames?",
    answer: "Instagram doesn't have a native export. For small giveaways (under 200 comments): open the post on desktop, scroll through all comments and copy each username manually. For large giveaways: tools like Phantombuster or Instaloader can export comments. Paste the list of usernames into RealWheelPicker — one username per line.",
  },
  {
    question: "Can I verify that entrants actually follow my account?",
    answer: "Yes. After the spin, check the winner's profile. If they don't follow you (and that was a requirement), draw again. Checking just the winner — not all entrants — is the practical approach. Always state this verification step in your giveaway post.",
  },
  {
    question: "How do I handle duplicate comments?",
    answer: "Decide before the draw: one entry per person or multiple entries allowed. If one per person, remove duplicate usernames from your list before loading. If multiple entries are allowed, keep duplicates — each comment counts as an extra entry.",
  },
  {
    question: "Should I go live on Instagram for the draw?",
    answer: "Going live is the gold standard for transparency — your audience watches the wheel spin in real time. But if going live isn't practical, screen-recording the draw and sharing it as a Story or Reel also works well. Both methods prove the draw was fair.",
  },
  {
    question: "What's the best prize for an Instagram giveaway?",
    answer: "Products you already sell, gift cards to popular retailers, or cash via PayPal/Venmo. Show the prize on camera — visual products drive much higher entry counts. Niche-specific prizes (e.g., a camera for a photography account) attract your actual target audience rather than prize hunters.",
  },
  {
    question: "Is this tool free?",
    answer: "100% free. No account required, no limits on entries or spins. All processing happens in your browser — no participant data is sent to any server.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": "https://realwheelpicker.com/instagram-giveaway-picker#app",
      "name": "Instagram Giveaway Picker — Real Wheel Picker",
      "url": "https://realwheelpicker.com/instagram-giveaway-picker",
      "description": description,
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "publisher": { "@type": "Organization", "name": "Real Wheel Picker", "url": "https://realwheelpicker.com" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Instagram Giveaway Picker" },
      ],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonical="/instagram-giveaway-picker"
  jsonLd={jsonLd}
  hreflangLinks={[
    { hreflang: 'en', href: 'https://realwheelpicker.com/instagram-giveaway-picker' },
    { hreflang: 'x-default', href: 'https://realwheelpicker.com/instagram-giveaway-picker' },
  ]}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Instagram Giveaway Picker", url: "https://realwheelpicker.com/instagram-giveaway-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Instagram Giveaway Picker</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Instagram Giveaway Picker — Pick a Random Winner Your Followers Trust
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Copy Instagram comment usernames, paste into the wheel, spin live or record the draw, and share as a Story or Reel.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Cryptographically fair</p>
      </section>

      <!-- How it works -->
      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How Does the Instagram Giveaway Picker Work?</h2>
        <p class="text-muted-foreground leading-relaxed">
          Collect the usernames of everyone who entered your giveaway — from comments, DMs, or a separate entry form. Paste them into the wheel (one per line), then hit Spin. The winner is selected using <code>crypto.getRandomValues()</code> — cryptographic randomness, not <code>Math.random()</code>. Record the spin as proof and post it to your Story.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Instagram is the #1 platform for brand giveaways, but it's also where "rigged" accusations are most common. Showing the actual wheel spin — ideally live — is the clearest proof that the draw was fair. RealWheelPicker was built for exactly this use case.
        </p>
      </section>

      <!-- Interactive tool -->
      <SEOPageIsland slug="instagram-giveaway-picker" client:load />

      <!-- Step-by-step guide -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Run an Instagram Giveaway — Step by Step</h2>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 1: Post Your Giveaway</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Create a post with a clear image of the prize. In the caption, state: what the prize is, how to enter (Follow + Like + Comment a specific word), how many winners, the deadline, and when you'll draw. Add the legal disclosure: "Not affiliated with or sponsored by Instagram / Meta." Pin the post to your profile.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 2: Collect Eligible Entries</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Once the giveaway closes, scroll through all comments. Copy each eligible username into a text file — one per line. Remove duplicates (unless you allow multiple entries). For large giveaways (500+ comments), a comment export tool like Phantombuster or EasyPromos saves significant time.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 3: Verify and Clean the List</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Quickly check: did they like the post? Do they follow you? Remove obvious bots (0 posts, no profile picture, random character usernames). You don't need to verify every entry — just spot-check and remove flagrant ineligible entries. 5 minutes here prevents accusations of picking an ineligible winner.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 4: Spin the Wheel</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Paste your verified list into RealWheelPicker. Start a screen recording (iOS: Control Center → Screen Record; Android: Quick Settings → Screen Record). Hit Spin. The wheel randomly selects a winner. Stop recording after the result appears.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 5: Announce and Deliver</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Post the recording to your Story or Reels. Tag the winner in the caption. DM them directly with instructions to claim. Give 48 hours to respond before redrawing. Share a "Congratulations" Story tagging the winner once delivery is confirmed.</p>
        </div>
      </section>

      <!-- Use Cases -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">Instagram Giveaway Types</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { emoji: "💬", title: "Comment Draws", desc: "Pick winners from post comments" },
            { emoji: "📖", title: "Story Polls", desc: "Draw winners from poll voters" },
            { emoji: "👥", title: "Tag-a-Friend", desc: "Bonus entries for tagging friends" },
            { emoji: "🎞️", title: "Reels Giveaways", desc: "Draw from Reels comment section" },
            { emoji: "🤝", title: "Brand Collabs", desc: "Multi-brand sponsored giveaways" },
            { emoji: "🏆", title: "Follower Milestones", desc: "Celebrate follower count milestones" },
          ].map((c) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center hover:scale-105 transition-all hover:border-primary/50">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-3 bg-primary/10 text-2xl">{c.emoji}</div>
              <h3 class="font-semibold text-foreground text-sm mb-1">{c.title}</h3>
              <p class="text-xs text-muted-foreground">{c.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- SEO bottom -->
      <section class="py-8 px-6 rounded-xl border bg-primary/5 border-primary/20 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Free Instagram Giveaway Picker — Fair, Transparent Winner Selection</h2>
        <p class="text-muted-foreground leading-relaxed">
          RealWheelPicker is the most transparent way to pick an Instagram giveaway winner. Unlike apps that pick a winner with no visible draw, our spinning wheel shows the selection happening in real time. The animated wheel, the slowing spin, the moment it stops — your audience sees exactly how the winner was chosen. Screen-record it, post it to your Story, and end all "rigged" accusations permanently.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Cryptographic randomness means the result is impossible to predict or manipulate. Every participant has an exactly equal chance — weighted by however many entries you give them. No server, no data storage, no account needed.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          For other platforms, see our <a href="/tiktok-giveaway-picker" class="text-primary hover:underline">TikTok Giveaway Picker</a>, <a href="/youtube-giveaway-picker" class="text-primary hover:underline">YouTube Giveaway Picker</a>, and <a href="/discord-giveaway-picker" class="text-primary hover:underline">Discord Giveaway Picker</a>.
        </p>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/tiktok-giveaway-picker", label: "TikTok Giveaway Picker", desc: "Pick random winners from TikTok video comments and post the draw as a new video." },
            { href: "/youtube-giveaway-picker", label: "YouTube Giveaway Picker", desc: "Export YouTube comments and spin the wheel on camera for your next upload." },
            { href: "/discord-giveaway-picker", label: "Discord Giveaway Picker", desc: "Run Discord giveaways without a bot — collect reaction participants, spin to pick a winner." },
            { href: "/giveaway-picker", label: "Universal Giveaway Picker", desc: "Works for any platform — paste any list of names and spin." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
