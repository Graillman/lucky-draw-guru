---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Free Instagram Giveaway Picker · Random Winner from Comments · No Login";
const description = "Pick a random Instagram giveaway winner from comments in 30 seconds. Paste @usernames, spin the wheel, screen-record the draw, post as Story or Reel. 100% free, no login, no data sent to any server.";

const faqItems = [
  {
    question: "How do I export comments from an Instagram giveaway post?",
    answer: "Instagram has no native comment export. For under 200 comments, scroll the post on desktop and copy each @username. For larger giveaways, use a comment export tool — Phantombuster, EasyPromos, or Comment Picker handle the bulk export. Once you have a list (one @username per line), paste it into Real Wheel Picker. Bulk paste is supported.",
  },
  {
    question: "Is the Instagram giveaway picker really free, with no login or signup?",
    answer: "Yes. Real Wheel Picker is 100% free, no account required, no email, no signin. The picker runs entirely in your browser — your comment list never leaves your device. There is no usage limit on entries or spins, and no premium tier locking the giveaway features.",
  },
  {
    question: "Can I require Follow + Like + Comment as eligibility?",
    answer: "Standard practice is to declare these requirements in your post caption, then verify only the winner — not all entrants. After the wheel picks a winner, open their Instagram profile: did they follow you? Did they like the post? If yes, announce the winner. If no, redraw and document the reason. Verifying everyone before the draw is impractical for hundreds of entries and adds selection bias risk.",
  },
  {
    question: "How do I give bonus entries for tagging friends or sharing the post?",
    answer: "Use the weighted mode (also free): set base entries to weight 1, give weight 2 to people who shared, weight 3 to those who tagged 3 friends, etc. Each participant gets a wheel segment proportional to their bonus entries. Switch to the weighted picker if you want this — link inside the wheel above the spin button.",
  },
  {
    question: "Should I draw the giveaway winner live or record the spin?",
    answer: "Going live on Instagram is the gold standard for transparency — viewers see the wheel spin in real time and can screenshot the result. If live is impractical, screen-recording the draw and posting it within 10 minutes works equally well. Posting hours later raises suspicion. iOS: Control Center → Screen Record. Android: Quick Settings → Screen Record. Desktop: OBS, QuickTime, or Win+G.",
  },
  {
    question: "How do I handle duplicate comments or bot accounts?",
    answer: "State your duplicate policy in the post caption upfront — usually 'one entry per user'. Before pasting comments into the wheel, deduplicate (sort A-Z and remove obvious duplicates, or use a free dedup tool). For suspected bots: 0 posts, no profile picture, random-character usernames. Spot-checking the top 20 most-active commenters takes 5 minutes and prevents picking an obvious bot as winner.",
  },
  {
    question: "Is the random selection actually fair, or could you rig it?",
    answer: "It is cryptographically fair. Real Wheel Picker uses window.crypto.getRandomValues() — the Web Crypto API, the same standard as SSL certificates and password managers. Math.random() (used by most free pickers) is technically reproducible from the system clock. crypto.getRandomValues() is sourced from your device's hardware entropy and is not predictable, reproducible, or manipulable — even by us. The picker also runs entirely in your browser, so no external party can influence the result.",
  },
  {
    question: "Does Instagram require any specific giveaway disclosure or rules?",
    answer: "Yes. Instagram's Promotion Guidelines require: (1) acknowledge that the promotion is not associated with Instagram, (2) provide complete official rules with eligibility, prize details, deadlines, and odds of winning. Add 'Not affiliated with or endorsed by Instagram / Meta' to your caption. For prizes over $600 (US) or €1500 (FR), additional legal disclosure may be required by local law.",
  },
  {
    question: "Can I use this picker for Instagram Reels and Stories giveaways too?",
    answer: "Yes. The picker works for any source where you can collect a list of usernames: post comments, Reels comments, Story poll voters, DMs, even external sign-up forms. Paste the deduplicated username list, spin, and announce the winner the same way regardless of platform.",
  },
  {
    question: "What if the picked winner doesn't claim the prize?",
    answer: "Standard practice: give the winner 48 hours to respond to your DM. If they don't claim, redraw transparently — record the second spin and post it as a Story explaining 'first winner did not respond, redrawing now'. Doing this transparently maintains audience trust. Always document the redraw rule in your original post caption.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "@id": "https://realwheelpicker.com/instagram-giveaway-picker#app",
      "name": "Free Instagram Giveaway Picker — Real Wheel Picker",
      "url": "https://realwheelpicker.com/instagram-giveaway-picker",
      "description": description,
      "applicationCategory": "UtilitiesApplication",
      "applicationSubCategory": "Social Media Giveaway Tool",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "browserRequirements": "Requires JavaScript and HTML5 Canvas. Tested on iOS Safari 15+, Chrome 100+, Firefox 100+, Android WebView.",
      "publisher": { "@id": "https://realwheelpicker.com/#organization" },
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": [
        "Pick a random winner from Instagram comments in 30 seconds",
        "Bulk paste @usernames from any comment export tool",
        "Cryptographically fair selection (crypto.getRandomValues)",
        "Multi-winner mode without replacement (1 grand prize + 5 runner-ups)",
        "Optional weighted mode for bonus entries (tag friends, share to story)",
        "Screen-record-friendly visual spin for Story / Reel posting",
        "100% browser-based — no login, no server, no data collection",
        "Free with no usage limit on entries or spins"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "bestRating": "5",
        "worstRating": "1",
        "ratingCount": "6",
        "reviewCount": "6"
      }
    },
    {
      "@type": "HowTo",
      "@id": "https://realwheelpicker.com/instagram-giveaway-picker#howto",
      "name": "How to pick a random Instagram giveaway winner",
      "description": "Step-by-step guide to running a fair, transparent Instagram giveaway and selecting a random winner from comments.",
      "totalTime": "PT10M",
      "tool": [
        { "@type": "HowToTool", "name": "Real Wheel Picker (web browser)" },
        { "@type": "HowToTool", "name": "Screen recorder (iOS Control Center, Android Quick Settings, OBS, or QuickTime)" }
      ],
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Post your giveaway with clear rules",
          "text": "Create an Instagram post showing the prize. State entry requirements (Follow, Like, Comment a keyword), number of winners, deadline, and draw date. Include the legal disclosure 'Not affiliated with Instagram / Meta'. Pin the post."
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "Collect eligible comments",
          "text": "After the deadline, copy each eligible @username into a text file — one per line. Use a comment export tool for large giveaways (Phantombuster, EasyPromos)."
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "Deduplicate and clean the list",
          "text": "Remove duplicate usernames, obvious bot accounts (0 posts, random-character names), and ineligible entries. Spot-check 5-10 entries; do not verify every comment."
        },
        {
          "@type": "HowToStep",
          "position": 4,
          "name": "Paste, screen-record, and spin",
          "text": "Paste the cleaned username list into Real Wheel Picker. Start a screen recording on your phone (iOS: Control Center, Android: Quick Settings). Hit Spin — the wheel selects a winner with crypto.getRandomValues()."
        },
        {
          "@type": "HowToStep",
          "position": 5,
          "name": "Announce, verify, and deliver",
          "text": "Post the recording to your Story or Reels, tagging the winner. DM them with claim instructions. Verify the winner met requirements (followed, liked). Give 48 hours to respond before redrawing transparently."
        }
      ]
    }
  ]
};
---

<Layout
  title={title}
  description={description}
  canonical="/instagram-giveaway-picker"
  jsonLd={jsonLd}
  hreflangLinks={[
    { hreflang: 'en',        href: 'https://realwheelpicker.com/instagram-giveaway-picker' },
    { hreflang: 'fr',        href: 'https://realwheelpicker.com/tirage-au-sort-instagram' },
    { hreflang: 'es',        href: 'https://realwheelpicker.com/sorteo-instagram' },
    { hreflang: 'pt',        href: 'https://realwheelpicker.com/sorteio-instagram' },
    { hreflang: 'it',        href: 'https://realwheelpicker.com/sorteggio-instagram' },
    { hreflang: 'x-default', href: 'https://realwheelpicker.com/instagram-giveaway-picker' },
  ]}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Instagram Giveaway Picker", url: "https://realwheelpicker.com/instagram-giveaway-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Instagram Giveaway Picker</span>
      </nav>

      <!-- Hero — keyword-dense -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-primary/15 text-primary border border-primary/30">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse" aria-hidden="true"></span>
          Free · No login · Cryptographically fair
        </span>
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Free Instagram Giveaway Picker — Random Winner from Comments
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Paste @usernames, spin the wheel, screen-record the draw, post as Story or Reel. Pick a fair, transparent winner in 30 seconds.
        </p>
        <div class="flex flex-wrap gap-2 justify-center text-xs text-muted-foreground pt-1">
          <span class="px-2 py-0.5 rounded-md bg-muted/60">No signup</span>
          <span class="px-2 py-0.5 rounded-md bg-muted/60">No usage limit</span>
          <span class="px-2 py-0.5 rounded-md bg-muted/60">No data sent</span>
          <span class="px-2 py-0.5 rounded-md bg-muted/60">Bulk paste</span>
          <span class="px-2 py-0.5 rounded-md bg-muted/60">Multi-winner</span>
        </div>
      </section>

      <!-- Interactive tool — above the fold so users land directly on the wheel -->
      <SEOPageIsland slug="instagram-giveaway-picker" hideHero client:load />

      <!-- How it works -->
      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How the Instagram giveaway picker works</h2>
        <p class="text-muted-foreground leading-relaxed">
          Collect @usernames from comments on your giveaway post — manually for under 200 comments, with a comment export tool (Phantombuster, EasyPromos, Comment Picker) for larger draws. Paste the deduplicated list into the wheel, one @username per line. Hit <strong class="text-foreground">Spin</strong>. The wheel picks a winner with <code class="bg-muted px-1 rounded font-mono text-xs">crypto.getRandomValues()</code> — cryptographic randomness, not <code class="bg-muted px-1 rounded font-mono text-xs">Math.random()</code>. Screen-record the spin and post it to your Story as proof.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Instagram is the platform where "rigged giveaway" accusations are most common — followers can't see the selection process inside a black-box app. A visible wheel spin, ideally live, ends those accusations. Real Wheel Picker is built for that exact use case.
        </p>
      </section>

      <!-- Cross-link weighted picker for bonus entries -->
      <section class="p-5 rounded-xl border bg-amber-500/5 border-amber-500/30 flex flex-col md:flex-row md:items-center gap-3 md:gap-5">
        <div class="text-3xl shrink-0">⚖️</div>
        <div class="space-y-1 flex-1">
          <h3 class="text-base md:text-lg font-bold text-foreground">Want bonus entries for tagging or sharing?</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Switch to the <a href="/weighted-random-picker" class="text-primary hover:underline font-semibold">Weighted Random Picker</a> — give participants 2× or 3× the odds for tagging friends, sharing to Story, or being a long-time follower. Same cryptographic fairness, with a 10 000-spin simulator to prove the math.
          </p>
        </div>
        <a href="/weighted-random-picker" class="px-3 py-2 rounded-md bg-primary text-primary-foreground text-sm font-bold whitespace-nowrap hover:opacity-90 transition-opacity">Open weighted →</a>
      </section>

      <!-- Step-by-step (HowTo schema-aligned) -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Run an Instagram giveaway — step by step</h2>

        {[
          { n: '1', t: 'Post your giveaway with clear rules', d: 'Show the prize on camera. State: how to enter (Follow + Like + Comment a keyword), number of winners, deadline, draw date. Add the legal disclosure: "Not affiliated with or endorsed by Instagram / Meta." Pin the post to your profile.' },
          { n: '2', t: 'Collect eligible comments', d: 'Once entries close, copy each eligible @username into a text file — one per line. For large giveaways (500+ comments), a comment export tool (Phantombuster, EasyPromos, Comment Picker) saves significant time.' },
          { n: '3', t: 'Deduplicate and verify the list', d: 'Remove duplicates (or keep them if multiple entries are allowed — be consistent with your stated rules). Drop obvious bot accounts (0 posts, no profile pic, random-character names). Spot-check 5-10 entries; do not verify every comment — you only verify the winner.' },
          { n: '4', t: 'Screen-record the spin', d: 'Start a screen recording on your phone before pasting the list (iOS: Control Centre → Screen Record. Android: Quick Settings → Screen Record. Desktop: OBS, QuickTime, Win+G). Paste the list into the wheel above. Hit Spin. Stop recording after the result appears.' },
          { n: '5', t: 'Announce, verify, deliver', d: 'Post the recording to your Story or Reels, tagging the winner. DM them claim instructions. Verify the winner met the requirements (followed, liked, commented). Give 48 hours to respond before redrawing — and record the redraw too if it happens.' },
        ].map(({ n, t, d }) => (
          <div class="p-6 rounded-xl border bg-card border-border flex gap-4">
            <span class="w-8 h-8 rounded-full bg-primary text-primary-foreground text-sm font-bold flex items-center justify-center shrink-0 mt-0.5">{n}</span>
            <div class="space-y-2">
              <h3 class="text-lg font-bold text-foreground">{t}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">{d}</p>
            </div>
          </div>
        ))}
      </section>

      <!-- Comparison vs other Instagram giveaway tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Real Wheel Picker vs other Instagram giveaway tools</h2>
        <p class="text-muted-foreground leading-relaxed text-sm">
          Most Instagram giveaway tools — Wask, Simpliers, EasyPromos, Comment Picker — are paywalled, require login, or hide the selection inside a black box. Here is how Real Wheel Picker compares:
        </p>
        <div class="overflow-x-auto rounded-xl border border-border">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-primary/10 border-b border-border">
                <th class="text-left p-3 font-bold text-foreground">Feature</th>
                <th class="text-center p-3 font-bold text-primary">Real Wheel Picker</th>
                <th class="text-center p-3 font-bold text-muted-foreground">Wask</th>
                <th class="text-center p-3 font-bold text-muted-foreground">Comment Picker</th>
                <th class="text-center p-3 font-bold text-muted-foreground">EasyPromos</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              <tr class="bg-card"><td class="p-3 text-foreground">Free unlimited entries</td><td class="p-3 text-center text-green-600 font-semibold">Yes</td><td class="p-3 text-center text-yellow-500">Free tier limited</td><td class="p-3 text-center text-yellow-500">Up to 1k</td><td class="p-3 text-center text-red-500">Paid only</td></tr>
              <tr class="bg-card/50"><td class="p-3 text-foreground">No login / signup</td><td class="p-3 text-center text-green-600 font-semibold">Yes</td><td class="p-3 text-center text-red-500">Account required</td><td class="p-3 text-center text-red-500">Account required</td><td class="p-3 text-center text-red-500">Account required</td></tr>
              <tr class="bg-card"><td class="p-3 text-foreground">Visible wheel spin (proof)</td><td class="p-3 text-center text-green-600 font-semibold">Yes — animated wheel</td><td class="p-3 text-center text-red-500">Hidden algorithm</td><td class="p-3 text-center text-yellow-500">Result list only</td><td class="p-3 text-center text-yellow-500">Result list only</td></tr>
              <tr class="bg-card/50"><td class="p-3 text-foreground">Cryptographic randomness</td><td class="p-3 text-center text-green-600 font-semibold">Yes (crypto.getRandomValues)</td><td class="p-3 text-center text-red-500">No (Math.random)</td><td class="p-3 text-center text-red-500">No</td><td class="p-3 text-center text-red-500">Server-side, opaque</td></tr>
              <tr class="bg-card"><td class="p-3 text-foreground">Bonus entries (weighted)</td><td class="p-3 text-center text-green-600 font-semibold">Yes — free</td><td class="p-3 text-center text-yellow-500">Premium tier</td><td class="p-3 text-center text-red-500">No</td><td class="p-3 text-center text-yellow-500">Premium tier</td></tr>
              <tr class="bg-card/50"><td class="p-3 text-foreground">Multi-winner draw</td><td class="p-3 text-center text-green-600 font-semibold">Yes — without replacement</td><td class="p-3 text-center text-yellow-500">Free tier limited</td><td class="p-3 text-center text-yellow-500">Yes</td><td class="p-3 text-center text-yellow-500">Yes</td></tr>
              <tr class="bg-card"><td class="p-3 text-foreground">Privacy (no data uploaded)</td><td class="p-3 text-center text-green-600 font-semibold">100% browser</td><td class="p-3 text-center text-red-500">Server-stored</td><td class="p-3 text-center text-red-500">Server-stored</td><td class="p-3 text-center text-red-500">Server-stored</td></tr>
              <tr class="bg-card/50"><td class="p-3 text-foreground">Screen-record-friendly</td><td class="p-3 text-center text-green-600 font-semibold">Yes — visible spin animation</td><td class="p-3 text-center text-red-500">Result modal only</td><td class="p-3 text-center text-yellow-500">Static</td><td class="p-3 text-center text-yellow-500">Static</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-muted-foreground leading-relaxed text-sm">
          The visible spin is what changes the audience experience. A black-box result page never builds the same trust as a wheel slowing down on the winner — recorded, posted, watched.
        </p>
      </section>

      <!-- Use Cases -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">Instagram giveaway formats supported</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { emoji: "💬", title: "Comment draws", desc: "Pick winners from post comments — the standard Instagram giveaway format." },
            { emoji: "🎞️", title: "Reels giveaways", desc: "Reels comments work the same way — copy @usernames, paste, spin." },
            { emoji: "📖", title: "Story poll voters", desc: "Story polls let you collect voters' usernames; export and pick a random voter." },
            { emoji: "👥", title: "Tag-a-friend", desc: "Bonus entries for each friend tagged — combine with the weighted picker." },
            { emoji: "🤝", title: "Brand collab giveaways", desc: "Multi-brand sponsored giveaways with separate entry pools and aggregate winners." },
            { emoji: "🏆", title: "Follower milestones", desc: "Celebrate 10k / 50k / 100k followers with a transparent fair giveaway." },
            { emoji: "🛍️", title: "Product launches", desc: "Drive engagement on a launch post with a giveaway tied to a comment keyword." },
            { emoji: "📅", title: "Recurring weekly draws", desc: "Subscriber/follower weekly raffles — bookmark this picker for repeat use." },
            { emoji: "🎁", title: "Themed seasonal", desc: "Christmas, Valentine's, Black Friday — weighted entries for early followers." },
          ].map((c) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center hover:scale-105 transition-all hover:border-primary/50">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-3 bg-primary/10 text-2xl">{c.emoji}</div>
              <h3 class="font-semibold text-foreground text-sm mb-1">{c.title}</h3>
              <p class="text-xs text-muted-foreground">{c.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ — visible -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently asked questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <details class="bg-card border border-border rounded-xl p-5 group">
              <summary class="font-semibold text-foreground cursor-pointer select-none flex items-start justify-between gap-4">
                <span>{question}</span>
                <span class="text-muted-foreground group-open:rotate-45 transition-transform shrink-0">+</span>
              </summary>
              <p class="text-muted-foreground text-sm leading-relaxed mt-3">{answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- SEO bottom + cross-platform internal linking -->
      <section class="py-8 px-6 rounded-xl border bg-primary/5 border-primary/20 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Free Instagram giveaway picker — fair, transparent, no login</h2>
        <p class="text-muted-foreground leading-relaxed">
          Real Wheel Picker is the most transparent way to pick an Instagram giveaway winner. Most "free" Instagram comment pickers force a login, store your data on their servers, and hide the selection inside a result modal — your followers see only the final name, not the process. Our spinning wheel shows the selection happening in real time. The animated wheel, the slowing spin, the moment it stops — your audience sees exactly how the winner was chosen. Screen-record it, post it to your Story, and end the "rigged" accusations permanently.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Cryptographic randomness ensures the result is impossible to predict or manipulate — even by us. Every participant has an equal chance, weighted by however many entries you give them via the weighted mode. No server, no data storage, no account, no email. Open the page, paste your list, spin.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          For other platforms: <a href="/tiktok-giveaway-picker" class="text-primary hover:underline">TikTok Giveaway Picker</a>, <a href="/youtube-giveaway-picker" class="text-primary hover:underline">YouTube Giveaway Picker</a>, <a href="/discord-giveaway-picker" class="text-primary hover:underline">Discord Giveaway Picker</a>, <a href="/twitch-giveaway-picker" class="text-primary hover:underline">Twitch Giveaway Picker</a>, <a href="/twitter-giveaway-picker" class="text-primary hover:underline">Twitter / X Giveaway Picker</a>, <a href="/facebook-giveaway-picker" class="text-primary hover:underline">Facebook Giveaway Picker</a>.
        </p>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/weighted-random-picker", label: "Weighted Random Picker", desc: "Bonus entries for tagging, sharing, or being a top fan — with 10 000-spin fairness simulator." },
            { href: "/tiktok-giveaway-picker", label: "TikTok Giveaway Picker", desc: "Pick random winners from TikTok video comments and post the draw as a new video." },
            { href: "/youtube-giveaway-picker", label: "YouTube Giveaway Picker", desc: "Export YouTube comments and spin the wheel on camera for your next upload." },
            { href: "/discord-giveaway-picker", label: "Discord Giveaway Picker", desc: "Run Discord giveaways without a bot — collect reaction participants, spin to pick a winner." },
            { href: "/giveaway-picker", label: "Universal Giveaway Picker", desc: "Works for any platform — paste any list of names and spin." },
            { href: "/blog/how-to-run-instagram-giveaway", label: "Article — How to Run an Instagram Giveaway", desc: "Step-by-step deep dive: rules, comment exports, picking the winner, legal disclosures." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
