---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Christmas Gift Idea Wheel — Random Present Picker";
const description = "Stuck on what to buy? Spin for a random Christmas gift idea. Pre-loaded with 10 universally appreciated gift categories. Works for Secret Santa too.";
const canonical = "/templates/christmas-gift-wheel";

const faqItems = [
  {
    question: "How do I use this for Secret Santa?",
    answer: "Load the wheel with gift ideas within your Secret Santa budget. Spin to get a starting point, then personalize based on what you know about your recipient. Or load it with specific gift options and let the wheel make the final call.",
  },
  {
    question: "What's a good budget for Christmas gifts?",
    answer: "For close family: $30-100+. For friends and coworkers: $15-30. For Secret Santa: whatever the agreed limit is (usually $20-25). The wheel works at any budget — just add category options that fit your spend.",
  },
  {
    question: "Can I use this to decide gift categories for multiple people?",
    answer: "Yes. Spin once per person on your list. You'll end up with a diverse set of gift directions rather than buying the same type of thing for everyone. Great for getting out of the 'gift card for everyone' rut.",
  },
];

const defaultParticipants = [
  { pseudo: "Experience gift", weight: 1 },
  { pseudo: "Book or journal", weight: 1 },
  { pseudo: "Cozy kit", weight: 1 },
  { pseudo: "Tech accessory", weight: 1 },
  { pseudo: "Food hamper", weight: 1 },
  { pseudo: "Board game", weight: 1 },
  { pseudo: "Subscription box", weight: 1 },
  { pseudo: "Personalized item", weight: 1 },
  { pseudo: "Skincare set", weight: 1 },
  { pseudo: "Hobby supply", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/christmas-gift-wheel",
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Christmas Gift Idea Wheel", url: "https://realwheelpicker.com/templates/christmas-gift-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Christmas Gift Idea Wheel</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Christmas Gift Idea Wheel — Random Present Picker
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Replace the defaults with gift ideas for your recipient, spin, and commit. Great for Secret Santa, family gift exchanges, and anyone with a long shopping list.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <section class="space-y-8">
        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Why Gift Choosing Is Harder Than It Should Be</h2>
          <p class="text-muted-foreground leading-relaxed">
            Buying a gift for someone you know well shouldn't require three hours of Amazon browsing. The problem is usually not lack of ideas — it's too many equally valid options and the fear of picking the wrong one. You want to get it right, so you keep researching, and December 20th arrives with nothing ordered.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Loading the wheel with your shortlist and spinning forces a commitment. Once the wheel picks, you act on it — you stop second-guessing and start buying. The gift you actually give beats the perfect gift you never ordered.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/gift-idea-wheel", label: "Gift Idea Wheel", desc: "General gift ideas for any occasion, not just Christmas." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Randomly assign Secret Santa pairings." },
            { href: "/yes-or-no-wheel", label: "Yes or No Wheel", desc: "Quick decision for borderline gift choices." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:load />
  </div>
</Layout>
