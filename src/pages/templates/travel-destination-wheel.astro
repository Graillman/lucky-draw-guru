---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Travel Destination Spinner — Where Should I Go?";
const description = "Can't decide where to travel next? Spin the destination wheel. Pre-loaded with 12 popular spots or add your bucket list. Free, instant.";
const canonical = "/templates/travel-destination-wheel";

const faqItems = [
  {
    question: "How do I use this for trip planning?",
    answer: "Add the destinations you're genuinely considering — places you'd be happy visiting. Remove any you can't afford or reach. Spin, then commit. The wheel eliminates endless back-and-forth research paralysis.",
  },
  {
    question: "Can I add cities within a country instead of countries?",
    answer: "Yes. Replace country names with specific cities, regions, or even neighborhoods. 'Southeast Asia' or 'Tuscany, Italy' work just as well as country names.",
  },
  {
    question: "What if I'm on a tight budget?",
    answer: "Only add destinations within your budget range. If you'd only realistically visit Europe or Southeast Asia, don't include Australia. The wheel gives you a fair random choice within your actual options.",
  },
];

const defaultParticipants = [
  { pseudo: "Tokyo, Japan", weight: 1 },
  { pseudo: "Paris, France", weight: 1 },
  { pseudo: "New York, USA", weight: 1 },
  { pseudo: "Bali, Indonesia", weight: 1 },
  { pseudo: "Barcelona, Spain", weight: 1 },
  { pseudo: "Iceland", weight: 1 },
  { pseudo: "Marrakech, Morocco", weight: 1 },
  { pseudo: "New Zealand", weight: 1 },
  { pseudo: "Rome, Italy", weight: 1 },
  { pseudo: "Thailand", weight: 1 },
  { pseudo: "Peru", weight: 1 },
  { pseudo: "Santorini, Greece", weight: 1 },
];

const myColors = ['#0ea5e9','#f97316','#14b8a6','#f59e0b','#06b6d4','#fb923c','#22d3ee','#fbbf24'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/travel-destination-wheel",
};
---

<style>
/* ===== COUCHER DE SOLEIL TROPICAL ===== */
.travel-page {
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
  background: #0a0020;
}

/* Ciel coucher de soleil */
.travel-sky {
  position: fixed;
  inset: 0;
  z-index: 0;
  background: linear-gradient(
    180deg,
    #0a0020 0%,
    #1a0a3d 20%,
    #3d1060 35%,
    #7c2d87 50%,
    #c2410c 65%,
    #ea580c 78%,
    #f97316 88%,
    #fbbf24 100%
  );
}

/* Soleil couchant demi-cercle */
.travel-sun {
  position: fixed;
  bottom: -80px;
  left: 50%;
  transform: translateX(-50%);
  width: 280px;
  height: 280px;
  border-radius: 50%;
  background: radial-gradient(circle, #fef08a 0%, #fbbf24 30%, #f97316 60%, #ea580c 100%);
  box-shadow: 0 0 80px 40px rgba(251,191,36,0.4), 0 0 160px 80px rgba(249,115,22,0.2);
  z-index: 1;
  animation: sunRise 8s ease-in-out infinite alternate;
}

/* Reflet soleil sur l'eau */
.sun-reflection {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 200px;
  background: linear-gradient(180deg, rgba(251,191,36,0.6) 0%, rgba(249,115,22,0.3) 50%, transparent 100%);
  z-index: 2;
  animation: sunReflect 8s ease-in-out infinite alternate;
  border-radius: 50%;
}

/* Avion avec traînée */
.travel-plane {
  position: fixed;
  z-index: 5;
  font-size: 2rem;
  filter: drop-shadow(0 0 10px rgba(255,200,100,0.8));
  animation: travelPlaneFly 16s linear infinite;
}
.travel-plane:nth-child(2) {
  font-size: 1.4rem;
  animation-delay: -8s;
  animation-duration: 20s;
}

/* Traînée avion */
.travel-trail {
  position: fixed;
  height: 2px;
  width: 150px;
  z-index: 4;
  animation: travelTrailFly 16s linear infinite;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), rgba(255,220,100,0.4), transparent);
}

/* Nuages de voyage */
.travel-cloud {
  position: fixed;
  background: rgba(255,255,255,0.08);
  border-radius: 50px;
  filter: blur(8px);
  z-index: 2;
  animation: cloudDrift 20s ease-in-out infinite;
}

/* Cartes postales tombantes */
.postcard {
  position: fixed;
  font-size: 1.5rem;
  z-index: 4;
  animation: postcardFall linear infinite;
  filter: drop-shadow(0 4px 8px rgba(0,0,0,0.4));
}

/* ===== KEYFRAMES ===== */
@keyframes sunRise {
  0% { bottom: -90px; box-shadow: 0 0 60px 30px rgba(251,191,36,0.3), 0 0 120px 60px rgba(249,115,22,0.15); }
  100% { bottom: -60px; box-shadow: 0 0 100px 50px rgba(251,191,36,0.5), 0 0 200px 100px rgba(249,115,22,0.25); }
}

@keyframes sunReflect {
  0% { opacity: 0.5; width: 50px; }
  100% { opacity: 0.8; width: 80px; }
}

@keyframes travelPlaneFly {
  0% { left: -5%; top: 20%; opacity: 0; transform: translateY(0); }
  5% { opacity: 1; }
  95% { opacity: 1; }
  100% { left: 108%; top: 15%; opacity: 0; transform: translateY(-20px); }
}

@keyframes travelTrailFly {
  0% { left: -160px; top: 21%; opacity: 0; }
  5% { opacity: 0.8; }
  95% { opacity: 0.3; }
  100% { left: 108%; top: 16%; opacity: 0; }
}

@keyframes cloudDrift {
  0% { transform: translateX(-30px); opacity: 0.4; }
  50% { transform: translateX(30px); opacity: 0.7; }
  100% { transform: translateX(-30px); opacity: 0.4; }
}

@keyframes postcardFall {
  0% { top: -80px; opacity: 0; transform: rotate(-15deg); }
  10% { opacity: 1; }
  90% { opacity: 0.8; }
  100% { top: 110%; opacity: 0; transform: rotate(15deg); }
}

/* ===== CONTENU ===== */
.travel-content {
  position: relative;
  z-index: 10;
}

.travel-title {
  background: linear-gradient(135deg, #fef08a 0%, #f97316 40%, #fb923c 70%, #fbbf24 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 20px rgba(249,115,22,0.5));
}

.travel-card {
  background: rgba(10, 0, 32, 0.75);
  border: 1px solid rgba(251,191,36,0.2);
  backdrop-filter: blur(12px);
}

.travel-card:hover {
  border-color: rgba(249,115,22,0.4);
}

.travel-tag {
  background: rgba(249,115,22,0.15);
  border: 1px solid rgba(249,115,22,0.35);
  color: #fbbf24;
  padding: 4px 12px;
  border-radius: 9999px;
  font-size: 0.75rem;
}

.travel-link {
  background: rgba(10, 0, 32, 0.75);
  border: 1px solid rgba(251,191,36,0.2);
  backdrop-filter: blur(8px);
  transition: all 0.2s;
}
.travel-link:hover {
  border-color: rgba(249,115,22,0.5);
  box-shadow: 0 4px 20px rgba(249,115,22,0.15);
}

.travel-highlight {
  background: rgba(249,115,22,0.1);
  border: 1px solid rgba(249,115,22,0.2);
}

.travel-faq {
  background: rgba(10, 0, 32, 0.7);
  border: 1px solid rgba(251,191,36,0.15);
  backdrop-filter: blur(8px);
}
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Travel Destination Spinner", url: "https://realwheelpicker.com/templates/travel-destination-wheel" },
  ]} />

  <div class="travel-page">
    <div class="travel-sky"></div>

    <!-- Soleil couchant -->
    <div class="travel-sun"></div>
    <div class="sun-reflection"></div>

    <!-- Nuages -->
    <div class="travel-cloud" style="width:200px;height:60px;top:22%;left:5%;animation-delay:0s;"></div>
    <div class="travel-cloud" style="width:150px;height:45px;top:30%;left:72%;animation-delay:4s;animation-duration:25s;"></div>
    <div class="travel-cloud" style="width:250px;height:70px;top:18%;left:40%;animation-delay:8s;animation-duration:28s;"></div>
    <div class="travel-cloud" style="width:120px;height:40px;top:42%;left:85%;animation-delay:2s;animation-duration:22s;"></div>

    <!-- Avions -->
    <div class="travel-plane" style="top:20%;">&#9992;</div>
    <div class="travel-plane" style="top:38%;">&#9992;</div>
    <div class="travel-trail" style="top:21%;"></div>

    <!-- Cartes postales -->
    <div class="postcard" style="left:8%;animation-duration:12s;animation-delay:0s;">&#128205;</div>
    <div class="postcard" style="left:25%;animation-duration:15s;animation-delay:4s;">&#9992;</div>
    <div class="postcard" style="left:60%;animation-duration:18s;animation-delay:2s;">&#127963;</div>
    <div class="postcard" style="left:80%;animation-duration:14s;animation-delay:7s;">&#127754;</div>
    <div class="postcard" style="left:45%;animation-duration:20s;animation-delay:9s;">&#128247;</div>

    <div class="travel-content">
      <HeaderIsland client:load />
      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="text-xs flex gap-1 mb-6" style="color:rgba(251,191,36,0.6)">
          <a href="/" class="hover:text-yellow-300 transition-colors" style="color:rgba(251,191,36,0.6)">Home</a>
          <span style="color:rgba(251,191,36,0.3)">/</span>
          <a href="/templates" class="hover:text-yellow-300 transition-colors" style="color:rgba(251,191,36,0.6)">Templates</a>
          <span style="color:rgba(251,191,36,0.3)">/</span>
          <span style="color:#fbbf24">Travel Destination Spinner</span>
        </nav>

        <!-- Hero -->
        <section class="text-center space-y-4 py-4 mb-8">
          <div class="flex justify-center gap-2 flex-wrap mb-3">
            <span class="travel-tag">&#9992; Adventure</span>
            <span class="travel-tag">&#127963; Destinations</span>
            <span class="travel-tag">&#127758; World</span>
          </div>
          <h1 class="text-3xl md:text-5xl font-bold leading-tight travel-title">
            Travel Destination Spinner
          </h1>
          <p class="text-lg md:text-xl max-w-2xl mx-auto" style="color:rgba(253,186,116,0.9)">
            Stop overthinking your next trip. Add your dream destinations, spin the wheel, and book it. Adventure chosen.
          </p>
          <p class="text-sm" style="color:rgba(251,191,36,0.5)">Free &bull; No account &bull; Instant result</p>
        </section>

        <!-- Wheel -->
        <SimpleWheelIsland defaultParticipants={defaultParticipants} colors={myColors} wheelShape="circle" hubTheme="teal" client:load />

      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <section class="space-y-6">
          <div class="travel-card p-6 rounded-xl space-y-4">
            <h2 class="text-xl md:text-2xl font-bold" style="color:#fbbf24">Stop Researching, Start Going</h2>
            <p class="leading-relaxed" style="color:rgba(253,186,116,0.8)">
              Travel research is the enemy of travel. You open 40 tabs comparing hotels in Tokyo vs. Bali vs. Barcelona. Weeks pass. You still haven't booked. The problem isn't information — it's too much information with no forcing function to decide.
            </p>
            <p class="leading-relaxed" style="color:rgba(253,186,116,0.8)">
              The travel destination wheel is that forcing function. You pre-filter your list to destinations you'd genuinely love to visit. The wheel removes the paradox of choice by picking for you. Once the wheel lands, you stop comparing and start planning that specific trip.
            </p>
          </div>

          <div class="travel-card p-6 rounded-xl space-y-4">
            <h2 class="text-xl md:text-2xl font-bold" style="color:#fbbf24">How to Build Your Destination Wheel</h2>
            <ul class="space-y-2" style="color:rgba(253,186,116,0.8)">
              <li class="flex gap-3"><span class="font-bold" style="color:#f97316">&#8594;</span><span><strong style="color:#fef08a">Set a budget filter first.</strong> Only add destinations your budget can realistically cover.</span></li>
              <li class="flex gap-3"><span class="font-bold" style="color:#f97316">&#8594;</span><span><strong style="color:#fef08a">Consider the season.</strong> Remove destinations that are rainy or peak-price during your travel window.</span></li>
              <li class="flex gap-3"><span class="font-bold" style="color:#f97316">&#8594;</span><span><strong style="color:#fef08a">Add continents or regions</strong> for a high-level pick, then do a second spin for the specific city.</span></li>
              <li class="flex gap-3"><span class="font-bold" style="color:#f97316">&#8594;</span><span><strong style="color:#fef08a">Commit before spinning.</strong> The rule: whatever the wheel picks, you look up flights within 24 hours.</span></li>
            </ul>
          </div>
        </section>

        <!-- FAQ -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#fbbf24">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="travel-faq rounded-xl p-5">
                <p class="font-semibold mb-2" style="color:#fef08a">{question}</p>
                <p class="text-sm leading-relaxed" style="color:rgba(253,186,116,0.7)">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Related Tools -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#fbbf24">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/templates/weekend-activity-wheel", label: "Weekend Activity Spinner", desc: "Closer to home — spin for a fun local activity this weekend." },
              { href: "/random-wheel", label: "Random Wheel", desc: "Build a fully custom wheel for any destination list." },
              { href: "/yes-or-no-wheel", label: "Yes or No Wheel", desc: "Stuck on go vs. stay? Flip the coin wheel." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="travel-link flex items-start gap-3 p-4 rounded-xl">
                  <span class="font-bold text-sm mt-0.5" style="color:#f97316">&#8594;</span>
                  <span>
                    <span class="font-semibold" style="color:#fef08a">{label}</span>
                    <span class="text-sm" style="color:rgba(253,186,116,0.6)"> &mdash; {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
