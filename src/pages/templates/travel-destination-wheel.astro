---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Travel Destination Spinner — Where Should I Go?";
const description = "Can't decide where to travel next? Spin the destination wheel. Pre-loaded with 12 popular spots or add your bucket list. Free, instant.";
const canonical = "/templates/travel-destination-wheel";

const faqItems = [
  {
    question: "How do I use this for trip planning?",
    answer: "Add the destinations you're genuinely considering — places you'd be happy visiting. Remove any you can't afford or reach. Spin, then commit. The wheel eliminates endless back-and-forth research paralysis.",
  },
  {
    question: "Can I add cities within a country instead of countries?",
    answer: "Yes. Replace country names with specific cities, regions, or even neighborhoods. 'Southeast Asia' or 'Tuscany, Italy' work just as well as country names.",
  },
  {
    question: "What if I'm on a tight budget?",
    answer: "Only add destinations within your budget range. If you'd only realistically visit Europe or Southeast Asia, don't include Australia. The wheel gives you a fair random choice within your actual options.",
  },
];

const defaultParticipants = [
  { pseudo: "Tokyo, Japan", weight: 1 },
  { pseudo: "Paris, France", weight: 1 },
  { pseudo: "New York, USA", weight: 1 },
  { pseudo: "Bali, Indonesia", weight: 1 },
  { pseudo: "Barcelona, Spain", weight: 1 },
  { pseudo: "Iceland", weight: 1 },
  { pseudo: "Marrakech, Morocco", weight: 1 },
  { pseudo: "New Zealand", weight: 1 },
  { pseudo: "Rome, Italy", weight: 1 },
  { pseudo: "Thailand", weight: 1 },
  { pseudo: "Peru", weight: 1 },
  { pseudo: "Santorini, Greece", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/travel-destination-wheel",
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Travel Destination Spinner", url: "https://realwheelpicker.com/templates/travel-destination-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Travel Destination Spinner</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Travel Destination Spinner — Where Should I Go?
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Stop overthinking your next trip. Add your dream destinations, spin the wheel, and book it. Adventure chosen.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <section class="space-y-8">
        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Stop Researching, Start Going</h2>
          <p class="text-muted-foreground leading-relaxed">
            Travel research is the enemy of travel. You open 40 tabs comparing hotels in Tokyo vs. Bali vs. Barcelona. Weeks pass. You still haven't booked. The problem isn't information — it's too much information with no forcing function to decide.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The travel destination wheel is that forcing function. You pre-filter your list to destinations you'd genuinely love to visit. The wheel removes the paradox of choice by picking for you. Once the wheel lands, you stop comparing and start planning that specific trip.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Replace the defaults with your actual bucket list or the shortlist you're currently choosing from. The wheel works best when every option is one you'd be happy with — not a list of maybes and "somedays."
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Build Your Destination Wheel</h2>
          <ul class="space-y-2 text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span><strong class="text-foreground">Set a budget filter first.</strong> Only add destinations your budget can realistically cover.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span><strong class="text-foreground">Consider the season.</strong> Remove destinations that are rainy, freezing, or peak-price during your travel window.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span><strong class="text-foreground">Add continents or regions</strong> for a high-level pick, then do a second spin for the specific city.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span><strong class="text-foreground">Commit before spinning.</strong> The rule: whatever the wheel picks, you look up flights within 24 hours.</span></li>
          </ul>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/weekend-activity-wheel", label: "Weekend Activity Spinner", desc: "Closer to home — spin for a fun local activity this weekend." },
            { href: "/random-wheel", label: "Random Wheel", desc: "Build a fully custom wheel for any destination list." },
            { href: "/yes-or-no-wheel", label: "Yes or No Wheel", desc: "Stuck on go vs. stay? Flip the coin wheel." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:load />
  </div>
</Layout>
