---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Random Task Picker — What to Work on Next";
const description = "Overwhelmed by your to-do list? Spin to pick your next task. Beat decision paralysis and start working. Add your own tasks, spin, do it.";
const canonical = "/templates/random-task-wheel";

const faqItems = [
  {
    question: "Is it a good idea to pick tasks randomly?",
    answer: "For tasks of roughly equal priority, yes. Random selection eliminates the time you waste deciding which task to start. The biggest productivity killer isn't working slowly — it's not starting. The wheel solves the starting problem.",
  },
  {
    question: "What about urgent tasks?",
    answer: "Only add tasks that are genuinely interchangeable in priority. Keep urgent or deadline-driven tasks off the wheel and handle those directly. The wheel is for the mid-priority backlog that you keep deferring because you can't decide where to begin.",
  },
  {
    question: "How many tasks should I put on the wheel?",
    answer: "4-8 is ideal. Too few and the randomness isn't meaningful. Too many and seeing all your tasks at once creates overwhelm. Group related small tasks into single items if needed.",
  },
];

const defaultParticipants = [
  { pseudo: "Clear email inbox", weight: 1 },
  { pseudo: "Tackle urgent item", weight: 1 },
  { pseudo: "Long overdue task", weight: 1 },
  { pseudo: "Quick win (< 15 min)", weight: 1 },
  { pseudo: "Deep focus work", weight: 1 },
  { pseudo: "Admin / paperwork", weight: 1 },
  { pseudo: "Creative task", weight: 1 },
  { pseudo: "Review something", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/random-task-wheel",
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Random Task Picker", url: "https://realwheelpicker.com/templates/random-task-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Random Task Picker</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Random Task Picker — What to Work on Next
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Replace the defaults with your actual to-do list. Spin. Start that task immediately. Decision made.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <section class="space-y-8">
        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">The Hidden Cost of Task Selection</h2>
          <p class="text-muted-foreground leading-relaxed">
            Knowledge workers spend an estimated 20% of their time deciding what to work on — not working, just deciding. Every time you finish a task and open your to-do list, you face a mini-decision problem: evaluate all options, weigh priorities, consider effort vs. impact, then pick. Repeat 15 times a day.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The random task wheel eliminates this overhead for the subset of tasks that are genuinely interchangeable. Load it with your medium-priority backlog — the tasks that aren't urgent but need to get done eventually — and let the wheel pick. You start faster, which means you finish more.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/sprint-retrospective-wheel", label: "Sprint Retro Wheel", desc: "Randomize your retrospective discussion topics." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Assign tasks randomly to team members." },
            { href: "/yes-or-no-wheel", label: "Yes or No Wheel", desc: "Quick binary decisions — should I work on this now?" },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:load />
  </div>
</Layout>
