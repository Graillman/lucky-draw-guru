---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Chore Wheel — Fair Household Chore Assignment Spinner";
const description = "Assign household chores randomly. No arguments, no favoritism. Spin the wheel weekly and everyone does their fair share.";
const canonical = "/templates/chore-wheel";

const faqItems = [
  {
    question: "What if the same person always spins the worst chores?",
    answer: "Remove completed chores from the wheel after each person spins, so everyone gets different assignments. Reset the wheel each week.",
  },
  {
    question: "Should chores be assigned by person or shared?",
    answer: "By person — when chores are 'shared,' they often don't get done. Individual assignment with a deadline is more effective.",
  },
  {
    question: "Can I use this for kids' chore charts?",
    answer: "Yes — kids often find it more fair when chance determines their chore rather than a parent. The wheel removes perceived favoritism.",
  },
];

const defaultParticipants = [
  { pseudo: "Dishes", weight: 1 },
  { pseudo: "Vacuuming", weight: 1 },
  { pseudo: "Laundry", weight: 1 },
  { pseudo: "Bathroom", weight: 1 },
  { pseudo: "Kitchen", weight: 1 },
  { pseudo: "Trash", weight: 1 },
  { pseudo: "Groceries", weight: 1 },
  { pseudo: "Cooking", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/chore-wheel",
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Chore Wheel", url: "https://realwheelpicker.com/templates/chore-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Chore Wheel</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Chore Wheel — Fair Household Chore Assignment Spinner
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Assign household chores randomly and fairly. Spin the wheel weekly — no arguments, no favoritism. Pre-loaded with 8 common chores.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- Wheel -->
      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <!-- Article Content -->
      <section class="space-y-8">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">The Chore Argument Problem</h2>
          <p class="text-muted-foreground leading-relaxed">
            Every shared household has chore arguments. The same people always do the same tasks. Someone always feels like they're doing more. The chore wheel makes assignment random, fair, and inarguable.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Weekly Chore Wheel System</h2>
          <ol class="space-y-2 text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span><span>Every Monday: each household member spins the wheel once.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span><span>Write down their chore assignment.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span><span>Complete it before next Monday.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">4.</span><span>If someone spins a chore they can't do (e.g., allergic to cleaning products), spin again.</span></li>
          </ol>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">For Families with Kids</h2>
          <p class="text-muted-foreground leading-relaxed">
            Create an age-appropriate chore wheel for kids. The wheel makes chore assignment feel fair rather than arbitrary.
          </p>
          <div class="space-y-3">
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Younger children</p>
              <p class="text-muted-foreground text-sm">Set the table, feed pets, put away toys.</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Older kids</p>
              <p class="text-muted-foreground text-sm">Vacuum, load dishwasher, take out trash.</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Teens</p>
              <p class="text-muted-foreground text-sm">Cooking, grocery pickup, yard work.</p>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Flat / Roommate Setup</h2>
          <p class="text-muted-foreground leading-relaxed">
            For shared apartments: put all chores on the wheel. Each roommate spins for their weekly responsibilities. Track completions on a shared notes app or whiteboard. The randomness removes the feeling that anyone is targeting anyone.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Seasonal Chores</h2>
          <p class="text-muted-foreground leading-relaxed">
            Add seasonal tasks when relevant: window cleaning (spring), gutter clearing (fall), deep-clean refrigerator (monthly). Remove them when done. The wheel adapts to what needs doing right now.
          </p>
        </div>

      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/", label: "Spin the Wheel", desc: "The main wheel picker — add any names or options and spin." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random name from your list without the wheel animation." },
            { href: "/party-wheel", label: "Party Wheel", desc: "Pre-loaded with party game ideas for your next gathering." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
