---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Random Color Wheel — Spin to Pick a Random Color";
const description = "Spin the color wheel for design decisions, art projects, and games. Random color selection made visual and instant.";
const canonical = "/templates/color-wheel-picker";

const faqItems = [
  {
    question: "Can I add specific hex colors or Pantone shades?",
    answer: "Add any color name you want — specific shades like 'Cobalt Blue' or 'Burnt Sienna' work perfectly.",
  },
  {
    question: "Is this useful for interior design?",
    answer: "Yes — put your shortlisted paint colors on the wheel. Spin to pick which room to test each color in first.",
  },
  {
    question: "Can I use this for fashion?",
    answer: "Absolutely. Spin to pick the accent color for your outfit. Great for building capsule wardrobe variety.",
  },
];

const defaultParticipants = [
  { pseudo: "Red", weight: 1 },
  { pseudo: "Blue", weight: 1 },
  { pseudo: "Green", weight: 1 },
  { pseudo: "Yellow", weight: 1 },
  { pseudo: "Purple", weight: 1 },
  { pseudo: "Orange", weight: 1 },
  { pseudo: "Pink", weight: 1 },
  { pseudo: "Teal", weight: 1 },
  { pseudo: "Gold", weight: 1 },
  { pseudo: "Black", weight: 1 },
  { pseudo: "White", weight: 1 },
  { pseudo: "Coral", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/color-wheel-picker",
};

const themeColors = ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#06b6d4','#84cc16','#a855f7'];
---

<style>
  /* ═══ PRISME ARC-EN-CIEL ═══ */
  .cw-page {
    background: #000000;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  .cw-sky {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 50%, rgba(139,92,246,0.06) 0%, transparent 55%),
                linear-gradient(180deg, #000000 0%, #020004 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Colored rays from center */
  .cw-ray {
    position: fixed;
    top: 50%;
    left: 50%;
    width: 4px;
    height: 55vh;
    transform-origin: top center;
    pointer-events: none;
    z-index: 1;
    animation: cwRayPulse ease-in-out infinite alternate;
    border-radius: 2px;
  }
  @keyframes cwRayPulse {
    0%   { opacity: 0.2; transform: rotate(var(--deg)) scaleY(0.85); }
    100% { opacity: 0.65; transform: rotate(var(--deg)) scaleY(1.15); }
  }

  /* Rainbow particles */
  .cw-particle {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    animation: cwParticleOrbit linear infinite;
  }
  @keyframes cwParticleOrbit {
    0%   { transform: translateY(0px) translateX(0px) rotate(0deg); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 0.7; }
    100% { transform: translateY(-110vh) translateX(var(--drift)) rotate(360deg); opacity: 0; }
  }

  /* Prism rotation div */
  .cw-prism {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 200px;
    height: 200px;
    pointer-events: none;
    z-index: 1;
    border-radius: 50%;
    animation: cwPrismRotate linear infinite;
    background: conic-gradient(#ef4444, #f97316, #eab308, #22c55e, #3b82f6, #8b5cf6, #ec4899, #ef4444);
    opacity: 0.12;
    filter: blur(30px);
  }
  @keyframes cwPrismRotate {
    0%   { transform: translate(-50%, -50%) rotate(0deg) scale(1); }
    50%  { transform: translate(-50%, -50%) rotate(180deg) scale(1.2); }
    100% { transform: translate(-50%, -50%) rotate(360deg) scale(1); }
  }

  /* Corner halos */
  .cw-corner-halo {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(60px);
    animation: cwHaloGlow ease-in-out infinite alternate;
  }
  @keyframes cwHaloGlow {
    0%   { opacity: 0.2; transform: scale(0.9); }
    100% { opacity: 0.5; transform: scale(1.1); }
  }

  /* Floating sparks */
  .cw-spark {
    position: fixed;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 3;
    animation: cwSparkFloat ease-in-out infinite;
  }
  @keyframes cwSparkFloat {
    0%, 100% { opacity: 0; transform: scale(0.2) translateY(0px); }
    40%, 60%  { opacity: 1; transform: scale(1.5) translateY(-8px); }
  }

  /* Diffraction streaks */
  .cw-streak {
    position: fixed;
    height: 2px;
    border-radius: 1px;
    pointer-events: none;
    z-index: 1;
    animation: cwStreakSlide linear infinite;
  }
  @keyframes cwStreakSlide {
    0%   { transform: translateX(-120px) scaleX(0.3); opacity: 0; }
    20%  { opacity: 0.8; transform: translateX(0px) scaleX(1); }
    80%  { opacity: 0.5; }
    100% { transform: translateX(120px) scaleX(0.2); opacity: 0; }
  }

  /* Content */
  .cw-content { position: relative; z-index: 10; }

  .cw-title {
    background: linear-gradient(90deg, #ef4444, #f97316, #eab308, #22c55e, #3b82f6, #8b5cf6, #ec4899, #ef4444);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: cwTitleShimmer 6s linear infinite;
    filter: drop-shadow(0 0 30px rgba(139,92,246,0.6));
  }
  @keyframes cwTitleShimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  .cw-tag {
    background: rgba(139,92,246,0.15);
    border: 1px solid rgba(139,92,246,0.4);
    color: rgba(200,160,255,0.9);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .cw-card {
    background: rgba(5,0,12,0.82);
    border: 1px solid rgba(139,92,246,0.2);
    border-radius: 1rem;
    transition: border-color 0.2s, background 0.2s;
    backdrop-filter: blur(8px);
  }
  .cw-card:hover {
    border-color: rgba(139,92,246,0.5);
    background: rgba(8,0,18,0.9);
  }

  details.cw-faq {
    background: rgba(5,0,12,0.82);
    border: 1px solid rgba(139,92,246,0.18);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
  details.cw-faq[open] {
    border-color: rgba(139,92,246,0.45);
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Color Wheel Picker", url: "https://realwheelpicker.com/templates/color-wheel-picker" },
  ]} />

  <div class="cw-page">
    <div class="cw-sky"></div>

    <!-- Central prism rotation -->
    <div class="cw-prism"></div>

    <!-- 4 corner halos -->
    <div class="cw-corner-halo" style="width:300px;height:300px;background:rgba(239,68,68,0.3);top:-80px;left:-80px;animation-duration:5s;"></div>
    <div class="cw-corner-halo" style="width:300px;height:300px;background:rgba(59,130,246,0.3);top:-80px;right:-80px;animation-duration:7s;animation-delay:1.5s;"></div>
    <div class="cw-corner-halo" style="width:280px;height:280px;background:rgba(34,197,94,0.25);bottom:-60px;left:-60px;animation-duration:6s;animation-delay:3s;"></div>
    <div class="cw-corner-halo" style="width:280px;height:280px;background:rgba(168,85,247,0.3);bottom:-60px;right:-60px;animation-duration:8s;animation-delay:0.8s;"></div>

    <!-- 8 colored rays from center -->
    {[
      { color: '#ef4444', deg: 0 },
      { color: '#f97316', deg: 45 },
      { color: '#eab308', deg: 90 },
      { color: '#22c55e', deg: 135 },
      { color: '#3b82f6', deg: 180 },
      { color: '#8b5cf6', deg: 225 },
      { color: '#ec4899', deg: 270 },
      { color: '#06b6d4', deg: 315 },
    ].map(({ color, deg }, i) => (
      <div class="cw-ray" style={`background:linear-gradient(180deg, transparent 0%, ${color} 50%, transparent 100%);--deg:${deg}deg;animation-duration:${3 + i * 0.5}s;animation-delay:${i * 0.3}s;`}></div>
    ))}

    <!-- 35 rainbow particles -->
    {Array.from({ length: 35 }, (_, i) => {
      const colors = ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#06b6d4','#84cc16','#a855f7'];
      const c = colors[i % colors.length];
      const size = 3 + (i % 6);
      const drift = ((i % 3) - 1) * 30;
      return (
        <div class="cw-particle" style={`width:${size}px;height:${size}px;left:${(i * 2.8 + 1) % 98}%;bottom:-10px;background:${c};box-shadow:0 0 6px ${c};animation-duration:${5 + i % 5}s;animation-delay:${i * 0.22}s;--drift:${drift}px;`}></div>
      );
    })}

    <!-- 20 floating sparks -->
    {Array.from({ length: 20 }, (_, i) => {
      const colors = ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#06b6d4'];
      return (
        <div class="cw-spark" style={`left:${(i * 4.9 + 2) % 97}%;top:${(i * 8 + 5) % 90}%;background:${colors[i % colors.length]};box-shadow:0 0 8px ${colors[i % colors.length]};animation-duration:${2 + i * 0.25}s;animation-delay:${i * 0.2}s;`}></div>
      );
    })}

    <!-- 10 diffraction streaks -->
    {Array.from({ length: 10 }, (_, i) => {
      const colors = ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#06b6d4','#84cc16','#a855f7'];
      return (
        <div class="cw-streak" style={`width:${60 + i * 15}px;background:${colors[i]};left:${(i * 9 + 3) % 80}%;top:${(i * 11 + 8) % 85}%;animation-duration:${4 + i * 0.6}s;animation-delay:${i * 0.5}s;opacity:0.6;`}></div>
      );
    })}

    <div class="cw-content">
      <HeaderIsland client:load />
      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Color Wheel Picker</span>
        </nav>
        <div class="text-center mb-8">
          <div class="text-5xl mb-3">🌈</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight cw-title mb-3">Random Color Wheel</h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">Spin the prism and let the spectrum decide. Random color selection for design, art, and games — made visual and instant.</p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="cw-tag">Design Tool</span>
            <span class="cw-tag">Art Projects</span>
            <span class="cw-tag">Spectrum Picker</span>
          </div>
        </div>
        <SimpleWheelIsland defaultParticipants={defaultParticipants} colors={themeColors} wheelShape="hexagon" hubTheme="cosmic" client:load />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="cw-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Creative Uses for the Random Color Wheel</h2>
          <p class="text-white/60 leading-relaxed"><span class="font-semibold text-white">Art challenge:</span> Spin to pick your primary color for today's painting or drawing. Constraint breeds creativity — working with a color you wouldn't normally choose produces surprising results.</p>
          <p class="text-white/60 leading-relaxed"><span class="font-semibold text-white">Design decisions:</span> Can't choose between several brand color options? Put them all on the wheel. Spin. Commit to prototyping with that color first.</p>
          <p class="text-white/60 leading-relaxed"><span class="font-semibold text-white">Teaching color theory:</span> Teachers use random color selection to give students the same constraint — paint with this color using only tints and shades.</p>
        </div>

        <div class="cw-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Color Mixing Challenge</h2>
          <p class="text-white/60 leading-relaxed">Spin twice. Mix the two colors you land on. Challenge: create three variations (light, medium, dark) using only those colors plus white and black.</p>
          <p class="text-white/60 leading-relaxed">This constraint forces creative exploration. Landing on two colors you wouldn't normally pair — say, Gold and Teal — produces unexpected combinations that often turn out stronger than your first instinct would suggest.</p>
        </div>

        <div class="cw-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Game Night Uses</h2>
          <div class="space-y-3">
            <div class="p-4 rounded-lg bg-purple-500/10 border border-purple-500/20">
              <p class="font-semibold text-white text-sm mb-1">Charades variant</p>
              <p class="text-white/60 text-sm">Spin for a color, act out or describe something that matches. Team guesses the color you were given.</p>
            </div>
            <div class="p-4 rounded-lg bg-blue-500/10 border border-blue-500/20">
              <p class="font-semibold text-white text-sm mb-1">Drawing challenge</p>
              <p class="text-white/60 text-sm">Everyone gets the same random color. Draw something beautiful using only variations of that color.</p>
            </div>
            <div class="p-4 rounded-lg bg-green-500/10 border border-green-500/20">
              <p class="font-semibold text-white text-sm mb-1">Fashion spin</p>
              <p class="text-white/60 text-sm">Spin to pick the accent color for tomorrow's outfit. Escape your comfort zone one spin at a time.</p>
            </div>
          </div>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="cw-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/", label: "Spin the Wheel", desc: "The main wheel picker — add any names or options and spin." },
              { href: "/weighted-random-picker", label: "Weighted Picker", desc: "Assign different probabilities to each option." },
              { href: "/templates/wheel-of-fortune", label: "Wheel of Fortune", desc: "Prize wheel game for parties and game nights." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="cw-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      </main>

      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
