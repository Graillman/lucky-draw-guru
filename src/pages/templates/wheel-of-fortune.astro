---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Wheel of Fortune Game Online — Free Spinning Prize Wheel";
const description = "Play Wheel of Fortune online free — customize prizes, Bankrupt, Free Spin, and Jackpot. Perfect for classrooms, game nights, and office parties. No download, instant.";
const canonical = "/templates/wheel-of-fortune";

const faqItems = [
  {
    question: "Is this the real Wheel of Fortune game?",
    answer: "No — this is a free prize spinner inspired by the classic TV format. You provide the puzzle and the prizes. Our wheel handles the spin. It's perfect for classroom games, family nights, and custom prize drawings where you want the visual drama of a wheel.",
  },
  {
    question: "Can I add my own prize amounts?",
    answer: "Yes. Click any segment label to rename it. Replace $100 with any prize, dare, activity, or challenge. The wheel adapts to whatever you put in it — office raffle prizes, birthday dares, or custom game show prizes.",
  },
  {
    question: "How do I play in teams?",
    answer: "Split players into teams. Each team spins once per turn. If they land on a dollar amount, they guess a letter. Correct letter = earn the money. Bankrupt = lose all earnings. Highest total after all puzzles wins.",
  },
  {
    question: "Can I use this for a school or classroom game?",
    answer: "Absolutely. Replace the dollar amounts with vocabulary words, math problems, history questions, or bonus points. Teachers use it for review games, spelling bees, and reward drawings. The spinning animation builds genuine anticipation — better than any flashcard.",
  },
  {
    question: "How many prize options can I add?",
    answer: "Up to dozens of segments. The wheel scales automatically to fit your entries. For the classic Wheel of Fortune feel, 8 to 12 segments works best — enough variety without making the segments too small to read.",
  },
  {
    question: "Can I save my custom wheel for next time?",
    answer: "Yes. Your custom prize configuration can be saved to your browser's local storage. It will reload automatically the next time you visit. Nothing is sent to a server — all data stays on your device.",
  },
  {
    question: "Is the spin result random?",
    answer: "Yes. The wheel uses crypto.getRandomValues() — cryptographic hardware randomness, not Math.random(). Each spin is completely independent and impossible to predict or manipulate.",
  },
];

const defaultParticipants = [
  { pseudo: "$100", weight: 1 },
  { pseudo: "$200", weight: 1 },
  { pseudo: "$500", weight: 1 },
  { pseudo: "$1000", weight: 1 },
  { pseudo: "Bankrupt", weight: 1 },
  { pseudo: "Lose a Turn", weight: 1 },
  { pseudo: "Free Spin", weight: 1 },
  { pseudo: "$300", weight: 1 },
  { pseudo: "$750", weight: 1 },
  { pseudo: "Jackpot!", weight: 1 },
];

const myColors = ['#ffd700','#1a4fa0','#dc2626','#22c55e','#ffffff','#7c3aed','#f97316','#ec4899'];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Wheel of Fortune Game — Real Wheel Picker",
      "url": "https://realwheelpicker.com/templates/wheel-of-fortune",
      "description": description,
      "applicationCategory": "GameApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "publisher": { "@type": "Organization", "name": "Real Wheel Picker", "url": "https://realwheelpicker.com" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Templates", "item": "https://realwheelpicker.com/templates" },
        { "@type": "ListItem", "position": 3, "name": "Wheel of Fortune" },
      ],
    },
  ],
};
---

<style>
  /* ===== WHEEL OF FORTUNE — TV SHOW SPECTACULAIRE ===== */

  .wof-page {
    min-height: 100vh;
    background: #050510;
    position: relative;
    overflow-x: hidden;
  }

  /* Fond scène de télévision */
  .wof-bg {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 30%, #0a0830 0%, #05050f 45%, #020208 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* 8 spotlights de scène en cône */
  .wof-spot {
    position: fixed;
    top: -60px;
    width: 220px;
    height: 650px;
    background: linear-gradient(180deg,
      rgba(255,255,200,0.18) 0%,
      rgba(255,255,180,0.08) 35%,
      transparent 100%
    );
    transform-origin: top center;
    pointer-events: none;
    z-index: 2;
    border-radius: 0 0 50% 50%;
    filter: blur(3px);
    animation: scanSpot ease-in-out infinite alternate;
  }
  @keyframes scanSpot {
    0%   { transform: rotate(-22deg); opacity: 0.4; }
    100% { transform: rotate(22deg);  opacity: 1; }
  }

  /* Sequins / paillettes tombantes */
  .wof-sequin {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    border-radius: 2px;
    opacity: 0;
    animation: sequinFall linear infinite;
  }
  @keyframes sequinFall {
    0%   { transform: translateY(-20px) rotate(0deg);   opacity: 0; }
    8%   { opacity: 0.9; }
    90%  { opacity: 0.6; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }

  /* Confettis permanents */
  .wof-confetti {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    width: 10px;
    height: 10px;
    opacity: 0;
    animation: confettiDrift ease-in-out infinite;
  }
  @keyframes confettiDrift {
    0%   { transform: translateY(-20px) translateX(0) rotate(0deg);    opacity: 0; }
    10%  { opacity: 0.8; }
    50%  { transform: translateY(50vh) translateX(30px) rotate(180deg); opacity: 0.6; }
    90%  { opacity: 0.5; }
    100% { transform: translateY(110vh) translateX(-20px) rotate(360deg); opacity: 0; }
  }

  /* Lueurs ambiantes colorées */
  .wof-glow {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    filter: blur(90px);
    animation: wofGlowPulse ease-in-out infinite alternate;
  }
  @keyframes wofGlowPulse {
    0%   { opacity: 0.35; transform: scale(1); }
    100% { opacity: 0.7;  transform: scale(1.25); }
  }

  /* Logo WOF en haut */
  .wof-logo {
    text-align: center;
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.25em;
    color: #ffd700;
    text-shadow:
      0 0 10px rgba(255,215,0,0.9),
      0 0 20px rgba(255,165,0,0.6),
      0 0 40px rgba(255,100,0,0.3);
    padding: 0.3rem 1.5rem;
    border: 2px solid rgba(255,215,0,0.5);
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 0.5rem;
    background: rgba(255,215,0,0.05);
    animation: logoShimmer 3s ease-in-out infinite alternate;
  }
  @keyframes logoShimmer {
    0%   { text-shadow: 0 0 10px rgba(255,215,0,0.9), 0 0 20px rgba(255,165,0,0.6); }
    100% { text-shadow: 0 0 20px rgba(255,215,0,1), 0 0 40px rgba(255,165,0,0.8), 0 0 60px rgba(255,100,0,0.4); }
  }

  /* Barre de lumières en bas */
  .wof-lights-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 16px;
    display: flex;
    z-index: 100;
    pointer-events: none;
  }
  .wof-bulb {
    flex: 1;
    border-radius: 50% 50% 0 0;
    animation: bulbFlash ease-in-out infinite alternate;
  }
  @keyframes bulbFlash {
    0%   { opacity: 0.3; }
    100% { opacity: 1; box-shadow: 0 0 8px currentColor; }
  }

  /* Contenu */
  .wof-content { position: relative; z-index: 10; }

  /* Cards */
  .wof-card {
    background: rgba(4,4,18,0.85);
    border: 1px solid rgba(255,215,0,0.25);
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 0 30px rgba(255,215,0,0.06), inset 0 1px 0 rgba(255,255,255,0.04);
    backdrop-filter: blur(12px);
  }
  .wof-inner-card {
    background: rgba(255,215,0,0.04);
    border: 1px solid rgba(255,215,0,0.18);
    border-radius: 0.75rem;
    padding: 0.875rem;
  }
  .wof-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    border: 1px solid;
  }
  .faq-card {
    background: rgba(4,4,18,0.8);
    border: 1px solid rgba(100,100,255,0.2);
    border-radius: 1rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
  .related-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(4,4,18,0.78);
    border: 1px solid rgba(255,215,0,0.2);
    border-radius: 1rem;
    text-decoration: none;
    transition: all 0.2s;
    backdrop-filter: blur(8px);
  }
  .related-card:hover {
    border-color: rgba(255,215,0,0.7);
    box-shadow: 0 0 20px rgba(255,215,0,0.15);
    transform: translateY(-2px);
  }

  h1 {
    color: #ffd700;
    text-shadow:
      0 0 30px rgba(255,215,0,0.7),
      0 0 60px rgba(255,165,0,0.4),
      2px 2px 4px rgba(0,0,0,0.9);
    font-style: italic;
    letter-spacing: -0.02em;
  }
  h2 { color: #ffe680; }
  .body-text  { color: #c8c0e8; }
  .muted-text { color: #8880aa; }
  .bc-link { color: #8880aa; text-decoration: none; transition: color 0.2s; }
  .bc-link:hover { color: #ffd700; }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Wheel of Fortune", url: "https://realwheelpicker.com/templates/wheel-of-fortune" },
  ]} />

  <div class="wof-page">
    <div class="wof-bg"></div>

    <!-- Lueurs ambiantes -->
    <div class="wof-glow" style="top:-120px; left:-80px; width:500px; height:500px; background:rgba(255,215,0,0.2); animation-duration:8s;"></div>
    <div class="wof-glow" style="top:-80px; right:-80px; width:400px; height:400px; background:rgba(220,38,38,0.2); animation-duration:6s;"></div>
    <div class="wof-glow" style="bottom:-80px; left:35%; width:500px; height:300px; background:rgba(124,58,237,0.2); animation-duration:9s;"></div>
    <div class="wof-glow" style="top:40%; left:-60px; width:300px; height:300px; background:rgba(34,197,94,0.15); animation-duration:7s;"></div>

    <!-- 8 spotlights de scène -->
    {[
      {l:"2%",dur:"9s",del:"0s"},{l:"14%",dur:"11s",del:"-2s"},{l:"26%",dur:"8s",del:"-4s"},
      {l:"38%",dur:"12s",del:"-1s"},{l:"52%",dur:"10s",del:"-6s"},{l:"64%",dur:"13s",del:"-3s"},
      {l:"76%",dur:"9s",del:"-5s"},{l:"88%",dur:"11s",del:"-7s"},
    ].map(({l,dur,del}) => (
      <div class="wof-spot" style={`left:${l}; animation-duration:${dur}; animation-delay:${del};`}></div>
    ))}

    <!-- Sequins colorés tombants -->
    {[
      {l:"5%",w:"8px",h:"8px",c:"#ffd700",dur:"7s",del:"0s"},{l:"12%",w:"6px",h:"6px",c:"#dc2626",dur:"9s",del:"-2s"},
      {l:"20%",w:"10px",h:"6px",c:"#3b82f6",dur:"11s",del:"-4s"},{l:"28%",w:"7px",h:"7px",c:"#22c55e",dur:"8s",del:"-1s"},
      {l:"36%",w:"9px",h:"5px",c:"#ec4899",dur:"13s",del:"-6s"},{l:"44%",w:"6px",h:"8px",c:"#f97316",dur:"10s",del:"-3s"},
      {l:"52%",w:"8px",h:"6px",c:"#ffd700",dur:"12s",del:"-5s"},{l:"60%",w:"7px",h:"9px",c:"#7c3aed",dur:"9s",del:"-7s"},
      {l:"68%",w:"10px",h:"6px",c:"#dc2626",dur:"11s",del:"-2s"},{l:"76%",w:"6px",h:"7px",c:"#22c55e",dur:"8s",del:"-4s"},
      {l:"84%",w:"8px",h:"8px",c:"#ec4899",dur:"14s",del:"-1s"},{l:"92%",w:"7px",h:"6px",c:"#ffd700",dur:"10s",del:"-6s"},
      {l:"16%",w:"5px",h:"9px",c:"#3b82f6",dur:"13s",del:"-8s"},{l:"70%",w:"9px",h:"5px",c:"#f97316",dur:"7s",del:"-3s"},
      {l:"40%",w:"6px",h:"6px",c:"#ffd700",dur:"15s",del:"-9s"},
    ].map(({l,w,h,c,dur,del}) => (
      <div class="wof-sequin" style={`left:${l}; width:${w}; height:${h}; background:${c}; animation-duration:${dur}; animation-delay:${del}; box-shadow:0 0 4px ${c};`}></div>
    ))}

    <!-- Confettis permanents -->
    {[
      {l:"8%",c:"#ffd700",dur:"16s",del:"0s"},{l:"25%",c:"#dc2626",dur:"20s",del:"-5s"},
      {l:"42%",c:"#3b82f6",dur:"18s",del:"-10s"},{l:"58%",c:"#22c55e",dur:"22s",del:"-3s"},
      {l:"75%",c:"#ec4899",dur:"17s",del:"-8s"},{l:"90%",c:"#7c3aed",dur:"21s",del:"-12s"},
    ].map(({l,c,dur,del}) => (
      <div class="wof-confetti" style={`left:${l}; background:${c}; animation-duration:${dur}; animation-delay:${del}; border-radius:2px;`}></div>
    ))}

    <!-- Barre de lumières en bas -->
    <div class="wof-lights-bar">
      {["#ffd700","#dc2626","#3b82f6","#22c55e","#ec4899","#f97316","#7c3aed","#ffd700","#dc2626","#3b82f6","#22c55e","#ec4899","#f97316","#7c3aed","#ffd700","#dc2626","#3b82f6","#22c55e","#ec4899","#f97316"].map((c, i) => (
        <div class="wof-bulb" style={`background:${c}; color:${c}; animation-delay:${i * 0.12}s;`}></div>
      ))}
    </div>

    <div class="wof-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-6 pb-16">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="text-xs flex gap-1 mb-6 muted-text">
          <a href="/" class="bc-link">Home</a>
          <span>/</span>
          <a href="/templates" class="bc-link">Templates</a>
          <span>/</span>
          <span style="color:#ffe680;">Wheel of Fortune</span>
        </nav>

        <!-- Hero -->
        <section class="text-center space-y-4 py-4 mb-6">
          <div class="wof-logo">WHEEL OF FORTUNE</div>
          <div class="text-5xl mb-2">🎡</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight">
            Wheel of Fortune — Free Online Prize Spinner
          </h1>
          <p class="text-lg md:text-xl body-text max-w-2xl mx-auto">
            The classic game show format as a free online spinner. Spin for prizes, earn money, land on Bankrupt — or set up your own custom prize wheel for any occasion.
          </p>
          <div class="flex flex-wrap justify-center gap-2 mt-3">
            <span class="wof-tag" style="border-color:#ffd700; color:#fde68a; background:rgba(255,215,0,0.1);">🎡 Game Show</span>
            <span class="wof-tag" style="border-color:#dc2626; color:#fca5a5; background:rgba(220,38,38,0.1);">💰 Prizes</span>
            <span class="wof-tag" style="border-color:#7c3aed; color:#c4b5fd; background:rgba(124,58,237,0.1);">🆓 Free</span>
          </div>
        </section>

        <!-- Wheel -->
        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={myColors}
          wheelShape="star8"
          hubTheme="gold"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <section class="space-y-6">
          <div class="wof-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">How to Play Wheel of Fortune Online</h2>
            <p class="body-text leading-relaxed">
              The classic TV format in your browser. The default wheel includes prize amounts ($100, $200, $500, $1000), Bankrupt, Lose a Turn, Free Spin, and Jackpot — exactly the structure of the original game show. Customize any segment by clicking it.
            </p>
            <ol class="space-y-3 text-sm body-text">
              {[
                { step: "Set up your puzzle", desc: "Write a word, phrase, or category on paper or a whiteboard. Keep it hidden from other players." },
                { step: "Take turns spinning", desc: "Each player spins and calls out a consonant if they land on money. Vowels cost $250." },
                { step: "Guess correctly to earn", desc: "Every time the letter appears in the puzzle, add the spin amount to your total score." },
                { step: "Bankrupt = lose everything", desc: "Landing on Bankrupt wipes your current round earnings. All previously banked amounts are safe." },
                { step: "Solve to win the round", desc: "The first player to solve the puzzle wins all their accumulated earnings from that round." },
              ].map((item, i) => (
                <li class="flex gap-3">
                  <span class="flex-shrink-0 w-6 h-6 rounded-full font-bold text-xs flex items-center justify-center mt-0.5" style="background:rgba(255,215,0,0.15); color:#ffd700;">{i + 1}</span>
                  <div>
                    <span class="font-semibold" style="color:#ffe680;">{item.step} — </span>
                    {item.desc}
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <div class="wof-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Custom Prize Wheel Ideas</h2>
            <p class="body-text leading-relaxed">
              Replace the default dollar amounts with anything you want. Click any segment to rename it:
            </p>
            <div class="grid sm:grid-cols-2 gap-3 text-sm">
              {[
                { title: "Office party", prizes: "Extra PTO, Gift card, Coffee on the boss, Work from home day, Bonus spin" },
                { title: "Birthday party", prizes: "Pick the movie, Choose the restaurant, Skip a chore, Double dessert, Mystery prize" },
                { title: "Classroom review", prizes: "5 bonus points, Extra time, Skip homework, Class choice, Brain teaser question" },
                { title: "Family game night", prizes: "Pick the next game, Choose snacks, Skip a turn, Wild card, Double points" },
              ].map((item) => (
                <div class="wof-inner-card">
                  <p class="font-semibold text-sm mb-1" style="color:#ffe680;">{item.title}</p>
                  <p class="muted-text text-xs">{item.prizes}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="wof-card space-y-3">
            <h2 class="text-xl md:text-2xl font-bold">Why the Wheel Format Works</h2>
            <p class="body-text leading-relaxed">
              The visual drama of a spinning wheel slowing down — the pointer clicking through each segment — creates anticipation that no app, card, or static random number can replicate. That uncertain moment before the wheel stops is why Wheel of Fortune has been the most-watched game show in US history for over 40 years.
            </p>
          </div>
        </section>

        <!-- FAQ -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#ffe680;">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="faq-card">
                <p class="font-semibold mb-2" style="color:#ffd700;">{question}</p>
                <p class="muted-text text-sm leading-relaxed">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Related Tools -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#ffe680;">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/", label: "Spin the Wheel", desc: "The main wheel picker — add any names or options and spin." },
              { href: "/weighted-random-picker", label: "Weighted Random Picker", desc: "Give different odds to each prize — like bigger prize amounts having lower probability." },
              { href: "/templates/dice-roller-wheel", label: "Dice Roller Wheel", desc: "Virtual 6-sided die with equal 1-in-6 odds." },
              { href: "/party-wheel", label: "Party Wheel", desc: "Pre-loaded with party games, dares, and activities." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="related-card">
                  <span style="color:#ffd700; font-weight:700; font-size:0.875rem; margin-top:2px;">→</span>
                  <span>
                    <span class="font-semibold" style="color:#ffe680;">{label}</span>
                    <span class="muted-text text-sm"> — {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:idle />
    </div>
  </div>
</Layout>
