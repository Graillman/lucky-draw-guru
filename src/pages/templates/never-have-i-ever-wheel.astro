---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Never Have I Ever Wheel — Random Questions Spinner";
const description = "Spin the Never Have I Ever wheel for random questions. 10 prompts pre-loaded. Perfect for parties, sleepovers, and icebreakers. Free, instant, customizable.";
const canonical = "/templates/never-have-i-ever-wheel";

const faqItems = [
  {
    question: "How do you play Never Have I Ever with a wheel?",
    answer: "Spin the wheel to get a prompt. Everyone who HAS done it raises their hand (or takes a sip, depending on your rules). Everyone who hasn't done it keeps their hand down. Go around a few times. The person who has done the most things 'wins' — or loses, depending on perspective.",
  },
  {
    question: "Is this appropriate for kids?",
    answer: "The pre-loaded prompts are mild and family-appropriate. You can further edit them to remove anything that doesn't fit your group. Add kid-friendly versions like 'Never have I ever stayed up past midnight' or 'Never have I ever eaten a whole pizza'.",
  },
  {
    question: "How many prompts should I put on the wheel?",
    answer: "10-15 is ideal. Enough variety for a full game session without running out of questions, but not so many that the same prompt never comes up twice and tension never builds.",
  },
];

const defaultParticipants = [
  { pseudo: "Traveled solo", weight: 1 },
  { pseudo: "Lied to skip work", weight: 1 },
  { pseudo: "Eaten off the floor", weight: 1 },
  { pseudo: "Ghosted someone", weight: 1 },
  { pseudo: "Sung karaoke", weight: 1 },
  { pseudo: "Skipped school", weight: 1 },
  { pseudo: "Cried at a movie", weight: 1 },
  { pseudo: "Broken a bone", weight: 1 },
  { pseudo: "Met a celebrity", weight: 1 },
  { pseudo: "Slept in public", weight: 1 },
];

const myColors = ['#dc2626','#b91c1c','#7f1d1d','#ef4444','#fee2e2','#991b1b','#fca5a5','#450a0a'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/never-have-i-ever-wheel",
};
---

<style>
  /* ══════════ SOIRÉE JEUX — NEVER HAVE I EVER THEME ══════════ */
  .nhie-page {
    min-height: 100vh;
    position: relative;
    background: #060002;
    color: #f0d0d0;
    overflow-x: hidden;
  }

  /* Fond noir/rouge profond */
  .nhie-sky {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 90% 55% at 50% -5%,  rgba(200,0,30,0.5)  0%, transparent 55%),
      radial-gradient(ellipse 70% 45% at 0%   60%,  rgba(120,0,20,0.35) 0%, transparent 55%),
      radial-gradient(ellipse 70% 45% at 100% 60%,  rgba(120,0,20,0.35) 0%, transparent 55%),
      radial-gradient(ellipse 80% 40% at 50%  105%, rgba(180,0,40,0.4)  0%, transparent 55%),
      linear-gradient(180deg, #060002 0%, #120004 50%, #060002 100%);
    animation: nhieSkyBreath 8s ease-in-out infinite alternate;
  }
  @keyframes nhieSkyBreath {
    0%   { opacity: 0.8; }
    100% { opacity: 1; }
  }

  /* Spotlight central pulsant */
  .nhie-spotlight {
    position: fixed; top: -80px; left: 50%; transform: translateX(-50%);
    width: 640px; height: 760px;
    background: radial-gradient(ellipse at top, rgba(255,50,50,0.2) 0%, rgba(180,0,30,0.1) 40%, transparent 70%);
    z-index: 1; pointer-events: none;
    animation: spotlightPulse 4s ease-in-out infinite;
  }
  @keyframes spotlightPulse {
    0%, 100% { opacity: 0.6; transform: translateX(-50%) scaleX(1); }
    50%       { opacity: 1;   transform: translateX(-50%) scaleX(1.12); }
  }

  /* Halo rouge central qui pulse */
  .nhie-halo {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 80vmin; height: 80vmin;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(220,0,30,0.15) 0%, transparent 70%);
    pointer-events: none; z-index: 1;
    animation: nhieHalo 5s ease-in-out infinite;
  }
  @keyframes nhieHalo {
    0%, 100% { opacity: 0.4; transform: translate(-50%,-50%) scale(1); }
    50%       { opacity: 0.9; transform: translate(-50%,-50%) scale(1.25); }
  }

  /* 15 fumée/brume rouge (fixed) */
  .nhie-mist {
    position: fixed; inset: 0; z-index: 1; pointer-events: none;
    background:
      radial-gradient(ellipse 55% 35% at 25% 75%, rgba(140,0,20,0.28) 0%, transparent 65%),
      radial-gradient(ellipse 45% 40% at 80% 30%, rgba(100,0,15,0.22) 0%, transparent 60%);
    animation: mistFloat 20s ease-in-out infinite alternate;
    filter: blur(2px);
  }
  @keyframes mistFloat {
    0%   { transform: translate(0,0);    opacity: 0.7; }
    100% { transform: translate(2%,-3%); opacity: 1; }
  }

  /* 20 sparkles rouges/oranges scintillants */
  .nhie-sparkles {
    position: fixed; inset: 0; z-index: 2; pointer-events: none; overflow: hidden;
  }
  .nhie-sparkle {
    position: absolute;
    width: var(--sw, 3px); height: var(--sw, 3px);
    border-radius: 50%;
    background: var(--sc, #ff2200);
    box-shadow: 0 0 6px var(--sc, #ff2200), 0 0 12px rgba(255,50,0,0.4);
    left: var(--sl, 50%);
    top: var(--st, 50%);
    opacity: 0;
    animation: sparkle var(--sdur, 3s) ease-in-out infinite;
    animation-delay: var(--sdelay, 0s);
  }
  @keyframes sparkle {
    0%, 100% { opacity: 0;   transform: scale(0) translateY(0); }
    20%       { opacity: 1;   transform: scale(1) translateY(-5px); }
    50%       { opacity: 0.8; transform: scale(1.5) translateY(-15px); }
    80%       { opacity: 0.3; transform: scale(0.8) translateY(-25px); }
  }

  /* Scan line rouge */
  .nhie-scan {
    position: fixed; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255,30,30,0.7) 50%, transparent 100%);
    z-index: 2; pointer-events: none;
    animation: nhieScan 12s linear infinite;
  }
  @keyframes nhieScan {
    0%   { top: -2px;  opacity: 0; }
    3%   { opacity: 1; }
    97%  { opacity: 0.5; }
    100% { top: 100vh; opacity: 0; }
  }

  /* Contenu */
  .nhie-content { position: relative; z-index: 10; }

  /* Titre rouge vif ultra-dramatique */
  .nhie-title {
    background: linear-gradient(135deg, #ff0000 0%, #dc2626 30%, #ff4444 60%, #ff0000 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: nhieTitlePulse 4s linear infinite, nhieGlow 3s ease-in-out infinite;
    filter: drop-shadow(0 0 25px rgba(255,0,30,0.9));
  }
  @keyframes nhieTitlePulse {
    0%   { background-position: 0%   center; }
    100% { background-position: 200% center; }
  }
  @keyframes nhieGlow {
    0%, 100% { filter: drop-shadow(0 0 20px rgba(220,0,30,0.8)); }
    50%       { filter: drop-shadow(0 0 40px rgba(255,50,50,1)) drop-shadow(0 0 70px rgba(180,0,20,0.6)); }
  }

  .nhie-subtitle { color: #c08888; }
  .nhie-badge    { color: #806060; font-size: 0.875rem; }

  /* Breadcrumb */
  .nhie-breadcrumb a         { color: rgba(200,100,110,0.7); text-decoration: none; transition: color 0.2s; }
  .nhie-breadcrumb a:hover   { color: #ff6666; }
  .nhie-breadcrumb .sep      { color: rgba(160,60,70,0.5); }
  .nhie-breadcrumb .cur      { color: rgba(240,190,190,0.9); }

  /* Cards */
  .nhie-card {
    background: rgba(30, 0, 8, 0.85);
    border: 1px solid rgba(200, 0, 40, 0.4);
    border-radius: 16px;
    padding: 1.5rem;
    backdrop-filter: blur(14px);
    box-shadow: 0 0 35px rgba(180,0,30,0.2), inset 0 1px 0 rgba(255,80,80,0.07);
  }
  .nhie-card h2 { color: #ff5566; text-shadow: 0 0 12px rgba(255,30,50,0.5); margin-bottom: 0.5rem; }
  .nhie-card p, .nhie-card li { color: #c09898; line-height: 1.65; }

  .nhie-tag {
    background: rgba(120, 0, 20, 0.28);
    border: 1px solid rgba(200, 0, 40, 0.4);
    border-radius: 10px;
    padding: 1rem;
  }
  .nhie-tag .tag-label { color: #ff7788; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.2rem; }
  .nhie-tag .tag-desc  { color: #b09090; font-size: 0.875rem; }

  /* FAQ */
  .nhie-faq {
    background: rgba(20, 0, 5, 0.9);
    border: 1px solid rgba(180, 0, 30, 0.32);
    border-radius: 12px;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
  .nhie-faq .faq-q { color: #ff6677; font-weight: 600; margin-bottom: 0.5rem; }
  .nhie-faq .faq-a { color: #b09090; font-size: 0.875rem; line-height: 1.6; }

  /* Related links */
  .nhie-link {
    display: flex; align-items: flex-start; gap: 0.75rem;
    padding: 1rem;
    background: rgba(20, 0, 5, 0.8);
    border: 1px solid rgba(180, 0, 30, 0.3);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    backdrop-filter: blur(8px);
  }
  .nhie-link:hover {
    border-color: rgba(255, 50, 60, 0.65);
    box-shadow: 0 0 22px rgba(200, 0, 30, 0.3);
  }
  .nhie-link .arrow      { color: #dd0022; font-weight: 700; font-size: 0.875rem; margin-top: 2px; flex-shrink: 0; }
  .nhie-link .link-title { color: #ff6677; font-weight: 600; }
  .nhie-link .link-desc  { color: #907878; font-size: 0.875rem; }

  .section-title { color: #ff5566; text-shadow: 0 0 12px rgba(255,30,50,0.45); }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Never Have I Ever Wheel", url: "https://realwheelpicker.com/templates/never-have-i-ever-wheel" },
  ]} />

  <div class="nhie-page">

    <!-- Fond atmosphérique (position: fixed) -->
    <div class="nhie-sky"></div>
    <div class="nhie-spotlight"></div>
    <div class="nhie-halo"></div>
    <div class="nhie-mist"></div>
    <div class="nhie-scan"></div>

    <!-- 20 sparkles scintillants -->
    <div class="nhie-sparkles">
      {Array.from({length: 20}).map((_, i) => (
        <div class="nhie-sparkle" style={`--sl:${(i*17+5)%96}%;--st:${(i*13+8)%90}%;--sw:${2+(i%3)}px;--sc:${i%3===0?'#ff2200':i%3===1?'#ff6600':'#cc0022'};--sdur:${2+(i*0.4)%3}s;--sdelay:-${(i*0.7)%4}s`}></div>
      ))}
    </div>

    <div class="nhie-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="nhie-breadcrumb text-xs flex gap-1 mb-8">
          <a href="/">Home</a>
          <span class="sep">/</span>
          <a href="/templates">Templates</a>
          <span class="sep">/</span>
          <span class="cur">Never Have I Ever Wheel</span>
        </nav>

        <section class="text-center space-y-4 py-2 md:py-6 mb-8">
          <h1 class="text-3xl md:text-5xl font-bold leading-tight nhie-title">
            Never Have I Ever Wheel &mdash; Random Questions Spinner
          </h1>
          <p class="text-lg md:text-xl max-w-2xl mx-auto nhie-subtitle">
            Spin for your next Never Have I Ever prompt. No more blanking on questions mid-game. Let the wheel keep the conversation going all night.
          </p>
          <p class="nhie-badge">Free &bull; No account &bull; Instant result</p>
        </section>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={myColors}
          wheelShape="circle"
          hubTheme="crimson"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <section class="space-y-6">
          <div class="nhie-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">How to Play Never Have I Ever</h2>
            <p>
              Never Have I Ever is a party game where players take turns making statements about things they have never done. Anyone who HAS done the thing must acknowledge it &mdash; and in drinking game versions, take a sip. The original version requires creative prompt generation, which is where games slow down and people repeat themselves.
            </p>
            <p>
              The wheel solves the blank-mind problem. Instead of everyone trying to think of interesting prompts on the spot, the wheel generates them randomly. This keeps the game moving and surfaces prompts that nobody would think to say out loud unprompted.
            </p>
            <p>
              Customize the wheel with prompts you know will land well for your specific group. Generic prompts work, but prompts built around shared history create better moments.
            </p>
          </div>

          <div class="nhie-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Prompt Ideas by Occasion</h2>
            <div class="space-y-3">
              <div class="nhie-tag">
                <p class="tag-label">Family-Friendly</p>
                <p class="tag-desc">Stayed up all night, eaten a whole pizza, won a competition, been on TV, visited another country</p>
              </div>
              <div class="nhie-tag">
                <p class="tag-label">Work Team</p>
                <p class="tag-desc">Fallen asleep in a meeting, sent an email to the wrong person, worked from a vacation spot, been promoted unexpectedly</p>
              </div>
              <div class="nhie-tag">
                <p class="tag-label">College / Adult Friends</p>
                <p class="tag-desc">Missed a flight, been to a music festival, lived alone, adopted a pet, learned a language</p>
              </div>
            </div>
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold section-title">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="nhie-faq">
                <p class="faq-q">{question}</p>
                <p class="faq-a">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold section-title">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/templates/truth-or-dare-wheel", label: "Truth or Dare Wheel", desc: "For when you want truths and dares alongside the never-evers." },
              { href: "/templates/dare-wheel", label: "Dare Wheel", desc: "Pure challenge-based party game for more active groups." },
              { href: "/templates/would-you-rather-wheel", label: "Would You Rather Wheel", desc: "Another great conversation-starting party game format." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="nhie-link">
                  <span class="arrow">&#8594;</span>
                  <span>
                    <span class="link-title">{label}</span>
                    <span class="link-desc"> &mdash; {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>

      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
