---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Writing Prompt Spinner — Random Story Starter";
const description = "Spin the writing prompt wheel for a random story starter. 10 unique prompts pre-loaded. Beat writer's block instantly. Great for writers, students, and NaNoWriMo. Free.";
const canonical = "/templates/writing-prompt-wheel";

const faqItems = [
  {
    question: "How long should I write for each prompt?",
    answer: "There's no rule. Some writers use prompts for 10-minute free-writing sessions. Others use them as seeds for full short stories or novels. The prompt is just the starting point — you decide where to take it and how far.",
  },
  {
    question: "Can I add my own writing prompts?",
    answer: "Yes — edit the wheel and add any prompts that inspire you. Genre-specific prompts (horror, romance, sci-fi), prompts from writing books, or your own original starters all work perfectly on the wheel.",
  },
  {
    question: "What if the prompt doesn't match my genre?",
    answer: "That's a feature, not a bug. A horror writer using a romance prompt, or a sci-fi writer using a fantasy prompt, produces unexpected creative combinations. The constraint of an 'wrong genre' prompt often generates the most original work.",
  },
];

const defaultParticipants = [
  { pseudo: "A letter from the future", weight: 1 },
  { pseudo: "The last person on Mars", weight: 1 },
  { pseudo: "A door that shouldn't exist", weight: 1 },
  { pseudo: "The memory thief", weight: 1 },
  { pseudo: "Waking up as someone else", weight: 1 },
  { pseudo: "The missing week", weight: 1 },
  { pseudo: "A gift that changes everything", weight: 1 },
  { pseudo: "The town that forgot", weight: 1 },
  { pseudo: "The last day", weight: 1 },
  { pseudo: "An impossible choice", weight: 1 },
];

const wpColors = ['#1a1a2e','#d4a853','#f5f5dc','#4a3728','#2d4a8a','#c5b358','#8b7355','#0f2744','#b8860b','#e8d5b7'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/writing-prompt-wheel",
};
---

<style>
  /* ═══════════ WRITING PROMPT — NOCTURNAL WRITER'S DESK ═══════════ */
  .wp-page {
    background: #050812;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  .wp-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% -5%, rgba(212,168,83,0.18) 0%, transparent 55%),
      radial-gradient(ellipse 60% 50% at 80% 5%,  rgba(45,74,138,0.22) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 50% 100%, rgba(139,115,85,0.15) 0%, transparent 60%),
      linear-gradient(180deg, #050812 0%, #0a0f20 50%, #050812 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Moon */
  .wp-moon {
    position: fixed;
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #fffde7, #f5deb3, #d4a853);
    box-shadow: 0 0 40px rgba(212,168,83,0.5), 0 0 80px rgba(212,168,83,0.25);
    top: 6%;
    right: 8%;
    pointer-events: none;
    z-index: 1;
    animation: wpMoonGlow 6s ease-in-out infinite alternate;
  }
  @keyframes wpMoonGlow {
    from { box-shadow: 0 0 30px rgba(212,168,83,0.4), 0 0 60px rgba(212,168,83,0.2); }
    to   { box-shadow: 0 0 55px rgba(212,168,83,0.7), 0 0 110px rgba(212,168,83,0.35); }
  }

  /* Moon craters */
  .wp-moon::before {
    content: '';
    position: absolute;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: rgba(0,0,0,0.12);
    top: 22%; left: 58%;
  }
  .wp-moon::after {
    content: '';
    position: absolute;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: rgba(0,0,0,0.1);
    top: 55%; left: 30%;
  }

  /* Flying paper pages */
  .wp-page-leaf {
    position: fixed;
    width: 28px;
    height: 36px;
    background: rgba(245,245,220,0.12);
    border: 1px solid rgba(245,245,220,0.18);
    border-radius: 2px;
    pointer-events: none;
    z-index: 1;
    animation: wpPageFly ease-in-out infinite;
  }
  @keyframes wpPageFly {
    0%   { transform: translateY(110vh) translateX(0) rotate(0deg); opacity: 0; }
    8%   { opacity: 0.7; }
    50%  { transform: translateY(50vh) translateX(40px) rotate(180deg); opacity: 0.5; }
    92%  { opacity: 0.3; }
    100% { transform: translateY(-15vh) translateX(-20px) rotate(360deg); opacity: 0; }
  }

  /* Ink drops */
  .wp-ink {
    position: fixed;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
    animation: wpInkPulse ease-in-out infinite alternate;
  }
  @keyframes wpInkPulse {
    from { opacity: 0.08; transform: scale(0.9); }
    to   { opacity: 0.18; transform: scale(1.1); }
  }

  /* Stars */
  .wp-star {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    animation: wpStarTwinkle ease-in-out infinite alternate;
  }
  @keyframes wpStarTwinkle {
    from { opacity: 0.1; transform: scale(0.5); }
    to   { opacity: 0.95; transform: scale(1.4); box-shadow: 0 0 8px currentColor; }
  }

  /* Quill pen floating */
  .wp-quill {
    position: fixed;
    font-size: 2.2rem;
    pointer-events: none;
    z-index: 1;
    animation: wpQuillFloat ease-in-out infinite;
    opacity: 0.35;
  }
  @keyframes wpQuillFloat {
    0%,100% { transform: translateY(0) rotate(-15deg); }
    50%     { transform: translateY(-25px) rotate(-20deg); }
  }

  /* Writing lines */
  .wp-line {
    position: fixed;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(245,245,220,0.15), transparent);
    pointer-events: none;
    z-index: 0;
    animation: wpLineAppear linear infinite;
    opacity: 0;
  }
  @keyframes wpLineAppear {
    0%   { opacity: 0; width: 0; }
    20%  { opacity: 0.6; width: 40%; }
    80%  { opacity: 0.3; width: 70%; }
    100% { opacity: 0; width: 80%; }
  }

  /* Shooting stars */
  .wp-shoot {
    position: fixed;
    height: 1px;
    background: linear-gradient(90deg, transparent, #f5deb3, transparent);
    pointer-events: none;
    z-index: 1;
    border-radius: 2px;
    animation: wpShoot linear infinite;
    opacity: 0;
  }
  @keyframes wpShoot {
    0%   { transform: translateX(-200px) rotate(-25deg); opacity: 0; }
    5%   { opacity: 0.9; }
    40%  { opacity: 0.5; }
    100% { transform: translateX(110vw) rotate(-25deg); opacity: 0; }
  }

  .wp-content { position: relative; z-index: 10; }

  .wp-title {
    background: linear-gradient(135deg, #f5deb3 0%, #d4a853 30%, #8b7355 60%, #f5deb3 100%);
    background-size: 250%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: wpShimmer 6s ease-in-out infinite;
    filter: drop-shadow(0 0 28px rgba(212,168,83,0.5));
  }
  @keyframes wpShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .wp-tag {
    background: rgba(212,168,83,0.1);
    border: 1px solid rgba(212,168,83,0.3);
    color: rgba(245,220,180,0.9);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .wp-card {
    background: rgba(212,168,83,0.05);
    border: 1px solid rgba(212,168,83,0.18);
    border-radius: 1rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .wp-card:hover {
    border-color: rgba(212,168,83,0.45);
    background: rgba(212,168,83,0.1);
  }

  details.wp-faq {
    background: rgba(212,168,83,0.04);
    border: 1px solid rgba(212,168,83,0.16);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Writing Prompt Spinner", url: "https://realwheelpicker.com/templates/writing-prompt-wheel" },
  ]} />

  <div class="wp-page">
    <div class="wp-sky"></div>

    <!-- Moon -->
    <div class="wp-moon"></div>

    <!-- Ink atmosphere -->
    <div class="wp-ink" style="width:500px;height:400px;background:radial-gradient(circle,rgba(45,74,138,0.3) 0%,transparent 70%);top:-100px;left:-80px;animation-duration:7s;"></div>
    <div class="wp-ink" style="width:400px;height:350px;background:radial-gradient(circle,rgba(139,115,85,0.25) 0%,transparent 70%);bottom:5%;right:-60px;animation-duration:9s;animation-delay:2s;"></div>
    <div class="wp-ink" style="width:300px;height:250px;background:radial-gradient(circle,rgba(212,168,83,0.15) 0%,transparent 70%);top:40%;left:5%;animation-duration:8s;animation-delay:1s;"></div>

    <!-- Flying pages — 28 -->
    {Array.from({ length: 28 }, (_, i) => (
      <div class="wp-page-leaf" style={`left:${i * 3.6}%;animation-duration:${6 + i % 7}s;animation-delay:${i * 0.4}s;transform:rotate(${i * 13}deg);`}></div>
    ))}

    <!-- Stars — 30 -->
    {[
      {l:"5%",t:"8%",s:3,c:"#f5deb3",dur:"1.8s",del:"0s"},{l:"12%",t:"22%",s:2,c:"#d4a853",dur:"2.5s",del:"0.6s"},
      {l:"20%",t:"12%",s:4,c:"#fffde7",dur:"2.1s",del:"1.2s"},{l:"30%",t:"30%",s:2,c:"#f5deb3",dur:"3.0s",del:"0.3s"},
      {l:"40%",t:"7%",s:3,c:"#d4a853",dur:"1.9s",del:"1.7s"},{l:"50%",t:"18%",s:2,c:"#fffde7",dur:"2.4s",del:"0.8s"},
      {l:"60%",t:"25%",s:4,c:"#f5deb3",dur:"2.7s",del:"0.1s"},{l:"70%",t:"10%",s:3,c:"#d4a853",dur:"2.0s",del:"2.1s"},
      {l:"78%",t:"35%",s:2,c:"#fffde7",dur:"1.6s",del:"1.4s"},{l:"88%",t:"15%",s:4,c:"#f5deb3",dur:"2.9s",del:"0.5s"},
      {l:"95%",t:"28%",s:2,c:"#d4a853",dur:"2.2s",del:"1.9s"},{l:"7%",t:"45%",s:3,c:"#fffde7",dur:"1.7s",del:"0.9s"},
      {l:"18%",t:"55%",s:2,c:"#f5deb3",dur:"2.6s",del:"2.3s"},{l:"28%",t:"65%",s:4,c:"#d4a853",dur:"3.1s",del:"0.2s"},
      {l:"38%",t:"72%",s:2,c:"#fffde7",dur:"1.8s",del:"1.1s"},{l:"48%",t:"80%",s:3,c:"#f5deb3",dur:"2.3s",del:"1.6s"},
      {l:"58%",t:"68%",s:2,c:"#d4a853",dur:"2.8s",del:"0.7s"},{l:"68%",t:"78%",s:4,c:"#fffde7",dur:"1.5s",del:"2.0s"},
      {l:"77%",t:"60%",s:3,c:"#f5deb3",dur:"2.0s",del:"0.4s"},{l:"86%",t:"70%",s:2,c:"#d4a853",dur:"2.5s",del:"1.3s"},
      {l:"93%",t:"50%",s:4,c:"#fffde7",dur:"1.9s",del:"0.6s"},{l:"3%",t:"75%",s:2,c:"#f5deb3",dur:"2.7s",del:"1.8s"},
      {l:"15%",t:"85%",s:3,c:"#d4a853",dur:"2.2s",del:"0.3s"},{l:"25%",t:"90%",s:2,c:"#fffde7",dur:"3.0s",del:"2.5s"},
      {l:"45%",t:"92%",s:4,c:"#f5deb3",dur:"1.6s",del:"1.0s"},{l:"55%",t:"88%",s:2,c:"#d4a853",dur:"2.4s",del:"0.8s"},
      {l:"65%",t:"95%",s:3,c:"#fffde7",dur:"1.7s",del:"1.5s"},{l:"75%",t:"85%",s:2,c:"#f5deb3",dur:"2.9s",del:"0.1s"},
      {l:"85%",t:"92%",s:4,c:"#d4a853",dur:"2.1s",del:"2.2s"},{l:"92%",t:"80%",s:2,c:"#fffde7",dur:"1.8s",del:"1.7s"},
    ].map(st => (
      <div class="wp-star" style={`width:${st.s}px;height:${st.s}px;background:${st.c};color:${st.c};left:${st.l};top:${st.t};animation-duration:${st.dur};animation-delay:${st.del};`}></div>
    ))}

    <!-- Quill pens decorative -->
    <div class="wp-quill" style="left:4%;top:55%;animation-duration:7s;">✒️</div>
    <div class="wp-quill" style="right:5%;top:62%;animation-duration:9s;animation-delay:2s;font-size:1.6rem;">📝</div>
    <div class="wp-quill" style="left:8%;top:30%;animation-duration:8s;animation-delay:3s;font-size:1.4rem;">🖊️</div>

    <!-- Writing lines -->
    {Array.from({ length: 8 }, (_, i) => (
      <div class="wp-line" style={`top:${30 + i * 8}%;left:5%;animation-duration:${5 + i}s;animation-delay:${i * 1.2}s;`}></div>
    ))}

    <!-- Shooting stars -->
    <div class="wp-shoot" style="width:180px;top:12%;left:0%;animation-duration:6s;animation-delay:0s;"></div>
    <div class="wp-shoot" style="width:240px;top:28%;left:15%;animation-duration:8s;animation-delay:3s;"></div>
    <div class="wp-shoot" style="width:150px;top:8%;left:35%;animation-duration:7s;animation-delay:5s;"></div>

    <div class="wp-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Writing Prompt Spinner</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">✍️</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight wp-title mb-3">
            Writing Prompt Spinner
          </h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">
            Beat writer's block instantly. Spin for a random story starter — 10 evocative prompts pre-loaded.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="wp-tag">✒️ Story Starters</span>
            <span class="wp-tag">📖 NaNoWriMo</span>
            <span class="wp-tag">🌙 Creative Writing</span>
            <span class="wp-tag">🖊️ Beat Block</span>
          </div>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={wpColors}
          wheelShape="hexagon"
          hubTheme="amber"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="wp-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Using Prompts to Beat Writer's Block</h2>
          <p class="text-white/60 leading-relaxed">
            Writer's block is mostly a problem of infinite possibility. When you can write anything, choosing what to write becomes paralyzing. A prompt eliminates that paralysis by collapsing your options to one — this prompt, right now, go.
          </p>
          <p class="text-white/60 leading-relaxed">
            The spinning wheel adds a ritual to prompt selection. The act of spinning, watching the wheel slow, and seeing the result creates a moment of anticipation that primes your creative brain. By the time the wheel stops, you're already imagining possibilities.
          </p>
          <p class="text-white/60 leading-relaxed">
            For regular writing practice, set a timer (10 to 30 minutes), spin the wheel, and write without stopping until the timer ends. Don't edit, don't pause, don't judge. The goal is words on the page.
          </p>
        </div>

        <div class="wp-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Prompt Expansion Techniques</h2>
          <p class="text-white/60 leading-relaxed">
            A prompt is a seed. Here's how to expand any single-line prompt into a full story concept:
          </p>
          <ul class="space-y-3">
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold">→</span>
              <span class="text-white/60"><strong class="text-white">Who?</strong> Who is the protagonist? What do they want? What stands in their way?</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold">→</span>
              <span class="text-white/60"><strong class="text-white">When?</strong> What era, season, or time of day? How does this affect the story's mood?</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold">→</span>
              <span class="text-white/60"><strong class="text-white">Where?</strong> What setting makes this premise most interesting?</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold">→</span>
              <span class="text-white/60"><strong class="text-white">What if?</strong> Add one unexpected twist to deepen the premise.</span>
            </li>
          </ul>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="wp-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/templates/reading-genre-wheel", label: "📚 Book Genre Spinner", desc: "Get reading inspiration before you write." },
              { href: "/templates/vocabulary-wheel", label: "📖 Vocabulary Wheel", desc: "Build your writing vocabulary with random word practice." },
              { href: "/templates/hobby-wheel", label: "🎨 Random Hobby Spinner", desc: "Other creative pursuits to complement your writing." },
              { href: "/templates", label: "🎡 All Templates", desc: "Browse all pre-loaded wheel templates." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="wp-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
