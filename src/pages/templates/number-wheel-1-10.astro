---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Number Wheel 1 to 10 — Random Number Spinner";
const description = "Spin to pick a random number from 1 to 10. For games, guessing contests, and classroom activities. Instant, free.";
const canonical = "/templates/number-wheel-1-10";

const faqItems = [
  {
    question: "Is this truly random?",
    answer: "Yes — uses cryptographic randomness via the Web Crypto API. Each spin is independent and cannot be predicted.",
  },
  {
    question: "Can I change the range to 1-100?",
    answer: "You can add any numbers. For large ranges, the random number generator (/random-number-generator) may be more convenient.",
  },
  {
    question: "What's the difference between this and dice?",
    answer: "A 10-sided wheel lets you add, remove, or customize values. A standard die is fixed. The wheel is more flexible.",
  },
];

const defaultParticipants = [
  { pseudo: "1", weight: 1 },
  { pseudo: "2", weight: 1 },
  { pseudo: "3", weight: 1 },
  { pseudo: "4", weight: 1 },
  { pseudo: "5", weight: 1 },
  { pseudo: "6", weight: 1 },
  { pseudo: "7", weight: 1 },
  { pseudo: "8", weight: 1 },
  { pseudo: "9", weight: 1 },
  { pseudo: "10", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/number-wheel-1-10",
};
---

<style>
    /* === DIGITAL NUMBERS / LED MATRIX THEME === */
    .led-bg {
      background: #000a08;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }

    /* LED grid overlay — dot matrix pattern */
    .led-grid {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image:
        radial-gradient(circle, rgba(0,255,120,0.08) 1px, transparent 1px);
      background-size: 28px 28px;
      animation: gridPulse 4s ease-in-out infinite;
    }

    @keyframes gridPulse {
      0%, 100% { opacity: 0.6; }
      50%       { opacity: 1; }
    }

    /* Scanlines effect */
    .scanlines {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: repeating-linear-gradient(
        0deg,
        transparent 0px,
        transparent 3px,
        rgba(0, 0, 0, 0.12) 3px,
        rgba(0, 0, 0, 0.12) 4px
      );
    }

    /* Central glow — terminal green */
    .terminal-glow {
      position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 700px; height: 500px;
      background: radial-gradient(ellipse, rgba(0,220,100,0.08) 0%, rgba(0,180,200,0.05) 40%, transparent 70%);
      z-index: 0; pointer-events: none;
      animation: terminalPulse 3s ease-in-out infinite;
    }

    @keyframes terminalPulse {
      0%, 100% { opacity: 0.7; transform: translate(-50%, -50%) scale(1); }
      50%       { opacity: 1;   transform: translate(-50%, -50%) scale(1.05); }
    }

    /* Vertical LED bars on sides */
    .led-bar-left {
      position: fixed; top: 0; left: 0; width: 4px; height: 100vh;
      background: linear-gradient(180deg,
        transparent 0%,
        #00ff78 10%, transparent 20%,
        #00e5ff 35%, transparent 45%,
        #00ff78 60%, transparent 70%,
        #00e5ff 85%, transparent 100%
      );
      z-index: 0; pointer-events: none;
      animation: barScroll 3s linear infinite;
    }
    .led-bar-right {
      position: fixed; top: 0; right: 0; width: 4px; height: 100vh;
      background: linear-gradient(180deg,
        transparent 0%,
        #00e5ff 15%, transparent 25%,
        #00ff78 40%, transparent 50%,
        #00e5ff 65%, transparent 75%,
        #00ff78 90%, transparent 100%
      );
      z-index: 0; pointer-events: none;
      animation: barScroll 3s linear infinite reverse;
    }

    @keyframes barScroll {
      0%   { transform: translateY(-100%); }
      100% { transform: translateY(100%); }
    }

    /* Falling digit rain */
    .digit-rain {
      position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
    }
    .digit-rain span {
      position: absolute; top: -40px;
      font-family: 'Courier New', monospace; font-weight: bold;
      color: rgba(0, 255, 120, 0.4); font-size: 1rem;
      animation: digitFall linear infinite;
    }
    .digit-rain span:nth-child(1)  { left: 5%;  animation-duration: 5s;  animation-delay: 0s;   }
    .digit-rain span:nth-child(2)  { left: 12%; animation-duration: 7s;  animation-delay: 1s;   }
    .digit-rain span:nth-child(3)  { left: 20%; animation-duration: 4s;  animation-delay: 2.5s; color: rgba(0,229,255,0.35); }
    .digit-rain span:nth-child(4)  { left: 30%; animation-duration: 9s;  animation-delay: 0.5s; }
    .digit-rain span:nth-child(5)  { left: 40%; animation-duration: 6s;  animation-delay: 3s;   color: rgba(0,255,120,0.5); }
    .digit-rain span:nth-child(6)  { left: 50%; animation-duration: 8s;  animation-delay: 1.5s; }
    .digit-rain span:nth-child(7)  { left: 60%; animation-duration: 5.5s;animation-delay: 4s;   color: rgba(0,229,255,0.45); }
    .digit-rain span:nth-child(8)  { left: 70%; animation-duration: 7.5s;animation-delay: 0.8s; }
    .digit-rain span:nth-child(9)  { left: 80%; animation-duration: 4.5s;animation-delay: 2s;   color: rgba(0,255,120,0.3); }
    .digit-rain span:nth-child(10) { left: 90%; animation-duration: 6.5s;animation-delay: 1.2s; }
    .digit-rain span:nth-child(11) { left: 25%; animation-duration: 10s; animation-delay: 5s;   color: rgba(180,255,120,0.4); }
    .digit-rain span:nth-child(12) { left: 75%; animation-duration: 3.5s;animation-delay: 3.5s; }

    @keyframes digitFall {
      0%   { top: -40px; opacity: 0; }
      5%   { opacity: 1; }
      95%  { opacity: 0.6; }
      100% { top: 110vh; opacity: 0; }
    }

    /* Horizontal data stream lines */
    .data-stream {
      position: fixed; left: -200px; height: 1px;
      background: linear-gradient(90deg, transparent 0%, rgba(0,255,120,0.5) 50%, transparent 100%);
      z-index: 0; pointer-events: none;
      animation: streamRight linear infinite;
    }
    .data-stream:nth-child(1) { top: 20%; width: 400px; animation-duration: 5s; animation-delay: 0s; }
    .data-stream:nth-child(2) { top: 45%; width: 300px; animation-duration: 7s; animation-delay: 2s; background: linear-gradient(90deg, transparent 0%, rgba(0,229,255,0.5) 50%, transparent 100%); }
    .data-stream:nth-child(3) { top: 70%; width: 500px; animation-duration: 6s; animation-delay: 1s; }
    .data-stream:nth-child(4) { top: 85%; width: 350px; animation-duration: 8s; animation-delay: 3s; background: linear-gradient(90deg, transparent 0%, rgba(0,229,255,0.4) 50%, transparent 100%); }

    @keyframes streamRight {
      0%   { left: -600px; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 0.8; }
      100% { left: 110vw; opacity: 0; }
    }

    /* Bottom tech floor */
    .tech-floor {
      position: fixed; bottom: 0; left: 0; right: 0; height: 200px;
      background: linear-gradient(0deg, rgba(0,60,40,0.4) 0%, transparent 100%);
      z-index: 0; pointer-events: none;
    }

    /* Content z-index */
    .led-content { position: relative; z-index: 1; }

    /* Cards */
    .led-card {
      background: rgba(0, 14, 10, 0.88);
      border: 1px solid rgba(0, 220, 100, 0.35);
      border-radius: 1rem; padding: 1.5rem;
      backdrop-filter: blur(8px);
      box-shadow: 0 0 30px rgba(0,200,80,0.12), inset 0 1px 0 rgba(0,255,120,0.06);
    }
    .led-card h2 { color: #80ffcc; }
    .led-card p  { color: rgba(160, 255, 210, 0.8); }
    .led-card strong { color: #00ff88; }

    .led-tag {
      background: rgba(0,100,60,0.2);
      border: 1px solid rgba(0,220,100,0.35);
      border-radius: 0.5rem; padding: 1rem;
    }
    .led-tag .label { color: #40ffa0; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem; }
    .led-tag .desc  { color: rgba(160,255,210,0.7); font-size: 0.875rem; }

    .led-faq {
      background: rgba(0, 10, 8, 0.9);
      border: 1px solid rgba(0, 200, 90, 0.28);
      border-radius: 1rem; padding: 1.25rem;
      backdrop-filter: blur(6px);
    }
    .led-faq .q { color: #60ffb0; font-weight: 600; margin-bottom: 0.5rem; }
    .led-faq .a { color: rgba(160,255,210,0.75); font-size: 0.875rem; line-height: 1.6; }

    .led-link {
      display: flex; align-items: flex-start; gap: 0.75rem; padding: 1rem;
      background: rgba(0, 10, 8, 0.85);
      border: 1px solid rgba(0, 200, 90, 0.25);
      border-radius: 1rem; text-decoration: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      backdrop-filter: blur(6px);
    }
    .led-link:hover {
      border-color: rgba(0,255,120,0.6);
      box-shadow: 0 0 20px rgba(0,200,80,0.25);
    }
    .led-link .arrow     { color: #00ff88; font-weight: 700; font-size: 0.875rem; margin-top: 0.125rem; flex-shrink: 0; }
    .led-link .link-title { color: #80ffcc; font-weight: 600; }
    .led-link .link-desc  { color: rgba(160,255,210,0.65); font-size: 0.875rem; }

    .breadcrumb-nav a { color: rgba(0,220,130,0.65); transition: color 0.2s; }
    .breadcrumb-nav a:hover { color: #80ffcc; }
    .breadcrumb-nav .sep { color: rgba(0,180,100,0.4); }
    .breadcrumb-nav .cur { color: rgba(160,255,210,0.9); }

    .hero-title { color: #e0fff5; text-shadow: 0 0 40px rgba(0,255,120,0.5), 0 0 80px rgba(0,200,255,0.2); font-family: 'Courier New', monospace; }
    .hero-sub   { color: rgba(160,255,210,0.8); }
    .hero-badge { color: rgba(0,220,130,0.65); }
    .section-title { color: #80ffcc; }
  </style>

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Number Wheel 1-10", url: "https://realwheelpicker.com/templates/number-wheel-1-10" },
  ]} />

  
  <div class="led-bg">
    <!-- Atmospheric layers -->
    <div class="led-grid"></div>
    <div class="scanlines"></div>
    <div class="terminal-glow"></div>
    <div class="led-bar-left"></div>
    <div class="led-bar-right"></div>
    <div class="digit-rain">
      <span>7</span><span>3</span><span>9</span><span>1</span><span>5</span>
      <span>8</span><span>2</span><span>6</span><span>4</span><span>10</span>
      <span>0</span><span>7</span>
    </div>
    <div class="data-stream"></div>
    <div class="data-stream"></div>
    <div class="data-stream"></div>
    <div class="data-stream"></div>
    <div class="tech-floor"></div>

    <div class="led-content">
      <HeaderIsland client:load />

      <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="breadcrumb-nav text-xs flex gap-1">
          <a href="/">Home</a>
          <span class="sep">/</span>
          <a href="/templates">Templates</a>
          <span class="sep">/</span>
          <span class="cur">Number Wheel 1-10</span>
        </nav>

        <!-- Hero -->
        <section class="text-center space-y-4 py-2 md:py-6">
          <h1 class="hero-title text-3xl md:text-5xl font-bold leading-tight">
            Number Wheel 1 to 10 — Random Number Spinner
          </h1>
          <p class="hero-sub text-lg md:text-xl max-w-2xl mx-auto">
            Spin to pick a random number from 1 to 10. For games, guessing contests, and classroom activities.
          </p>
          <p class="hero-badge text-sm">Free • No account • Instant result</p>
        </section>

        <!-- Wheel -->
        <section class="flex flex-col items-center">
          <SimpleWheelIsland
            defaultParticipants={defaultParticipants}
            colors={["#00c864","#0090d8","#00e5c8","#00ff88","#0060b0","#00d4a8","#008040","#00a8e8","#20d870","#0070c8"]}
            wheelShape="hexagon"
            hubTheme="neon"
            client:load
          />
        </section>

        <!-- Article Content -->
        <section class="space-y-8">

          <div class="led-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Uses for the 1-10 Number Wheel</h2>
            <p class="leading-relaxed">
              <strong>Guessing game:</strong> Think of a number 1-10. Someone spins. If the wheel matches, they win. Simple, fast, endlessly repeatable.
            </p>
            <p class="leading-relaxed">
              <strong>Classroom:</strong> Use for random student selection (assign each student a number), random problem selection on a worksheet, or random group assignment.
            </p>
            <p class="leading-relaxed">
              <strong>Decision making:</strong> Can't choose between options? Number them 1-10. Spin. Done.
            </p>
          </div>

          <div class="led-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Scaling Up or Down</h2>
            <p class="leading-relaxed">
              Need 1-6 for dice simulation? Remove numbers 7-10. Need 1-20? Add numbers 11-20. The wheel adapts to whatever range you need.
            </p>
            <p class="leading-relaxed">
              For custom probability, use the weighted picker instead — assign higher weights to numbers you want to appear more often. For completely standard equal-probability ranges, this wheel is faster to set up.
            </p>
          </div>

          <div class="led-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Party Games</h2>
            <div class="space-y-3">
              <div class="led-tag">
                <p class="label">The Price Is Right style</p>
                <p class="desc">Pick a number, then reveal the answer. Closest to the actual number without going over wins.</p>
              </div>
              <div class="led-tag">
                <p class="label">Hot or cold</p>
                <p class="desc">One person thinks of a number. Others guess. Wheel picks the next guesser.</p>
              </div>
            </div>
          </div>

        </section>

        <!-- FAQ -->
        <section class="space-y-4">
          <h2 class="section-title text-xl md:text-2xl font-bold">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="led-faq">
                <p class="q">{question}</p>
                <p class="a">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Related Tools -->
        <section class="space-y-4">
          <h2 class="section-title text-xl md:text-2xl font-bold">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/random-number-generator", label: "Random Number Generator", desc: "Pick any number from any range — no wheel needed." },
              { href: "/weighted-random-picker", label: "Weighted Picker", desc: "Assign different probabilities to each number." },
              { href: "/templates/alphabet-wheel", label: "Alphabet Wheel", desc: "Spin to pick a random letter A-Z." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="led-link">
                  <span class="arrow">→</span>
                  <span>
                    <span class="link-title">{label}</span>
                    <span class="link-desc"> — {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>

      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
