---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Wheel Templates — Pre-Made Spinner Wheels for Every Occasion";
const description = "Browse 15+ ready-to-spin wheel templates. Truth or dare, food picker, workout generator, baby names, and more. Click and spin instantly.";
const canonical = "/templates";

const templates = [
  { name: "Truth or Dare Wheel", url: "/templates/truth-or-dare-wheel", desc: "Party prompts for any group" },
  { name: "What to Eat Wheel", url: "/templates/what-to-eat-wheel", desc: "End the meal decision debate" },
  { name: "Random Country Wheel", url: "/templates/random-country-wheel", desc: "Geography games & travel planning" },
  { name: "Workout Wheel", url: "/templates/workout-wheel", desc: "Random exercise circuit generator" },
  { name: "Movie Picker Wheel", url: "/templates/movie-picker-wheel", desc: "Stop scrolling, start watching" },
  { name: "Drinking Game Wheel", url: "/templates/drinking-game-wheel", desc: "Classic party games for adults (21+)" },
  { name: "Baby Name Wheel", url: "/templates/baby-name-wheel", desc: "Let fate pick the perfect name" },
  { name: "Icebreaker Wheel", url: "/templates/icebreaker-wheel", desc: "Random questions for teams & meetings" },
  { name: "Chore Wheel", url: "/templates/chore-wheel", desc: "Fair household chore assignment" },
  { name: "Date Night Wheel", url: "/templates/date-night-wheel", desc: "Break the routine with random date ideas" },
  { name: "Wheel of Fortune", url: "/templates/wheel-of-fortune", desc: "Prize wheel game for parties" },
  { name: "Alphabet Wheel", url: "/templates/alphabet-wheel", desc: "Random letter A-Z for word games" },
  { name: "Color Wheel Picker", url: "/templates/color-wheel-picker", desc: "Random color for art & design" },
  { name: "Would You Rather Wheel", url: "/templates/would-you-rather-wheel", desc: "Dilemma questions for any group" },
  { name: "Number Wheel 1-10", url: "/templates/number-wheel-1-10", desc: "Simple random number spinner" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Wheel Templates",
  "description": "Pre-made spinner wheel templates for every occasion",
  "url": "https://realwheelpicker.com/templates",
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Templates</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Wheel Templates
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Pre-made spinner wheels for every occasion. Click any template to open it with the wheel pre-loaded and ready to spin.
        </p>
        <p class="text-sm text-muted-foreground">15 templates • Free • No account required</p>
      </section>

      <!-- Templates Grid -->
      <section>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {templates.map(({ name, url, desc }) => (
            <a
              href={url}
              class="flex flex-col gap-1.5 p-5 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all group"
            >
              <span class="font-semibold text-foreground group-hover:text-primary transition-colors">{name}</span>
              <span class="text-muted-foreground text-sm leading-relaxed">{desc}</span>
              <span class="text-primary text-xs font-medium mt-1">Spin now →</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Bottom CTA -->
      <section class="text-center space-y-4 py-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Need a Custom Wheel?</h2>
        <p class="text-muted-foreground max-w-xl mx-auto">
          Every template is fully customizable. Open any wheel, edit the entries, and save your setup. Or start from scratch with the main wheel picker.
        </p>
        <a
          href="/"
          class="inline-block px-6 py-3 bg-primary text-primary-foreground font-semibold rounded-xl hover:opacity-90 transition-opacity"
        >
          Build Your Own Wheel
        </a>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
