const DEFAULT_PALETTE = ["#3a86ff","#ff006e","#06d6a0","#ffbe0b","#8338ec","#ff4d6d"];

// Generate mini SVG wheel
function miniWheel(slug: string, count: number = 8): string {
  const palette = PALETTES[slug] || DEFAULT_PALETTE;
  const r = 32, cx = 40, cy = 40;
  const step = (2 * Math.PI) / count;
  let paths = '';
  for (let i = 0; i < count; i++) {
    const a1 = i * step - Math.PI / 2;
    const a2 = a1 + step;
    const x1 = cx + r * Math.cos(a1), y1 = cy + r * Math.sin(a1);
    const x2 = cx + r * Math.cos(a2), y2 = cy + r * Math.sin(a2);
    const large = step > Math.PI ? 1 : 0;
    const color = palette[i % palette.length];
    paths += `<path d="M${cx},${cy} L${x1.toFixed(1)},${y1.toFixed(1)} A${r},${r} 0 ${large},1 ${x2.toFixed(1)},${y2.toFixed(1)} Z" fill="${color}" stroke="rgba(255,255,255,0.25)" stroke-width="0.8"/>`;
  }
  return `<svg width="80" height="80" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
    <circle cx="${cx}" cy="${cy}" r="${r+3}" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
    ${paths}
    <circle cx="${cx}" cy="${cy}" r="9" fill="#0f172a"/>
    <circle cx="${cx}" cy="${cy}" r="9" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="1.5"/>
    <circle cx="${cx}" cy="${cy}" r="3.5" fill="rgba(255,255,255,0.6)"/>
    <polygon points="${cx},${cy-r-7} ${cx-5},${cy-r+3} ${cx+5},${cy-r+3}" fill="rgba(255,255,255,0.9)"/>
  </svg>`;
}

