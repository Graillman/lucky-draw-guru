---

<style>
  .tmpl-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1rem;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }
  .tmpl-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.4);
  }
  .wheel-preview {
    flex-shrink: 0;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
    transition: transform 0.3s;
  }
  .tmpl-card:hover .wheel-preview {
    transform: rotate(30deg) scale(1.08);
  }
  .cat-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 9999px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-6xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Templates</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Wheel Templates
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Pre-made spinner wheels for every occasion. Click any template to open it with the wheel pre-loaded and ready to spin.
        </p>
        <p class="text-sm text-muted-foreground">50 templates • Free • No account required</p>
      </section>

      <!-- Templates Grid by category -->
      {["Party", "Food", "Gaming", "Education", "Lifestyle", "Work", "Seasonal"].map((cat) => {
        const accent = CAT_ACCENT[cat] || "#3a86ff";
        return (
          <div class="mb-10">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-3 h-3 rounded-full" style={`background:${accent};box-shadow:0 0 8px ${accent};`}></div>
              <h2 class="text-lg font-bold text-foreground">{cat}</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {templates.filter(t => t.category === cat).map(({ name, url, slug, desc }) => (
                <a
                  href={url}
                  class="tmpl-card flex items-center gap-4 p-4 group"
                  style={`--accent:${CAT_ACCENT[cat] || "#3a86ff"}`}
                >
                  <!-- Mini wheel preview -->
                  <div class="wheel-preview" set:html={miniWheel(slug, getCount(slug))} />

                  <!-- Text -->
                  <div class="min-w-0 flex-1">
                    <span
                      class="cat-badge"
                      style={`background:${accent}22;color:${accent};border:1px solid ${accent}44;`}
                    >{cat}</span>
                    <p class="font-semibold text-foreground group-hover:text-primary transition-colors text-sm mt-1.5 leading-snug">{name}</p>
                    <p class="text-muted-foreground text-xs leading-relaxed mt-1">{desc}</p>
                    <span class="text-primary text-xs font-medium mt-2 inline-block">Spin now →</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}

      <!-- Bottom CTA -->
      <section class="text-center space-y-4 py-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Need a Custom Wheel?</h2>
        <p class="text-muted-foreground max-w-xl mx-auto">
          Every template is fully customizable. Open any wheel, edit the entries, and save your setup. Or start from scratch with the main wheel picker.
        </p>
        <a
          href="/"
          class="inline-block px-6 py-3 bg-primary text-primary-foreground font-semibold rounded-xl hover:opacity-90 transition-opacity"
        >
          Build Your Own Wheel
        </a>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
