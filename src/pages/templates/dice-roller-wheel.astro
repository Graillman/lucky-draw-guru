---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Dice Roller Wheel — Virtual 6-Sided Die Spinner Online";
const description = "Roll a virtual dice by spinning the wheel. 6-sided die with equal 1-in-6 odds, cryptographically random. Free online dice roller for board games, D&D, and classroom activities.";
const canonical = "/templates/dice-roller-wheel";

const faqItems = [
  {
    question: "Is this a fair dice roller?",
    answer: "Yes. Each face (1–6) has exactly 1/6 probability on every roll. The selection uses crypto.getRandomValues() — hardware-sourced cryptographic randomness, not Math.random(). Each roll is completely independent.",
  },
  {
    question: "Can I use this for D&D and tabletop RPGs?",
    answer: "For a standard d6, yes. For other dice types (d4, d8, d10, d12, d20, d100), use our random number picker and set the range to match your die type. Both use the same cryptographic randomness.",
  },
  {
    question: "How does this compare to a physical dice?",
    answer: "A physical dice can have manufacturing imperfections that slightly favor certain faces. This digital roller uses hardware random number generation with no physical bias — each face has exactly equal probability.",
  },
  {
    question: "Can I roll multiple dice at once?",
    answer: "Spin multiple times in sequence. For board games requiring two dice, spin twice and add the results. For craps or other multi-dice games, set up two browser tabs each with a dice wheel.",
  },
];

const defaultParticipants = [
  { pseudo: "⚀ 1", weight: 1 },
  { pseudo: "⚁ 2", weight: 1 },
  { pseudo: "⚂ 3", weight: 1 },
  { pseudo: "⚃ 4", weight: 1 },
  { pseudo: "⚄ 5", weight: 1 },
  { pseudo: "⚅ 6", weight: 1 },
];

const myColors = ['#1a6b35','#ffffff','#ffd700','#dc2626','#1a1a2e','#c41e3a','#2d8a4e','#f0c040'];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Dice Roller Wheel — Virtual 6-Sided Die",
      "url": "https://realwheelpicker.com/templates/dice-roller-wheel",
      "description": description,
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Templates", "item": "https://realwheelpicker.com/templates" },
        { "@type": "ListItem", "position": 3, "name": "Dice Roller Wheel" },
      ],
    },
  ],
};
---

<style>
  /* ══════════ CASINO LAS VEGAS — DICE ROLLER THEME ══════════ */
  .casino-page {
    min-height: 100vh;
    position: relative;
    background: #020e06;
    color: #e8f5e9;
    overflow-x: hidden;
  }

  /* Tapis vert casino profond */
  .casino-sky {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 100% 60% at 50% 0%,   rgba(10,60,20,0.7)  0%, transparent 55%),
      radial-gradient(ellipse 80%  50% at 0%   50%,  rgba(5,40,15,0.5)   0%, transparent 55%),
      radial-gradient(ellipse 80%  50% at 100% 50%,  rgba(5,40,15,0.5)   0%, transparent 55%),
      radial-gradient(ellipse 60%  40% at 50%  100%, rgba(20,80,30,0.45) 0%, transparent 55%),
      linear-gradient(180deg, #020e06 0%, #071a0a 50%, #020e06 100%);
  }

  /* Texture tapis feutrine */
  .casino-felt {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image: repeating-linear-gradient(
      0deg, transparent 0px, transparent 3px,
      rgba(255,255,255,0.012) 3px, rgba(255,255,255,0.012) 4px
    ),
    repeating-linear-gradient(
      90deg, transparent 0px, transparent 3px,
      rgba(255,255,255,0.012) 3px, rgba(255,255,255,0.012) 4px
    );
  }

  /* Filets dorés du tapis */
  .casino-grid {
    position: fixed; inset: 0; z-index: 1; pointer-events: none;
    background-image:
      linear-gradient(rgba(255,215,0,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,215,0,0.08) 1px, transparent 1px);
    background-size: 80px 80px;
    animation: gridPulse 6s ease-in-out infinite;
  }
  @keyframes gridPulse {
    0%, 100% { opacity: 0.6; }
    50%       { opacity: 1; }
  }

  /* Néons rouges/dorés sur les bords */
  .casino-neon-top {
    position: fixed; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, transparent 0%, #ffd700 20%, #dc2626 50%, #ffd700 80%, transparent 100%);
    z-index: 3; pointer-events: none;
    box-shadow: 0 0 20px rgba(255,215,0,0.8), 0 0 40px rgba(220,38,38,0.5);
    animation: neonBlink 3s ease-in-out infinite;
  }
  .casino-neon-bottom {
    position: fixed; bottom: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, transparent 0%, #dc2626 20%, #ffd700 50%, #dc2626 80%, transparent 100%);
    z-index: 3; pointer-events: none;
    box-shadow: 0 0 20px rgba(220,38,38,0.8), 0 0 40px rgba(255,215,0,0.5);
    animation: neonBlink 3s ease-in-out infinite 1.5s;
  }
  .casino-neon-left {
    position: fixed; top: 0; left: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, transparent 0%, #ffd700 30%, #dc2626 70%, transparent 100%);
    z-index: 3; pointer-events: none;
    box-shadow: 0 0 15px rgba(255,215,0,0.7);
    animation: neonBlink 4s ease-in-out infinite 0.8s;
  }
  .casino-neon-right {
    position: fixed; top: 0; right: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, transparent 0%, #dc2626 30%, #ffd700 70%, transparent 100%);
    z-index: 3; pointer-events: none;
    box-shadow: 0 0 15px rgba(220,38,38,0.7);
    animation: neonBlink 4s ease-in-out infinite 2s;
  }
  @keyframes neonBlink {
    0%, 100% { opacity: 1; }
    45%       { opacity: 0.7; }
    50%       { opacity: 1; }
    52%       { opacity: 0.5; }
    54%       { opacity: 1; }
  }

  /* 15 dés flottants */
  .casino-dice-layer {
    position: fixed; inset: 0; z-index: 1; pointer-events: none; overflow: hidden;
  }
  .casino-die {
    position: absolute;
    width: var(--dw, 40px); height: var(--dw, 40px);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,215,0,0.25);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: var(--dfs, 20px);
    color: rgba(255,215,0,0.4);
    left: var(--dl, 10%);
    top: var(--dt, 10%);
    animation: floatDie var(--ddur, 12s) ease-in-out infinite;
    animation-delay: var(--ddelay, 0s);
    box-shadow: 0 0 15px rgba(255,215,0,0.1);
  }
  @keyframes floatDie {
    0%   { transform: translateY(0)    rotate(0deg)   scale(1); opacity: 0.3; }
    25%  { transform: translateY(-20px) rotate(45deg)  scale(1.05); opacity: 0.5; }
    50%  { transform: translateY(-8px)  rotate(90deg)  scale(0.95); opacity: 0.4; }
    75%  { transform: translateY(-25px) rotate(135deg) scale(1.08); opacity: 0.6; }
    100% { transform: translateY(0)    rotate(180deg) scale(1); opacity: 0.3; }
  }

  /* Spotlight central doré */
  .casino-spotlight {
    position: fixed; top: -100px; left: 50%; transform: translateX(-50%);
    width: 700px; height: 800px;
    background: radial-gradient(ellipse at top, rgba(255,215,0,0.12) 0%, rgba(26,107,53,0.06) 50%, transparent 70%);
    z-index: 1; pointer-events: none;
    animation: spotPulse 5s ease-in-out infinite;
  }
  @keyframes spotPulse {
    0%, 100% { opacity: 0.7; transform: translateX(-50%) scaleX(1); }
    50%       { opacity: 1;   transform: translateX(-50%) scaleX(1.1); }
  }

  /* Contenu */
  .casino-content { position: relative; z-index: 10; }

  /* Titre */
  .casino-title {
    background: linear-gradient(135deg, #ffd700 0%, #f0c040 30%, #ffffff 50%, #ffd700 70%, #dc2626 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: goldShift 4s linear infinite;
    filter: drop-shadow(0 0 20px rgba(255,215,0,0.7));
  }
  @keyframes goldShift {
    0%   { background-position: 0%   center; }
    100% { background-position: 200% center; }
  }
  .casino-subtitle { color: #a0c8a0; }
  .casino-badge    { color: #5a7a5a; font-size: 0.875rem; }

  /* Breadcrumb */
  .casino-breadcrumb a         { color: rgba(160,200,120,0.7); text-decoration: none; transition: color 0.2s; }
  .casino-breadcrumb a:hover   { color: #ffd700; }
  .casino-breadcrumb .sep      { color: rgba(100,140,80,0.5); }
  .casino-breadcrumb .cur      { color: rgba(220,200,160,0.9); }

  /* Cards — feutrine verte sombre */
  .casino-card {
    background: rgba(2, 20, 8, 0.88);
    border: 1px solid rgba(255, 215, 0, 0.25);
    border-radius: 16px;
    padding: 1.5rem;
    backdrop-filter: blur(14px);
    box-shadow: 0 0 30px rgba(255,215,0,0.08), inset 0 1px 0 rgba(255,215,0,0.06);
  }
  .casino-card h2 { color: #ffd700; text-shadow: 0 0 15px rgba(255,215,0,0.4); margin-bottom: 0.5rem; }
  .casino-card p, .casino-card li { color: #a0c8a0; line-height: 1.65; }

  .casino-tag {
    background: rgba(10, 40, 15, 0.8);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 10px;
    padding: 0.875rem;
  }
  .casino-tag .tag-label { color: #ffd700; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.2rem; }
  .casino-tag .tag-desc  { color: #88aa88; font-size: 0.875rem; }

  .casino-die-link {
    display: block;
    padding: 0.75rem;
    background: rgba(5, 20, 8, 0.85);
    border: 1px solid rgba(255,215,0,0.18);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .casino-die-link:hover {
    border-color: rgba(255,215,0,0.5);
    box-shadow: 0 0 20px rgba(255,215,0,0.15);
  }
  .casino-die-link .die-face { color: #ffd700; font-weight: 700; font-size: 0.875rem; }
  .casino-die-link .die-use  { color: #6a8a6a; font-size: 0.75rem; }

  /* FAQ */
  .casino-faq {
    background: rgba(2, 14, 6, 0.9);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 12px;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
  .casino-faq .faq-q { color: #ffd700; font-weight: 600; margin-bottom: 0.5rem; }
  .casino-faq .faq-a { color: #88aa88; font-size: 0.875rem; line-height: 1.6; }

  /* Related links */
  .casino-link {
    display: flex; align-items: flex-start; gap: 0.75rem;
    padding: 1rem;
    background: rgba(2, 14, 6, 0.85);
    border: 1px solid rgba(255, 215, 0, 0.18);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    backdrop-filter: blur(8px);
  }
  .casino-link:hover {
    border-color: rgba(255, 215, 0, 0.5);
    box-shadow: 0 0 20px rgba(255, 215, 0, 0.15);
  }
  .casino-link .arrow      { color: #ffd700; font-weight: 700; font-size: 0.875rem; margin-top: 2px; flex-shrink: 0; }
  .casino-link .link-title { color: #ffd700; font-weight: 600; }
  .casino-link .link-desc  { color: #6a8a6a; font-size: 0.875rem; }

  .section-title { color: #ffd700; text-shadow: 0 0 12px rgba(255,215,0,0.4); }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Dice Roller Wheel", url: "https://realwheelpicker.com/templates/dice-roller-wheel" },
  ]} />

  <div class="casino-page">

    <!-- Fond casino atmosphérique (position: fixed) -->
    <div class="casino-sky"></div>
    <div class="casino-felt"></div>
    <div class="casino-grid"></div>
    <div class="casino-spotlight"></div>
    <div class="casino-neon-top"></div>
    <div class="casino-neon-bottom"></div>
    <div class="casino-neon-left"></div>
    <div class="casino-neon-right"></div>

    <!-- 15 dés flottants -->
    <div class="casino-dice-layer">
      {[
        {face:'⚀',w:'36px',fs:'18px'},{face:'⚅',w:'44px',fs:'22px'},{face:'⚂',w:'32px',fs:'16px'},
        {face:'⚃',w:'48px',fs:'24px'},{face:'⚁',w:'40px',fs:'20px'},{face:'⚄',w:'38px',fs:'19px'},
        {face:'⚅',w:'50px',fs:'25px'},{face:'⚀',w:'30px',fs:'15px'},{face:'⚂',w:'42px',fs:'21px'},
        {face:'⚃',w:'36px',fs:'18px'},{face:'⚄',w:'44px',fs:'22px'},{face:'⚁',w:'34px',fs:'17px'},
        {face:'⚅',w:'46px',fs:'23px'},{face:'⚀',w:'38px',fs:'19px'},{face:'⚂',w:'40px',fs:'20px'},
      ].map((d, i) => (
        <div class="casino-die" style={`--dw:${d.w};--dfs:${d.fs};--dl:${(i*17+3)%92}%;--dt:${(i*13+5)%85}%;--ddur:${10+(i*1.7)%8}s;--ddelay:-${(i*2.3)%12}s`}>{d.face}</div>
      ))}
    </div>

    <div class="casino-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="casino-breadcrumb text-xs flex gap-1 mb-8">
          <a href="/">Home</a>
          <span class="sep">/</span>
          <a href="/templates">Templates</a>
          <span class="sep">/</span>
          <span class="cur">Dice Roller Wheel</span>
        </nav>

        <section class="text-center space-y-4 py-2 md:py-6 mb-8">
          <h1 class="text-3xl md:text-5xl font-bold leading-tight casino-title">
            Dice Roller Wheel &mdash; Roll a Virtual 6-Sided Die
          </h1>
          <p class="text-lg md:text-xl max-w-2xl mx-auto casino-subtitle">
            Spin the wheel to roll a d6. Equal 1-in-6 odds, cryptographically random &mdash; no physical bias, instant result.
          </p>
          <p class="casino-badge">Free &bull; No account &bull; Unbiased 1&ndash;6</p>
        </section>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={myColors}
          wheelShape="hexagon"
          hubTheme="gold"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <section class="space-y-6">
          <div class="casino-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Uses for a Virtual Dice Roller</h2>
            <div class="grid sm:grid-cols-2 gap-3 text-sm">
              {[
                { use: "Board games", example: "Monopoly, Snakes & Ladders, Catan — when you've lost the physical dice" },
                { use: "D&D and tabletop RPGs", example: "Quick d6 rolls for damage, skill checks, or improvised tables" },
                { use: "Classroom math", example: "Probability lessons — track 50 rolls and chart the distribution" },
                { use: "Coding challenges", example: "Generate random numbers for testing when Math.random() isn't enough" },
                { use: "Games with dice rules", example: "Yahtzee scoring practice, Farkle, or any dice-based game variant" },
                { use: "Party games", example: "Replacement for physical dice in drinking games or activity spinners" },
              ].map((item) => (
                <div class="casino-tag">
                  <p class="tag-label">{item.use}</p>
                  <p class="tag-desc">{item.example}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="casino-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Other Dice Types</h2>
            <p>Need a different die type? Use our <a href="/random-number-picker" style="color:#ffd700;text-decoration:underline;">Random Number Picker</a> and set the range:</p>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm">
              {[
                { die: "d4 (1–4)", use: "Damage rolls, small checks" },
                { die: "d8 (1–8)", use: "Weapon damage in D&D" },
                { die: "d10 (1–10)", use: "Percentile rolls" },
                { die: "d12 (1–12)", use: "Month picker, high damage" },
                { die: "d20 (1–20)", use: "D&D attack and saving throws" },
                { die: "d100 (1–100)", use: "Percentile chance events" },
              ].map((d) => (
                <a href="/random-number-picker" class="casino-die-link">
                  <p class="die-face">{d.die}</p>
                  <p class="die-use">{d.use}</p>
                </a>
              ))}
            </div>
          </div>

          <div class="casino-card space-y-3">
            <h2 class="text-xl md:text-2xl font-bold">Why Use a Digital Dice Roller?</h2>
            <p>
              Physical dice get lost, roll off tables, and can be weighted. Casino dice are manufactured to tight tolerances precisely because standard dice have measurable bias. Our digital dice roller uses <code style="color:#ffd700;background:rgba(255,215,0,0.1);padding:0 4px;border-radius:3px;">crypto.getRandomValues()</code> &mdash; the same cryptographic standard used in online banking &mdash; so every face has exactly 1/6 probability on every roll, guaranteed.
            </p>
            <p>
              The spinning wheel visualization also makes it more engaging than a static number display &mdash; the anticipation of where it lands is part of the experience.
            </p>
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold section-title">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="casino-faq">
                <p class="faq-q">{question}</p>
                <p class="faq-a">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold section-title">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/random-number-picker", label: "Random Number Picker", desc: "Any range — d4, d8, d10, d12, d20, d100, or custom." },
              { href: "/templates/coin-flip-wheel", label: "Coin Flip Wheel", desc: "Virtual heads or tails — exactly 50/50." },
              { href: "/decision-wheel", label: "Decision Wheel", desc: "Add any options for custom multi-choice decisions." },
              { href: "/templates/number-wheel-1-10", label: "Number Wheel 1–10", desc: "Spin to pick a random number from 1 to 10." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="casino-link">
                  <span class="arrow">&#8594;</span>
                  <span>
                    <span class="link-title">{label}</span>
                    <span class="link-desc"> &mdash; {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>

      <GlobalFooterIsland client:idle />
    </div>
  </div>
</Layout>
