---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Drinking Game Wheel — Free Party Spinner (21+)";
const description = "Spin for drinking game challenges. Pre-loaded with 8 classic party prompts for adults 21+. The wheel picks, you drink.";
const canonical = "/templates/drinking-game-wheel";

const faqItems = [
  {
    question: "Can I customize the games?",
    answer: "Yes — remove any game you don't know the rules for and add your favorites. You can also add 'Drink 2' or 'Skip Turn' as wheel options.",
  },
  {
    question: "What's the ideal number of players?",
    answer: "4-8 players is the sweet spot. Fewer than 4 makes some games awkward; more than 10 makes rounds too long.",
  },
  {
    question: "Can this be used without alcohol?",
    answer: "Absolutely. Replace drinking with push-ups, telling a joke, or any other light penalty. Makes it great for teens or sober party nights too.",
  },
];

const defaultParticipants = [
  { pseudo: "Waterfall", weight: 1 },
  { pseudo: "Never Have I Ever", weight: 1 },
  { pseudo: "Categories", weight: 1 },
  { pseudo: "Rhyme Time", weight: 1 },
  { pseudo: "Most Likely To", weight: 1 },
  { pseudo: "Kings Rule", weight: 1 },
  { pseudo: "Truth or Drink", weight: 1 },
  { pseudo: "Two Truths One Lie", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/drinking-game-wheel",
};

const themeColors = ['#22d3ee','#a855f7','#84cc16','#ec4899','#f59e0b','#06b6d4','#8b5cf6','#10b981','#f97316','#3b82f6'];
---

<style>
  /* ═══ BAR PARTY ÉLECTRIQUE ═══ */
  .dg-page {
    background: #03010a;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  .dg-sky {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 100% 50% at 20% 50%, rgba(34,211,238,0.12) 0%, transparent 55%),
                radial-gradient(ellipse 90% 45% at 80% 60%, rgba(168,85,247,0.12) 0%, transparent 55%),
                radial-gradient(ellipse 70% 40% at 50% 100%, rgba(132,204,22,0.08) 0%, transparent 50%),
                linear-gradient(180deg, #010008 0%, #03010a 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Beer bubbles */
  .dg-bubble {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    animation: dgBubbleRise ease-in-out infinite;
    border: 1px solid;
  }
  @keyframes dgBubbleRise {
    0%   { transform: translateY(110vh) translateX(0px); opacity: 0; }
    8%   { opacity: 0.7; }
    50%  { transform: translateY(50vh) translateX(15px); opacity: 0.5; }
    100% { transform: translateY(-5vh) translateX(-10px); opacity: 0; }
  }

  /* Neon blinking signs */
  .dg-neon {
    position: fixed;
    pointer-events: none;
    z-index: 3;
    font-weight: 900;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 2px solid;
    border-radius: 3px;
    animation: dgNeonBlink ease-in-out infinite;
  }
  @keyframes dgNeonBlink {
    0%, 100% { opacity: 1; text-shadow: 0 0 8px currentColor, 0 0 20px currentColor; box-shadow: 0 0 8px currentColor, inset 0 0 8px rgba(255,255,255,0.05); }
    35%      { opacity: 0.5; text-shadow: none; box-shadow: none; }
    40%      { opacity: 1; text-shadow: 0 0 8px currentColor, 0 0 20px currentColor; box-shadow: 0 0 8px currentColor; }
    70%      { opacity: 0.3; text-shadow: none; box-shadow: none; }
    75%      { opacity: 1; text-shadow: 0 0 8px currentColor, 0 0 20px currentColor; box-shadow: 0 0 8px currentColor; }
  }

  /* Sparkle particles */
  .dg-spark {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    animation: dgSparkle ease-in-out infinite;
  }
  @keyframes dgSparkle {
    0%, 100% { opacity: 0; transform: scale(0.3) rotate(0deg); }
    40%, 60% { opacity: 1; transform: scale(1.2) rotate(180deg); }
  }

  /* Glow orbs */
  .dg-glow {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(70px);
    animation: dgGlowPulse ease-in-out infinite alternate;
  }
  @keyframes dgGlowPulse {
    0%   { opacity: 0.3; transform: scale(1); }
    100% { opacity: 0.5; transform: scale(1.2); }
  }

  /* Floor reflections */
  .dg-reflect {
    position: fixed;
    bottom: 0;
    height: 200px;
    pointer-events: none;
    z-index: 1;
    animation: dgReflectShimmer 4s ease-in-out infinite alternate;
    filter: blur(20px);
  }
  @keyframes dgReflectShimmer {
    0%   { opacity: 0.15; }
    100% { opacity: 0.3; }
  }

  /* Floating emoji */
  .dg-emoji {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    animation: dgEmojiFloat ease-in-out infinite;
  }
  @keyframes dgEmojiFloat {
    0%, 100% { transform: translateY(0px) rotate(-5deg); opacity: 0.6; }
    50%       { transform: translateY(-20px) rotate(5deg); opacity: 0.9; }
  }

  /* Content */
  .dg-content { position: relative; z-index: 10; }

  /* Title */
  .dg-title {
    background: linear-gradient(90deg, #22d3ee, #a855f7, #84cc16, #ec4899, #22d3ee);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: dgTitleShimmer 5s linear infinite;
    filter: drop-shadow(0 0 25px rgba(34,211,238,0.6));
  }
  @keyframes dgTitleShimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  .dg-tag {
    background: rgba(34,211,238,0.12);
    border: 1px solid rgba(34,211,238,0.35);
    color: rgba(34,211,238,0.9);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .dg-card {
    background: rgba(5,2,15,0.8);
    border: 1px solid rgba(34,211,238,0.2);
    border-radius: 1rem;
    transition: border-color 0.2s, background 0.2s;
    backdrop-filter: blur(8px);
  }
  .dg-card:hover {
    border-color: rgba(34,211,238,0.5);
    background: rgba(8,3,20,0.9);
  }

  details.dg-faq {
    background: rgba(5,2,15,0.8);
    border: 1px solid rgba(34,211,238,0.18);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
  details.dg-faq[open] {
    border-color: rgba(34,211,238,0.45);
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Drinking Game Wheel", url: "https://realwheelpicker.com/templates/drinking-game-wheel" },
  ]} />

  <div class="dg-page">
    <div class="dg-sky"></div>

    <!-- Glow orbs -->
    <div class="dg-glow" style="width:450px;height:380px;background:rgba(34,211,238,0.1);top:5%;left:-5%;animation-duration:8s;"></div>
    <div class="dg-glow" style="width:400px;height:350px;background:rgba(168,85,247,0.1);top:45%;right:-5%;animation-duration:10s;animation-delay:3s;"></div>
    <div class="dg-glow" style="width:300px;height:280px;background:rgba(132,204,22,0.08);bottom:20%;left:35%;animation-duration:7s;animation-delay:1.5s;"></div>

    <!-- Floor reflections -->
    <div class="dg-reflect" style="left:0;width:40%;background:linear-gradient(90deg, rgba(34,211,238,0.4), transparent);animation-delay:0s;"></div>
    <div class="dg-reflect" style="right:0;width:35%;background:linear-gradient(-90deg, rgba(168,85,247,0.4), transparent);animation-delay:2s;"></div>

    <!-- 30 beer bubbles rising -->
    {Array.from({ length: 30 }, (_, i) => {
      const colors = ['rgba(34,211,238,0.5)','rgba(168,85,247,0.5)','rgba(132,204,22,0.5)','rgba(236,72,153,0.5)','rgba(245,158,11,0.5)'];
      const c = colors[i % colors.length];
      const size = 5 + (i % 10);
      return (
        <div class="dg-bubble" style={`width:${size}px;height:${size}px;left:${i * 3.2 + 1}%;bottom:-20px;border-color:${c};background:${c.replace('0.5','0.15')};animation-duration:${4 + i % 6}s;animation-delay:${i * 0.25}s;`}></div>
      );
    })}

    <!-- 15 neon blinking signs -->
    <div class="dg-neon" style="color:#22d3ee;border-color:#22d3ee;top:8%;left:3%;animation-duration:3s;">OPEN</div>
    <div class="dg-neon" style="color:#a855f7;border-color:#a855f7;top:14%;right:4%;animation-duration:2.5s;animation-delay:0.8s;">BAR</div>
    <div class="dg-neon" style="color:#84cc16;border-color:#84cc16;top:28%;left:2%;animation-duration:4s;animation-delay:0.3s;">DRINKS</div>
    <div class="dg-neon" style="color:#ec4899;border-color:#ec4899;top:42%;right:3%;animation-duration:3.2s;animation-delay:1s;">PARTY</div>
    <div class="dg-neon" style="color:#f59e0b;border-color:#f59e0b;top:55%;left:4%;animation-duration:2.8s;animation-delay:1.5s;">GAMES</div>
    <div class="dg-neon" style="color:#06b6d4;border-color:#06b6d4;top:68%;right:5%;animation-duration:3.7s;animation-delay:0.5s;">FUN</div>
    <div class="dg-neon" style="color:#8b5cf6;border-color:#8b5cf6;bottom:25%;left:2%;animation-duration:2.3s;animation-delay:2s;">SHOTS</div>
    <div class="dg-neon" style="color:#10b981;border-color:#10b981;bottom:18%;right:3%;animation-duration:3.5s;animation-delay:0.7s;">PLAY</div>
    <div class="dg-neon" style="color:#f97316;border-color:#f97316;top:35%;left:48%;animation-duration:4.1s;animation-delay:1.2s;">GO!</div>
    <div class="dg-neon" style="color:#3b82f6;border-color:#3b82f6;top:72%;left:5%;animation-duration:2.9s;animation-delay:0.4s;">SPIN</div>
    <div class="dg-neon" style="color:#22d3ee;border-color:#22d3ee;top:80%;right:6%;animation-duration:3.8s;animation-delay:1.8s;">NIGHT</div>
    <div class="dg-neon" style="color:#ec4899;border-color:#ec4899;top:5%;left:45%;animation-duration:3.3s;animation-delay:0.6s;">21+</div>
    <div class="dg-neon" style="color:#a855f7;border-color:#a855f7;bottom:35%;left:42%;animation-duration:2.6s;animation-delay:2.2s;">RULES</div>
    <div class="dg-neon" style="color:#84cc16;border-color:#84cc16;bottom:10%;left:22%;animation-duration:4.5s;animation-delay:0.9s;">WILD</div>
    <div class="dg-neon" style="color:#f59e0b;border-color:#f59e0b;bottom:8%;right:20%;animation-duration:3.1s;animation-delay:1.3s;">CHEER</div>

    <!-- 20 sparkles -->
    {Array.from({ length: 20 }, (_, i) => {
      const colors = ['#22d3ee','#a855f7','#84cc16','#ec4899','#f59e0b','#06b6d4','#f97316','#3b82f6'];
      const size = 3 + (i % 5);
      return (
        <div class="dg-spark" style={`width:${size}px;height:${size}px;left:${(i * 4.8 + 2) % 98}%;top:${(i * 7 + 5) % 90}%;background:${colors[i % colors.length]};animation-duration:${1.5 + i * 0.2}s;animation-delay:${i * 0.18}s;box-shadow:0 0 6px ${colors[i % colors.length]};`}></div>
      );
    })}

    <!-- 8 floating emojis -->
    {['🍺','🍻','🎉','🥂','🎊','🍾','🎈','🥳'].map((e, i) => (
      <span class="dg-emoji" style={`font-size:${1.4 + (i % 3) * 0.4}rem;left:${5 + i * 12}%;top:${15 + (i % 4) * 18}%;animation-duration:${3 + i * 0.5}s;animation-delay:${i * 0.4}s;`}>{e}</span>
    ))}

    <div class="dg-content">
      <HeaderIsland client:load />
      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Drinking Game Wheel</span>
        </nav>
        <div class="text-center mb-8">
          <div class="text-5xl mb-3">🍺</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight dg-title mb-3">Drinking Game Wheel</h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">Spin the wheel and let it pick your next drinking game. Pre-loaded with 8 classics. For responsible adults 21+ only.</p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="dg-tag">Party</span>
            <span class="dg-tag">21+</span>
            <span class="dg-tag">Game Night</span>
          </div>
        </div>
        <SimpleWheelIsland defaultParticipants={defaultParticipants} colors={themeColors} wheelShape="circle" hubTheme="neon" client:load />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="dg-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Drinking Game Rules Made Easy</h2>
          <p class="text-white/60 leading-relaxed">The hardest part of any drinking game night isn't the drinking — it's agreeing on which game to play. The drinking game wheel solves that instantly. Spin, play the game it lands on, drink appropriately. Rotate after each round.</p>
        </div>

        <div class="dg-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Classic Games Explained</h2>
          <div class="space-y-3">
            <div class="p-4 rounded-lg bg-cyan-500/10 border border-cyan-500/20">
              <p class="font-semibold text-white text-sm mb-1">Waterfall</p>
              <p class="text-white/60 text-sm">Everyone drinks at the same time. The person who spun stops when they want. The next person can't stop until they do, and so on around the circle.</p>
            </div>
            <div class="p-4 rounded-lg bg-purple-500/10 border border-purple-500/20">
              <p class="font-semibold text-white text-sm mb-1">Never Have I Ever</p>
              <p class="text-white/60 text-sm">Person who spun says "Never have I ever [something]." Everyone who HAS done it drinks.</p>
            </div>
            <div class="p-4 rounded-lg bg-green-500/10 border border-green-500/20">
              <p class="font-semibold text-white text-sm mb-1">Categories</p>
              <p class="text-white/60 text-sm">Pick a category (car brands, countries, etc.). Go around the circle naming items. First person who can't name one drinks.</p>
            </div>
            <div class="p-4 rounded-lg bg-pink-500/10 border border-pink-500/20">
              <p class="font-semibold text-white text-sm mb-1">Rhyme Time</p>
              <p class="text-white/60 text-sm">Person who spun says a word. Go around the circle rhyming words. First person to fail or repeat drinks.</p>
            </div>
            <div class="p-4 rounded-lg bg-amber-500/10 border border-amber-500/20">
              <p class="font-semibold text-white text-sm mb-1">Most Likely To</p>
              <p class="text-white/60 text-sm">Person who spun asks "Who's most likely to [something]?" Everyone points at someone. Most pointed-at person drinks.</p>
            </div>
            <div class="p-4 rounded-lg bg-blue-500/10 border border-blue-500/20">
              <p class="font-semibold text-white text-sm mb-1">Two Truths One Lie</p>
              <p class="text-white/60 text-sm">Tell two truths and one lie. Others guess the lie. Wrong guessers drink.</p>
            </div>
          </div>
        </div>

        <div class="dg-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">House Rules</h2>
          <p class="text-white/60 leading-relaxed">Set clear rules before starting: What counts as a "drink"? Is there a maximum? What's the "pass" penalty? House rules prevent arguments and make the game run smoother.</p>
        </div>

        <div class="dg-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Safety First</h2>
          <p class="text-white/60 leading-relaxed">Always have non-alcoholic alternatives available. Never pressure anyone to drink. Have a designated driver or ride-share plan ready. This wheel is for responsible adult fun only.</p>
          <ul class="space-y-2 text-white/60">
            <li class="flex gap-3"><span class="text-cyan-400 font-bold">→</span><span>Keep non-alcoholic drinks on hand for anyone who wants to participate without alcohol.</span></li>
            <li class="flex gap-3"><span class="text-cyan-400 font-bold">→</span><span>Pace yourself — the wheel picks the game, not the intensity.</span></li>
            <li class="flex gap-3"><span class="text-cyan-400 font-bold">→</span><span>Plan your ride home before the night starts. Never drink and drive.</span></li>
          </ul>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="dg-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/", label: "Spin the Wheel", desc: "The main wheel picker — add any names or options and spin." },
              { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random name from your list without the wheel animation." },
              { href: "/party-wheel", label: "Party Wheel", desc: "Pre-loaded with party game ideas for your next gathering." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="dg-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      </main>

      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
