---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Dare Wheel — Spin for Random Party Challenges";
const description = "Spin the dare wheel for random party challenges. 8 dares pre-loaded and fully customizable. Great for party nights, sleepovers, and group games. Free, instant.";
const canonical = "/templates/dare-wheel";

const faqItems = [
  {
    question: "How is this different from the Truth or Dare wheel?",
    answer: "The dare wheel is dares only — no truth questions. Use this when your group wants pure challenges without the personal questions. It keeps the energy physical and active rather than conversational.",
  },
  {
    question: "Can I make the dares harder or easier?",
    answer: "Yes — completely customize the dare list. Remove easy options to ramp up difficulty, or swap all dares for mild challenges to keep it family-friendly. The wheel adapts to your group's comfort level.",
  },
  {
    question: "What's the best number of dares on the wheel?",
    answer: "8-12 works well. Enough variety that the same dare doesn't repeat too often, but few enough that everyone remembers what's on the wheel and builds anticipation for certain outcomes.",
  },
];

const defaultParticipants = [
  { pseudo: "Do 20 jumping jacks", weight: 1 },
  { pseudo: "Speak in accent for 5 min", weight: 1 },
  { pseudo: "Text someone 'hey'", weight: 1 },
  { pseudo: "Show your last selfie", weight: 1 },
  { pseudo: "Sing a verse of any song", weight: 1 },
  { pseudo: "Call a random contact", weight: 1 },
  { pseudo: "Dance for 30 seconds", weight: 1 },
  { pseudo: "Do an impression", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/dare-wheel",
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Dare Wheel", url: "https://realwheelpicker.com/templates/dare-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Dare Wheel</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Dare Wheel — Spin for Random Party Challenges
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Pure dares, no truths. Spin the wheel and accept whatever challenge fate assigns. Customize the dare list for your group's energy level.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- Wheel -->
      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <!-- Article Content -->
      <section class="space-y-8">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Why a Dare-Only Wheel Works</h2>
          <p class="text-muted-foreground leading-relaxed">
            Truth or dare is a classic, but sometimes you want the energy of dares without the vulnerability of personal questions. The dare wheel keeps the game active and physical — great for groups that are already comfortable with each other and want pure challenge-based fun.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            It also works better for mixed-age groups or professional settings (team building, office parties) where truth questions might cross comfort boundaries. Everyone knows what they're signing up for: a challenge, not a confession.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Pair this with a player name wheel: spin names to pick who goes, then spin this wheel for their dare. Two spins, one complete round. No targeting, no favoritism, pure randomness.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Dare Categories to Try</h2>
          <p class="text-muted-foreground leading-relaxed">
            Build your dare wheel around a theme for a more cohesive party experience:
          </p>
          <div class="space-y-3">
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Physical Dares</p>
              <p class="text-muted-foreground text-sm">Push-ups, planks, silly walks, dance challenges, voice impressions</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Social Dares</p>
              <p class="text-muted-foreground text-sm">Text someone, post to social media, call a contact, compliment a stranger</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Creative Dares</p>
              <p class="text-muted-foreground text-sm">Draw something in 60 seconds, improvise a song, act out a movie scene</p>
            </div>
          </div>
        </div>

      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/truth-or-dare-wheel", label: "Truth or Dare Wheel", desc: "The full truth or dare experience — questions and challenges combined." },
            { href: "/templates/never-have-i-ever-wheel", label: "Never Have I Ever Wheel", desc: "Classic party game questions — perfect follow-up to dares." },
            { href: "/party-wheel", label: "Party Wheel", desc: "More party challenges and game night options." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
