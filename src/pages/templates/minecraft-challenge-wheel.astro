---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Minecraft Challenge Wheel — Random Run Ideas";
const description = "Spin the Minecraft challenge wheel for a random run idea. 10 challenges pre-loaded from no armor to hardcore mode. Break your usual playstyle. Free, instant.";
const canonical = "/templates/minecraft-challenge-wheel";

const faqItems = [
  {
    question: "Can I add my own custom Minecraft challenges?",
    answer: "Yes — edit the wheel with any challenge you want. Add modded challenges, speedrun categories, or rules specific to your playstyle. The wheel works with any text, so 'No pickaxe run' or 'Only wood tools forever' are valid entries.",
  },
  {
    question: "How do I play the 'No crafting table' challenge?",
    answer: "You can only use items found in chests, mob drops, or naturally occurring in the world. No crafting at all — which means no tools beyond what you find. It's a brutal survival test that changes the entire game loop.",
  },
  {
    question: "Can I use this for YouTube challenge content?",
    answer: "Absolutely. Load the wheel with your planned challenge series, spin on camera for content variety, and commit to the result. It adds genuine randomness and viewer engagement to challenge videos.",
  },
];

const defaultParticipants = [
  { pseudo: "No armor run", weight: 1 },
  { pseudo: "Build a castle first", weight: 1 },
  { pseudo: "Speedrun to credits", weight: 1 },
  { pseudo: "Nether only", weight: 1 },
  { pseudo: "Vegetarian challenge", weight: 1 },
  { pseudo: "One biome only", weight: 1 },
  { pseudo: "Underground base only", weight: 1 },
  { pseudo: "No crafting table", weight: 1 },
  { pseudo: "Hardcore mode", weight: 1 },
  { pseudo: "Peaceful difficulty only", weight: 1 },
];

const myColors = ['#4ade80','#854d0e','#6b7280','#3b82f6','#22c55e','#78716c','#1d4ed8','#a16207'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/minecraft-challenge-wheel",
};
---

<style>
  /* === MINECRAFT PIXEL ART THEME === */
  .mc-page {
    min-height: 100vh;
    background: #1a3a5c;
    position: relative;
    overflow-x: hidden;
    font-family: inherit;
  }

  /* Minecraft sky gradient */
  .mc-sky {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: linear-gradient(180deg,
      #1a6bb5 0%,
      #2a8fd4 25%,
      #4aa8e0 45%,
      #6ec0f0 65%,
      #3a8ab0 80%,
      #1a5580 100%
    );
    pointer-events: none;
  }

  /* Pixel clouds */
  .mc-clouds {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 40%;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }
  .mc-cloud {
    position: absolute;
    background: rgba(255,255,255,0.85);
    image-rendering: pixelated;
    animation: cloudDrift linear infinite;
  }
  .mc-cloud::before, .mc-cloud::after {
    content: '';
    position: absolute;
    background: inherit;
  }
  .mc-cloud-1 {
    width: 80px; height: 32px;
    top: 15%; left: -100px;
    animation-duration: 40s;
    animation-delay: 0s;
  }
  .mc-cloud-1::before { width: 48px; height: 32px; top: -32px; left: 16px; }
  .mc-cloud-2 {
    width: 112px; height: 32px;
    top: 30%; left: -150px;
    animation-duration: 55s;
    animation-delay: 15s;
  }
  .mc-cloud-2::before { width: 64px; height: 32px; top: -32px; left: 24px; }
  .mc-cloud-3 {
    width: 64px; height: 32px;
    top: 10%; left: -90px;
    animation-duration: 45s;
    animation-delay: 28s;
  }
  .mc-cloud-3::before { width: 32px; height: 32px; top: -32px; left: 16px; }

  @keyframes cloudDrift {
    0%   { left: -200px; }
    100% { left: 110vw; }
  }

  /* Falling pixel blocks */
  .block-rain {
    position: fixed;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .mc-block {
    position: absolute;
    top: -30px;
    width: 20px;
    height: 20px;
    image-rendering: pixelated;
    animation: blockFall linear infinite;
    opacity: 0.75;
  }
  /* Grass block colors */
  .mc-block.grass {
    background: #4ade80;
    box-shadow: inset -4px -4px 0 #22c55e, inset 4px 0 0 #86efac;
  }
  .mc-block.dirt {
    background: #92400e;
    box-shadow: inset -4px -4px 0 #78350f, inset 4px 0 0 #b45309;
  }
  .mc-block.stone {
    background: #9ca3af;
    box-shadow: inset -4px -4px 0 #6b7280, inset 4px 0 0 #d1d5db;
  }
  .mc-block.wood {
    background: #a16207;
    box-shadow: inset -4px -4px 0 #854d0e, inset 4px 0 0 #ca8a04;
  }
  .mc-block.water {
    background: #1d4ed8;
    box-shadow: inset -4px -4px 0 #1e40af, inset 4px 0 0 #3b82f6;
    opacity: 0.6;
  }
  .mc-block:nth-child(1)  { left: 5%;  animation-duration: 6s;  animation-delay: 0s;   }
  .mc-block:nth-child(2)  { left: 13%; animation-duration: 8s;  animation-delay: 1s;   }
  .mc-block:nth-child(3)  { left: 21%; animation-duration: 5s;  animation-delay: 2s;   }
  .mc-block:nth-child(4)  { left: 30%; animation-duration: 9s;  animation-delay: 0.5s; }
  .mc-block:nth-child(5)  { left: 40%; animation-duration: 7s;  animation-delay: 3s;   }
  .mc-block:nth-child(6)  { left: 50%; animation-duration: 6.5s;animation-delay: 1.5s; }
  .mc-block:nth-child(7)  { left: 60%; animation-duration: 8.5s;animation-delay: 4s;   }
  .mc-block:nth-child(8)  { left: 70%; animation-duration: 5.5s;animation-delay: 2.5s; }
  .mc-block:nth-child(9)  { left: 80%; animation-duration: 7.5s;animation-delay: 0.8s; }
  .mc-block:nth-child(10) { left: 90%; animation-duration: 9.5s;animation-delay: 5s;   }
  .mc-block:nth-child(11) { left: 35%; animation-duration: 10s; animation-delay: 6s;   }
  .mc-block:nth-child(12) { left: 75%; animation-duration: 6s;  animation-delay: 3.5s; }
  .mc-block:nth-child(13) { left: 55%; animation-duration: 7s;  animation-delay: 7s;   }
  .mc-block:nth-child(14) { left: 25%; animation-duration: 8s;  animation-delay: 8s;   }
  .mc-block:nth-child(15) { left: 45%; animation-duration: 5s;  animation-delay: 9s;   }
  .mc-block:nth-child(16) { left: 65%; animation-duration: 11s; animation-delay: 2s;   }

  @keyframes blockFall {
    0%   { top: -30px; opacity: 0; transform: rotate(0deg); }
    5%   { opacity: 0.8; }
    90%  { opacity: 0.5; }
    100% { top: 110vh; opacity: 0; transform: rotate(180deg); }
  }

  /* Pixel ground at bottom */
  .mc-ground {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 64px;
    z-index: 3;
    pointer-events: none;
    display: flex;
    flex-direction: column;
  }
  .mc-ground-grass {
    height: 16px;
    background: #4ade80;
    image-rendering: pixelated;
  }
  .mc-ground-dirt {
    height: 48px;
    background: repeating-linear-gradient(
      90deg,
      #92400e 0px, #92400e 16px,
      #78350f 16px, #78350f 32px
    );
    image-rendering: pixelated;
  }

  /* Sun */
  .mc-sun {
    position: fixed;
    top: 8%;
    right: 10%;
    width: 48px;
    height: 48px;
    background: #fbbf24;
    image-rendering: pixelated;
    z-index: 2;
    pointer-events: none;
    box-shadow: 0 0 0 8px #fcd34d, 0 0 40px rgba(251,191,36,0.4);
    animation: sunGlow 3s ease-in-out infinite;
  }

  @keyframes sunGlow {
    0%, 100% { box-shadow: 0 0 0 8px #fcd34d, 0 0 40px rgba(251,191,36,0.4); }
    50%       { box-shadow: 0 0 0 12px #fde68a, 0 0 60px rgba(251,191,36,0.6); }
  }

  /* Content */
  .mc-content {
    position: relative;
    z-index: 10;
  }

  /* Cards — pixel style */
  .mc-card {
    background: rgba(15, 30, 50, 0.88);
    border: 2px solid rgba(74, 222, 128, 0.4);
    border-radius: 0;
    padding: 1.5rem;
    backdrop-filter: blur(8px);
    box-shadow: 4px 4px 0 rgba(34,197,94,0.2), inset 0 0 30px rgba(74,222,128,0.04);
    image-rendering: pixelated;
    font-family: 'Courier New', monospace;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .mc-card:hover {
    border-color: rgba(74, 222, 128, 0.7);
    box-shadow: 6px 6px 0 rgba(34,197,94,0.3);
  }
  .mc-card h2     { color: #4ade80; text-shadow: 2px 2px 0 rgba(0,0,0,0.5); font-family: 'Courier New', monospace; }
  .mc-card p      { color: rgba(187, 247, 208, 0.85); font-family: 'Courier New', monospace; }
  .mc-card strong { color: #86efac; }

  .mc-diff-box {
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(74,222,128,0.25);
    border-radius: 0;
    padding: 1rem;
    font-family: 'Courier New', monospace;
    image-rendering: pixelated;
  }
  .mc-diff-box .label { color: #4ade80; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem; }
  .mc-diff-box .desc  { color: rgba(187,247,208,0.7); font-size: 0.875rem; }

  .mc-faq {
    background: rgba(10, 20, 35, 0.9);
    border: 2px solid rgba(74,222,128,0.22);
    border-radius: 0;
    padding: 1.25rem;
    font-family: 'Courier New', monospace;
    box-shadow: 3px 3px 0 rgba(34,197,94,0.15);
  }
  .mc-faq .q { color: #86efac; font-weight: 600; margin-bottom: 0.5rem; }
  .mc-faq .a { color: rgba(187,247,208,0.75); font-size: 0.875rem; line-height: 1.6; }

  .mc-link {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(10, 20, 35, 0.88);
    border: 2px solid rgba(74,222,128,0.2);
    border-radius: 0;
    text-decoration: none;
    font-family: 'Courier New', monospace;
    box-shadow: 3px 3px 0 rgba(34,197,94,0.1);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .mc-link:hover {
    border-color: rgba(74,222,128,0.55);
    box-shadow: 5px 5px 0 rgba(34,197,94,0.25);
  }
  .mc-link .arrow      { color: #4ade80; font-weight: 700; font-size: 0.875rem; margin-top: 0.125rem; flex-shrink: 0; }
  .mc-link .link-title { color: #bbf7d0; font-weight: 600; }
  .mc-link .link-desc  { color: rgba(187,247,208,0.6); font-size: 0.875rem; }

  .mc-list-item { color: rgba(187,247,208,0.85); font-family: 'Courier New', monospace; }
  .mc-list-item strong { color: #86efac; }

  .breadcrumb-nav a { color: rgba(74,222,128,0.6); transition: color 0.2s; font-family: 'Courier New', monospace; }
  .breadcrumb-nav a:hover { color: #86efac; }
  .breadcrumb-nav .sep { color: rgba(74,222,128,0.35); }
  .breadcrumb-nav .cur { color: rgba(187,247,208,0.9); }

  .mc-hero-title {
    color: #dcfce7;
    text-shadow: 3px 3px 0 #166534, 0 0 30px rgba(74,222,128,0.4);
    font-family: 'Courier New', monospace;
    letter-spacing: 0.05em;
    image-rendering: pixelated;
  }
  .mc-hero-sub   { color: rgba(187,247,208,0.8); font-family: 'Courier New', monospace; }
  .mc-hero-badge { color: rgba(74,222,128,0.65); font-family: 'Courier New', monospace; }
  .mc-section-title { color: #86efac; text-shadow: 2px 2px 0 rgba(0,0,0,0.5); font-family: 'Courier New', monospace; }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Minecraft Challenge Wheel", url: "https://realwheelpicker.com/templates/minecraft-challenge-wheel" },
  ]} />

  <div class="mc-page">
    <div class="mc-sky"></div>

    <div class="mc-clouds">
      <div class="mc-cloud mc-cloud-1"></div>
      <div class="mc-cloud mc-cloud-2"></div>
      <div class="mc-cloud mc-cloud-3"></div>
    </div>

    <div class="mc-sun"></div>

    <div class="block-rain">
      <div class="mc-block grass"></div>
      <div class="mc-block dirt"></div>
      <div class="mc-block stone"></div>
      <div class="mc-block grass"></div>
      <div class="mc-block wood"></div>
      <div class="mc-block dirt"></div>
      <div class="mc-block stone"></div>
      <div class="mc-block grass"></div>
      <div class="mc-block water"></div>
      <div class="mc-block dirt"></div>
      <div class="mc-block stone"></div>
      <div class="mc-block wood"></div>
      <div class="mc-block grass"></div>
      <div class="mc-block dirt"></div>
      <div class="mc-block stone"></div>
      <div class="mc-block grass"></div>
    </div>

    <div class="mc-ground">
      <div class="mc-ground-grass"></div>
      <div class="mc-ground-dirt"></div>
    </div>

    <div class="mc-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="breadcrumb-nav text-xs flex gap-1 mb-8">
          <a href="/">Home</a>
          <span class="sep">/</span>
          <a href="/templates">Templates</a>
          <span class="sep">/</span>
          <span class="cur">Minecraft Challenge Wheel</span>
        </nav>

        <div class="text-center space-y-4 py-2 md:py-6 mb-8">
          <div class="flex flex-wrap justify-center gap-2 mb-3">
            <span style="background:rgba(74,222,128,0.15);border:2px solid rgba(74,222,128,0.4);color:#4ade80;padding:0.25rem 0.75rem;border-radius:0;font-size:0.75rem;font-family:'Courier New',monospace;">&#x1F7E9; Grass Block</span>
            <span style="background:rgba(133,77,14,0.2);border:2px solid rgba(133,77,14,0.5);color:#fbbf24;padding:0.25rem 0.75rem;border-radius:0;font-size:0.75rem;font-family:'Courier New',monospace;">&#x1F7EB; Dirt Block</span>
            <span style="background:rgba(107,114,128,0.15);border:2px solid rgba(107,114,128,0.4);color:#d1d5db;padding:0.25rem 0.75rem;border-radius:0;font-size:0.75rem;font-family:'Courier New',monospace;">&#x1F7EA; Stone</span>
          </div>
          <h1 class="mc-hero-title text-3xl md:text-5xl font-bold leading-tight">
            Minecraft Challenge Wheel — Random Run Ideas
          </h1>
          <p class="mc-hero-sub text-lg md:text-xl max-w-2xl mx-auto">
            Bored of your usual Minecraft playstyle? Spin the wheel and commit to a random challenge run. Fate decides your restrictions.
          </p>
          <p class="mc-hero-badge text-sm">Free • No account • Instant result</p>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={myColors}
          wheelShape="hexagon"
          hubTheme="forest"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <section class="space-y-8">
          <div class="mc-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Why Challenge Runs Make Minecraft Fresh Again</h2>
            <p class="leading-relaxed">
              After hundreds of hours in Minecraft, the default survival loop gets predictable. You know the optimal path: punch tree, craft tools, mine for diamonds, build a base, defeat the Ender Dragon. The challenge wheel breaks that pattern by imposing random restrictions that force creative problem-solving.
            </p>
            <p class="leading-relaxed">
              A no-armor run makes every cave terrifying again. A nether-only run completely changes your resource pool and base-building approach. A vegetarian challenge forces you to think about food sources you never touch in a normal playthrough. Each restriction transforms the game into something genuinely new.
            </p>
            <p class="leading-relaxed">
              The wheel adds a second layer: you don't pick the challenge, fate does. This removes the temptation to choose the easiest option and forces you into territory you might not have selected yourself.
            </p>
          </div>

          <div class="mc-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Challenge Difficulty Breakdown</h2>
            <div class="space-y-3">
              <div class="mc-diff-box">
                <p class="label">[EASY] Beginner Challenges</p>
                <p class="desc">Build a castle first, Peaceful difficulty only, One biome only — adds goals without extreme restrictions</p>
              </div>
              <div class="mc-diff-box">
                <p class="label">[MEDIUM] Intermediate Challenges</p>
                <p class="desc">No armor run, Vegetarian challenge, Underground base only, Speedrun — changes playstyle significantly</p>
              </div>
              <div class="mc-diff-box">
                <p class="label">[HARD] Expert Challenges</p>
                <p class="desc">Nether only, No crafting table, Hardcore mode — near-impossible without experience and strategy</p>
              </div>
            </div>
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="mc-section-title text-xl md:text-2xl font-bold">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="mc-faq">
                <p class="q">{question}</p>
                <p class="a">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="mc-section-title text-xl md:text-2xl font-bold">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/templates/roblox-wheel", label: "Roblox Game Picker", desc: "Spin for a random Roblox game when Minecraft needs a break." },
              { href: "/templates/video-game-picker", label: "Video Game Picker", desc: "Random game genre selector for all platforms." },
              { href: "/templates/fortnite-drop-wheel", label: "Fortnite Drop Location Wheel", desc: "Random drop location picker for Fortnite matches." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="mc-link">
                  <span class="arrow">→</span>
                  <span>
                    <span class="link-title">{label}</span>
                    <span class="link-desc"> — {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>

      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
