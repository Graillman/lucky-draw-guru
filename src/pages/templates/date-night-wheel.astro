---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Date Night Spinner — What Should We Do Tonight?";
const description = "Stuck in a routine? Spin the date night wheel for a random activity idea. Pre-loaded with 10 ideas from cozy to adventurous.";
const canonical = "/templates/date-night-wheel";

const faqItems = [
  {
    question: "What if we spin and neither of us is excited?",
    answer: "Allow one re-spin per month. But try the original result first — you're often more excited once you commit to the plan.",
  },
  {
    question: "Can we add our own ideas?",
    answer: "Yes — replace any defaults with ideas specific to your city, budget, or interests. Personal touches make it more fun.",
  },
  {
    question: "What if the activity requires advance planning?",
    answer: "Spin a week ahead if needed. Or have 'instant' and 'planned' wheels — spin the instant one for tonight, spin the planned one for a future special evening.",
  },
];

const defaultParticipants = [
  { pseudo: "Cook together", weight: 1 },
  { pseudo: "Restaurant", weight: 1 },
  { pseudo: "Movie night", weight: 1 },
  { pseudo: "Game night", weight: 1 },
  { pseudo: "Stargazing", weight: 1 },
  { pseudo: "DIY spa", weight: 1 },
  { pseudo: "Picnic", weight: 1 },
  { pseudo: "Bowling", weight: 1 },
  { pseudo: "Art class", weight: 1 },
  { pseudo: "Road trip", weight: 1 },
];

const themeColors = ['#f59e0b','#c5b358','#722f37','#d4af37','#8b1a1a','#b8860b','#dc143c','#ffd700','#9b1c1c','#d4a853'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/date-night-wheel",
};
---

<style>
  /* ═══ DATE NIGHT — BOUGIES, PÉTALES, CHAMPAGNE ═══ */
  .dn-page {
    background: #0a0005;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Ciel nocturne romantique */
  .dn-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 45% at 20% 20%, rgba(180,20,50,0.22) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 80% 15%, rgba(120,10,30,0.18) 0%, transparent 60%),
      radial-gradient(ellipse 60% 35% at 50% 95%, rgba(200,120,0,0.14) 0%, transparent 60%),
      linear-gradient(180deg, #0a0005 0%, #110008 50%, #0a0005 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Halos atmosphériques */
  .dn-halo-left {
    position: fixed;
    left: -120px;
    top: 20%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(185,30,60,0.18) 0%, transparent 70%);
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
    animation: dnHaloPulse 7s ease-in-out infinite alternate;
  }
  .dn-halo-right {
    position: fixed;
    right: -100px;
    top: 30%;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(100,20,40,0.16) 0%, transparent 70%);
    filter: blur(70px);
    z-index: 0;
    pointer-events: none;
    animation: dnHaloPulse 9s ease-in-out infinite alternate;
    animation-delay: 2s;
  }
  .dn-halo-bottom {
    position: fixed;
    bottom: -80px;
    left: 30%;
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(210,130,0,0.15) 0%, transparent 70%);
    filter: blur(80px);
    z-index: 0;
    pointer-events: none;
    animation: dnHaloPulse 11s ease-in-out infinite alternate;
    animation-delay: 4s;
  }
  @keyframes dnHaloPulse {
    from { opacity: 0.5; transform: scale(0.92); }
    to   { opacity: 1;   transform: scale(1.08); }
  }

  /* Flammes de bougies */
  .dn-flame {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    width: var(--fw, 8px);
    height: var(--fh, 18px);
    border-radius: 50% 50% 30% 30%;
    background: radial-gradient(ellipse at 50% 70%, #fff7aa 0%, #ffaa00 40%, #cc4400 80%, transparent 100%);
    filter: blur(0.5px);
    animation: dnCandleFlicker var(--fdur, 2s) ease-in-out infinite alternate;
    animation-delay: var(--fdelay, 0s);
    left: var(--fleft, 10%);
    bottom: var(--fbottom, 5%);
    box-shadow: 0 0 12px rgba(255,160,0,0.6), 0 0 30px rgba(200,80,0,0.3);
  }
  @keyframes dnCandleFlicker {
    0%   { transform: scaleX(1) scaleY(1) skewX(0deg); opacity: 0.9; }
    25%  { transform: scaleX(0.9) scaleY(1.05) skewX(-2deg); opacity: 1; }
    50%  { transform: scaleX(1.05) scaleY(0.95) skewX(1deg); opacity: 0.85; }
    75%  { transform: scaleX(0.95) scaleY(1.08) skewX(2deg); opacity: 1; }
    100% { transform: scaleX(1.02) scaleY(0.98) skewX(-1deg); opacity: 0.88; }
  }

  /* Lueur au pied des bougies */
  .dn-candle-glow {
    position: fixed;
    pointer-events: none;
    z-index: 1;
    width: var(--cw, 60px);
    height: var(--ch, 40px);
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(255,140,0,0.25) 0%, transparent 70%);
    filter: blur(4px);
    left: var(--cleft, 10%);
    bottom: var(--cbottom, 4%);
    animation: dnCandleFlicker var(--cdur, 2.5s) ease-in-out infinite alternate;
    animation-delay: var(--cdelay, 0s);
  }

  /* Pétales tombants */
  .dn-petal {
    position: fixed;
    top: -30px;
    pointer-events: none;
    z-index: 2;
    width: var(--pw, 10px);
    height: var(--ph, 14px);
    background: var(--pcolor, #cc3355);
    border-radius: 60% 0 60% 0;
    opacity: 0;
    animation: dnPetalFall var(--pdur, 10s) linear infinite;
    animation-delay: var(--pdelay, 0s);
    left: var(--pleft, 50%);
    filter: drop-shadow(0 0 4px rgba(180,20,60,0.4));
  }
  @keyframes dnPetalFall {
    0%   { transform: translateY(-30px) rotate(0deg) translateX(0px); opacity: 0; }
    5%   { opacity: 0.85; }
    30%  { transform: translateY(30vh) rotate(120deg) translateX(20px); }
    60%  { transform: translateY(65vh) rotate(280deg) translateX(-15px); }
    95%  { opacity: 0.6; }
    100% { transform: translateY(115vh) rotate(520deg) translateX(10px); opacity: 0; }
  }

  /* Bulles de champagne */
  .dn-bubble {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    width: var(--bw, 4px);
    height: var(--bh, 4px);
    border-radius: 50%;
    border: 1px solid rgba(255,230,100,0.5);
    background: rgba(255,240,180,0.12);
    opacity: 0;
    animation: dnBubbleRise var(--bdur, 6s) ease-in infinite;
    animation-delay: var(--bdelay, 0s);
    left: var(--bleft, 50%);
    bottom: -20px;
  }
  @keyframes dnBubbleRise {
    0%   { transform: translateY(0) translateX(0px); opacity: 0; }
    10%  { opacity: 0.7; }
    50%  { transform: translateY(-40vh) translateX(8px); opacity: 0.5; }
    90%  { opacity: 0.15; }
    100% { transform: translateY(-90vh) translateX(-5px); opacity: 0; }
  }

  /* Sparkles dorés/roses */
  .dn-sparkle {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    width: var(--sw, 3px);
    height: var(--sh, 3px);
    border-radius: 50%;
    background: var(--scolor, #ffd080);
    box-shadow: 0 0 8px var(--scolor, #ffd080);
    animation: dnSparkle var(--sdur, 3s) ease-in-out infinite;
    animation-delay: var(--sdelay, 0s);
    left: var(--sleft, 50%);
    top: var(--stop, 50%);
    opacity: 0;
  }
  @keyframes dnSparkle {
    0%,100% { opacity: 0; transform: scale(0.5); }
    20%     { opacity: 0.2; }
    50%     { opacity: 1; transform: scale(1.8); }
    80%     { opacity: 0.3; }
  }

  /* Étoiles filantes */
  .dn-shooting-star {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    width: var(--ssl, 120px);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,215,150,0.9), transparent);
    border-radius: 50%;
    top: var(--sstop, 15%);
    left: var(--ssleft, -20px);
    animation: dnShootingStar var(--ssdur, 5s) ease-in infinite;
    animation-delay: var(--ssdelay, 0s);
    opacity: 0;
    transform: rotate(-30deg);
  }
  @keyframes dnShootingStar {
    0%   { transform: translateX(0) translateY(0) rotate(-30deg); opacity: 0; }
    5%   { opacity: 1; }
    40%  { opacity: 0.8; }
    60%  { opacity: 0; transform: translateX(110vw) translateY(40vh) rotate(-30deg); }
    100% { opacity: 0; transform: translateX(110vw) translateY(40vh) rotate(-30deg); }
  }

  /* Lueur centrale romantique */
  .dn-center-glow {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(140,10,35,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
    animation: dnCenterGlow 8s ease-in-out infinite alternate;
  }
  @keyframes dnCenterGlow {
    from { opacity: 0.4; transform: translate(-50%,-50%) scale(0.95); }
    to   { opacity: 0.8; transform: translate(-50%,-50%) scale(1.05); }
  }

  /* Contenu */
  .dn-content { position: relative; z-index: 10; }

  /* Titre gradient bordeaux-or */
  .dn-title {
    background: linear-gradient(135deg, #ffd700 0%, #dc143c 25%, #d4af37 50%, #8b1a1a 75%, #ffd700 100%);
    background-size: 250%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: dnShimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 30px rgba(180,30,60,0.5));
  }
  @keyframes dnShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .dn-tag {
    background: rgba(120,20,40,0.3);
    border: 1px solid rgba(200,80,100,0.4);
    color: rgba(255,180,160,0.95);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .dn-card {
    background: rgba(20,4,10,0.82);
    border: 1px solid rgba(160,40,60,0.25);
    border-radius: 1rem;
    backdrop-filter: blur(12px);
    transition: border-color 0.2s, background 0.2s;
  }
  .dn-card:hover {
    border-color: rgba(220,100,80,0.45);
    background: rgba(30,6,14,0.88);
  }

  details.dn-faq {
    background: rgba(15,3,8,0.82);
    border: 1px solid rgba(150,35,55,0.25);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Date Night Wheel", url: "https://realwheelpicker.com/templates/date-night-wheel" },
  ]} />

  <div class="dn-page">
    <div class="dn-sky"></div>
    <div class="dn-halo-left"></div>
    <div class="dn-halo-right"></div>
    <div class="dn-halo-bottom"></div>
    <div class="dn-center-glow"></div>

    <!-- 8 flammes de bougie -->
    <div class="dn-flame" style="--fleft:4%;--fbottom:2%;--fw:7px;--fh:16px;--fdur:1.8s;--fdelay:0s;"></div>
    <div class="dn-candle-glow" style="--cleft:2.5%;--cbottom:1%;--cw:55px;--ch:35px;--cdur:1.8s;--cdelay:0s;"></div>
    <div class="dn-flame" style="--fleft:10%;--fbottom:3%;--fw:9px;--fh:20px;--fdur:2.2s;--fdelay:0.3s;"></div>
    <div class="dn-candle-glow" style="--cleft:8.5%;--cbottom:2%;--cw:65px;--ch:40px;--cdur:2.2s;--cdelay:0.3s;"></div>
    <div class="dn-flame" style="--fleft:20%;--fbottom:1.5%;--fw:6px;--fh:14px;--fdur:1.6s;--fdelay:0.7s;"></div>
    <div class="dn-candle-glow" style="--cleft:18.5%;--cbottom:0.5%;--cw:50px;--ch:30px;--cdur:1.6s;--cdelay:0.7s;"></div>
    <div class="dn-flame" style="--fleft:75%;--fbottom:2%;--fw:8px;--fh:18px;--fdur:2s;--fdelay:1s;"></div>
    <div class="dn-candle-glow" style="--cleft:73.5%;--cbottom:1%;--cw:60px;--ch:38px;--cdur:2s;--cdelay:1s;"></div>
    <div class="dn-flame" style="--fleft:83%;--fbottom:3.5%;--fw:10px;--fh:22px;--fdur:2.4s;--fdelay:0.5s;"></div>
    <div class="dn-candle-glow" style="--cleft:81.5%;--cbottom:2.5%;--cw:70px;--ch:45px;--cdur:2.4s;--cdelay:0.5s;"></div>
    <div class="dn-flame" style="--fleft:91%;--fbottom:1%;--fw:7px;--fh:15px;--fdur:1.9s;--fdelay:1.3s;"></div>
    <div class="dn-candle-glow" style="--cleft:89.5%;--cbottom:0%;--cw:52px;--ch:32px;--cdur:1.9s;--cdelay:1.3s;"></div>
    <div class="dn-flame" style="--fleft:96%;--fbottom:4%;--fw:8px;--fh:19px;--fdur:2.1s;--fdelay:0.9s;"></div>
    <div class="dn-candle-glow" style="--cleft:94.5%;--cbottom:3%;--cw:62px;--ch:42px;--cdur:2.1s;--cdelay:0.9s;"></div>

    <!-- 30 pétales de rose -->
    {Array.from({length: 30}).map((_, i) => (
      <div class="dn-petal" style={`--pleft:${(i*33+7)%100}%;--pdur:${9+((i*4)%8)}s;--pdelay:-${(i*1.7)%14}s;--pw:${8+((i*3)%8)}px;--ph:${12+((i*4)%8)}px;--pcolor:${i%4===0?'#cc3355':i%4===1?'#991133':i%4===2?'#dd6677':'#880022'}`}></div>
    ))}

    <!-- 20 bulles de champagne -->
    {Array.from({length: 20}).map((_, i) => (
      <div class="dn-bubble" style={`--bleft:${(i*47+13)%100}%;--bdur:${5+((i*3)%6)}s;--bdelay:-${(i*1.3)%8}s;--bw:${3+((i*2)%5)}px;--bh:${3+((i*2)%5)}px`}></div>
    ))}

    <!-- 15 sparkles -->
    {Array.from({length: 15}).map((_, i) => (
      <div class="dn-sparkle" style={`--sleft:${(i*67+11)%100}%;--stop:${(i*23+5)%85}%;--sdur:${2+((i*5)%4)}s;--sdelay:-${(i*1.9)%6}s;--sw:${2+((i%3))}px;--sh:${2+((i%3))}px;--scolor:${i%3===0?'#ffd080':i%3===1?'#ff99bb':'#ffcc66'}`}></div>
    ))}

    <!-- 3 étoiles filantes -->
    <div class="dn-shooting-star" style="--sstop:12%;--ssleft:-20px;--ssl:150px;--ssdur:7s;--ssdelay:0s;"></div>
    <div class="dn-shooting-star" style="--sstop:25%;--ssleft:-20px;--ssl:100px;--ssdur:9s;--ssdelay:3s;"></div>
    <div class="dn-shooting-star" style="--sstop:8%;--ssleft:-20px;--ssl:180px;--ssdur:11s;--ssdelay:6s;"></div>

    <div class="dn-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Date Night Wheel</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">🕯️</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight dn-title mb-3">
            Date Night Spinner
          </h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">
            Stuck in a routine? Spin for a random date night idea — from cozy candlelit evenings to spontaneous adventures.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="dn-tag">Romantic</span>
            <span class="dn-tag">Date Night</span>
            <span class="dn-tag">Couples</span>
            <span class="dn-tag">Romance</span>
          </div>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={themeColors}
          wheelShape="heart"
          hubTheme="rose"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="dn-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Breaking Out of the Routine</h2>
          <p class="text-white/60 leading-relaxed">
            Most couples default to the same 3 activities: restaurant, movie, stay home. Not because they're out of ideas, but because planning feels like work at the end of a long day. The date night wheel makes a decision for you in 3 seconds.
          </p>
          <p class="text-white/60 leading-relaxed">
            Whatever the wheel picks, commit fully. If it says "DIY spa," actually set it up properly — candles, music, face masks. If it says "bowling," make it a competition with a prize for the winner. Half-hearted execution kills any date idea.
          </p>
        </div>

        <div class="dn-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">How It Works</h2>
          <ol class="space-y-3">
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold shrink-0">1.</span>
              <span class="text-white/60">Each person adds 5 ideas they genuinely want to do.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold shrink-0">2.</span>
              <span class="text-white/60">Put all ideas on the wheel.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold shrink-0">3.</span>
              <span class="text-white/60">Spin. Commit to whatever it lands on, even if it's not your first choice.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold shrink-0">4.</span>
              <span class="text-white/60">The surprise is part of the fun.</span>
            </li>
          </ol>
        </div>

        <div class="dn-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Categories of Date Ideas</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            <div class="dn-card p-4">
              <p class="text-rose-300 font-semibold text-sm mb-1">Cozy</p>
              <p class="text-white/55 text-sm">Cook a new recipe together, board game night, movie marathon with themed snacks, puzzle night.</p>
            </div>
            <div class="dn-card p-4">
              <p class="text-amber-300 font-semibold text-sm mb-1">Active</p>
              <p class="text-white/55 text-sm">Hiking, rock climbing gym, kayaking, dancing class, mini golf.</p>
            </div>
            <div class="dn-card p-4">
              <p class="text-pink-300 font-semibold text-sm mb-1">Creative</p>
              <p class="text-white/55 text-sm">Pottery class, paint night, cooking class, escape room, improv show.</p>
            </div>
            <div class="dn-card p-4">
              <p class="text-orange-300 font-semibold text-sm mb-1">Spontaneous</p>
              <p class="text-white/55 text-sm">Drive somewhere random, try a restaurant in a new neighborhood, visit a museum you've never been to.</p>
            </div>
          </div>
        </div>

        <div class="dn-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">The Monthly Date Jar Alternative</h2>
          <p class="text-white/60 leading-relaxed">
            Write 20 date ideas on slips of paper. Put them in a jar. Draw one each week. The wheel is the digital version of this classic system — easier to customize and always available on any device.
          </p>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="dn-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/", label: "Spin the Wheel", desc: "The main wheel picker — add any names or options and spin." },
              { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random name from your list without the wheel animation." },
              { href: "/party-wheel", label: "Party Wheel", desc: "Pre-loaded with party game ideas for your next gathering." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="dn-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
