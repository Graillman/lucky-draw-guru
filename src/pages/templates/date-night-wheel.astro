---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Date Night Spinner — What Should We Do Tonight?";
const description = "Stuck in a routine? Spin the date night wheel for a random activity idea. Pre-loaded with 10 ideas from cozy to adventurous.";
const canonical = "/templates/date-night-wheel";

const faqItems = [
  {
    question: "What if we spin and neither of us is excited?",
    answer: "Allow one re-spin per month. But try the original result first — you're often more excited once you commit to the plan.",
  },
  {
    question: "Can we add our own ideas?",
    answer: "Yes — replace any defaults with ideas specific to your city, budget, or interests. Personal touches make it more fun.",
  },
  {
    question: "What if the activity requires advance planning?",
    answer: "Spin a week ahead if needed. Or have 'instant' and 'planned' wheels — spin the instant one for tonight, spin the planned one for a future special evening.",
  },
];

const defaultParticipants = [
  { pseudo: "Cook together", weight: 1 },
  { pseudo: "Restaurant", weight: 1 },
  { pseudo: "Movie night", weight: 1 },
  { pseudo: "Game night", weight: 1 },
  { pseudo: "Stargazing", weight: 1 },
  { pseudo: "DIY spa", weight: 1 },
  { pseudo: "Picnic", weight: 1 },
  { pseudo: "Bowling", weight: 1 },
  { pseudo: "Art class", weight: 1 },
  { pseudo: "Road trip", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/date-night-wheel",
};
---

<style>
    /* ── ROMANTIC CANDLELIGHT DINNER THEME ── */
    .date-page { min-height: 100vh; position: relative; background: #1a0a00; color: #f5e8d0; }

    .date-bg-sky {
      position: fixed; inset: 0; z-index: 0;
      background: radial-gradient(ellipse at 50% 30%, #3d1500 0%, #1a0800 50%, #0d0400 100%);
    }
    .date-candlelight {
      position: fixed; inset: 0; z-index: 1; pointer-events: none;
      background:
        radial-gradient(ellipse 40% 60% at 20% 50%, rgba(255,140,0,0.12) 0%, transparent 70%),
        radial-gradient(ellipse 35% 55% at 80% 45%, rgba(255,120,0,0.1) 0%, transparent 65%),
        radial-gradient(ellipse 50% 40% at 50% 80%, rgba(180,60,0,0.08) 0%, transparent 60%);
      animation: candleFlicker 4s ease-in-out infinite;
    }
    .date-glow-top {
      position: fixed; top: 0; left: 0; right: 0; height: 40%; z-index: 1; pointer-events: none;
      background: radial-gradient(ellipse at 50% 0%, rgba(255,160,60,0.08) 0%, transparent 70%);
      animation: glowPulse 5s ease-in-out infinite;
    }
    .date-petals {
      position: fixed; inset: 0; z-index: 2; pointer-events: none; overflow: hidden;
    }
    .date-petal {
      position: absolute;
      top: -30px;
      width: var(--w, 10px);
      height: var(--h, 14px);
      background: var(--color, #cc4466);
      border-radius: 50% 0 50% 0;
      opacity: 0.7;
      animation: petalFall var(--dur, 10s) linear infinite;
      animation-delay: var(--delay, 0s);
      left: var(--left, 50%);
    }
    .date-sparkles {
      position: fixed; inset: 0; z-index: 1; pointer-events: none;
    }
    .date-sparkle {
      position: absolute;
      width: 2px; height: 2px;
      background: #ffd080;
      border-radius: 50%;
      animation: twinkle var(--dur, 3s) ease-in-out infinite;
      animation-delay: var(--delay, 0s);
      left: var(--left, 50%);
      top: var(--top, 50%);
      box-shadow: 0 0 6px #ffaa40;
    }
    .date-candle-flames {
      position: fixed; bottom: 0; left: 0; right: 0; height: 30%; z-index: 1; pointer-events: none;
      background:
        radial-gradient(ellipse 20% 80% at 15% 100%, rgba(255,120,0,0.15) 0%, transparent 70%),
        radial-gradient(ellipse 20% 80% at 50% 100%, rgba(255,100,0,0.12) 0%, transparent 70%),
        radial-gradient(ellipse 20% 80% at 85% 100%, rgba(255,130,0,0.15) 0%, transparent 70%);
      animation: flamesDance 3s ease-in-out infinite alternate;
    }

    @keyframes candleFlicker {
      0%, 100% { opacity: 0.8; transform: scale(1); }
      25% { opacity: 1; transform: scale(1.02); }
      50% { opacity: 0.7; transform: scale(0.98); }
      75% { opacity: 0.95; transform: scale(1.01); }
    }
    @keyframes glowPulse {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 1; }
    }
    @keyframes petalFall {
      0% { transform: translateY(-30px) rotate(0deg); opacity: 0; }
      5% { opacity: 0.8; }
      95% { opacity: 0.6; }
      100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
    }
    @keyframes twinkle {
      0%, 100% { opacity: 0.2; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.8); }
    }
    @keyframes flamesDance {
      0% { transform: scaleX(1) translateY(0); }
      100% { transform: scaleX(1.05) translateY(-5px); }
    }
    @keyframes titleGlow {
      0%, 100% { text-shadow: 0 0 20px rgba(255,160,60,0.7), 0 0 40px rgba(200,80,30,0.4); }
      50% { text-shadow: 0 0 30px rgba(255,180,80,0.9), 0 0 60px rgba(220,100,40,0.6), 0 0 80px rgba(180,60,20,0.3); }
    }

    .date-content { position: relative; z-index: 10; }
    .date-card {
      background: rgba(30, 10, 0, 0.8);
      border: 1px solid rgba(200, 100, 30, 0.35);
      border-radius: 16px;
      padding: 1.5rem;
      backdrop-filter: blur(14px);
      box-shadow: 0 0 30px rgba(200,80,20,0.15), inset 0 1px 0 rgba(255,200,100,0.1);
    }
    .date-card h2 { color: #f0b060; text-shadow: 0 0 12px rgba(240,140,40,0.5); }
    .date-card p, .date-card li { color: #c4a880; }
    .date-tag {
      background: rgba(80,30,0,0.4);
      border: 1px solid rgba(180,80,20,0.4);
      border-radius: 8px; padding: 1rem;
    }
    .date-tag p:first-child { color: #e8b070; font-weight: 600; font-size: 0.875rem; margin-bottom: 4px; }
    .date-tag p:last-child { color: #b09070; font-size: 0.875rem; }
    .date-title { color: #f0b870; animation: titleGlow 4s ease-in-out infinite; }
    .date-subtitle { color: #b09070; }
    .date-free { color: #806850; font-size: 0.875rem; }
    .date-breadcrumb a { color: #806850; transition: color 0.2s; }
    .date-breadcrumb a:hover { color: #f0b060; }
    .date-breadcrumb span { color: #604030; }
    .date-faq {
      background: rgba(25,8,0,0.85);
      border: 1px solid rgba(180,80,20,0.3);
      border-radius: 12px; padding: 1.25rem;
      backdrop-filter: blur(8px);
    }
    .date-faq p:first-child { color: #f0b060; font-weight: 600; margin-bottom: 8px; }
    .date-faq p:last-child { color: #a08060; font-size: 0.875rem; line-height: 1.6; }
    .date-related a {
      display: flex; align-items: flex-start; gap: 0.75rem;
      padding: 1rem;
      background: rgba(20,6,0,0.75);
      border: 1px solid rgba(160,60,10,0.3);
      border-radius: 12px;
      backdrop-filter: blur(8px);
      transition: all 0.2s; text-decoration: none;
    }
    .date-related a:hover { border-color: rgba(240,160,60,0.5); box-shadow: 0 0 20px rgba(200,100,20,0.25); }
    .date-related .arrow { color: #cc8030; font-weight: bold; font-size: 0.875rem; margin-top: 2px; }
    .date-related .label { color: #f0b060; font-weight: 600; }
    .date-related .desc { color: #907050; font-size: 0.875rem; }
    .date-ol span:first-child { color: #cc8030; font-weight: bold; }
    .date-ol span:last-child { color: #b09070; }
  </style>

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Date Night Wheel", url: "https://realwheelpicker.com/templates/date-night-wheel" },
  ]} />

  
  <div class="date-page">
    <div class="date-bg-sky"></div>
    <div class="date-candlelight"></div>
    <div class="date-glow-top"></div>
    <div class="date-candle-flames"></div>
    <div class="date-sparkles">
      {Array.from({length: 30}).map((_, i) => (
        <div class="date-sparkle" style={`--left:${(i*31+7)%100}%;--top:${(i*17+13)%90}%;--dur:${2+((i*5)%4)}s;--delay:-${(i*2.3)%5}s`}></div>
      ))}
    </div>
    <div class="date-petals">
      {Array.from({length: 18}).map((_, i) => (
        <div class="date-petal" style={`--left:${(i*53+11)%100}%;--dur:${8+((i*3)%7)}s;--delay:-${(i*1.8)%12}s;--w:${8+((i*3)%8)}px;--h:${12+((i*5)%8)}px;--color:${i%3===0?'#cc4466':i%3===1?'#993355':'#dd6688'}`}></div>
      ))}
    </div>

    <div class="date-content">
      <HeaderIsland client:load />

      <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

        <nav aria-label="breadcrumb" class="date-breadcrumb text-xs flex gap-1">
          <a href="/">Home</a><span>/</span>
          <a href="/templates">Templates</a><span>/</span>
          <span style="color:#c09060">Date Night Wheel</span>
        </nav>

        <section class="text-center space-y-4 py-2 md:py-6">
          <h1 class="text-3xl md:text-5xl font-bold leading-tight date-title">
            Date Night Spinner — What Should We Do Tonight?
          </h1>
          <p class="text-lg md:text-xl max-w-2xl mx-auto date-subtitle">
            Stuck in a routine? Spin the wheel for a random date night idea. Pre-loaded with 10 activities from cozy to adventurous.
          </p>
          <p class="date-free">Free • No account • Instant result</p>
        </section>

        <section class="flex flex-col items-center">
          <SimpleWheelIsland
            defaultParticipants={defaultParticipants}
            colors={["#8B1A3A","#C4791A","#6B3050","#D4A030","#9B2040","#E8B040","#7A2545","#B86820"]}
            wheelShape="heart"
            hubTheme="rose"
            client:load
          />
        </section>

        <section class="space-y-8">
          <div class="date-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Breaking Out of the Routine</h2>
            <p class="leading-relaxed">
              Most couples default to the same 3 activities: restaurant, movie, stay home. Not because they're out of ideas, but because planning feels like work at the end of a long day. The date night wheel makes a decision for you in 3 seconds.
            </p>
          </div>

          <div class="date-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">How It Works</h2>
            <ol class="space-y-2 date-ol">
              <li class="flex gap-3"><span>1.</span><span>Each person adds 5 ideas they genuinely want to do.</span></li>
              <li class="flex gap-3"><span>2.</span><span>Put all ideas on the wheel.</span></li>
              <li class="flex gap-3"><span>3.</span><span>Spin. Commit to whatever it lands on, even if it's not your first choice.</span></li>
              <li class="flex gap-3"><span>4.</span><span>The surprise is part of the fun.</span></li>
            </ol>
          </div>

          <div class="date-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Categories of Date Ideas</h2>
            <div class="space-y-3">
              <div class="date-tag">
                <p>Cozy</p>
                <p>Cook a new recipe together, board game night, movie marathon with themed snacks, puzzle night.</p>
              </div>
              <div class="date-tag">
                <p>Active</p>
                <p>Hiking, rock climbing gym, kayaking, dancing class, mini golf.</p>
              </div>
              <div class="date-tag">
                <p>Creative</p>
                <p>Pottery class, paint night, cooking class, escape room, improv show.</p>
              </div>
              <div class="date-tag">
                <p>Spontaneous</p>
                <p>Drive somewhere random, try a restaurant in a new neighborhood, visit a museum you've never been to.</p>
              </div>
              <div class="date-tag">
                <p>Free / Cheap</p>
                <p>Stargazing, picnic in the park, free outdoor concert, library book exchange.</p>
              </div>
            </div>
          </div>

          <div class="date-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">The Monthly Date Jar Alternative</h2>
            <p class="leading-relaxed">
              Write 20 date ideas on slips of paper. Put in a jar. Draw one each week. The wheel is the digital version of this classic system — easier to customize and always available.
            </p>
          </div>

          <div class="date-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Making It Special</h2>
            <p class="leading-relaxed">
              Whatever the wheel picks, commit fully. If it says "DIY spa," actually set it up properly — candles, music, face masks. If it says "bowling," make it a competition with a prize for the winner. Half-hearted execution kills any date idea.
            </p>
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#f0b060">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="date-faq">
                <p>{question}</p>
                <p>{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="date-related space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#f0b060">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/", label: "Spin the Wheel", desc: "The main wheel picker — add any names or options and spin." },
              { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random name from your list without the wheel animation." },
              { href: "/party-wheel", label: "Party Wheel", desc: "Pre-loaded with party game ideas for your next gathering." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href}>
                  <span class="arrow">→</span>
                  <span><span class="label">{label}</span><span class="desc"> — {desc}</span></span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
