---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Self-Care Wheel — Random Wellness Activity Spinner";
const description = "Spin for a random self-care activity. Pre-loaded with 12 wellness habits. Perfect for building a daily self-care practice without overthinking it.";
const canonical = "/templates/self-care-wheel";

const faqItems = [
  {
    question: "How do I use this as a daily practice?",
    answer: "Spin once in the morning or evening and commit to the activity for that day. It removes the decision fatigue of choosing what to do for yourself, which ironically is one of the biggest barriers to self-care.",
  },
  {
    question: "Can I customize the activities for my lifestyle?",
    answer: "Absolutely. Replace activities that don't resonate with ones that do. If meditation isn't your thing, swap it for a 10-minute walk. The wheel works best when every option is genuinely good for you.",
  },
  {
    question: "What if I land on something I don't have time for?",
    answer: "Keep a 'quick version' mindset — a bath can be a 5-minute shower with no phone, a workout can be 10 minutes of stretching, a digital detox can be 30 minutes. Every activity scales to whatever time you have.",
  },
];

const defaultParticipants = [
  { pseudo: "Meditate 10 min", weight: 1 },
  { pseudo: "Take a bath", weight: 1 },
  { pseudo: "Journal", weight: 1 },
  { pseudo: "Call a friend", weight: 1 },
  { pseudo: "Go outside", weight: 1 },
  { pseudo: "Stretch session", weight: 1 },
  { pseudo: "Digital detox 1 hr", weight: 1 },
  { pseudo: "Cook healthy meal", weight: 1 },
  { pseudo: "Read for fun", weight: 1 },
  { pseudo: "Early bedtime", weight: 1 },
  { pseudo: "Gratitude list", weight: 1 },
  { pseudo: "Deep breathing", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/self-care-wheel",
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Self-Care Wheel", url: "https://realwheelpicker.com/templates/self-care-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Self-Care Wheel</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Self-Care Wheel — Random Wellness Activity Spinner
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Stop planning self-care and start doing it. Spin the wheel, get a random wellness activity, and actually follow through today.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <section class="space-y-8">
        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">The Self-Care Paradox</h2>
          <p class="text-muted-foreground leading-relaxed">
            Most people who struggle with self-care don't lack motivation — they lack decision clarity. You finish a long day and know you should do something for yourself, but then spend 20 minutes deciding what. By then, you're too tired to do anything.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The self-care wheel solves this by making the decision instant and random. You've already pre-loaded the wheel with activities that are good for you. Whatever it lands on, you do — no second-guessing, no comparison. The randomness also keeps the practice fresh so you're not stuck in the same routine.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Customize Your Wellness Wheel</h2>
          <p class="text-muted-foreground leading-relaxed">
            The default activities cover the main pillars of wellness: movement (stretch, go outside), mental health (meditate, journal, deep breathing), social connection (call a friend), nutrition (cook healthy meal), rest (early bedtime), and digital wellbeing (detox). Adjust based on what you actually need more of in your life.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/hobby-wheel", label: "Hobby Wheel", desc: "Spin for a random activity when you have free time." },
            { href: "/templates/weekend-activity-wheel", label: "Weekend Activity Spinner", desc: "Plan your weekend with a random activity pick." },
            { href: "/yes-or-no-wheel", label: "Yes or No Wheel", desc: "Simple go/no-go decisions — should you take a break right now?" },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:load />
  </div>
</Layout>
