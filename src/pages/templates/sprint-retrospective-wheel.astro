---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Sprint Retro Wheel — Random Discussion Topics";
const description = "Spin for sprint retrospective discussion prompts. Keep retros fresh and focused. Pre-loaded with 8 proven prompts for agile teams.";
const canonical = "/templates/sprint-retrospective-wheel";

const faqItems = [
  {
    question: "How do we structure a retro using this wheel?",
    answer: "Spin 3-4 times to pick the topics for the session. Spend 5-10 minutes on each. This keeps retros focused and under 45 minutes, which prevents the energy drain of open-ended sessions.",
  },
  {
    question: "Can we add our own retro formats?",
    answer: "Yes. Replace defaults with prompts specific to your team's current challenges — 'On-call pain points', 'Documentation gaps', 'Cross-team dependencies'. The wheel works for any retrospective format.",
  },
  {
    question: "How often should we change the prompts?",
    answer: "Every 2-3 sprints. Using the same prompts repeatedly reduces engagement. Refresh the wheel with new questions when you notice shorter answers and less discussion.",
  },
];

const defaultParticipants = [
  { pseudo: "What went well?",      weight: 1 },
  { pseudo: "What to improve?",     weight: 1 },
  { pseudo: "Biggest blocker?",     weight: 1 },
  { pseudo: "Team highlight?",      weight: 1 },
  { pseudo: "Process to change?",   weight: 1 },
  { pseudo: "Communication check",  weight: 1 },
  { pseudo: "Tool feedback?",       weight: 1 },
  { pseudo: "Workload balance?",    weight: 1 },
];

const retroColors = ['#9d4edd','#c77dff','#7b2fbe','#5a189a','#e0aaff','#3c096c','#c084fc','#a855f7'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/sprint-retrospective-wheel",
};
---

<style>
  /* ═══ TERMINAL HACKER — CODE VIOLET, CIRCUIT, MATRIX ═══ */
  .sr-page {
    background: #020008;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Fond terminal noir profond */
  .sr-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 15% 5%, rgba(140,40,220,0.22) 0%, transparent 65%),
      radial-gradient(ellipse 55% 45% at 85% 8%, rgba(80,20,160,0.18) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 50% 95%, rgba(100,60,200,0.14) 0%, transparent 60%),
      linear-gradient(180deg, #020008 0%, #05000f 50%, #020008 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Grille circuit imprimé */
  .sr-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(157,78,237,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(157,78,237,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 1;
    animation: srGridPulse 8s ease-in-out infinite alternate;
  }
  @keyframes srGridPulse {
    from { opacity: 0.5; }
    to   { opacity: 1; }
  }

  /* Halos violets */
  .sr-halo-tl {
    position: fixed;
    left: -100px;
    top: -80px;
    width: 600px;
    height: 500px;
    background: radial-gradient(circle, rgba(157,78,237,0.2) 0%, transparent 70%);
    filter: blur(80px);
    z-index: 0;
    pointer-events: none;
    animation: srHaloPulse 7s ease-in-out infinite alternate;
  }
  .sr-halo-br {
    position: fixed;
    right: -80px;
    bottom: -60px;
    width: 500px;
    height: 450px;
    background: radial-gradient(circle, rgba(100,20,200,0.18) 0%, transparent 70%);
    filter: blur(90px);
    z-index: 0;
    pointer-events: none;
    animation: srHaloPulse 9s ease-in-out infinite alternate;
    animation-delay: 3s;
  }
  .sr-halo-center {
    position: fixed;
    top: 35%;
    left: 40%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(120,40,200,0.12) 0%, transparent 70%);
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
    animation: srHaloPulse 11s ease-in-out infinite alternate;
    animation-delay: 5s;
  }
  @keyframes srHaloPulse {
    from { opacity: 0.4; transform: scale(0.92); }
    to   { opacity: 0.85; transform: scale(1.08); }
  }

  /* Scanlines effet CRT */
  .sr-scanlines {
    position: fixed;
    inset: 0;
    z-index: 3;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0,0,0,0.06) 3px,
      rgba(0,0,0,0.06) 4px
    );
    pointer-events: none;
    animation: srScanMove 10s linear infinite;
  }
  @keyframes srScanMove {
    0%   { background-position: 0 0; }
    100% { background-position: 0 8px; }
  }

  /* Colonnes de code tombant (Matrix violet) */
  .sr-code-col {
    position: fixed;
    top: -100%;
    pointer-events: none;
    z-index: 2;
    font-family: 'Courier New', monospace;
    font-size: 10px;
    line-height: 1.5;
    white-space: pre;
    opacity: 0;
    animation: srCodeRain var(--crdur, 14s) linear infinite;
    animation-delay: var(--crdelay, 0s);
    left: var(--crleft, 5%);
    color: var(--crcolor, #9d4edd);
  }
  @keyframes srCodeRain {
    0%   { transform: translateY(0); opacity: 0; }
    5%   { opacity: 0.18; }
    90%  { opacity: 0.10; }
    100% { transform: translateY(230vh); opacity: 0; }
  }

  /* Lignes de code flottantes */
  .sr-code-line {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    font-family: 'Courier New', monospace;
    font-size: 8px;
    color: var(--clcolor, rgba(157,78,237,0.5));
    opacity: 0;
    animation: srCodeFloat var(--cldur, 8s) ease-in-out infinite;
    animation-delay: var(--cldelay, 0s);
    left: var(--clleft, 5%);
    top: var(--cltop, 30%);
    white-space: nowrap;
    border: 1px solid var(--clborder, rgba(100,40,180,0.3));
    background: rgba(2,0,8,0.7);
    padding: 2px 6px;
    border-radius: 2px;
  }
  @keyframes srCodeFloat {
    0%   { transform: translateY(0) translateX(0px); opacity: 0; }
    10%  { opacity: 0.5; }
    50%  { transform: translateY(-15px) translateX(8px); opacity: 0.4; }
    90%  { opacity: 0.2; }
    100% { transform: translateY(-30px) translateX(-5px); opacity: 0; }
  }

  /* Particules violettes montantes */
  .sr-particle {
    position: fixed;
    bottom: -10px;
    pointer-events: none;
    z-index: 2;
    width: var(--ppw, 3px);
    height: var(--pph, 3px);
    border-radius: 50%;
    background: var(--ppcolor, #9d4edd);
    box-shadow: 0 0 8px var(--ppcolor, #9d4edd);
    opacity: 0;
    animation: srParticleRise var(--ppdur, 6s) ease-in infinite;
    animation-delay: var(--ppdelay, 0s);
    left: var(--ppleft, 50%);
  }
  @keyframes srParticleRise {
    0%   { transform: translateY(0) translateX(0px); opacity: 0; }
    10%  { opacity: 0.8; }
    50%  { transform: translateY(-40vh) translateX(10px); opacity: 0.5; }
    90%  { opacity: 0.1; }
    100% { transform: translateY(-90vh) translateX(-8px); opacity: 0; }
  }

  /* Curseurs clignotants */
  .sr-cursor {
    position: fixed;
    z-index: 3;
    width: 8px;
    height: 16px;
    background: var(--curcolor, #9d4edd);
    opacity: 0;
    pointer-events: none;
    animation: srCursorBlink 1.1s step-end infinite;
    animation-delay: var(--curdelay, 0s);
  }
  @keyframes srCursorBlink {
    0%,100% { opacity: 0.65; }
    50%     { opacity: 0; }
  }

  /* Tickets JIRA flottants */
  .sr-ticket {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    border-radius: 3px;
    border: 1px solid var(--tkborder, rgba(157,78,237,0.4));
    font-family: 'Courier New', monospace;
    font-size: 8px;
    padding: 3px 7px;
    white-space: nowrap;
    color: var(--tkcolor, rgba(167,139,250,0.7));
    background: rgba(2,0,8,0.8);
    opacity: 0;
    animation: srTicketDrift var(--tkdur, 9s) ease-in-out infinite;
    animation-delay: var(--tkdelay, 0s);
    left: var(--tkleft, 5%);
    top: var(--tktop, 40%);
  }
  @keyframes srTicketDrift {
    0%   { transform: translateY(0) rotate(-2deg); opacity: 0; }
    10%  { opacity: 0.5; }
    90%  { opacity: 0.25; }
    100% { transform: translateY(-50px) rotate(2deg); opacity: 0; }
  }

  /* Contenu */
  .sr-content { position: relative; z-index: 10; }

  /* Titre violet/cyan gradient */
  .sr-title {
    background: linear-gradient(135deg, #e0aaff 0%, #9d4edd 25%, #c77dff 50%, #7c3aed 75%, #e0aaff 100%);
    background-size: 250%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: srShimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 25px rgba(157,78,237,0.6));
    font-family: 'Courier New', monospace;
  }
  @keyframes srShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .sr-tag {
    background: rgba(157,78,237,0.15);
    border: 1px solid rgba(157,78,237,0.4);
    color: rgba(224,170,255,0.95);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
    font-family: 'Courier New', monospace;
  }

  .sr-card {
    background: rgba(5,0,15,0.85);
    border: 1px solid rgba(157,78,237,0.22);
    border-radius: 1rem;
    backdrop-filter: blur(12px);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .sr-card:hover {
    border-color: rgba(199,125,255,0.45);
    box-shadow: 0 0 20px rgba(157,78,237,0.12);
  }

  details.sr-faq {
    background: rgba(3,0,10,0.85);
    border: 1px solid rgba(157,78,237,0.22);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }

  /* Terminal décoratif */
  .sr-terminal {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 220px;
    background: rgba(2,0,8,0.92);
    border: 1px solid rgba(157,78,237,0.4);
    border-radius: 6px;
    padding: 10px 14px;
    font-family: 'Courier New', monospace;
    font-size: 9px;
    color: rgba(157,78,237,0.7);
    z-index: 3;
    pointer-events: none;
    box-shadow: 0 0 20px rgba(100,20,200,0.2);
    animation: srTerminalGlow 4s ease-in-out infinite alternate;
  }
  @keyframes srTerminalGlow {
    from { box-shadow: 0 0 15px rgba(100,20,200,0.15); }
    to   { box-shadow: 0 0 30px rgba(157,78,237,0.3); }
  }
  .sr-terminal-bar {
    display: flex;
    gap: 5px;
    margin-bottom: 8px;
  }
  .sr-terminal-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .sr-prompt { color: rgba(199,125,255,0.8); }
  .sr-cmd    { color: rgba(100,220,180,0.7); }
  .sr-out    { color: rgba(157,78,237,0.5); }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Sprint Retro Wheel", url: "https://realwheelpicker.com/templates/sprint-retrospective-wheel" },
  ]} />

  <div class="sr-page">
    <div class="sr-sky"></div>
    <div class="sr-grid"></div>
    <div class="sr-scanlines"></div>
    <div class="sr-halo-tl"></div>
    <div class="sr-halo-br"></div>
    <div class="sr-halo-center"></div>

    <!-- 12 colonnes de code tombant -->
    <div class="sr-code-col" style="--crleft:2%;--crdur:12s;--crdelay:0s;--crcolor:#9d4edd;">{'sprint.run()\nconst ret\nfunc()=>\nlet done\nreturn 1\n{} [] ()'}
    </div>
    <div class="sr-code-col" style="--crleft:10%;--crdur:15s;--crdelay:2s;--crcolor:#c77dff;">{'async fn\nretro()\nteam.ok\nconst x\nimport *\nexport{}'}
    </div>
    <div class="sr-code-col" style="--crleft:19%;--crdur:11s;--crdelay:4s;--crcolor:#7b2fbe;">{'git push\nCI pass\nbuild ok\ntest run\ndeploy!\n=> prod'}
    </div>
    <div class="sr-code-col" style="--crleft:28%;--crdur:14s;--crdelay:1s;--crcolor:#9d4edd;">{'velocity\npoints++\nsprint=8\nburn dwn\ncapacity\nplanning'}
    </div>
    <div class="sr-code-col" style="--crleft:37%;--crdur:16s;--crdelay:6s;--crcolor:#e0aaff;">{'TODO fix\nFIXME now\nHACK note\nNB: check\ncomment!\n// done!'}
    </div>
    <div class="sr-code-col" style="--crleft:46%;--crdur:13s;--crdelay:3s;--crcolor:#a855f7;">{'review ok\napproved!\nmerged in\nhotfix go\nrollback?\ndeploy ok'}
    </div>
    <div class="sr-code-col" style="--crleft:56%;--crdur:17s;--crdelay:5s;--crcolor:#7c3aed;">{'npm test\nall green\npassed 42\ncoverage!\n100% ok\nno errors'}
    </div>
    <div class="sr-code-col" style="--crleft:65%;--crdur:12s;--crdelay:7s;--crcolor:#9d4edd;">{'standup!\nblocked?\nhelp req\nPR open\nreview!\nshippit!'}
    </div>
    <div class="sr-code-col" style="--crleft:74%;--crdur:15s;--crdelay:1.5s;--crcolor:#c77dff;">{'retro ok\naction!\nnext spr\ngoal set\nvision!\nalign ok'}
    </div>
    <div class="sr-code-col" style="--crleft:82%;--crdur:13s;--crdelay:8s;--crcolor:#7b2fbe;">{'bug #117\nfix prod\nlog tail\nerror!\ncatch err\nresolve!'}
    </div>
    <div class="sr-code-col" style="--crleft:89%;--crdur:18s;--crdelay:2.5s;--crcolor:#e0aaff;">{'kanban!\nscrum ok\nagile do\nlean go\ncraft it\nship now'}
    </div>
    <div class="sr-code-col" style="--crleft:95%;--crdur:11s;--crdelay:9s;--crcolor:#a855f7;">{'done:42\nwip: 3\ntodo:8\nsprint!\npoint=5\nspeed++'}
    </div>

    <!-- 15 lignes de code flottantes -->
    <div class="sr-code-line" style="--clleft:3%;--cltop:35%;--cldur:8s;--cldelay:0s;--clcolor:rgba(199,125,255,0.6);--clborder:rgba(157,78,237,0.35);">git commit -m "retro: fix"</div>
    <div class="sr-code-line" style="--clleft:68%;--cltop:22%;--cldur:11s;--cldelay:3s;--clcolor:rgba(100,220,180,0.6);--clborder:rgba(80,180,140,0.3);">npm run retro --team</div>
    <div class="sr-code-line" style="--clleft:5%;--cltop:62%;--cldur:9s;--cldelay:5s;--clcolor:rgba(157,78,237,0.6);--clborder:rgba(120,40,200,0.3);">TODO: fix blocker #99</div>
    <div class="sr-code-line" style="--clleft:75%;--cltop:55%;--cldur:12s;--cldelay:1s;--clcolor:rgba(251,146,60,0.6);--clborder:rgba(200,100,30,0.3);">DONE: shipped to prod</div>
    <div class="sr-code-line" style="--clleft:20%;--cltop:78%;--cldur:7s;--cldelay:6s;--clcolor:rgba(74,222,128,0.5);--clborder:rgba(40,180,80,0.3);">SCRUM-42: velocity++</div>
    <div class="sr-code-line" style="--clleft:55%;--cltop:15%;--cldur:10s;--cldelay:2s;--clcolor:rgba(157,78,237,0.5);--clborder:rgba(100,40,180,0.3);">sprint.review(team)</div>
    <div class="sr-code-line" style="--clleft:40%;--cltop:88%;--cldur:14s;--cldelay:4s;--clcolor:rgba(199,125,255,0.5);--clborder:rgba(157,78,237,0.3);">async retrospective()</div>
    <div class="sr-code-line" style="--clleft:82%;--cltop:40%;--cldur:8s;--cldelay:7s;--clcolor:rgba(100,220,180,0.5);--clborder:rgba(80,180,140,0.25);">BUG-117: resolved ✓</div>
    <div class="sr-code-line" style="--clleft:12%;--cltop:48%;--cldur:11s;--cldelay:0.5s;--clcolor:rgba(224,170,255,0.5);--clborder:rgba(180,100,240,0.3);">FEAT-88: deployed</div>
    <div class="sr-code-line" style="--clleft:60%;--cltop:70%;--cldur:9s;--cldelay:8s;--clcolor:rgba(157,78,237,0.55);--clborder:rgba(120,40,200,0.3);">const team = happy()</div>
    <div class="sr-code-line" style="--clleft:30%;--cltop:25%;--cldur:13s;--cldelay:3.5s;--clcolor:rgba(251,146,60,0.5);--clborder:rgba(200,100,30,0.25);">build.status: GREEN</div>
    <div class="sr-code-line" style="--clleft:88%;--cltop:80%;--cldur:10s;--cldelay:6.5s;--clcolor:rgba(74,222,128,0.5);--clborder:rgba(40,180,80,0.25);">DONE ✓ all tests pass</div>
    <div class="sr-code-line" style="--clleft:48%;--cltop:44%;--cldur:7s;--cldelay:1.8s;--clcolor:rgba(199,125,255,0.5);--clborder:rgba(157,78,237,0.28);">deploy.then(celebrate)</div>
    <div class="sr-code-line" style="--clleft:15%;--cltop:92%;--cldur:15s;--cldelay:9s;--clcolor:rgba(157,78,237,0.45);--clborder:rgba(100,40,180,0.25);">sprint.close(); // done</div>
    <div class="sr-code-line" style="--clleft:72%;--cltop:8%;--cldur:12s;--cldelay:4.5s;--clcolor:rgba(224,170,255,0.5);--clborder:rgba(180,100,240,0.28);">review.approved = true</div>

    <!-- 20 particules montantes -->
    {Array.from({length: 20}).map((_, i) => (
      <div class="sr-particle" style={`--ppleft:${(i*53+7)%100}%;--ppdur:${5+((i*3)%6)}s;--ppdelay:-${(i*1.7)%9}s;--ppw:${2+((i%3))}px;--pph:${2+((i%3))}px;--ppcolor:${i%4===0?'#9d4edd':i%4===1?'#c77dff':i%4===2?'#7b2fbe':'#e0aaff'}`}></div>
    ))}

    <!-- 3 curseurs clignotants -->
    <div class="sr-cursor" style="top:18%;left:8%;--curcolor:#9d4edd;--curdelay:0s;"></div>
    <div class="sr-cursor" style="top:55%;right:12%;--curcolor:#c77dff;--curdelay:0.5s;"></div>
    <div class="sr-cursor" style="top:75%;left:18%;--curcolor:#7b2fbe;--curdelay:1s;"></div>

    <!-- 4 tickets flottants -->
    <div class="sr-ticket" style="--tkleft:4%;--tktop:40%;--tkdur:8s;--tkdelay:0s;--tkborder:rgba(157,78,237,0.4);--tkcolor:rgba(199,125,255,0.7);">SCRUM-42</div>
    <div class="sr-ticket" style="--tkleft:77%;--tktop:55%;--tkdur:11s;--tkdelay:3s;--tkborder:rgba(100,220,180,0.4);--tkcolor:rgba(80,200,160,0.7);">BUG-117</div>
    <div class="sr-ticket" style="--tkleft:60%;--tktop:28%;--tkdur:9s;--tkdelay:6s;--tkborder:rgba(251,146,60,0.4);--tkcolor:rgba(251,146,60,0.7);">FEAT-88</div>
    <div class="sr-ticket" style="--tkleft:22%;--tktop:72%;--tkdur:7s;--tkdelay:1.5s;--tkborder:rgba(74,222,128,0.4);--tkcolor:rgba(74,222,128,0.7);">DONE ✓</div>

    <!-- Terminal décoratif -->
    <div class="sr-terminal">
      <div class="sr-terminal-bar">
        <div class="sr-terminal-dot" style="background:#ff5f57;"></div>
        <div class="sr-terminal-dot" style="background:#febc2e;"></div>
        <div class="sr-terminal-dot" style="background:#28c840;"></div>
      </div>
      <div class="sr-prompt">$ <span class="sr-cmd">npm run retro</span></div>
      <div class="sr-out">Loading topics...</div>
      <div class="sr-prompt">$ <span class="sr-cmd">spin --team agile</span></div>
      <div class="sr-out">Randomizing... ✓</div>
      <div class="sr-prompt" style="animation: srCursorBlink 1.1s step-end infinite;">$_</div>
    </div>

    <div class="sr-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Sprint Retro Wheel</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">⚙️</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight sr-title mb-3">
            Sprint Retro Wheel
          </h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">
            Keep retrospectives fresh. Spin to pick the discussion topic — no more stale formats or repetitive sessions.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="sr-tag">Agile</span>
            <span class="sr-tag">Scrum</span>
            <span class="sr-tag">Sprint</span>
            <span class="sr-tag">Retrospective</span>
          </div>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={retroColors}
          wheelShape="hexagon"
          hubTheme="purple"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="sr-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Fix Stale Retrospectives</h2>
          <p class="text-white/60 leading-relaxed">
            The most common retro problem: teams fall into the same format every sprint. "What went well, what didn't, what to improve" — repeated verbatim for months. Engagement drops, answers get shorter, and the retro becomes a box-ticking exercise.
          </p>
          <p class="text-white/60 leading-relaxed">
            Adding randomness to the format breaks this pattern. Spin 3-4 topics from the wheel. The uncertainty of what comes next keeps the team engaged. Add prompts specific to your current sprint challenges to keep it relevant.
          </p>
        </div>

        <div class="sr-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">How to Structure the Retro</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            <div class="sr-card p-4">
              <p class="text-purple-300 font-semibold text-sm mb-1 font-mono">Step 1: Spin 3-4 topics</p>
              <p class="text-white/55 text-sm">Select the discussion areas for the session before anyone arrives.</p>
            </div>
            <div class="sr-card p-4">
              <p class="text-violet-300 font-semibold text-sm mb-1 font-mono">Step 2: 5-10 min each</p>
              <p class="text-white/55 text-sm">Time-box each topic. Set a visible timer to maintain pace.</p>
            </div>
            <div class="sr-card p-4">
              <p class="text-fuchsia-300 font-semibold text-sm mb-1 font-mono">Step 3: Action items</p>
              <p class="text-white/55 text-sm">End each topic with one concrete action item, not just discussion.</p>
            </div>
            <div class="sr-card p-4">
              <p class="text-cyan-300 font-semibold text-sm mb-1 font-mono">Step 4: Refresh wheel</p>
              <p class="text-white/55 text-sm">Update prompts every 2-3 sprints to maintain engagement.</p>
            </div>
          </div>
        </div>

        <div class="sr-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Advanced Retro Prompts</h2>
          <p class="text-white/60 leading-relaxed">
            Beyond the defaults, consider adding team-specific prompts: "On-call pain points", "Documentation gaps", "Cross-team dependency blockers", "Tech debt that slowed us down", "Ceremony that should be shorter", "Tool that frustrated the team". The more specific to your current context, the more useful the conversation.
          </p>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="sr-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/templates/standup-order-wheel", label: "Standup Order Wheel", desc: "Who speaks first at standup?" },
              { href: "/templates/team-building-wheel", label: "Team Building Wheel", desc: "Random team activities and icebreakers." },
              { href: "/templates/icebreaker-wheel", label: "Icebreaker Wheel", desc: "Warm up any team meeting." },
              { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random team member for any task." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="sr-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
