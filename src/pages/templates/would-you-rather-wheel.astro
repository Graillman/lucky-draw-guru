---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Would You Rather Wheel — Random Dilemma Spinner";
const description = "Spin for would-you-rather questions. Pre-loaded with 8 fun dilemmas for parties, teams, and games.";
const canonical = "/templates/would-you-rather-wheel";

const faqItems = [
  {
    question: "Can I add my own dilemmas?",
    answer: "Yes — replace any option with your own would-you-rather question. The wheel can hold any number of dilemmas.",
  },
  {
    question: "What's the ideal group size?",
    answer: "3-10 people. Larger groups work if you give everyone time to answer each question.",
  },
  {
    question: "Are there kid-friendly versions?",
    answer: "Keep questions age-appropriate: Would you rather be a superhero or a wizard? Have a pet dragon or pet dinosaur?",
  },
];

const defaultParticipants = [
  { pseudo: "Fly or Invisible?", weight: 1 },
  { pseudo: "Time travel: Past or Future?", weight: 1 },
  { pseudo: "No internet or No AC?", weight: 1 },
  { pseudo: "Read minds or See future?", weight: 1 },
  { pseudo: "Rich or Famous?", weight: 1 },
  { pseudo: "City or Country?", weight: 1 },
  { pseudo: "Always hot or Always cold?", weight: 1 },
  { pseudo: "No music or No movies?", weight: 1 },
];

const wyrColors = ['#dc2626','#2563eb','#ffffff','#f59e0b','#991b1b','#1d4ed8','#fbbf24','#eff6ff','#7f1d1d','#1e3a8a'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/would-you-rather-wheel",
};
---

<style>
  /* ═══════════ WOULD YOU RATHER — BINARY CHOICE CLASH ═══════════ */
  .wyr-page {
    background: #050008;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Split sky: red left / blue right */
  .wyr-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 100% at 0% 50%,   rgba(180,10,10,0.55) 0%, transparent 65%),
      radial-gradient(ellipse 60% 100% at 100% 50%,  rgba(15,50,200,0.55) 0%, transparent 65%),
      radial-gradient(ellipse 20% 80% at 50% 50%,   rgba(255,255,255,0.04) 0%, transparent 60%),
      linear-gradient(180deg, #050008 0%, #0a000f 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Central lightning bolt */
  .wyr-lightning {
    position: fixed;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 3px;
    transform: translateX(-50%);
    background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.9) 30%, rgba(255,255,255,0.7) 70%, transparent 100%);
    pointer-events: none;
    z-index: 2;
    box-shadow: 0 0 20px rgba(255,255,255,0.8), 0 0 40px rgba(255,255,255,0.4);
    animation: wyrLightningPulse 3s ease-in-out infinite;
  }
  @keyframes wyrLightningPulse {
    0%,100% { opacity: 0.5; box-shadow: 0 0 15px rgba(255,255,255,0.6), 0 0 30px rgba(255,255,255,0.3); }
    50%     { opacity: 1;   box-shadow: 0 0 30px rgba(255,255,255,1),   0 0 60px rgba(255,255,255,0.6); }
  }

  /* Red stars left side */
  .wyr-star-red {
    position: fixed;
    border-radius: 50%;
    background: #ef4444;
    pointer-events: none;
    z-index: 1;
    animation: wyrStarRed ease-in-out infinite alternate;
  }
  @keyframes wyrStarRed {
    from { opacity: 0.15; transform: scale(0.5); box-shadow: none; }
    to   { opacity: 0.9;  transform: scale(1.4); box-shadow: 0 0 10px #ef4444, 0 0 20px #ef4444; }
  }

  /* Blue stars right side */
  .wyr-star-blue {
    position: fixed;
    border-radius: 50%;
    background: #3b82f6;
    pointer-events: none;
    z-index: 1;
    animation: wyrStarBlue ease-in-out infinite alternate;
  }
  @keyframes wyrStarBlue {
    from { opacity: 0.15; transform: scale(0.5); box-shadow: none; }
    to   { opacity: 0.9;  transform: scale(1.4); box-shadow: 0 0 10px #3b82f6, 0 0 20px #3b82f6; }
  }

  /* Side glow panels */
  .wyr-glow-red {
    position: fixed;
    width: 350px; height: 600px;
    background: radial-gradient(circle, rgba(220,38,38,0.3) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
    left: -80px; top: 15%;
    animation: wyrGlowPulse 5s ease-in-out infinite alternate;
  }
  .wyr-glow-blue {
    position: fixed;
    width: 350px; height: 600px;
    background: radial-gradient(circle, rgba(37,99,235,0.3) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
    right: -80px; top: 15%;
    animation: wyrGlowPulse 5s ease-in-out infinite alternate;
    animation-delay: 1.5s;
  }
  @keyframes wyrGlowPulse {
    from { opacity: 0.6; }
    to   { opacity: 1; }
  }

  /* OR label */
  .wyr-or {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    font-size: 1.4rem;
    font-weight: 900;
    color: #fff;
    background: rgba(0,0,0,0.7);
    border: 2px solid rgba(255,255,255,0.4);
    border-radius: 50%;
    width: 52px; height: 52px;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
    z-index: 3;
    box-shadow: 0 0 20px rgba(255,255,255,0.3);
    animation: wyrOrPulse 4s ease-in-out infinite alternate;
  }
  @keyframes wyrOrPulse {
    from { box-shadow: 0 0 15px rgba(255,255,255,0.3); }
    to   { box-shadow: 0 0 30px rgba(255,255,255,0.7), 0 0 50px rgba(255,255,255,0.3); }
  }

  /* Side labels A / B */
  .wyr-label {
    position: fixed;
    top: 8%;
    font-size: 5rem;
    font-weight: 900;
    pointer-events: none;
    z-index: 1;
    opacity: 0.07;
    line-height: 1;
    animation: wyrLabelPulse 6s ease-in-out infinite alternate;
  }
  @keyframes wyrLabelPulse {
    from { opacity: 0.05; }
    to   { opacity: 0.12; }
  }

  /* Electric sparks at center */
  .wyr-spark {
    position: fixed;
    width: 2px;
    pointer-events: none;
    z-index: 2;
    background: #ffffff;
    animation: wyrSpark linear infinite;
    opacity: 0;
    transform-origin: bottom center;
  }
  @keyframes wyrSpark {
    0%   { opacity: 0; transform: rotate(var(--angle)) scaleY(0); }
    20%  { opacity: 1; transform: rotate(var(--angle)) scaleY(1); }
    80%  { opacity: 0.5; }
    100% { opacity: 0; transform: rotate(var(--angle)) scaleY(0.2); }
  }

  .wyr-content { position: relative; z-index: 10; }

  .wyr-title {
    background: linear-gradient(135deg, #ef4444 0%, #ffffff 45%, #3b82f6 100%);
    background-size: 250%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: wyrShimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 20px rgba(150,100,200,0.5));
  }
  @keyframes wyrShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .wyr-tag {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.85);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .wyr-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 1rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .wyr-card:hover {
    border-color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.08);
  }

  details.wyr-faq {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Would You Rather Wheel", url: "https://realwheelpicker.com/templates/would-you-rather-wheel" },
  ]} />

  <div class="wyr-page">
    <div class="wyr-sky"></div>
    <div class="wyr-lightning"></div>
    <div class="wyr-or">OR</div>
    <div class="wyr-glow-red"></div>
    <div class="wyr-glow-blue"></div>
    <div class="wyr-label" style="left:8%;color:#ef4444;">A</div>
    <div class="wyr-label" style="right:8%;color:#3b82f6;">B</div>

    <!-- Red stars — left side -->
    {[
      {l:"3%",t:"10%",s:4,dur:"1.8s",del:"0s"},{l:"8%",t:"28%",s:3,dur:"2.5s",del:"0.6s"},
      {l:"5%",t:"45%",s:5,dur:"2.1s",del:"1.2s"},{l:"12%",t:"60%",s:3,dur:"3.0s",del:"0.3s"},
      {l:"7%",t:"75%",s:4,dur:"1.9s",del:"1.7s"},{l:"18%",t:"18%",s:2,dur:"2.4s",del:"0.8s"},
      {l:"20%",t:"38%",s:4,dur:"2.7s",del:"0.1s"},{l:"15%",t:"55%",s:3,dur:"2.0s",del:"2.1s"},
      {l:"22%",t:"70%",s:2,dur:"1.6s",del:"1.4s"},{l:"10%",t:"85%",s:4,dur:"2.9s",del:"0.5s"},
      {l:"3%",t:"92%",s:3,dur:"2.2s",del:"1.9s"},{l:"25%",t:"88%",s:2,dur:"1.7s",del:"0.9s"},
      {l:"17%",t:"93%",s:4,dur:"2.6s",del:"2.3s"},{l:"6%",t:"33%",s:3,dur:"1.8s",del:"1.1s"},
      {l:"13%",t:"50%",s:2,dur:"3.1s",del:"0.2s"},
    ].map((st, i) => (
      <div class="wyr-star-red" style={`width:${st.s}px;height:${st.s}px;left:${st.l};top:${st.t};animation-duration:${st.dur};animation-delay:${st.del};`}></div>
    ))}

    <!-- Blue stars — right side -->
    {[
      {r:"3%",t:"10%",s:4,dur:"1.8s",del:"0.3s"},{r:"8%",t:"28%",s:3,dur:"2.5s",del:"0.9s"},
      {r:"5%",t:"45%",s:5,dur:"2.1s",del:"1.5s"},{r:"12%",t:"60%",s:3,dur:"3.0s",del:"0.6s"},
      {r:"7%",t:"75%",s:4,dur:"1.9s",del:"2.0s"},{r:"18%",t:"18%",s:2,dur:"2.4s",del:"1.1s"},
      {r:"20%",t:"38%",s:4,dur:"2.7s",del:"0.4s"},{r:"15%",t:"55%",s:3,dur:"2.0s",del:"2.4s"},
      {r:"22%",t:"70%",s:2,dur:"1.6s",del:"1.7s"},{r:"10%",t:"85%",s:4,dur:"2.9s",del:"0.8s"},
      {r:"3%",t:"92%",s:3,dur:"2.2s",del:"2.2s"},{r:"25%",t:"88%",s:2,dur:"1.7s",del:"1.2s"},
      {r:"17%",t:"93%",s:4,dur:"2.6s",del:"2.6s"},{r:"6%",t:"33%",s:3,dur:"1.8s",del:"1.4s"},
      {r:"13%",t:"50%",s:2,dur:"3.1s",del:"0.5s"},
    ].map((st, i) => (
      <div class="wyr-star-blue" style={`width:${st.s}px;height:${st.s}px;right:${st.r};top:${st.t};animation-duration:${st.dur};animation-delay:${st.del};`}></div>
    ))}

    <div class="wyr-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Would You Rather Wheel</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">⚡</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight wyr-title mb-3">
            Would You Rather Wheel
          </h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">
            Spin for would-you-rather dilemmas. No "it depends" allowed — commit to a choice.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="wyr-tag">🔴 Choice A</span>
            <span class="wyr-tag">🔵 Choice B</span>
            <span class="wyr-tag">🎉 Party Game</span>
            <span class="wyr-tag">🤝 Team Building</span>
          </div>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={wyrColors}
          wheelShape="hexagon"
          hubTheme="purple"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="wyr-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Why Would You Rather Works</h2>
          <p class="text-white/60 leading-relaxed">
            Forced-choice questions reveal personality in a way that open-ended questions don't. There's no "it depends" answer — you have to commit. This makes conversations more interesting, surprising, and revealing than typical small talk.
          </p>
          <p class="text-white/60 leading-relaxed">
            The wheel adds an element of randomness to which question gets asked, removing the awkwardness of one person always picking. Spin, answer, move on. Everyone gets an equal mix of easy and challenging dilemmas.
          </p>
        </div>

        <div class="wyr-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">For Team Building</h2>
          <p class="text-white/60 leading-relaxed">
            Use would-you-rather questions in meetings, onboarding sessions, or team retreats. Light, low-stakes dilemmas get people talking and reveal values in a fun way. After each answer, ask one follow-up: "Why?" — that's where the real conversation starts.
          </p>
        </div>

        <div class="wyr-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Escalating Difficulty</h2>
          <div class="space-y-3">
            <div class="p-4 rounded-lg" style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);">
              <p class="font-semibold text-white text-sm mb-1">Light</p>
              <p class="text-white/60 text-sm">Would you rather have unlimited coffee or unlimited pizza?</p>
            </div>
            <div class="p-4 rounded-lg" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.15);">
              <p class="font-semibold text-white text-sm mb-1">Deeper</p>
              <p class="text-white/60 text-sm">Would you rather always tell the truth or always lie?</p>
            </div>
            <div class="p-4 rounded-lg" style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);">
              <p class="font-semibold text-white text-sm mb-1">Philosophical</p>
              <p class="text-white/60 text-sm">Would you rather be remembered after death or have amnesia but be happy now?</p>
            </div>
          </div>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="wyr-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/templates/truth-or-dare-wheel", label: "🎭 Truth or Dare Wheel", desc: "Party prompts for any group." },
              { href: "/templates/icebreaker-wheel", label: "💬 Icebreaker Wheel", desc: "Random questions for teams and meetings." },
              { href: "/party-wheel", label: "🎉 Party Wheel", desc: "Pre-loaded with party games and activities." },
              { href: "/templates", label: "🎡 All Templates", desc: "Browse all pre-loaded wheel templates." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="wyr-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
