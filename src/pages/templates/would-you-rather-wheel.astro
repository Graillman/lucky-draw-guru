---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Would You Rather Wheel — Random Dilemma Spinner";
const description = "Spin for would-you-rather questions. Pre-loaded with 8 fun dilemmas for parties, teams, and games.";
const canonical = "/templates/would-you-rather-wheel";

const faqItems = [
  {
    question: "Can I add my own dilemmas?",
    answer: "Yes — replace any option with your own would-you-rather question. The wheel can hold any number of dilemmas.",
  },
  {
    question: "What's the ideal group size?",
    answer: "3-10 people. Larger groups work if you give everyone time to answer each question.",
  },
  {
    question: "Are there kid-friendly versions?",
    answer: "Keep questions age-appropriate: Would you rather be a superhero or a wizard? Have a pet dragon or pet dinosaur?",
  },
];

const defaultParticipants = [
  { pseudo: "Fly or Invisible?", weight: 1 },
  { pseudo: "Time travel: Past or Future?", weight: 1 },
  { pseudo: "No internet or No AC?", weight: 1 },
  { pseudo: "Read minds or See future?", weight: 1 },
  { pseudo: "Rich or Famous?", weight: 1 },
  { pseudo: "City or Country?", weight: 1 },
  { pseudo: "Always hot or Always cold?", weight: 1 },
  { pseudo: "No music or No movies?", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/would-you-rather-wheel",
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Would You Rather Wheel", url: "https://realwheelpicker.com/templates/would-you-rather-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Would You Rather Wheel</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Would You Rather Wheel — Random Dilemma Spinner
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Spin for would-you-rather questions. Pre-loaded with dilemmas for parties, teams, and games. No "it depends" allowed.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- Wheel -->
      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <!-- Article Content -->
      <section class="space-y-8">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Why Would You Rather Works</h2>
          <p class="text-muted-foreground leading-relaxed">
            Forced-choice questions reveal personality in a way that open-ended questions don't. There's no "it depends" answer — you have to commit. This makes conversations more interesting, surprising, and revealing than typical small talk.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The wheel adds an element of randomness to which question gets asked, removing the awkwardness of one person always picking the questions. Spin, answer, move on. Everyone gets an equal mix of easy and challenging dilemmas.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">For Team Building</h2>
          <p class="text-muted-foreground leading-relaxed">
            Use would-you-rather questions in meetings, onboarding sessions, or team retreats. Light, low-stakes dilemmas get people talking and reveal values in a fun way. After each answer, ask one follow-up: "Why?" That's where the real conversation starts.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            A would-you-rather session at the start of a meeting takes 5 minutes and does more for team cohesion than a formal icebreaker exercise. People remember what their colleagues said for weeks.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Escalating Difficulty</h2>
          <div class="space-y-3">
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Light</p>
              <p class="text-muted-foreground text-sm">Would you rather have unlimited coffee or unlimited pizza?</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Deeper</p>
              <p class="text-muted-foreground text-sm">Would you rather always tell the truth or always lie?</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Philosophical</p>
              <p class="text-muted-foreground text-sm">Would you rather be remembered after death or have amnesia but be happy now?</p>
            </div>
          </div>
        </div>

      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/truth-or-dare-wheel", label: "Truth or Dare Wheel", desc: "Party prompts for any group." },
            { href: "/templates/icebreaker-wheel", label: "Icebreaker Wheel", desc: "Random questions for teams and meetings." },
            { href: "/party-wheel", label: "Party Wheel", desc: "Pre-loaded with party games and activities." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
