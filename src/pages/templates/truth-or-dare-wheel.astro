---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Truth or Dare Wheel — Free Spinner for Parties";
const description = "Spin the truth or dare wheel to pick your next challenge. Pre-loaded with 20 prompts. Perfect for parties, sleepovers, and game nights. Free, instant.";
const canonical = "/templates/truth-or-dare-wheel";

const faqItems = [
  {
    question: "Can I add my own truth or dare prompts?",
    answer: "Yes — edit the wheel entries to add whatever prompts you want. The pre-loaded list is a starting point. You can customize it for your group's humor and comfort level.",
  },
  {
    question: "How many players can play?",
    answer: "No limit. For large groups (10+), consider adding player names to a separate wheel to pick who goes next, then spin this wheel for truth or dare.",
  },
  {
    question: "Is there a kids' version?",
    answer: "Make it kid-friendly by customizing the prompts. Remove anything inappropriate and add fun, age-appropriate challenges like 'Do your best animal impression' or 'Tell us a joke'.",
  },
];

const defaultParticipants = [
  { pseudo: "Truth: Most embarrassing moment?", weight: 1 },
  { pseudo: "Dare: Do 10 push-ups", weight: 1 },
  { pseudo: "Truth: Last lie you told?", weight: 1 },
  { pseudo: "Dare: Sing the chorus of a song", weight: 1 },
  { pseudo: "Truth: Biggest fear?", weight: 1 },
  { pseudo: "Dare: Let someone post on your social media", weight: 1 },
  { pseudo: "Truth: Secret crush?", weight: 1 },
  { pseudo: "Dare: Call someone and compliment them", weight: 1 },
  { pseudo: "Truth: Worst date ever?", weight: 1 },
  { pseudo: "Dare: Talk in an accent for 3 rounds", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/truth-or-dare-wheel",
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Truth or Dare Wheel", url: "https://realwheelpicker.com/templates/truth-or-dare-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Truth or Dare Wheel</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Truth or Dare Wheel — Free Spinner for Parties
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Spin the wheel and let fate pick your truth or dare. Pre-loaded with prompts for any group. Customize for your crew.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- Wheel -->
      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <!-- Article Content -->
      <section class="space-y-8">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Play Truth or Dare with a Spinner Wheel</h2>
          <p class="text-muted-foreground leading-relaxed">
            Truth or dare is simple but the decision of who goes and what they get is where arguments start. The wheel eliminates both problems: spin once for who, spin again for truth or dare.
          </p>
          <p class="text-muted-foreground leading-relaxed font-semibold">Classic Rules:</p>
          <ol class="space-y-2 text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span><span>Everyone sits in a circle (or joins a video call).</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span><span>Spin the wheel to get a truth or dare prompt.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span><span>The player must complete it or face a double dare penalty.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">4.</span><span>Play continues until someone quits or everyone's had enough.</span></li>
          </ol>
          <p class="text-muted-foreground leading-relaxed">
            The wheel removes the social awkwardness of choosing: nobody picks on anyone, the spinner decides. This matters especially in mixed groups where some players are bolder than others. The random selection keeps the game balanced and keeps the energy moving.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            You can run two wheels simultaneously — one with player names, one with truth or dare prompts — for fully randomized rounds. Spin the name wheel to pick who goes next, then spin this wheel for the prompt. No arguments, no targeting, no hesitation.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Making It Better</h2>
          <p class="text-muted-foreground leading-relaxed">
            The pre-loaded prompts above are starting points. The best truth or dare games use custom prompts tailored to your group. Add inside jokes, group-specific challenges, and escalating difficulty. A wheel with generic prompts gets stale. A wheel built around your friend group gets legendary.
          </p>
          <p class="text-muted-foreground leading-relaxed font-semibold">Suggested prompt difficulty tiers:</p>
          <div class="space-y-3">
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Mild (early game)</p>
              <p class="text-muted-foreground text-sm">"What's your most-used emoji?" / "Do a silly dance for 10 seconds"</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Medium (warmed up)</p>
              <p class="text-muted-foreground text-sm">"Read your last sent text aloud" / "Let the group pick your profile picture for 24 hours"</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Spicy (late game)</p>
              <p class="text-muted-foreground text-sm">"Confess something nobody here knows" / "Call your mom and tell her you love her right now"</p>
            </div>
          </div>
          <p class="text-muted-foreground leading-relaxed">
            Start mild and escalate as the game progresses. This pacing keeps the energy building instead of peaking early. The wheel handles prompt selection automatically — your only job is writing good prompts up front.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Digital Truth or Dare</h2>
          <p class="text-muted-foreground leading-relaxed">
            Playing over Discord, Zoom, or FaceTime? The wheel works perfectly on screen share. One person controls the spinner while everyone watches. The visual anticipation — the wheel slowing down, the pointer clicking through segments — makes it more engaging than just texting "truth or dare?"
          </p>
          <p class="text-muted-foreground leading-relaxed">
            For remote groups, assign one person as the "host" who manages the wheel and keeps the game moving. The host spins for each round and the selected player completes the prompt on camera. Discord video calls work especially well because reactions are visible in real time.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            You can also share the link directly in chat — everyone has access to the same wheel. On mobile, the wheel is touch-optimized. Swipe or tap to spin on any smartphone.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Party Host Tips</h2>
          <p class="text-muted-foreground leading-relaxed">
            Start mild and escalate — don't open with the embarrassing stuff. The best party games warm up slowly, build trust, and then go somewhere memorable. Opening with "confess your deepest secret" kills the energy before it starts.
          </p>
          <ul class="space-y-2 text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span>Always allow a "pass" option with a penalty (like doing 20 jumping jacks). Forced participation ruins the fun.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span>Have a backup list of prompts ready for when creativity runs dry. The wheel removes the feeling of being "targeted" — it's random, not personal.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span>For mixed-comfort groups, create two wheels: one safe, one spicy. Players declare their tier before spinning.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span>Time-limit dares. "Talk in an accent for 3 rounds" is fun. Indefinite tasks drag the game down.</span></li>
          </ul>
          <p class="text-muted-foreground leading-relaxed">
            The wheel handles the selection. You handle the vibe. Keep it moving, keep it fun, and don't let any single player stall the game indefinitely.
          </p>
        </div>

      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/party-wheel", label: "Party Wheel", desc: "More party challenges and game night fun — spin for random dares and tasks." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random player name from your group to decide who goes next." },
            { href: "/yes-or-no-wheel", label: "Yes or No Wheel", desc: "Settle quick arguments with a yes/no spin." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
