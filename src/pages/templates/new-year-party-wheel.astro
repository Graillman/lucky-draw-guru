---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "New Year Party Wheel — Random NYE Activities & Games";
const description = "Plan the perfect New Year's Eve party with random activity picks. Spin for games, toasts, countdowns, and party activities. Pre-loaded with 10 NYE ideas.";
const canonical = "/templates/new-year-party-wheel";

const faqItems = [
  {
    question: "How do we use this during the party?",
    answer: "Keep the wheel open on a TV or laptop visible to guests. Every 20-30 minutes, spin for the next activity. It keeps the party moving without anyone having to hard-sell an activity to the group. The wheel takes the social risk out of suggesting something.",
  },
  {
    question: "What activities work best for mixed groups?",
    answer: "Countdown trivia, year-in-review game, resolution sharing, and dance-off are crowd-pleasers across age groups. Avoid anything too competitive if your group includes a wide range of ages. Customize the wheel to fit who's coming.",
  },
  {
    question: "Can I use this for a small NYE gathering?",
    answer: "Yes. For small groups (2-6 people), activities like resolution sharing, movie night, board games, and countdown trivia work well. Remove anything that needs a large group and add more intimate activities.",
  },
];

const defaultParticipants = [
  { pseudo: "Countdown trivia", weight: 1 },
  { pseudo: "Resolution sharing", weight: 1 },
  { pseudo: "Dance-off", weight: 1 },
  { pseudo: "Year-in-review game", weight: 1 },
  { pseudo: "Toast & champagne", weight: 1 },
  { pseudo: "Karaoke round", weight: 1 },
  { pseudo: "Party games", weight: 1 },
  { pseudo: "Midnight wish ritual", weight: 1 },
  { pseudo: "Photo booth session", weight: 1 },
  { pseudo: "Predictions for next year", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/new-year-party-wheel",
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "New Year Party Wheel", url: "https://realwheelpicker.com/templates/new-year-party-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">New Year Party Wheel</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          New Year Party Wheel — Random NYE Activities
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Keep your New Year's Eve party moving with random activity picks. Customize the wheel for your group, then spin throughout the night for what's next.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <section class="space-y-8">
        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Keep the Party Moving All Night</h2>
          <p class="text-muted-foreground leading-relaxed">
            NYE parties have a predictable problem: they start strong, hit a slow patch around 10pm, and either recover for midnight or don't. The slow patch happens when nobody wants to propose the next thing — suggesting an activity as the host feels forced, and guests don't want to seem demanding.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The wheel solves this without anyone losing face. "Let's spin the wheel" is a neutral, fun way to transition between activities. Everyone agreed the options are on the wheel, so there's no pushback on whatever it lands on. Project it on a TV during the party and make spinning part of the event.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/dare-wheel", label: "Dare Wheel", desc: "Party dares to keep things interesting after midnight." },
            { href: "/templates/never-have-i-ever-wheel", label: "Never Have I Ever Wheel", desc: "Classic party game for any NYE gathering." },
            { href: "/templates/new-years-resolution-wheel", label: "New Year's Resolution Wheel", desc: "Spin for a random resolution to commit to." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:load />
  </div>
</Layout>
