---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Dessert Picker Wheel — Random Sweet Treat Spinner";
const description = "Spin the dessert wheel for a random sweet treat. 12 options from ice cream to tiramisu. Perfect for restaurants, home baking, and dessert debates. Free.";
const canonical = "/templates/dessert-picker";

const faqItems = [
  {
    question: "Can I use this at a restaurant to pick dessert?",
    answer: "Yes — load the wheel with items from the actual dessert menu, spin, and order whatever lands. It removes the guilt of 'should I really get dessert?' and makes it fate's decision instead.",
  },
  {
    question: "What if I don't know how to make the dessert I land on?",
    answer: "Treat it as a baking adventure. Landing on Crème Brûlée and attempting it at home for the first time is more memorable than getting your usual brownie. The wheel pushes you toward new skills.",
  },
  {
    question: "How do I make the wheel kid-friendly?",
    answer: "Replace sophisticated options like Tiramisu with kid favorites: Brownie, Ice Cream Sundae, Cupcake, Pudding, Jello. Customize it for whoever is spinning.",
  },
];

const defaultParticipants = [
  { pseudo: "Ice Cream", weight: 1 },
  { pseudo: "Cake", weight: 1 },
  { pseudo: "Cookies", weight: 1 },
  { pseudo: "Brownie", weight: 1 },
  { pseudo: "Pie", weight: 1 },
  { pseudo: "Cheesecake", weight: 1 },
  { pseudo: "Crème Brûlée", weight: 1 },
  { pseudo: "Tiramisu", weight: 1 },
  { pseudo: "Churros", weight: 1 },
  { pseudo: "Mochi", weight: 1 },
  { pseudo: "Waffles", weight: 1 },
  { pseudo: "Fruit Tart", weight: 1 },
];

const themeColors = ['#ff80ab','#f48fb1','#ce93d8','#80cbc4','#ffcc80','#ef9a9a','#c5e1a5','#80deea','#f8bbd9','#b2dfdb'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/dessert-picker",
};
---

<style>
  /* ═══ CANDY SHOP — SPRINKLES, PASTELS, ÉTOILES SUCRÉES ═══ */
  .ds-page {
    background: #0a0008;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Fond sucré pastel */
  .ds-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 15% 10%, rgba(255,100,180,0.18) 0%, transparent 65%),
      radial-gradient(ellipse 55% 45% at 85% 15%, rgba(180,100,220,0.15) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 50% 90%, rgba(100,200,190,0.12) 0%, transparent 60%),
      linear-gradient(180deg, #0a0008 0%, #0d0010 50%, #0a0008 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Halos pastels */
  .ds-halo-pink {
    position: fixed;
    left: -80px;
    top: 10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255,100,180,0.16) 0%, transparent 70%);
    filter: blur(70px);
    z-index: 0;
    pointer-events: none;
    animation: dsHaloPulse 8s ease-in-out infinite alternate;
  }
  .ds-halo-lavender {
    position: fixed;
    right: -100px;
    top: 20%;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(180,100,220,0.14) 0%, transparent 70%);
    filter: blur(80px);
    z-index: 0;
    pointer-events: none;
    animation: dsHaloPulse 10s ease-in-out infinite alternate;
    animation-delay: 3s;
  }
  .ds-halo-mint {
    position: fixed;
    bottom: -80px;
    left: 25%;
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(80,200,180,0.12) 0%, transparent 70%);
    filter: blur(90px);
    z-index: 0;
    pointer-events: none;
    animation: dsHaloPulse 12s ease-in-out infinite alternate;
    animation-delay: 5s;
  }
  @keyframes dsHaloPulse {
    from { opacity: 0.45; transform: scale(0.9); }
    to   { opacity: 0.9;  transform: scale(1.1); }
  }

  /* Rayures candy cane décoratives */
  .ds-stripes {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.025;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 28px,
      rgba(255,120,180,0.6) 28px,
      rgba(255,120,180,0.6) 30px
    );
    animation: dsStripesDrift 25s linear infinite;
  }
  @keyframes dsStripesDrift {
    0%   { background-position: 0 0; }
    100% { background-position: 60px 60px; }
  }

  /* Sprinkles tombants */
  .ds-sprinkle {
    position: fixed;
    top: -20px;
    pointer-events: none;
    z-index: 2;
    width: var(--sw, 4px);
    height: var(--sh, 12px);
    border-radius: 3px;
    background: var(--scolor, #ff88cc);
    opacity: 0;
    animation: dsSprinkleFall var(--sdur, 7s) linear infinite;
    animation-delay: var(--sdelay, 0s);
    left: var(--sleft, 50%);
    transform: rotate(var(--srot, 30deg));
  }
  @keyframes dsSprinkleFall {
    0%   { transform: translateY(-20px) rotate(var(--srot, 30deg)); opacity: 0; }
    5%   { opacity: 0.9; }
    95%  { opacity: 0.6; }
    100% { transform: translateY(115vh) rotate(calc(var(--srot, 30deg) + 540deg)); opacity: 0; }
  }

  /* Étoiles sucrées scintillantes */
  .ds-star {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    font-size: var(--stsize, 14px);
    color: var(--stcolor, #ffbbee);
    opacity: 0;
    animation: dsStarTwinkle var(--stdur, 3s) ease-in-out infinite;
    animation-delay: var(--stdelay, 0s);
    left: var(--stleft, 50%);
    top: var(--sttop, 50%);
    filter: drop-shadow(0 0 6px var(--stcolor, #ffbbee));
  }
  @keyframes dsStarTwinkle {
    0%,100% { opacity: 0; transform: scale(0.5) rotate(0deg); }
    20%     { opacity: 0.3; }
    50%     { opacity: 1; transform: scale(1.5) rotate(20deg); }
    80%     { opacity: 0.4; transform: scale(1.1) rotate(10deg); }
  }

  /* Bulles de sucre */
  .ds-sugar-bubble {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    border-radius: 50%;
    border: 1px solid var(--sbcolor, rgba(255,150,200,0.4));
    background: rgba(255,200,230,0.06);
    opacity: 0;
    animation: dsSugarBubble var(--sbdur, 8s) ease-in infinite;
    animation-delay: var(--sbdelay, 0s);
    left: var(--sbleft, 50%);
    bottom: -30px;
    width: var(--sbw, 20px);
    height: var(--sbw, 20px);
  }
  @keyframes dsSugarBubble {
    0%   { transform: translateY(0) translateX(0px); opacity: 0; }
    8%   { opacity: 0.6; }
    50%  { transform: translateY(-45vh) translateX(12px); opacity: 0.4; }
    90%  { opacity: 0.1; }
    100% { transform: translateY(-95vh) translateX(-8px); opacity: 0; }
  }

  /* Emoji desserts tombants */
  .ds-emoji {
    position: fixed;
    top: -50px;
    pointer-events: none;
    z-index: 2;
    font-size: var(--esize, 20px);
    opacity: 0;
    animation: dsEmojiFall var(--edur, 12s) linear infinite;
    animation-delay: var(--edelay, 0s);
    left: var(--eleft, 50%);
  }
  @keyframes dsEmojiFall {
    0%   { transform: translateY(-50px) rotate(0deg); opacity: 0; }
    6%   { opacity: 0.8; }
    94%  { opacity: 0.5; }
    100% { transform: translateY(115vh) rotate(360deg); opacity: 0; }
  }

  /* Lueur glacée du bas */
  .ds-bottom-glow {
    position: fixed;
    bottom: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 300px;
    background: radial-gradient(ellipse at 50% 100%, rgba(255,140,200,0.14) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
    animation: dsBottomGlow 7s ease-in-out infinite alternate;
  }
  @keyframes dsBottomGlow {
    from { opacity: 0.5; transform: translateX(-50%) scaleX(0.9); }
    to   { opacity: 1;   transform: translateX(-50%) scaleX(1.1); }
  }

  /* Contenu */
  .ds-content { position: relative; z-index: 10; }

  /* Titre gradient pastel */
  .ds-title {
    background: linear-gradient(135deg, #ff80ab 0%, #ce93d8 25%, #80deea 50%, #ffcc80 75%, #ff80ab 100%);
    background-size: 250%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: dsShimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 25px rgba(255,100,180,0.45));
  }
  @keyframes dsShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .ds-tag {
    background: rgba(160,40,120,0.2);
    border: 1px solid rgba(220,100,180,0.4);
    color: rgba(255,190,230,0.95);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .ds-card {
    background: rgba(18,3,15,0.82);
    border: 1px solid rgba(220,100,180,0.22);
    border-radius: 1rem;
    backdrop-filter: blur(12px);
    transition: border-color 0.2s, background 0.2s;
  }
  .ds-card:hover {
    border-color: rgba(255,140,200,0.45);
    background: rgba(25,5,20,0.88);
  }

  details.ds-faq {
    background: rgba(12,2,10,0.82);
    border: 1px solid rgba(200,80,160,0.22);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Dessert Picker Wheel", url: "https://realwheelpicker.com/templates/dessert-picker" },
  ]} />

  <div class="ds-page">
    <div class="ds-sky"></div>
    <div class="ds-halo-pink"></div>
    <div class="ds-halo-lavender"></div>
    <div class="ds-halo-mint"></div>
    <div class="ds-stripes"></div>
    <div class="ds-bottom-glow"></div>

    <!-- 30 sprinkles tombants -->
    {Array.from({length: 30}).map((_, i) => (
      <div class="ds-sprinkle" style={`--sleft:${(i*33+5)%100}%;--sdur:${5+((i*2)%6)}s;--sdelay:-${(i*1.3)%10}s;--sw:${3+((i*2)%4)}px;--sh:${8+((i*3)%8)}px;--srot:${(i*37)%180}deg;--scolor:${['#ff88cc','#88ddcc','#ffcc88','#cc88ff','#88ccff','#ffaadd','#aaffcc'][i%7]}`}></div>
    ))}

    <!-- 20 étoiles sucrées -->
    {Array.from({length: 20}).map((_, i) => (
      <div class="ds-star" style={`--stleft:${(i*47+9)%100}%;--sttop:${(i*23+5)%85}%;--stdur:${2+((i*3)%4)}s;--stdelay:-${(i*1.7)%6}s;--stsize:${10+((i*4)%14)}px;--stcolor:${['#ffddee','#ccffee','#ffeedd','#ddccff','#eeffcc'][i%5]}`}>★</div>
    ))}

    <!-- 15 bulles de sucre -->
    {Array.from({length: 15}).map((_, i) => (
      <div class="ds-sugar-bubble" style={`--sbleft:${(i*67+11)%100}%;--sbdur:${7+((i*3)%6)}s;--sbdelay:-${(i*2.1)%10}s;--sbw:${14+((i*4)%20)}px;--sbcolor:${i%3===0?'rgba(255,150,200,0.4)':i%3===1?'rgba(180,120,220,0.4)':'rgba(100,210,200,0.4)'}`}></div>
    ))}

    <!-- 10 emoji desserts tombants -->
    {['🍰','🧁','🍭','🍬','🍫','🍩','🍪','🎂','🍮','🧇'].map((emoji, i) => (
      <div class="ds-emoji" style={`--eleft:${(i*97+7)%95}%;--edur:${10+((i*4)%8)}s;--edelay:-${(i*2.3)%12}s;--esize:${16+((i*3)%12)}px`}>{emoji}</div>
    ))}

    <div class="ds-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Dessert Picker Wheel</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">🍭</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight ds-title mb-3">
            Dessert Picker Wheel
          </h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">
            Can't choose between cheesecake and tiramisu? Let the dessert wheel decide. Spin for your sweet fate — no guilt, just delicious randomness.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="ds-tag">Sweets</span>
            <span class="ds-tag">Desserts</span>
            <span class="ds-tag">Candy Shop</span>
            <span class="ds-tag">Treats</span>
          </div>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={themeColors}
          wheelShape="circle"
          hubTheme="rose"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="ds-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">The Case for Random Dessert Selection</h2>
          <p class="text-white/60 leading-relaxed">
            Dessert decisions have a unique psychological trap: you want to try something new, but you keep ordering the same thing because it's safe. The dessert wheel breaks that cycle by removing the safety option from your hands. Whatever the wheel picks, that's what you're having.
          </p>
          <p class="text-white/60 leading-relaxed">
            This is especially powerful when baking at home. Instead of defaulting to brownies every weekend, spin for your next baking project. You might discover that making a fruit tart from scratch is both easier and more impressive than expected.
          </p>
          <p class="text-white/60 leading-relaxed">
            For families with kids, the dessert wheel becomes a ritual. Friday night dessert is whatever the wheel picks. Kids love the anticipation of the spin, and parents enjoy not being asked "can we have ice cream?" for the thousandth time.
          </p>
        </div>

        <div class="ds-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Dessert Night Ideas</h2>
          <p class="text-white/60 leading-relaxed">Use the dessert wheel to run a themed dessert night with friends or family:</p>
          <div class="grid sm:grid-cols-2 gap-3">
            <div class="ds-card p-4">
              <p class="text-pink-300 font-semibold text-sm mb-1">Bake-off</p>
              <p class="text-white/55 text-sm">Everyone spins, each person makes their result. Compare and taste-test at the end of the night.</p>
            </div>
            <div class="ds-card p-4">
              <p class="text-cyan-300 font-semibold text-sm mb-1">Restaurant Roulette</p>
              <p class="text-white/55 text-sm">Research which local spot does each dessert best, then visit based on your spin.</p>
            </div>
            <div class="ds-card p-4">
              <p class="text-purple-300 font-semibold text-sm mb-1">International Tour</p>
              <p class="text-white/55 text-sm">Load the wheel with desserts from different countries and make one per week.</p>
            </div>
            <div class="ds-card p-4">
              <p class="text-amber-300 font-semibold text-sm mb-1">Dessert Exchange</p>
              <p class="text-white/55 text-sm">Each person spins and brings that dessert to a group gathering.</p>
            </div>
          </div>
        </div>

        <div class="ds-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Customizing Your Dessert Wheel</h2>
          <p class="text-white/60 leading-relaxed">
            The default 12 options cover a wide range from simple to ambitious. Tailor it to your context: add your city's best specialty desserts, remove anything you're allergic to, or create themed versions — a "summer wheel" with ice cream, sorbet, and fruit-based desserts, or a "chocolate only" wheel for true chocoholics.
          </p>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="ds-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/templates/lunch-spinner", label: "Lunch Spinner", desc: "Decide what to eat for lunch before worrying about dessert." },
              { href: "/templates/restaurant-picker", label: "Restaurant Picker", desc: "Pick where to go for your full meal, dessert included." },
              { href: "/templates/what-to-eat-wheel", label: "What to Eat Wheel", desc: "General meal idea spinner for any time of day." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="ds-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
