---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Valentine's Day Idea Wheel — Random Date & Gift Ideas";
const description = "Spin for a random Valentine's Day idea. Pre-loaded with 10 date night and gift ideas for couples. Works for planning dates, activities, and surprises.";
const canonical = "/templates/valentines-day-wheel";

const faqItems = [
  {
    question: "What if we both want to spin to decide?",
    answer: "Load the wheel together with date ideas you've both agreed are acceptable. Each idea on the wheel is one you'd both enjoy — the spin just picks which one you do. Removing the negotiation is the whole point.",
  },
  {
    question: "Is this good for long-distance couples?",
    answer: "Yes. Add remote-friendly options: virtual movie night, online cooking class together, care package theme, video call dinner. Customize the wheel for what's actually possible in your situation.",
  },
  {
    question: "What are good last-minute Valentine's Day ideas?",
    answer: "Cooking a nice dinner at home, a movie marathon with their favorite films, handwritten letter with their favorite snacks, a walk to a meaningful place, or recreating your first date. All achievable same-day.",
  },
];

const defaultParticipants = [
  { pseudo: "💑 Fancy dinner out",      weight: 1 },
  { pseudo: "🍳 Cook together",         weight: 1 },
  { pseudo: "🎬 Movie marathon",        weight: 1 },
  { pseudo: "✈️ Weekend getaway",       weight: 1 },
  { pseudo: "💆 Spa day",               weight: 1 },
  { pseudo: "🧺 Picnic in the park",   weight: 1 },
  { pseudo: "👨‍🍳 Cooking class",         weight: 1 },
  { pseudo: "🌅 Sunset hike",           weight: 1 },
  { pseudo: "🎲 Board game night",      weight: 1 },
  { pseudo: "☕ Surprise breakfast",    weight: 1 },
];

const valColors = ['#ff006e','#ff85c1','#c77dff','#ff4d8e','#e040fb','#f48fb1','#ce93d8','#ff80ab','#ea80fc','#ff6090'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/valentines-day-wheel",
};
---

<style>
  /* ═══════════ VALENTINE'S DAY — FULL IMMERSIVE THEME ═══════════ */
  .val-page {
    background: #12000e;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Deep rose sky */
  .val-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 90% 70% at 15% -10%, rgba(255,0,110,0.4) 0%, transparent 55%),
      radial-gradient(ellipse 70% 60% at 85% -5%,  rgba(200,0,200,0.28) 0%, transparent 55%),
      radial-gradient(ellipse 60% 50% at 50% 105%, rgba(180,0,80,0.35) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 50% 50%,  rgba(255,0,110,0.08) 0%, transparent 60%),
      linear-gradient(180deg, #12000e 0%, #22001a 50%, #12000e 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Cupid glow orbs */
  .cupid-glow {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
    animation: cupidPulse ease-in-out infinite alternate;
  }
  @keyframes cupidPulse {
    from { opacity: 0.3; transform: scale(0.9); }
    to   { opacity: 0.7; transform: scale(1.1); }
  }

  /* Floating hearts — 30 of them */
  .heart {
    position: fixed;
    pointer-events: none;
    z-index: 1;
    animation: heartRise ease-in-out infinite;
    opacity: 0;
    line-height: 1;
    user-select: none;
  }
  @keyframes heartRise {
    0%   { transform: translateY(110vh) translateX(0) rotate(-10deg); opacity: 0; }
    5%   { opacity: 0.9; }
    50%  { transform: translateY(50vh) translateX(20px) rotate(10deg); opacity: 0.7; }
    95%  { opacity: 0.4; }
    100% { transform: translateY(-10vh) translateX(-10px) rotate(-5deg); opacity: 0; }
  }

  /* Rose petals */
  .petal {
    position: fixed;
    width: 9px; height: 13px;
    border-radius: 50% 50% 50% 0;
    pointer-events: none;
    z-index: 1;
    animation: petalFall linear infinite;
    opacity: 0;
  }
  @keyframes petalFall {
    0%   { transform: translateY(-20px) rotate(0deg); opacity: 0; }
    8%   { opacity: 0.8; }
    92%  { opacity: 0.45; }
    100% { transform: translateY(110vh) rotate(400deg); opacity: 0; }
  }

  /* Sparkle stars */
  .val-sparkle {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    animation: sparkleTwinkle ease-in-out infinite alternate;
  }
  @keyframes sparkleTwinkle {
    from { opacity: 0.05; transform: scale(0.4); box-shadow: none; }
    to   { opacity: 1;    transform: scale(1.4); box-shadow: 0 0 12px currentColor, 0 0 24px currentColor; }
  }

  /* Shooting star */
  .shooting-star {
    position: fixed;
    height: 2px;
    background: linear-gradient(90deg, transparent, #ff85c1, transparent);
    pointer-events: none;
    z-index: 1;
    border-radius: 2px;
    animation: shootingStar linear infinite;
    opacity: 0;
  }
  @keyframes shootingStar {
    0%   { transform: translateX(-200px) translateY(0) rotate(-30deg); opacity: 0; }
    5%   { opacity: 0.9; }
    40%  { opacity: 0.6; }
    100% { transform: translateX(110vw) translateY(-100px) rotate(-30deg); opacity: 0; }
  }

  /* Ribbon wave at bottom */
  .val-ribbon {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(180deg, transparent 0%, rgba(255,0,110,0.12) 100%);
    pointer-events: none;
    z-index: 1;
    animation: ribbonPulse 4s ease-in-out infinite alternate;
  }
  @keyframes ribbonPulse {
    from { opacity: 0.5; }
    to   { opacity: 1; }
  }

  /* Content layer */
  .val-content { position: relative; z-index: 10; }

  /* Title */
  .val-title {
    background: linear-gradient(135deg, #ff85c1 0%, #ff006e 35%, #e040fb 65%, #ff85c1 100%);
    background-size: 250%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: valShimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 30px rgba(255,0,110,0.5));
  }
  @keyframes valShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .val-tag {
    background: rgba(255,100,160,0.15);
    border: 1px solid rgba(255,100,160,0.4);
    color: rgba(255,160,200,0.95);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .val-card {
    background: rgba(255,0,110,0.06);
    border: 1px solid rgba(255,100,160,0.2);
    border-radius: 1rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .val-card:hover {
    border-color: rgba(255,100,160,0.55);
    background: rgba(255,0,110,0.12);
  }
  details.val-faq {
    background: rgba(255,0,110,0.05);
    border: 1px solid rgba(255,100,160,0.18);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Valentine's Day Idea Wheel", url: "https://realwheelpicker.com/templates/valentines-day-wheel" },
  ]} />

  <div class="val-page">
    <div class="val-sky"></div>

    <!-- Cupid glow pools -->
    <div class="cupid-glow" style="width:600px;height:500px;background:radial-gradient(circle,rgba(255,0,110,0.35) 0%,transparent 70%);top:-150px;left:-100px;animation-duration:5s;"></div>
    <div class="cupid-glow" style="width:500px;height:450px;background:radial-gradient(circle,rgba(200,0,200,0.25) 0%,transparent 70%);top:-100px;right:-80px;animation-duration:7s;animation-delay:1s;"></div>
    <div class="cupid-glow" style="width:400px;height:350px;background:radial-gradient(circle,rgba(255,0,110,0.2) 0%,transparent 70%);bottom:10%;left:50%;transform:translateX(-50%);animation-duration:6s;animation-delay:2s;"></div>

    <!-- Floating hearts — 30 -->
    {[
      {l:"3%",fs:"1.5rem",dur:"9s",del:"0s",e:"❤️"},{l:"8%",fs:"0.9rem",dur:"11s",del:"2s",e:"🩷"},
      {l:"14%",fs:"2rem",dur:"13s",del:"1s",e:"💕"},{l:"20%",fs:"1.1rem",dur:"8s",del:"3s",e:"💗"},
      {l:"27%",fs:"0.8rem",dur:"12s",del:"0.5s",e:"💖"},{l:"33%",fs:"1.6rem",dur:"10s",del:"4s",e:"💝"},
      {l:"40%",fs:"1rem",dur:"9s",del:"1.5s",e:"❤️"},{l:"47%",fs:"1.3rem",dur:"14s",del:"5s",e:"💞"},
      {l:"54%",fs:"0.7rem",dur:"11s",del:"2.5s",e:"🩷"},{l:"60%",fs:"1.8rem",dur:"8s",del:"0.8s",e:"💕"},
      {l:"67%",fs:"1.2rem",dur:"10s",del:"3.5s",e:"💗"},{l:"73%",fs:"0.9rem",dur:"13s",del:"1.2s",e:"💖"},
      {l:"79%",fs:"1.4rem",dur:"9s",del:"4.5s",e:"💝"},{l:"85%",fs:"0.8rem",dur:"11s",del:"2s",e:"❤️"},
      {l:"91%",fs:"1.7rem",dur:"12s",del:"0.3s",e:"💞"},{l:"96%",fs:"1rem",dur:"8s",del:"6s",e:"🩷"},
      {l:"11%",fs:"1.1rem",dur:"15s",del:"7s",e:"💗"},{l:"22%",fs:"0.7rem",dur:"10s",del:"3s",e:"💕"},
      {l:"36%",fs:"1.3rem",dur:"9s",del:"5.5s",e:"❤️"},{l:"50%",fs:"0.9rem",dur:"13s",del:"1.8s",e:"💖"},
      {l:"63%",fs:"1.5rem",dur:"11s",del:"4s",e:"💝"},{l:"76%",fs:"0.8rem",dur:"8s",del:"6.5s",e:"💞"},
      {l:"88%",fs:"1.2rem",dur:"12s",del:"2.8s",e:"🩷"},{l:"5%",fs:"2.2rem",dur:"16s",del:"8s",e:"💕"},
      {l:"30%",fs:"0.6rem",dur:"10s",del:"1s",e:"💗"},{l:"44%",fs:"1.4rem",dur:"9s",del:"7.5s",e:"❤️"},
      {l:"57%",fs:"0.8rem",dur:"11s",del:"3.8s",e:"💖"},{l:"70%",fs:"1rem",dur:"14s",del:"5s",e:"💝"},
      {l:"82%",fs:"1.6rem",dur:"8s",del:"0.6s",e:"💞"},{l:"94%",fs:"0.9rem",dur:"10s",del:"9s",e:"🩷"},
    ].map(h => (
      <span class="heart" style={`font-size:${h.fs};left:${h.l};animation-duration:${h.dur};animation-delay:${h.del};`}>{h.e}</span>
    ))}

    <!-- Rose petals — 24 -->
    {Array.from({ length: 24 }, (_, i) => (
      <div class="petal" style={`background:hsl(${335 + (i % 5) * 6},85%,${50 + (i % 4) * 10}%);left:${i * 4.2}%;animation-duration:${3.5 + (i % 6)}s;animation-delay:${i * 0.35}s;transform:rotate(${i * 15}deg);`}></div>
    ))}

    <!-- Sparkles — 20 -->
    {[
      {l:"7%",t:"15%",s:5,c:"#ff85c1",dur:"1.8s",del:"0s"},{l:"18%",t:"35%",s:3,c:"#c77dff",dur:"2.5s",del:"0.7s"},
      {l:"28%",t:"20%",s:6,c:"#ff006e",dur:"2s",del:"1.2s"},{l:"38%",t:"55%",s:4,c:"#ff85c1",dur:"3s",del:"0.4s"},
      {l:"48%",t:"12%",s:5,c:"#e040fb",dur:"2.2s",del:"1.8s"},{l:"58%",t:"42%",s:3,c:"#ff006e",dur:"1.6s",del:"0.9s"},
      {l:"68%",t:"25%",s:6,c:"#ff85c1",dur:"2.8s",del:"0.2s"},{l:"78%",t:"60%",s:4,c:"#c77dff",dur:"2.3s",del:"1.5s"},
      {l:"88%",t:"18%",s:5,c:"#e040fb",dur:"1.9s",del:"0.6s"},{l:"94%",t:"48%",s:3,c:"#ff85c1",dur:"2.6s",del:"2s"},
      {l:"13%",t:"70%",s:4,c:"#ff006e",dur:"2.1s",del:"1s"},{l:"23%",t:"80%",s:6,c:"#c77dff",dur:"3.2s",del:"0.3s"},
      {l:"43%",t:"75%",s:3,c:"#ff85c1",dur:"1.7s",del:"1.4s"},{l:"53%",t:"65%",s:5,c:"#e040fb",dur:"2.4s",del:"0.8s"},
      {l:"63%",t:"78%",s:4,c:"#ff006e",dur:"2.9s",del:"1.7s"},{l:"73%",t:"85%",s:3,c:"#ff85c1",dur:"1.5s",del:"0.1s"},
      {l:"83%",t:"72%",s:6,c:"#c77dff",dur:"2.7s",del:"2.2s"},{l:"33%",t:"90%",s:4,c:"#e040fb",dur:"2s",del:"1.1s"},
      {l:"3%",t:"82%",s:5,c:"#ff006e",dur:"3.1s",del:"0.5s"},{l:"97%",t:"30%",s:3,c:"#ff85c1",dur:"2.3s",del:"1.9s"},
    ].map(sp => (
      <div class="val-sparkle" style={`width:${sp.s}px;height:${sp.s}px;background:${sp.c};color:${sp.c};left:${sp.l};top:${sp.t};animation-duration:${sp.dur};animation-delay:${sp.del};`}></div>
    ))}

    <!-- Shooting stars -->
    <div class="shooting-star" style="width:200px;top:18%;left:0%;animation-duration:5s;animation-delay:0s;"></div>
    <div class="shooting-star" style="width:150px;top:35%;left:20%;animation-duration:7s;animation-delay:2.5s;"></div>
    <div class="shooting-star" style="width:300px;top:8%;left:40%;animation-duration:6s;animation-delay:4s;"></div>

    <div class="val-ribbon"></div>

    <div class="val-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Valentine's Day Wheel</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">💝</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight val-title mb-3">
            Valentine's Day Wheel
          </h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">
            Spin to discover your perfect date idea. Add your own, customize, let love decide.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="val-tag">❤️ Date Night</span>
            <span class="val-tag">🎁 Gift Ideas</span>
            <span class="val-tag">💑 Couples</span>
            <span class="val-tag">🌹 Romance</span>
          </div>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={valColors}
          wheelShape="heart"
          hubTheme="rose"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="val-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Make Planning Part of the Romance</h2>
          <p class="text-white/60 leading-relaxed">
            The classic Valentine's Day planning dynamic: one person asks "what do you want to do?", the other says "I don't mind, anything is fine", and somehow nothing gets booked until February 13th. The wheel breaks this loop.
          </p>
          <p class="text-white/60 leading-relaxed">
            Build the wheel together — each of you adds 3-4 ideas to the list. Everything on the wheel is something both of you would enjoy. Spin together. The result feels shared and spontaneous without the usual back-and-forth negotiation.
          </p>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="val-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/templates/gift-idea-wheel", label: "🎁 Gift Idea Wheel", desc: "Random gift ideas for any occasion." },
              { href: "/templates/restaurant-picker", label: "🍽️ Restaurant Picker", desc: "Spin to decide where to go for dinner." },
              { href: "/templates/date-night-wheel", label: "🌙 Date Night Wheel", desc: "More date night inspiration." },
              { href: "/yes-no-wheel", label: "✅ Yes or No Wheel", desc: "Quick binary decisions for borderline plans." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="val-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
