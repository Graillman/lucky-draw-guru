---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Baby Name Spinner Wheel — Pick a Name by Chance";
const description = "Can't decide on a baby name? Put your top choices on the wheel and let fate decide. A fun way to narrow down your shortlist.";
const canonical = "/templates/baby-name-wheel";

const faqItems = [
  {
    question: "What if the wheel picks a name I hate?",
    answer: "Remove it from the wheel and spin again. The wheel works best when all remaining options are ones you could genuinely accept.",
  },
  {
    question: "Can I use this for pet names too?",
    answer: "Absolutely — it works for any naming decision. Pets, characters, businesses, whatever needs a name.",
  },
  {
    question: "Should we tell people the wheel picked the name?",
    answer: "That's up to you. Some parents love the story; others prefer to say they 'just loved it.' Either way, it's a great conversation starter.",
  },
];

const defaultParticipants = [
  { pseudo: "Emma", weight: 1 },
  { pseudo: "Liam", weight: 1 },
  { pseudo: "Olivia", weight: 1 },
  { pseudo: "Noah", weight: 1 },
  { pseudo: "Ava", weight: 1 },
  { pseudo: "James", weight: 1 },
  { pseudo: "Sophia", weight: 1 },
  { pseudo: "Lucas", weight: 1 },
  { pseudo: "Mia", weight: 1 },
  { pseudo: "Ethan", weight: 1 },
  { pseudo: "Isabella", weight: 1 },
  { pseudo: "Mason", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/baby-name-wheel",
};

const myColors = ['#fda4af','#a5f3fc','#fbcfe8','#bfdbfe','#f9a8d4','#93c5fd','#fecdd3','#bae6fd'];
---

<style>
  /* ═══════════ BABY NAME — SOFT PASTEL DREAM THEME ═══════════ */

  .baby-page {
    background: #1a0f1f;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Soft pastel sky — pink to blue gradient */
  .baby-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 20% 30%, rgba(253,164,175,0.18) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 25%, rgba(147,197,253,0.2) 0%, transparent 55%),
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(249,168,212,0.15) 0%, transparent 55%),
      radial-gradient(ellipse 60% 60% at 50% 100%, rgba(165,243,252,0.1) 0%, transparent 60%),
      linear-gradient(180deg, #1a0f1f 0%, #150e22 40%, #0e1525 80%, #10151e 100%);
    pointer-events: none;
    z-index: 0;
    animation: babySkyBreath 10s ease-in-out infinite alternate;
  }

  @keyframes babySkyBreath {
    0%   { opacity: 0.85; }
    100% { opacity: 1; }
  }

  /* Falling soft stars */
  .baby-star {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    animation: babyStarFall linear infinite, babyStarTwinkle ease-in-out infinite;
  }

  @keyframes babyStarFall {
    0%   { top: -5vh; }
    100% { top: 110vh; }
  }

  @keyframes babyStarTwinkle {
    0%, 100% { opacity: 0; transform: scale(0.5) rotate(0deg); }
    30%, 70% { opacity: 0.65; transform: scale(1.2) rotate(20deg); }
  }

  /* Floating butterflies */
  .baby-butterfly {
    position: fixed;
    pointer-events: none;
    z-index: 3;
    font-size: 1.4rem;
    opacity: 0;
    animation: butterflyFloat ease-in-out infinite;
  }

  @keyframes butterflyFloat {
    0%   { transform: translateY(0) translateX(0) rotate(-5deg); opacity: 0; }
    10%  { opacity: 0.65; }
    40%  { transform: translateY(-30px) translateX(20px) rotate(8deg); opacity: 0.65; }
    60%  { transform: translateY(-10px) translateX(40px) rotate(-5deg); opacity: 0.55; }
    80%  { transform: translateY(-40px) translateX(60px) rotate(10deg); opacity: 0.65; }
    90%  { opacity: 0.3; }
    100% { transform: translateY(-20px) translateX(80px) rotate(-8deg); opacity: 0; }
  }

  /* Soft pink/blue sparkle particles */
  .baby-sparkle {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    animation: babySparkle ease-in-out infinite;
  }

  @keyframes babySparkle {
    0%, 100% { transform: scale(0.4); opacity: 0.15; }
    50%      { transform: scale(1.6); opacity: 0.8; }
  }

  /* Gentle moon glow top-right */
  .baby-moon {
    position: fixed;
    top: -50px;
    right: 60px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(253,164,175,0.35) 0%, rgba(249,168,212,0.15) 50%, transparent 75%);
    pointer-events: none;
    z-index: 1;
    animation: moonPulse 6s ease-in-out infinite alternate;
  }

  @keyframes moonPulse {
    0%   { opacity: 0.6; transform: scale(1); }
    100% { opacity: 1;   transform: scale(1.15); }
  }

  /* Small soft clouds drifting */
  .baby-cloud {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    filter: blur(30px);
    animation: cloudFloat linear infinite;
  }

  @keyframes cloudFloat {
    0%   { transform: translateX(-150px); opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 1; }
    100% { transform: translateX(calc(100vw + 150px)); opacity: 0; }
  }

  /* Content layer */
  .baby-content {
    position: relative;
    z-index: 10;
  }

  /* Title gradient pastel */
  .baby-title {
    background: linear-gradient(135deg, #fda4af 0%, #bfdbfe 40%, #fbcfe8 70%, #a5f3fc 100%);
    background-size: 250%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: pastelShimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 20px rgba(253,164,175,0.4));
  }

  @keyframes pastelShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .baby-tag {
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
    backdrop-filter: blur(6px);
  }

  .baby-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(253,164,175,0.2);
    border-radius: 0.75rem;
    padding: 1.5rem;
    backdrop-filter: blur(12px);
    transition: border-color 0.2s;
  }

  .baby-card:hover {
    border-color: rgba(253,164,175,0.45);
  }

  .baby-inner-card {
    background: rgba(253,164,175,0.08);
    border: 1px solid rgba(253,164,175,0.15);
    border-radius: 0.5rem;
    padding: 0.875rem;
  }

  details.baby-faq {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(147,197,253,0.2);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Baby Name Wheel", url: "https://realwheelpicker.com/templates/baby-name-wheel" },
  ]} />

  <div class="baby-page">
    <div class="baby-sky"></div>
    <div class="baby-moon"></div>

    <!-- Drifting soft clouds -->
    {[
      {top:"15%",h:"100px",w:"220px",bg:"rgba(253,164,175,0.25)",dur:"30s",delay:"0s"},
      {top:"40%",h:"80px", w:"180px",bg:"rgba(147,197,253,0.2)", dur:"38s",delay:"-15s"},
      {top:"65%",h:"90px", w:"200px",bg:"rgba(249,168,212,0.22)",dur:"28s",delay:"-8s"},
      {top:"82%",h:"70px", w:"160px",bg:"rgba(165,243,252,0.18)",dur:"42s",delay:"-22s"},
    ].map(({top,h,w,bg,dur,delay}) => (
      <div class="baby-cloud" style={`top:${top};height:${h};width:${w};background:${bg};animation-duration:${dur};animation-delay:${delay};`}></div>
    ))}

    <!-- Falling soft stars -->
    {Array.from({ length: 18 }, (_, i) => {
      const starSymbols = ["✦","✧","★","✩","✪","✫"];
      const pinkBlue = ["#fda4af","#a5f3fc","#fbcfe8","#bfdbfe","#f9a8d4","#93c5fd"];
      return (
        <div
          class="baby-star"
          style={`left:${(i*5.6)%100}%;font-size:${0.6+(i%4)*0.3}rem;color:${pinkBlue[i%pinkBlue.length]};animation-duration:${10+(i%6)*2}s,${2+(i%3)*0.7}s;animation-delay:-${(i*1.8)%15}s,-${i*0.4}s;`}
        >{starSymbols[i%starSymbols.length]}</div>
      );
    })}

    <!-- Floating butterflies -->
    {[
      {l:"8%",  t:"30%", d:"8s",  delay:"0s"},
      {l:"80%", t:"20%", d:"11s", delay:"2s"},
      {l:"55%", t:"60%", d:"9s",  delay:"4s"},
      {l:"25%", t:"70%", d:"13s", delay:"1s"},
      {l:"90%", t:"55%", d:"10s", delay:"3s"},
      {l:"40%", t:"15%", d:"7s",  delay:"5s"},
    ].map(({l,t,d,delay}) => (
      <div class="baby-butterfly" style={`left:${l};top:${t};animation-duration:${d};animation-delay:${delay};`}>🦋</div>
    ))}

    <!-- Sparkle dots -->
    {[
      {l:"5%",  t:"20%", bg:"#fda4af", d:"2s"},
      {l:"92%", t:"15%", bg:"#93c5fd", d:"2.8s"},
      {l:"48%", t:"5%",  bg:"#fbcfe8", d:"1.6s"},
      {l:"75%", t:"50%", bg:"#a5f3fc", d:"3.1s"},
      {l:"20%", t:"80%", bg:"#f9a8d4", d:"2.3s"},
      {l:"88%", t:"82%", bg:"#bfdbfe", d:"1.9s"},
      {l:"60%", t:"88%", bg:"#fecdd3", d:"2.6s"},
      {l:"33%", t:"42%", bg:"#bae6fd", d:"3.4s"},
    ].map(({l,t,bg,d}) => (
      <div class="baby-sparkle" style={`left:${l};top:${t};width:7px;height:7px;background:${bg};box-shadow:0 0 8px ${bg};animation-duration:${d};`}></div>
    ))}

    <div class="baby-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">

        <nav aria-label="breadcrumb" class="text-xs text-white/25 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/55 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/55 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/45">Baby Name Wheel</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">🍼</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight baby-title mb-3">
            Baby Name Spinner Wheel
          </h1>
          <p class="text-lg text-white/50 max-w-xl mx-auto mb-5">
            Can't decide on a baby name? Put your shortlist on the wheel and let fate break the deadlock. Pre-loaded with 12 popular names.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="baby-tag" style="background:rgba(253,164,175,0.18);border:1px solid rgba(253,164,175,0.3);color:#fda4af;">🌸 Names</span>
            <span class="baby-tag" style="background:rgba(147,197,253,0.18);border:1px solid rgba(147,197,253,0.3);color:#93c5fd;">🦋 Magical</span>
            <span class="baby-tag" style="background:rgba(249,168,212,0.18);border:1px solid rgba(249,168,212,0.3);color:#f9a8d4;">🧸 Soft</span>
            <span class="baby-tag" style="background:rgba(165,243,252,0.18);border:1px solid rgba(165,243,252,0.3);color:#a5f3fc;">✨ Free</span>
          </div>
        </div>

        <SimpleWheelIsland defaultParticipants={defaultParticipants} colors={myColors} wheelShape="circle" hubTheme="rose" client:load />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="baby-card space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">The Baby Name Dilemma</h2>
          <p class="text-white/55 leading-relaxed">
            You've been discussing baby names for weeks. Both of you have strong opinions. The list is down to 8 names and nobody will budge. The wheel doesn't have feelings — it just picks. Once you see the result, notice how you both feel: relief or disappointment? That gut reaction tells you everything.
          </p>
          <p class="text-white/55 leading-relaxed">
            Use this as a starting point, not a final verdict. The wheel helps you break analysis paralysis and start leaning toward something concrete.
          </p>
        </div>

        <div class="baby-card space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Name Origin Themes</h2>
          <div class="space-y-3">
            <div class="baby-inner-card">
              <p class="font-semibold text-white/80 text-sm mb-1">🏰 Classic English</p>
              <p class="text-white/50 text-sm">William, Charlotte, Henry, Eleanor, George, Alice</p>
            </div>
            <div class="baby-inner-card" style="border-color:rgba(147,197,253,0.2);">
              <p class="font-semibold text-white/80 text-sm mb-1">🍀 Irish</p>
              <p class="text-white/50 text-sm">Aoife, Ciarán, Siobhán, Padraig, Niamh, Darragh</p>
            </div>
            <div class="baby-inner-card" style="border-color:rgba(165,243,252,0.2);">
              <p class="font-semibold text-white/80 text-sm mb-1">❄️ Scandinavian</p>
              <p class="text-white/50 text-sm">Astrid, Lars, Freya, Bjorn, Ingrid, Magnus</p>
            </div>
            <div class="baby-inner-card" style="border-color:rgba(249,168,212,0.2);">
              <p class="font-semibold text-white/80 text-sm mb-1">🌸 Japanese</p>
              <p class="text-white/50 text-sm">Hana, Kenji, Yuki, Riku, Sakura, Haruto</p>
            </div>
          </div>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="baby-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/55 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/", label: "🎡 Spin the Wheel", desc: "The main wheel picker — add any options and spin." },
              { href: "/random-name-picker", label: "🎲 Random Name Picker", desc: "Pick a random name from your list instantly." },
              { href: "/party-wheel", label: "🎉 Party Wheel", desc: "Pre-loaded with party game ideas." },
              { href: "/templates", label: "✨ All Templates", desc: "Browse all pre-loaded wheel templates." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="baby-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
