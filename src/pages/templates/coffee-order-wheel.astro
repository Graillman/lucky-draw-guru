---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Coffee Order Spinner — Random Drink Generator";
const description = "Spin the coffee wheel to discover your next drink order. 12 options from espresso to cold brew. Great for coffee shop adventures and breaking routine.";
const canonical = "/templates/coffee-order-wheel";

const faqItems = [
  {
    question: "What if I land on something with dairy and I'm lactose intolerant?",
    answer: "Customize the wheel — remove items you can't have or add your dairy-free alternatives. Swap 'Latte' for 'Oat Milk Latte' or 'Almond Cappuccino'. The wheel adapts to your preferences.",
  },
  {
    question: "Can I use this at a coffee shop with friends?",
    answer: "Absolutely. Pass your phone around and let each person spin for their order. It's a fun way to try something new when everyone's tempted to order the same thing every time.",
  },
  {
    question: "Is the Affogato really a coffee drink?",
    answer: "It's a dessert and a coffee in one — espresso poured over vanilla ice cream. Technically a beverage, definitely a treat. Landing on it is a win.",
  },
];

const defaultParticipants = [
  { pseudo: "Espresso", weight: 1 },
  { pseudo: "Latte", weight: 1 },
  { pseudo: "Cappuccino", weight: 1 },
  { pseudo: "Americano", weight: 1 },
  { pseudo: "Flat White", weight: 1 },
  { pseudo: "Cold Brew", weight: 1 },
  { pseudo: "Mocha", weight: 1 },
  { pseudo: "Chai Latte", weight: 1 },
  { pseudo: "Matcha Latte", weight: 1 },
  { pseudo: "Iced Coffee", weight: 1 },
  { pseudo: "Cortado", weight: 1 },
  { pseudo: "Affogato", weight: 1 },
];

const myColors = ['#6f4e37','#c8a96e','#d4a853','#8b5e3c','#f0c040','#a0522d','#cd853f','#daa520'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/coffee-order-wheel",
};
---

<style>
  /* ═══════════ COFFEE — CAFÉ COSY AMBRÉ ═══════════ */
  .coffee-page {
    background: #0d0500;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Fond espresso profond avec chaleur ambrée */
  .coffee-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 55% at 20% -10%, rgba(160,82,45,0.5) 0%, transparent 55%),
      radial-gradient(ellipse 60% 45% at 80% 0%, rgba(218,165,32,0.3) 0%, transparent 55%),
      radial-gradient(ellipse 70% 50% at 50% 110%, rgba(111,78,55,0.45) 0%, transparent 60%),
      linear-gradient(180deg, #0d0500 0%, #150800 45%, #0d0500 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Halos chaleur ambrée */
  .coffee-glow {
    position: fixed;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: 0;
    animation: coffeeGlowPulse ease-in-out infinite alternate;
  }
  @keyframes coffeeGlowPulse {
    from { opacity: 0.25; transform: scale(0.88); }
    to   { opacity: 0.6; transform: scale(1.12); }
  }

  /* Grains de café tombants — 20 */
  .coffee-bean {
    position: fixed;
    border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
    pointer-events: none;
    z-index: 1;
    animation: beanFall linear infinite;
    opacity: 0;
  }
  @keyframes beanFall {
    0%   { transform: translateY(-20px) rotate(0deg); opacity: 0; }
    8%   { opacity: 0.7; }
    92%  { opacity: 0.4; }
    100% { transform: translateY(110vh) rotate(540deg); opacity: 0; }
  }

  /* Volutes de vapeur — 15 */
  .coffee-steam {
    position: fixed;
    pointer-events: none;
    z-index: 1;
    border-radius: 50%;
    filter: blur(12px);
    animation: steamRise ease-out infinite;
    opacity: 0;
  }
  @keyframes steamRise {
    0%   { transform: translateY(0px) translateX(0px) scale(0.5); opacity: 0; }
    15%  { opacity: 0.35; }
    60%  { transform: translateY(-120px) translateX(20px) scale(1.4); opacity: 0.2; }
    100% { transform: translateY(-200px) translateX(-10px) scale(2); opacity: 0; }
  }

  /* Particules d'or — petits éclats ambrés */
  .coffee-spark {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    animation: sparkAmber ease-in-out infinite alternate;
  }
  @keyframes sparkAmber {
    from { opacity: 0.08; transform: scale(0.4); box-shadow: none; }
    to   { opacity: 0.95; transform: scale(2); box-shadow: 0 0 6px currentColor, 0 0 16px currentColor; }
  }

  /* Halo chaleur bas de page */
  .coffee-warmth {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 150px;
    background: linear-gradient(0deg, rgba(160,82,45,0.2) 0%, rgba(218,165,32,0.08) 50%, transparent 100%);
    pointer-events: none;
    z-index: 1;
    animation: warmthPulse 5s ease-in-out infinite alternate;
  }
  @keyframes warmthPulse {
    from { opacity: 0.5; }
    to   { opacity: 1; }
  }

  /* Texture bois subtile */
  .coffee-wood {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.025;
    background: repeating-linear-gradient(
      88deg,
      transparent,
      transparent 40px,
      rgba(160,82,45,0.8) 40px,
      rgba(160,82,45,0.8) 41px
    );
  }

  /* Contenu */
  .coffee-content { position: relative; z-index: 10; }

  /* Titre gradient brun-caramel-or */
  .coffee-title {
    background: linear-gradient(135deg, #f0c040 0%, #cd853f 30%, #daa520 60%, #f0c040 100%);
    background-size: 250%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: caramelShimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 20px rgba(218,165,32,0.5));
  }
  @keyframes caramelShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .coffee-tag {
    background: rgba(111,78,55,0.2);
    border: 1px solid rgba(200,169,110,0.4);
    color: rgba(240,192,64,0.9);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .coffee-card {
    background: rgba(13,5,0,0.8);
    border: 1px solid rgba(160,82,45,0.28);
    border-radius: 1rem;
    padding: 1.5rem;
    backdrop-filter: blur(14px);
    box-shadow: 0 0 30px rgba(111,78,55,0.1), inset 0 1px 0 rgba(218,165,32,0.06);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .coffee-card:hover {
    border-color: rgba(200,169,110,0.45);
    box-shadow: 0 0 40px rgba(160,82,45,0.18);
  }
  .coffee-card h2 { color: #daa520; text-shadow: 0 0 12px rgba(218,165,32,0.4); margin-bottom: 1rem; }
  .coffee-card p { color: #9a7a55; line-height: 1.75; }

  details.coffee-faq {
    background: rgba(8,3,0,0.85);
    border: 1px solid rgba(160,82,45,0.22);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
  details.coffee-faq summary { color: #daa520; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 8px; }
  details.coffee-faq p { color: #9a7a55; font-size: 0.875rem; line-height: 1.65; margin-top: 0.75rem; }

  .coffee-drink-card {
    background: rgba(20,8,0,0.65);
    border: 1px solid rgba(200,169,110,0.18);
    border-radius: 0.5rem;
    padding: 0.75rem;
  }
  .coffee-drink-card strong { color: #c8a96e; display: block; margin-bottom: 4px; font-size: 0.9rem; }
  .coffee-drink-card span { color: #7a6040; font-size: 0.78rem; }

  .coffee-related a {
    display: flex; align-items: flex-start; gap: 0.75rem; padding: 1rem;
    background: rgba(8,3,0,0.75);
    border: 1px solid rgba(160,82,45,0.22);
    border-radius: 0.75rem;
    backdrop-filter: blur(8px);
    transition: all 0.2s; text-decoration: none;
  }
  .coffee-related a:hover { border-color: rgba(218,165,32,0.5); box-shadow: 0 0 20px rgba(160,82,45,0.2); }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Coffee Order Spinner", url: "https://realwheelpicker.com/templates/coffee-order-wheel" },
  ]} />

  <div class="coffee-page">
    <div class="coffee-sky"></div>
    <div class="coffee-wood"></div>

    <!-- Halos chaleur ambrée -->
    <div class="coffee-glow" style="width:650px;height:550px;background:radial-gradient(circle,rgba(160,82,45,0.4) 0%,transparent 70%);top:-180px;left:-130px;animation-duration:6s;"></div>
    <div class="coffee-glow" style="width:550px;height:450px;background:radial-gradient(circle,rgba(218,165,32,0.28) 0%,transparent 70%);top:-80px;right:-100px;animation-duration:8s;animation-delay:2s;"></div>
    <div class="coffee-glow" style="width:450px;height:380px;background:radial-gradient(circle,rgba(111,78,55,0.32) 0%,transparent 70%);bottom:8%;left:50%;transform:translateX(-50%);animation-duration:7s;animation-delay:1s;"></div>

    <!-- Grains de café tombants — 20 -->
    {Array.from({ length: 20 }, (_, i) => (
      <div class="coffee-bean" style={`width:${7+((i*3)%6)}px;height:${9+((i*4)%6)}px;background:hsl(${20+(i%5)*5},${50+(i%3)*10}%,${15+(i%4)*5}%);left:${(i*5+3)%100}%;animation-duration:${5+((i*2)%6)}s;animation-delay:-${(i*1.4)%9}s;`}></div>
    ))}

    <!-- Volutes de vapeur — 15 -->
    {Array.from({ length: 15 }, (_, i) => (
      <div class="coffee-steam" style={`width:${30+((i*7)%30)}px;height:${30+((i*7)%30)}px;background:rgba(255,245,235,0.15);left:${(i*7+8)%95}%;bottom:${5+((i*11)%30)}%;animation-duration:${3+((i*2)%4)}s;animation-delay:-${(i*1.1)%5}s;`}></div>
    ))}

    <!-- Particules ambrées -->
    {[
      {l:"6%",t:"22%",s:4,c:"#f0c040",dur:"1.8s",del:"0s"},{l:"17%",t:"48%",s:3,c:"#daa520",dur:"2.5s",del:"0.8s"},
      {l:"29%",t:"18%",s:5,c:"#cd853f",dur:"2s",del:"1.4s"},{l:"41%",t:"65%",s:3,c:"#f0c040",dur:"3s",del:"0.5s"},
      {l:"53%",t:"10%",s:4,c:"#daa520",dur:"2.2s",del:"1.9s"},{l:"65%",t:"38%",s:3,c:"#c8a96e",dur:"1.6s",del:"0.9s"},
      {l:"77%",t:"28%",s:5,c:"#f0c040",dur:"2.8s",del:"0.2s"},{l:"89%",t:"55%",s:4,c:"#daa520",dur:"2.3s",del:"1.6s"},
      {l:"11%",t:"75%",s:3,c:"#cd853f",dur:"2.1s",del:"1.1s"},{l:"33%",t:"85%",s:5,c:"#f0c040",dur:"3.2s",del:"0.4s"},
      {l:"55%",t:"70%",s:4,c:"#daa520",dur:"1.7s",del:"1.3s"},{l:"73%",t:"80%",s:3,c:"#c8a96e",dur:"2.4s",del:"0.7s"},
    ].map(sp => (
      <div class="coffee-spark" style={`width:${sp.s}px;height:${sp.s}px;background:${sp.c};color:${sp.c};left:${sp.l};top:${sp.t};animation-duration:${sp.dur};animation-delay:${sp.del};`}></div>
    ))}

    <div class="coffee-warmth"></div>

    <div class="coffee-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/25 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/55 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/55 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/40">Coffee Order Spinner</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">☕</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight coffee-title mb-3">
            Coffee Order Spinner
          </h1>
          <p class="text-lg text-white/40 max-w-xl mx-auto mb-5">
            Break out of your coffee rut. Spin the wheel and try something different — from bold espresso to creamy matcha latte.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="coffee-tag">☕ Morning Ritual</span>
            <span class="coffee-tag">🫘 Coffee Shop</span>
            <span class="coffee-tag">🧋 Hot or Iced</span>
            <span class="coffee-tag">Free</span>
          </div>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={myColors}
          wheelShape="circle"
          hubTheme="amber"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="coffee-card space-y-4">
          <h2 class="text-xl md:text-2xl font-bold">Break Your Coffee Routine</h2>
          <p>
            Most people order the same coffee drink every single day. Not because it's objectively the best, but because it's familiar and ordering something new requires decision energy you don't have at 8am. The coffee spinner handles the decision for you.
          </p>
          <p>
            Give yourself a week of spinning for your order. You might discover a cortado is exactly what you've been missing, or that cold brew on a Wednesday changes the whole workday. The wheel introduces low-stakes variety that makes your coffee routine interesting again.
          </p>
          <p>
            If you land on something you genuinely dislike, remove it from the wheel. After a few weeks you'll have a curated list of drinks you actually enjoy — a personal coffee menu built through experimentation.
          </p>
        </div>

        <div class="coffee-card space-y-4">
          <h2 class="text-xl md:text-2xl font-bold">Know Your Options</h2>
          <p>Not all coffee drinks are created equal. Here's a quick reference for what you might land on:</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {[
              ["Espresso", "Pure, concentrated shot — intense flavor, quick drink"],
              ["Flat White", "Like a latte but less milk, stronger coffee flavor"],
              ["Cortado", "Equal parts espresso and steamed milk — balanced"],
              ["Cold Brew", "Steeped overnight, low acidity, naturally sweet"],
              ["Affogato", "Espresso shot over vanilla ice cream — dessert hybrid"],
              ["Chai Latte", "Spiced tea with steamed milk — caffeine but no coffee"],
            ].map(([name, desc]) => (
              <div class="coffee-drink-card">
                <strong>{name}</strong>
                <span>{desc}</span>
              </div>
            ))}
          </div>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#daa520">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="coffee-faq group">
                <summary>
                  {question}
                  <span style="color:rgba(218,165,32,0.4)" class="shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p>{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="coffee-related space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#daa520">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/templates/restaurant-picker", label: "🍽️ Restaurant Picker Wheel", desc: "Decide where to eat for your next meal or coffee outing." },
              { href: "/templates/lunch-spinner", label: "🥗 Lunch Spinner", desc: "What to eat for lunch? Let the wheel decide." },
              { href: "/yes-or-no-wheel", label: "✅ Yes or No Wheel", desc: "Quick binary decisions — should I get a second coffee?" },
              { href: "/templates", label: "🎡 All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href}>
                  <span style="color:#a0522d;font-weight:bold;font-size:0.875rem;margin-top:2px;">→</span>
                  <span>
                    <span style="color:#daa520;font-weight:600;">{label}</span>
                    <span style="color:#7a6040;font-size:0.875rem;display:block;margin-top:2px;">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
