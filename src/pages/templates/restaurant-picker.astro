---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Restaurant Picker Wheel — Where Should We Eat?";
const description = "Can't decide where to eat? Spin the restaurant picker wheel and let fate choose. Pre-loaded with 12 cuisine types. Free, instant, no signup.";
const canonical = "/templates/restaurant-picker";

const faqItems = [
  {
    question: "How do I add my local restaurants?",
    answer: "Edit the wheel items and replace the cuisine types with your actual restaurant names — 'Tony's Pizza', 'Golden Dragon', etc. The wheel works the same with any text.",
  },
  {
    question: "Can I use this to settle group disagreements about where to eat?",
    answer: "That's exactly what it's for. Everyone nominates a restaurant, you add those to the wheel, and one spin ends the debate. No more 20-minute 'I don't know, where do you want to go?' loops.",
  },
  {
    question: "What if I land on something I don't want?",
    answer: "Spin again — or use it as a veto token. Some groups give each person one veto per week. The wheel picks, but a veto is allowed once.",
  },
];

const defaultParticipants = [
  { pseudo: "Italian", weight: 1 },
  { pseudo: "Chinese", weight: 1 },
  { pseudo: "Mexican", weight: 1 },
  { pseudo: "Thai", weight: 1 },
  { pseudo: "Japanese", weight: 1 },
  { pseudo: "Indian", weight: 1 },
  { pseudo: "Burger Joint", weight: 1 },
  { pseudo: "Pizza", weight: 1 },
  { pseudo: "Seafood", weight: 1 },
  { pseudo: "Steakhouse", weight: 1 },
  { pseudo: "Vegan", weight: 1 },
  { pseudo: "Mediterranean", weight: 1 },
];

const myColors = ['#8b1a1a','#d4af37','#f5f5dc','#722f37','#c5b358','#8b4513','#dc143c','#b8860b'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/restaurant-picker",
};
---

<style>
  /* ═══════════ RESTAURANT — ÉLÉGANT NOCTURNE ═══════════ */
  .resto-page {
    background: #06000a;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Fond noir bordeaux profond */
  .resto-sky {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 50% at 15% -8%, rgba(139,26,26,0.42) 0%, transparent 55%),
      radial-gradient(ellipse 60% 45% at 85% 0%, rgba(180,134,11,0.3) 0%, transparent 55%),
      radial-gradient(ellipse 50% 45% at 50% 105%, rgba(114,47,55,0.35) 0%, transparent 60%),
      linear-gradient(180deg, #06000a 0%, #0c0208 50%, #06000a 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Halos dorés */
  .resto-glow {
    position: fixed;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: 0;
    animation: restoGlowPulse ease-in-out infinite alternate;
  }
  @keyframes restoGlowPulse {
    from { opacity: 0.22; transform: scale(0.88); }
    to   { opacity: 0.55; transform: scale(1.12); }
  }

  /* Flammes de bougie — 12 */
  .resto-candle {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .resto-flame {
    width: 8px;
    height: 14px;
    background: radial-gradient(ellipse at 50% 80%, #ffd700 0%, #ff8c00 50%, rgba(220,20,60,0.3) 100%);
    border-radius: 50% 50% 30% 30%;
    animation: flickerCandle ease-in-out infinite alternate;
    box-shadow: 0 0 8px #ffd700, 0 0 20px rgba(255,165,0,0.5), 0 0 40px rgba(220,20,60,0.2);
  }
  .resto-wick {
    width: 2px;
    height: 8px;
    background: #4a3000;
    border-radius: 1px;
  }
  @keyframes flickerCandle {
    0%   { transform: scaleX(1) scaleY(1) rotate(-2deg); opacity: 0.9; }
    20%  { transform: scaleX(0.85) scaleY(1.1) rotate(3deg); opacity: 1; }
    40%  { transform: scaleX(1.1) scaleY(0.9) rotate(-1deg); opacity: 0.85; }
    60%  { transform: scaleX(0.9) scaleY(1.15) rotate(2deg); opacity: 1; }
    80%  { transform: scaleX(1.05) scaleY(0.95) rotate(-3deg); opacity: 0.9; }
    100% { transform: scaleX(1) scaleY(1) rotate(1deg); opacity: 0.95; }
  }

  /* Etoiles Michelin flottantes */
  .resto-star {
    position: fixed;
    pointer-events: none;
    z-index: 1;
    animation: starFloat ease-in-out infinite;
    opacity: 0;
    user-select: none;
    font-size: 1rem;
    color: #d4af37;
    filter: drop-shadow(0 0 6px #d4af37);
  }
  @keyframes starFloat {
    0%   { transform: translateY(105vh) rotate(-20deg); opacity: 0; }
    7%   { opacity: 0.8; }
    50%  { transform: translateY(48vh) rotate(15deg); opacity: 0.6; }
    93%  { opacity: 0.2; }
    100% { transform: translateY(-5vh) rotate(-10deg); opacity: 0; }
  }

  /* Lueur nappe blanche */
  .resto-tablecloth {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(0deg, rgba(212,175,55,0.15) 0%, rgba(139,26,26,0.08) 50%, transparent 100%);
    pointer-events: none;
    z-index: 1;
    animation: tablePulse 6s ease-in-out infinite alternate;
  }
  @keyframes tablePulse {
    from { opacity: 0.5; }
    to   { opacity: 1; }
  }

  /* Particules dorées */
  .resto-gold {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    animation: goldTwinkle ease-in-out infinite alternate;
  }
  @keyframes goldTwinkle {
    from { opacity: 0.05; transform: scale(0.4); box-shadow: none; }
    to   { opacity: 0.9; transform: scale(2); box-shadow: 0 0 6px #d4af37, 0 0 16px rgba(212,175,55,0.6); }
  }

  /* Contenu */
  .resto-content { position: relative; z-index: 10; }

  /* Titre gradient or-bordeaux */
  .resto-title {
    background: linear-gradient(135deg, #d4af37 0%, #b8860b 30%, #dc143c 60%, #d4af37 100%);
    background-size: 280%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: goldShimmer 6s ease-in-out infinite;
    filter: drop-shadow(0 0 22px rgba(212,175,55,0.55));
  }
  @keyframes goldShimmer {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
  }

  .resto-tag {
    background: rgba(139,26,26,0.15);
    border: 1px solid rgba(212,175,55,0.35);
    color: rgba(240,215,100,0.95);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .resto-card {
    background: rgba(6,0,10,0.8);
    border: 1px solid rgba(212,175,55,0.2);
    border-radius: 1rem;
    padding: 1.5rem;
    backdrop-filter: blur(14px);
    box-shadow: 0 0 30px rgba(139,26,26,0.1), inset 0 1px 0 rgba(212,175,55,0.06);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .resto-card:hover {
    border-color: rgba(212,175,55,0.42);
    box-shadow: 0 0 40px rgba(139,26,26,0.2);
  }
  .resto-card h2 { color: #d4af37; text-shadow: 0 0 12px rgba(212,175,55,0.4); margin-bottom: 1rem; }
  .resto-card p { color: #9a8060; line-height: 1.75; }
  .resto-card li { color: #9a8060; }

  details.resto-faq {
    background: rgba(3,0,5,0.85);
    border: 1px solid rgba(212,175,55,0.18);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
  details.resto-faq summary { color: #d4af37; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 8px; }
  details.resto-faq p { color: #9a8060; font-size: 0.875rem; line-height: 1.65; margin-top: 0.75rem; }

  .resto-related a {
    display: flex; align-items: flex-start; gap: 0.75rem; padding: 1rem;
    background: rgba(3,0,5,0.75);
    border: 1px solid rgba(212,175,55,0.18);
    border-radius: 0.75rem;
    backdrop-filter: blur(8px);
    transition: all 0.2s; text-decoration: none;
  }
  .resto-related a:hover { border-color: rgba(212,175,55,0.48); box-shadow: 0 0 20px rgba(139,26,26,0.2); }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Restaurant Picker Wheel", url: "https://realwheelpicker.com/templates/restaurant-picker" },
  ]} />

  <div class="resto-page">
    <div class="resto-sky"></div>

    <!-- Halos dorés -->
    <div class="resto-glow" style="width:650px;height:550px;background:radial-gradient(circle,rgba(139,26,26,0.4) 0%,transparent 70%);top:-200px;left:-140px;animation-duration:6s;"></div>
    <div class="resto-glow" style="width:550px;height:480px;background:radial-gradient(circle,rgba(212,175,55,0.28) 0%,transparent 70%);top:-100px;right:-110px;animation-duration:8s;animation-delay:2s;"></div>
    <div class="resto-glow" style="width:480px;height:400px;background:radial-gradient(circle,rgba(114,47,55,0.3) 0%,transparent 70%);bottom:5%;left:50%;transform:translateX(-50%);animation-duration:7s;animation-delay:1s;"></div>

    <!-- Bougies vacillantes — 12 -->
    {[
      {l:"3%",bt:"15%"},{l:"8%",bt:"8%"},{l:"15%",bt:"20%"},{l:"22%",bt:"5%"},
      {l:"30%",bt:"12%"},{l:"38%",bt:"18%"},{l:"62%",bt:"10%"},{l:"70%",bt:"16%"},
      {l:"78%",bt:"7%"},{l:"85%",bt:"14%"},{l:"91%",bt:"20%"},{l:"97%",bt:"9%"},
    ].map((c, i) => (
      <div class="resto-candle" style={`left:${c.l};bottom:${c.bt};animation-delay:${i*0.3}s;`}>
        <div class="resto-flame" style={`animation-duration:${0.8+((i*0.3)%0.8)}s;animation-delay:${i*0.25}s;`}></div>
        <div class="resto-wick"></div>
      </div>
    ))}

    <!-- Etoiles Michelin flottantes -->
    {[
      {l:"5%",dur:"11s",del:"0s"},{l:"12%",dur:"14s",del:"2s"},{l:"20%",dur:"9s",del:"1s"},
      {l:"30%",dur:"12s",del:"3.5s"},{l:"40%",dur:"10s",del:"0.5s"},{l:"52%",dur:"13s",del:"5s"},
      {l:"63%",dur:"11s",del:"1.8s"},{l:"74%",dur:"9s",del:"4s"},{l:"84%",dur:"14s",del:"2.5s"},
      {l:"93%",dur:"10s",del:"6s"},{l:"16%",dur:"12s",del:"8s"},{l:"47%",dur:"9s",del:"3s"},
    ].map((s, i) => (
      <span class="resto-star" style={`left:${s.l};animation-duration:${s.dur};animation-delay:${s.del};font-size:${0.8+(i%3)*0.4}rem;`}>⭐</span>
    ))}

    <!-- Particules dorées -->
    {[
      {l:"7%",t:"18%",s:3,dur:"1.9s",del:"0s"},{l:"18%",t:"42%",s:4,dur:"2.6s",del:"0.7s"},
      {l:"30%",t:"25%",s:3,dur:"2s",del:"1.5s"},{l:"42%",t:"68%",s:5,dur:"3.1s",del:"0.4s"},
      {l:"54%",t:"12%",s:3,dur:"2.3s",del:"2s"},{l:"66%",t:"50%",s:4,dur:"1.7s",del:"0.9s"},
      {l:"78%",t:"32%",s:3,dur:"2.8s",del:"0.2s"},{l:"90%",t:"60%",s:5,dur:"2.2s",del:"1.6s"},
      {l:"12%",t:"78%",s:4,dur:"2s",del:"1.1s"},{l:"35%",t:"88%",s:3,dur:"3.3s",del:"0.4s"},
      {l:"57%",t:"75%",s:4,dur:"1.8s",del:"1.4s"},{l:"80%",t:"82%",s:3,dur:"2.5s",del:"0.6s"},
    ].map(g => (
      <div class="resto-gold" style={`width:${g.s}px;height:${g.s}px;background:#d4af37;left:${g.l};top:${g.t};animation-duration:${g.dur};animation-delay:${g.del};`}></div>
    ))}

    <div class="resto-tablecloth"></div>

    <div class="resto-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/25 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/55 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/55 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/40">Restaurant Picker Wheel</span>
        </nav>

        <div class="text-center mb-8">
          <div class="text-5xl mb-3">🕯️</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight resto-title mb-3">
            Restaurant Picker Wheel
          </h1>
          <p class="text-lg text-white/40 max-w-xl mx-auto mb-5">
            End the "where should we eat?" debate instantly. Spin the wheel and let fate decide your next meal.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="resto-tag">⭐ Fine Dining</span>
            <span class="resto-tag">🍽️ Date Night</span>
            <span class="resto-tag">👥 Group Dinner</span>
            <span class="resto-tag">Free</span>
          </div>
        </div>

        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={myColors}
          wheelShape="circle"
          hubTheme="amber"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="resto-card space-y-4">
          <h2 class="text-xl md:text-2xl font-bold">Stop the "Where Should We Eat?" Loop</h2>
          <p>
            Every group has the same conversation. Someone asks where to eat. Everyone shrugs. Suggestions get vetoed. Time passes. Eventually someone caves and picks somewhere mediocre out of hunger and frustration. The restaurant picker wheel breaks this cycle completely.
          </p>
          <p>
            The trick is commitment before spinning. Everyone agrees in advance to honor the wheel's choice. Once you remove "maybe we can change it" from the equation, the decision actually gets made — and it's surprisingly fun to let chance decide your dinner.
          </p>
          <p>
            Start with the cuisine types pre-loaded, or replace them with actual restaurant names from your area. The wheel works identically whether it says "Italian" or "Mario's on 5th Street."
          </p>
        </div>

        <div class="resto-card space-y-4">
          <h2 class="text-xl md:text-2xl font-bold">How to Use the Restaurant Wheel Effectively</h2>
          <p>
            The best approach depends on your group. For couples, load actual restaurant names from your saved list. For offices, use cuisine categories so different dietary needs can still be met. For families, add a "Everyone picks" option and a "Chef's choice at home" option to keep spontaneity balanced with budget.
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3"><span style="color:#d4af37;font-weight:bold;">→</span><span>Add only places everyone is willing to go — no sabotage entries.</span></li>
            <li class="flex gap-3"><span style="color:#d4af37;font-weight:bold;">→</span><span>Give each person one nomination per spin session for fairness.</span></li>
            <li class="flex gap-3"><span style="color:#d4af37;font-weight:bold;">→</span><span>Use the share link to send the wheel to remote friends who want to join the decision.</span></li>
            <li class="flex gap-3"><span style="color:#d4af37;font-weight:bold;">→</span><span>Keep a list of past results so you don't repeat the same place too often.</span></li>
          </ul>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#d4af37">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="resto-faq group">
                <summary>
                  {question}
                  <span style="color:rgba(212,175,55,0.4)" class="shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p>{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="resto-related space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#d4af37">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/templates/what-to-eat-wheel", label: "🍜 What to Eat Wheel", desc: "Spin for a random meal idea when you can't decide what to cook or order." },
              { href: "/templates/lunch-spinner", label: "🥗 Lunch Spinner", desc: "Quick lunchtime decisions — 12 options for what to eat at noon." },
              { href: "/templates/dessert-picker", label: "🍰 Dessert Picker", desc: "Can't choose a sweet treat? Let the wheel pick your dessert." },
              { href: "/templates", label: "🎡 All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href}>
                  <span style="color:#b8860b;font-weight:bold;font-size:0.875rem;margin-top:2px;">→</span>
                  <span>
                    <span style="color:#d4af37;font-weight:600;">{label}</span>
                    <span style="color:#9a8060;font-size:0.875rem;display:block;margin-top:2px;">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
