---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Back to School Wheel — Random Subject & Study Activity Picker";
const description = "Spin for a random subject to study or school activity. Pre-loaded with 10 back-to-school topics. Beat study procrastination — spin and start.";
const canonical = "/templates/back-to-school-wheel";

const faqItems = [
  {
    question: "How can teachers use this in the classroom?",
    answer: "Spin to pick which student answers next, which topic to review, which group presents first, or which activity to do for a free block. Works for any grade level — just replace the defaults with your subject matter.",
  },
  {
    question: "How should students use this for studying?",
    answer: "Load it with all subjects you need to study. Spin to pick where to start. Once you finish 25-30 minutes on that subject, spin again for the next one. Randomizing study order prevents overloading any one subject and keeps sessions interesting.",
  },
  {
    question: "Can parents use this for school prep activities?",
    answer: "Yes. Load it with back-to-school tasks: buy supplies, label books, set up study space, review summer work, plan schedule. Spin to delegate tasks among siblings or decide what to tackle first.",
  },
];

const defaultParticipants = [
  { pseudo: "Math review", weight: 1 },
  { pseudo: "Reading practice", weight: 1 },
  { pseudo: "Science chapter", weight: 1 },
  { pseudo: "History notes", weight: 1 },
  { pseudo: "English writing", weight: 1 },
  { pseudo: "Vocabulary drill", weight: 1 },
  { pseudo: "Study flashcards", weight: 1 },
  { pseudo: "Practice test", weight: 1 },
  { pseudo: "Art project", weight: 1 },
  { pseudo: "PE / exercise", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/back-to-school-wheel",
};
---

<style>
  /* ===== BACK TO SCHOOL THEME ===== */

  .school-page {
    min-height: 100vh;
    background: #fffde7;
    position: relative;
    overflow-x: hidden;
  }

  /* Notebook-paper lined background */
  .school-paper {
    position: fixed;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        transparent,
        transparent 27px,
        rgba(173, 216, 230, 0.35) 27px,
        rgba(173, 216, 230, 0.35) 28px
      ),
      linear-gradient(90deg, rgba(255, 105, 97, 0.2) 0px, rgba(255, 105, 97, 0.2) 2px, transparent 2px);
    background-size: 100% 28px, 60px 100%;
    z-index: 0;
    pointer-events: none;
  }

  /* School bus yellow ambient */
  .school-glow-top {
    position: fixed;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(255, 214, 0, 0.25) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
    animation: busGlow 5s ease-in-out infinite alternate;
  }

  @keyframes busGlow {
    0%   { opacity: 0.7; transform: translateX(-50%) scaleX(1); }
    100% { opacity: 1;   transform: translateX(-50%) scaleX(1.1); }
  }

  /* Corner apple glow */
  .school-apple-glow {
    position: fixed;
    top: 30px;
    right: 30px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(229, 57, 53, 0.25) 0%, transparent 70%);
    z-index: 1;
    pointer-events: none;
    animation: appleGlow 4s ease-in-out infinite alternate;
  }

  @keyframes appleGlow {
    0%   { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.2); opacity: 1; }
  }

  /* Floating school icons */
  .school-icon {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    font-size: 1.8rem;
    animation: floatSchoolIcon linear infinite;
  }

  @keyframes floatSchoolIcon {
    0%   { transform: translateY(110vh) rotate(-10deg); opacity: 0; }
    5%   { opacity: 0.2; }
    90%  { opacity: 0.2; }
    100% { transform: translateY(-15vh) rotate(15deg); opacity: 0; }
  }

  /* Math symbols floating */
  .school-math {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    font-family: 'Georgia', serif;
    font-weight: 700;
    opacity: 0.09;
    color: #1565c0;
    animation: mathFloat ease-in-out infinite;
  }

  @keyframes mathFloat {
    0%, 100% { transform: translateY(0) rotate(-5deg); opacity: 0.09; }
    50%       { transform: translateY(-20px) rotate(5deg); opacity: 0.15; }
  }

  /* Bottom chalkboard strip */
  .school-chalk-strip {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 8px;
    background: linear-gradient(90deg, #f44336, #ff9800, #ffeb3b, #4caf50, #2196f3);
    z-index: 100;
    pointer-events: none;
  }

  /* Ruler marks decoration */
  .school-ruler {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    background: repeating-linear-gradient(
      90deg,
      #ff9800 0px, #ff9800 10px,
      #f44336 10px, #f44336 20px,
      #ffeb3b 20px, #ffeb3b 30px,
      #4caf50 30px, #4caf50 40px,
      #2196f3 40px, #2196f3 50px
    );
    z-index: 100;
    pointer-events: none;
  }

  /* Content */
  .school-content {
    position: relative;
    z-index: 10;
  }

  /* Cards — warm paper look */
  .school-card {
    background: rgba(255, 253, 231, 0.88);
    border: 2px solid rgba(255, 160, 0, 0.35);
    border-radius: 0.75rem;
    padding: 1.5rem;
    box-shadow: 3px 3px 0 rgba(255, 193, 7, 0.3), 0 4px 24px rgba(255, 152, 0, 0.08);
    backdrop-filter: blur(4px);
  }

  .school-inner-card {
    background: rgba(255, 243, 224, 0.7);
    border-left: 4px solid #ff9800;
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 0.875rem;
  }

  .school-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .faq-card {
    background: rgba(255, 253, 231, 0.85);
    border: 2px solid rgba(33, 150, 243, 0.25);
    border-radius: 0.75rem;
    padding: 1.25rem;
    border-left: 5px solid #2196f3;
  }

  .related-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(255, 253, 231, 0.85);
    border: 2px solid rgba(76, 175, 80, 0.3);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 2px 2px 0 rgba(76, 175, 80, 0.2);
  }

  .related-card:hover {
    border-color: rgba(76, 175, 80, 0.7);
    box-shadow: 4px 4px 0 rgba(76, 175, 80, 0.3);
    transform: translate(-2px, -2px);
  }

  h1 { color: #bf360c; }
  h2 { color: #e65100; }
  .body-text { color: #4e342e; }
  .muted-text { color: #6d4c41; }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Back to School Wheel", url: "https://realwheelpicker.com/templates/back-to-school-wheel" },
  ]} />

  <div class="school-page">
    <!-- Fixed layers -->
    <div class="school-ruler"></div>
    <div class="school-chalk-strip"></div>
    <div class="school-paper"></div>
    <div class="school-glow-top"></div>
    <div class="school-apple-glow"></div>

    <!-- Floating school icons -->
    {[
      {icon:"🍎", l:"5%",  dur:"14s", delay:"0s"},
      {icon:"✏️", l:"18%", dur:"18s", delay:"-4s"},
      {icon:"📚", l:"32%", dur:"16s", delay:"-8s"},
      {icon:"🖊️", l:"50%", dur:"20s", delay:"-2s"},
      {icon:"📐", l:"65%", dur:"13s", delay:"-11s"},
      {icon:"🔬", l:"78%", dur:"17s", delay:"-5s"},
      {icon:"🎒", l:"90%", dur:"15s", delay:"-9s"},
      {icon:"🏫", l:"42%", dur:"22s", delay:"-14s"},
    ].map(({icon,l,dur,delay}) => (
      <div class="school-icon" style={`left:${l}; animation-duration:${dur}; animation-delay:${delay};`}>{icon}</div>
    ))}

    <!-- Math symbols -->
    {[
      {sym:"∑", l:"7%",  t:"20%", size:"3rem", dur:"5s"},
      {sym:"π", l:"85%", t:"30%", size:"2.5rem", dur:"6s"},
      {sym:"√", l:"60%", t:"15%", size:"2.8rem", dur:"4.5s"},
      {sym:"∞", l:"25%", t:"80%", size:"2.2rem", dur:"7s"},
      {sym:"Δ", l:"92%", t:"70%", size:"2rem", dur:"5.5s"},
    ].map(({sym,l,t,size,dur}) => (
      <div class="school-math" style={`left:${l}; top:${t}; font-size:${size}; animation-duration:${dur};`}>{sym}</div>
    ))}

    <div class="school-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-6 pb-12">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="text-xs muted-text flex gap-1 mb-6">
          <a href="/" class="hover:underline body-text transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:underline body-text transition-colors">Templates</a>
          <span>/</span>
          <span class="body-text font-medium">Back to School Wheel</span>
        </nav>

        <!-- Hero -->
        <section class="text-center space-y-4 py-4 mb-6">
          <div class="text-5xl mb-2">🎒</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight">
            Back to School Wheel — Random Subject & Activity Picker
          </h1>
          <p class="text-lg md:text-xl body-text max-w-2xl mx-auto">
            Replace the defaults with your actual subjects or school tasks. Spin to decide what to work on first. Works for students, teachers, and parents organizing back-to-school prep.
          </p>
          <div class="flex flex-wrap justify-center gap-2 mt-3">
            <span class="school-tag" style="background:#ff9800; color:#fff;">🍎 School</span>
            <span class="school-tag" style="background:#f44336; color:#fff;">📚 Study</span>
            <span class="school-tag" style="background:#2196f3; color:#fff;">🎓 Free</span>
            <span class="school-tag" style="background:#4caf50; color:#fff;">⚡ Instant</span>
          </div>
        </section>

        <!-- Wheel -->
        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={["#ff9800","#f44336","#2196f3","#ffeb3b","#ff5722","#4caf50","#ff9800","#e91e63","#1565c0","#ff6f00"]}
          wheelShape="circle"
          hubTheme="amber"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-10">

        <section class="space-y-6">
          <div class="school-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Why Random Study Order Works</h2>
            <p class="body-text leading-relaxed">
              Students who always study the same subjects in the same order hit a predictable pattern: they over-invest in the first subject (because they're fresh) and rush through the last one (because they're tired). Random order distributes attention more evenly across subjects and prevents the bias of "saving the hard one for when I have more energy" — which usually means not doing it at all.
            </p>
            <p class="body-text leading-relaxed">
              For teachers, a spinning wheel during class participation creates fairness and engagement. Students who know they might be called at any time pay more attention than those who know they won't be called for 15 minutes.
            </p>
          </div>
        </section>

        <!-- FAQ -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="faq-card">
                <p class="font-semibold body-text mb-2">{question}</p>
                <p class="muted-text text-sm leading-relaxed">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Related Tools -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/templates/vocabulary-wheel", label: "Vocabulary Wheel", desc: "Spin to practice random vocabulary words." },
              { href: "/templates/math-problem-wheel", label: "Math Problem Wheel", desc: "Random math topics for drills and practice." },
              { href: "/random-name-picker", label: "Random Name Picker", desc: "Call on random students during class." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="related-card">
                  <span style="color:#ff9800; font-weight:700; font-size:0.875rem; margin-top:2px;">→</span>
                  <span>
                    <span class="font-semibold body-text">{label}</span>
                    <span class="muted-text text-sm"> — {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
