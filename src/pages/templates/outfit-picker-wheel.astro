---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Outfit Picker Wheel — What Should I Wear Today?";
const description = "Can't decide what to wear? Spin the outfit wheel. Pick a style category and commit. Saves 10 minutes every morning. Free, instant, no signup.";
const canonical = "/templates/outfit-picker-wheel";

const faqItems = [
  {
    question: "How do I use this practically for getting dressed?",
    answer: "Spin to get a style direction — 'Casual', 'Smart Casual', 'All Black', etc. — then pick specific clothes within that style from your wardrobe. You're not picking an exact outfit, you're picking a direction, which is much faster.",
  },
  {
    question: "Can I add specific outfit combinations instead of styles?",
    answer: "Yes. Replace style names with your own outfit combinations: 'Blue jeans + white shirt', 'Floral dress', 'Work outfit 1', etc. This works best for planning a week of outfits in advance.",
  },
  {
    question: "What if I land on a style that doesn't fit my plans for the day?",
    answer: "The wheel can't know you have a business meeting or a gym session. Either customize it to include context-specific options ('Office day', 'Casual Friday', 'Gym') or re-spin if the result genuinely doesn't work.",
  },
];

const defaultParticipants = [
  { pseudo: "Casual", weight: 1 },
  { pseudo: "Smart Casual", weight: 1 },
  { pseudo: "Sporty", weight: 1 },
  { pseudo: "Business", weight: 1 },
  { pseudo: "All Black", weight: 1 },
  { pseudo: "Colorful", weight: 1 },
  { pseudo: "Vintage", weight: 1 },
  { pseudo: "Streetwear", weight: 1 },
  { pseudo: "Cozy & Layered", weight: 1 },
  { pseudo: "Dressy", weight: 1 },
  { pseudo: "Boho", weight: 1 },
  { pseudo: "Minimalist", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/outfit-picker-wheel",
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Outfit Picker Wheel", url: "https://realwheelpicker.com/templates/outfit-picker-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Outfit Picker Wheel</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Outfit Picker Wheel — What Should I Wear Today?
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          End the morning wardrobe paralysis. Spin for a style direction and get dressed in under 5 minutes.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <section class="space-y-8">
        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Why Getting Dressed Takes So Long</h2>
          <p class="text-muted-foreground leading-relaxed">
            The problem with getting dressed isn't a lack of clothes — most people own more clothes than they regularly wear. The problem is the daily re-evaluation of every combination. A style wheel short-circuits this by giving you a constraint. Instead of "which of my 40 possible outfits should I wear," you're answering the much simpler "which Casual outfit works today?"
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The random element also helps you rediscover clothes you own but rarely reach for. When the wheel lands on "Vintage" or "Colorful," you might pull out something that's been hanging untouched for months and remember why you liked it.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/hobby-wheel", label: "Hobby Wheel", desc: "Spin for a random activity after you're dressed and ready." },
            { href: "/yes-or-no-wheel", label: "Yes or No Wheel", desc: "Quick binary decisions — is this outfit good enough?" },
            { href: "/random-wheel", label: "Random Wheel", desc: "Build a custom wheel with your specific outfit options." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:load />
  </div>
</Layout>
