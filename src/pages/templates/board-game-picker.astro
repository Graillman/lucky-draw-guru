---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Board Game Picker — Random Game Night Selector";
const description = "Spin the board game picker wheel to decide what to play tonight. 12 popular games pre-loaded. Perfect for game nights when everyone can't agree. Free.";
const canonical = "/templates/board-game-picker";

const faqItems = [
  {
    question: "How do I make it fair for everyone?",
    answer: "Only add games that everyone in the group is willing to play. If one person hates Monopoly, remove it before spinning. The wheel should be a menu of acceptable options, not a list of everything you own.",
  },
  {
    question: "What about games with very different play times?",
    answer: "Consider adding a time filter. Create two wheels: quick games (under 30 minutes) and long games (1 hour+). Decide which wheel to use based on how much time you have, then spin for the specific game.",
  },
  {
    question: "Can I use this to pick expansions too?",
    answer: "Absolutely. Add expansion names alongside base games — 'Catan + Seafarers', 'Ticket to Ride Europe' — to include variant options in the selection.",
  },
];

const defaultParticipants = [
  { pseudo: "Catan", weight: 1 },
  { pseudo: "Monopoly", weight: 1 },
  { pseudo: "Scrabble", weight: 1 },
  { pseudo: "Codenames", weight: 1 },
  { pseudo: "Ticket to Ride", weight: 1 },
  { pseudo: "Azul", weight: 1 },
  { pseudo: "Pandemic", weight: 1 },
  { pseudo: "Uno", weight: 1 },
  { pseudo: "Chess", weight: 1 },
  { pseudo: "Risk", weight: 1 },
  { pseudo: "Jenga", weight: 1 },
  { pseudo: "Clue", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/board-game-picker",
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Board Game Picker", url: "https://realwheelpicker.com/templates/board-game-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Board Game Picker</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Board Game Picker — Random Game Night Selector
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          End the game night debate. Spin the wheel to pick your board game and get playing instead of arguing. Customize with your own collection.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- Wheel -->
      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <!-- Article Content -->
      <section class="space-y-8">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Running a Better Game Night</h2>
          <p class="text-muted-foreground leading-relaxed">
            Game nights have a consistent enemy: the selection process. You pull out the box collection, someone suggests Catan, someone else groans, Uno gets proposed, someone says they're bored of Uno, and twenty minutes later nobody has made a decision and enthusiasm is draining fast.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The board game picker wheel collapses that process to a single spin. The key is setting up the wheel before the night starts: ask everyone to text you their top three games they'd be happy to play, add those to the wheel, remove anything with a veto, and spin when everyone's seated and ready.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            This approach means the decision happens at setup time (low stakes, everyone contributes) rather than at start time (high stakes, decisions slow everything down). By the time you're all together, the wheel is ready and the game is just one spin away.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Game Night Tips</h2>
          <ul class="space-y-3 text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span><strong class="text-foreground">Rotate the spinner:</strong> Each week, a different person sets up the wheel. Their responsibility, their nominations influence the list.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span><strong class="text-foreground">Keep score across weeks:</strong> Which game gets chosen most often? Which one always gets removed? Interesting data about your group's actual preferences vs stated ones.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span><strong class="text-foreground">One newcomer per month:</strong> Add one game nobody has played before. Force discovery through the randomness of the wheel.</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">→</span><span><strong class="text-foreground">Backup rule:</strong> If the spin result would take longer than 90 minutes and it's already 9pm, spin again. Practical constraints override the wheel.</span></li>
          </ul>
        </div>

      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/video-game-picker", label: "Video Game Picker", desc: "For digital gaming sessions — spin for what to play on console or PC." },
            { href: "/templates/who-goes-first-wheel", label: "Who Goes First Wheel", desc: "Randomly decide turn order for any game." },
            { href: "/templates/truth-or-dare-wheel", label: "Truth or Dare Wheel", desc: "Add a party game after your board game session." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
