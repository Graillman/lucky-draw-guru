---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Board Game Picker — Random Game Night Selector";
const description = "Spin the board game picker wheel to decide what to play tonight. 12 popular games pre-loaded. Perfect for game nights when everyone can't agree. Free.";
const canonical = "/templates/board-game-picker";

const faqItems = [
  {
    question: "How do I make it fair for everyone?",
    answer: "Only add games that everyone in the group is willing to play. If one person hates Monopoly, remove it before spinning. The wheel should be a menu of acceptable options, not a list of everything you own.",
  },
  {
    question: "What about games with very different play times?",
    answer: "Consider adding a time filter. Create two wheels: quick games (under 30 minutes) and long games (1 hour+). Decide which wheel to use based on how much time you have, then spin for the specific game.",
  },
  {
    question: "Can I use this to pick expansions too?",
    answer: "Absolutely. Add expansion names alongside base games — 'Catan + Seafarers', 'Ticket to Ride Europe' — to include variant options in the selection.",
  },
];

const defaultParticipants = [
  { pseudo: "Catan", weight: 1 },
  { pseudo: "Monopoly", weight: 1 },
  { pseudo: "Scrabble", weight: 1 },
  { pseudo: "Codenames", weight: 1 },
  { pseudo: "Ticket to Ride", weight: 1 },
  { pseudo: "Azul", weight: 1 },
  { pseudo: "Pandemic", weight: 1 },
  { pseudo: "Uno", weight: 1 },
  { pseudo: "Chess", weight: 1 },
  { pseudo: "Risk", weight: 1 },
  { pseudo: "Jenga", weight: 1 },
  { pseudo: "Clue", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/board-game-picker",
};
---

<style>
  /* ===== GAME NIGHT THEME — dark wood table + neon signs ===== */

  .game-page {
    min-height: 100vh;
    background: #1a0a2e;
    position: relative;
    overflow-x: hidden;
  }

  /* Dark wood grain texture */
  .game-wood {
    position: fixed;
    inset: 0;
    background:
      repeating-linear-gradient(
        92deg,
        rgba(80, 40, 10, 0.15) 0px,
        rgba(80, 40, 10, 0.05) 4px,
        rgba(60, 30, 5, 0.1) 8px,
        rgba(100, 55, 15, 0.08) 14px,
        rgba(80, 40, 10, 0.12) 20px
      ),
      linear-gradient(180deg, #1a0a2e 0%, #0d0018 50%, #120820 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Neon sign glow — top */
  .game-neon-top {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #ff0080, #7b2fff, #00e5ff, #ff0080);
    background-size: 200% 100%;
    box-shadow: 0 0 12px rgba(123, 47, 255, 0.8), 0 0 24px rgba(255, 0, 128, 0.5);
    z-index: 100;
    pointer-events: none;
    animation: neonBorderScroll 4s linear infinite;
  }

  @keyframes neonBorderScroll {
    0%   { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }

  /* Glowing dice floating */
  .game-die {
    position: fixed;
    font-size: 2.5rem;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    filter: drop-shadow(0 0 8px rgba(255, 200, 50, 0.8));
    animation: dieRoll linear infinite;
  }

  @keyframes dieRoll {
    0%   { transform: translateY(110vh) rotate(0deg);   opacity: 0; }
    5%   { opacity: 0.5; }
    50%  { transform: translateY(45vh) rotate(180deg);  opacity: 0.5; }
    95%  { opacity: 0.5; }
    100% { transform: translateY(-15vh) rotate(360deg); opacity: 0; }
  }

  /* Neon ambient orbs */
  .game-orb {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    filter: blur(60px);
    animation: orbPulse ease-in-out infinite alternate;
  }

  @keyframes orbPulse {
    0%   { transform: scale(1);   opacity: 0.6; }
    100% { transform: scale(1.3); opacity: 1; }
  }

  /* Playing card suits floating */
  .game-suit {
    position: fixed;
    font-size: 1.4rem;
    pointer-events: none;
    z-index: 2;
    opacity: 0.12;
    animation: suitFloat ease-in-out infinite;
  }

  @keyframes suitFloat {
    0%, 100% { transform: translateY(0) rotate(-5deg); opacity: 0.12; }
    50%       { transform: translateY(-16px) rotate(5deg); opacity: 0.2; }
  }

  /* Board squares strip at bottom */
  .game-squares {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 12px;
    display: flex;
    z-index: 100;
    pointer-events: none;
  }

  .game-square {
    flex: 1;
    animation: squareFlash ease-in-out infinite alternate;
  }

  @keyframes squareFlash {
    0%   { opacity: 0.4; }
    100% { opacity: 1; }
  }

  /* Content */
  .game-content {
    position: relative;
    z-index: 10;
  }

  /* Dark cards */
  .game-card {
    background: rgba(15, 5, 35, 0.75);
    border: 1px solid rgba(123, 47, 255, 0.35);
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 0 20px rgba(123, 47, 255, 0.1), inset 0 1px 0 rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
  }

  .game-inner-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 200, 50, 0.2);
    border-radius: 0.75rem;
    padding: 0.875rem;
  }

  .game-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    border: 1px solid;
  }

  .faq-card {
    background: rgba(15, 5, 35, 0.7);
    border: 1px solid rgba(0, 229, 255, 0.25);
    border-radius: 1rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }

  .related-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(15, 5, 35, 0.7);
    border: 1px solid rgba(255, 0, 128, 0.25);
    border-radius: 1rem;
    text-decoration: none;
    transition: all 0.2s;
    backdrop-filter: blur(8px);
  }

  .related-card:hover {
    border-color: rgba(255, 0, 128, 0.7);
    box-shadow: 0 0 20px rgba(255, 0, 128, 0.2);
    transform: translateY(-2px);
  }

  h1 { color: #fff; text-shadow: 0 0 30px rgba(123, 47, 255, 0.5); }
  h2 { color: #e0b8ff; }
  .body-text { color: #c8b8e8; }
  .muted-text { color: #9b8aba; }
  .breadcrumb-text { color: #9b8aba; }
  .breadcrumb-text:hover { color: #e0b8ff; }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Board Game Picker", url: "https://realwheelpicker.com/templates/board-game-picker" },
  ]} />

  <div class="game-page">
    <!-- Fixed atmosphere -->
    <div class="game-neon-top"></div>
    <div class="game-wood"></div>

    <!-- Neon orbs -->
    {[
      {top:"-80px", left:"-80px",  w:"350px", h:"350px", bg:"rgba(123,47,255,0.35)", dur:"6s"},
      {top:"-60px", right:"-60px", w:"300px", h:"300px", bg:"rgba(255,0,128,0.25)",  dur:"8s"},
      {bottom:"-100px", left:"30%", w:"400px", h:"300px", bg:"rgba(0,229,255,0.2)", dur:"7s"},
    ].map(({top,left,right,bottom,w,h,bg,dur}) => (
      <div class="game-orb" style={`${top?`top:${top};`:''}${left?`left:${left};`:''}${right?`right:${right};`:''}${bottom?`bottom:${bottom};`:''} width:${w}; height:${h}; background:${bg}; animation-duration:${dur};`}></div>
    ))}

    <!-- Floating dice -->
    {["🎲","🎯","🎲","🃏","🎲","♟️","🎲","🎯"].map((icon, i) => (
      <div class="game-die" style={`left:${12 + i * 11}%; animation-duration:${14 + i * 2}s; animation-delay:-${i * 3}s;`}>{icon}</div>
    ))}

    <!-- Card suits -->
    {["♠","♥","♦","♣","♠","♥","♦","♣"].map((suit, i) => (
      <div class="game-suit" style={`left:${8 + i * 12}%; top:${15 + (i % 3) * 20}%; color:${i%2===0?'#ff4444':'#fff'}; font-size:${1.2 + (i%3)*0.4}rem; animation-duration:${4+i}s;`}>{suit}</div>
    ))}

    <!-- Bottom squares -->
    <div class="game-squares">
      {["#e53935","#1e88e5","#43a047","#fdd835","#8e24aa","#fb8c00","#e53935","#1e88e5","#43a047","#fdd835","#8e24aa","#fb8c00","#e53935","#1e88e5","#43a047","#fdd835","#8e24aa","#fb8c00","#e53935","#1e88e5"].map((c, i) => (
        <div class="game-square" style={`background:${c}; animation-delay:${i*0.15}s;`}></div>
      ))}
    </div>

    <div class="game-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-6 pb-12">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="text-xs breadcrumb-text flex gap-1 mb-6">
          <a href="/" class="breadcrumb-text transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="breadcrumb-text transition-colors">Templates</a>
          <span>/</span>
          <span style="color:#e0b8ff;">Board Game Picker</span>
        </nav>

        <!-- Hero -->
        <section class="text-center space-y-4 py-4 mb-6">
          <div class="text-5xl mb-2">🎲</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight">
            Board Game Picker — Random Game Night Selector
          </h1>
          <p class="text-lg md:text-xl body-text max-w-2xl mx-auto">
            End the game night debate. Spin the wheel to pick your board game and get playing instead of arguing. Customize with your own collection.
          </p>
          <div class="flex flex-wrap justify-center gap-2 mt-3">
            <span class="game-tag" style="border-color:#7b2fff; color:#c084fc; background:rgba(123,47,255,0.15);">🎲 Games</span>
            <span class="game-tag" style="border-color:#ff0080; color:#f9a8d4; background:rgba(255,0,128,0.1);">🃏 Night</span>
            <span class="game-tag" style="border-color:#00e5ff; color:#67e8f9; background:rgba(0,229,255,0.1);">⚡ Free</span>
          </div>
        </section>

        <!-- Wheel -->
        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={["#e53935","#1e88e5","#fdd835","#43a047","#8e24aa","#fb8c00","#e91e63","#00acc1","#ff5722","#7b1fa2","#f57c00","#2e7d32"]}
          wheelShape="hexagon"
          hubTheme="purple"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-10">

        <section class="space-y-6">
          <div class="game-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Running a Better Game Night</h2>
            <p class="body-text leading-relaxed">
              Game nights have a consistent enemy: the selection process. You pull out the box collection, someone suggests Catan, someone else groans, Uno gets proposed, someone says they're bored of Uno, and twenty minutes later nobody has made a decision and enthusiasm is draining fast.
            </p>
            <p class="body-text leading-relaxed">
              The board game picker wheel collapses that process to a single spin. The key is setting up the wheel before the night starts: ask everyone to text you their top three games they'd be happy to play, add those to the wheel, remove anything with a veto, and spin when everyone's seated and ready.
            </p>
            <p class="body-text leading-relaxed">
              This approach means the decision happens at setup time (low stakes, everyone contributes) rather than at start time (high stakes, decisions slow everything down). By the time you're all together, the wheel is ready and the game is just one spin away.
            </p>
          </div>

          <div class="game-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">Game Night Tips</h2>
            <ul class="space-y-3 body-text">
              <li class="flex gap-3"><span style="color:#7b2fff; font-weight:700;">→</span><span><strong style="color:#e0b8ff;">Rotate the spinner:</strong> Each week, a different person sets up the wheel. Their responsibility, their nominations influence the list.</span></li>
              <li class="flex gap-3"><span style="color:#ff0080; font-weight:700;">→</span><span><strong style="color:#e0b8ff;">Keep score across weeks:</strong> Which game gets chosen most often? Which one always gets removed? Interesting data about your group's actual preferences vs stated ones.</span></li>
              <li class="flex gap-3"><span style="color:#00e5ff; font-weight:700;">→</span><span><strong style="color:#e0b8ff;">One newcomer per month:</strong> Add one game nobody has played before. Force discovery through the randomness of the wheel.</span></li>
              <li class="flex gap-3"><span style="color:#fdd835; font-weight:700;">→</span><span><strong style="color:#e0b8ff;">Backup rule:</strong> If the spin result would take longer than 90 minutes and it's already 9pm, spin again. Practical constraints override the wheel.</span></li>
            </ul>
          </div>
        </section>

        <!-- FAQ -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#e0b8ff;">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="faq-card">
                <p class="font-semibold mb-2" style="color:#e0b8ff;">{question}</p>
                <p class="muted-text text-sm leading-relaxed">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Related Tools -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#e0b8ff;">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/templates/video-game-picker", label: "Video Game Picker", desc: "For digital gaming sessions — spin for what to play on console or PC." },
              { href: "/templates/who-goes-first-wheel", label: "Who Goes First Wheel", desc: "Randomly decide turn order for any game." },
              { href: "/templates/truth-or-dare-wheel", label: "Truth or Dare Wheel", desc: "Add a party game after your board game session." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="related-card">
                  <span style="color:#ff0080; font-weight:700; font-size:0.875rem; margin-top:2px;">→</span>
                  <span>
                    <span class="font-semibold" style="color:#e0b8ff;">{label}</span>
                    <span class="muted-text text-sm"> — {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
