---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Vocabulary Wheel — Random Word Practice Spinner";
const description = "Spin the vocabulary wheel for a random word to define, use in a sentence, or explore. 12 advanced words pre-loaded. Great for SAT prep, writers, and word lovers.";
const canonical = "/templates/vocabulary-wheel";

const faqItems = [
  {
    question: "How do I use this for vocabulary study?",
    answer: "Spin the wheel to get a word, then try to define it without looking it up. Check your answer, then use the word in an original sentence. Repeat for 5-10 words per session. Active recall (guessing before checking) is far more effective than passive reading.",
  },
  {
    question: "Can I replace the pre-loaded words with my own list?",
    answer: "Yes — paste in your own vocabulary list, SAT words, foreign language vocabulary, or subject-specific terminology. The wheel works with any language and any word list.",
  },
  {
    question: "Is this good for ESL or language learning?",
    answer: "Excellent for language learning. Load the wheel with target language words you're studying, spin for the word, try to recall the meaning, then check. The visual randomness keeps review sessions engaging rather than monotonous.",
  },
];

const defaultParticipants = [
  { pseudo: "Ephemeral", weight: 1 },
  { pseudo: "Ubiquitous", weight: 1 },
  { pseudo: "Serendipity", weight: 1 },
  { pseudo: "Melancholy", weight: 1 },
  { pseudo: "Eloquent", weight: 1 },
  { pseudo: "Tenacious", weight: 1 },
  { pseudo: "Ambiguous", weight: 1 },
  { pseudo: "Resilient", weight: 1 },
  { pseudo: "Pragmatic", weight: 1 },
  { pseudo: "Verbose", weight: 1 },
  { pseudo: "Enigmatic", weight: 1 },
  { pseudo: "Pensive", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/vocabulary-wheel",
};

const themeColors = ['#1e3a5f','#d4a853','#f5f5dc','#8b4513','#2d4a8a','#c5b358','#4a3728','#0f2744','#b8860b','#6b7280'];
---

<style>
  /* ═══ ENCRE ET PLUME ═══ */
  .vw-page {
    background: #050d1a;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  .vw-sky {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 90% 60% at 30% 40%, rgba(30,58,95,0.6) 0%, transparent 60%),
                radial-gradient(ellipse 70% 50% at 70% 70%, rgba(15,39,68,0.5) 0%, transparent 55%),
                radial-gradient(ellipse 50% 40% at 50% 10%, rgba(44,74,138,0.3) 0%, transparent 50%),
                linear-gradient(180deg, #020810 0%, #050d1a 60%, #030810 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Floating alphabet letters */
  .vw-letter {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    font-weight: 900;
    font-family: serif;
    color: rgba(212,168,83,0.35);
    animation: vwLetterFloat ease-in-out infinite;
    text-shadow: 0 0 10px rgba(212,168,83,0.2);
  }
  @keyframes vwLetterFloat {
    0%, 100% { transform: translateY(0px) rotate(var(--rot)); opacity: 0.25; }
    33%       { transform: translateY(-15px) rotate(calc(var(--rot) + 5deg)); opacity: 0.5; }
    66%       { transform: translateY(8px) rotate(calc(var(--rot) - 3deg)); opacity: 0.35; }
  }

  /* Ink blots */
  .vw-inkblot {
    position: fixed;
    pointer-events: none;
    z-index: 1;
    border-radius: 40% 60% 55% 45% / 50% 45% 55% 50%;
    background: rgba(5, 15, 35, 0.8);
    filter: blur(25px);
    animation: vwInkSpread ease-in-out infinite alternate;
  }
  @keyframes vwInkSpread {
    0%   { transform: scale(1) rotate(0deg); opacity: 0.6; }
    100% { transform: scale(1.08) rotate(3deg); opacity: 0.8; }
  }

  /* Moving quill */
  .vw-quill {
    position: fixed;
    pointer-events: none;
    z-index: 3;
    font-size: 2.5rem;
    animation: vwQuillMove ease-in-out infinite;
  }
  @keyframes vwQuillMove {
    0%   { transform: translate(0px, 0px) rotate(-15deg); }
    25%  { transform: translate(30px, -20px) rotate(-10deg); }
    50%  { transform: translate(60px, 5px) rotate(-18deg); }
    75%  { transform: translate(20px, 20px) rotate(-8deg); }
    100% { transform: translate(0px, 0px) rotate(-15deg); }
  }

  /* Floating words */
  .vw-word {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    font-family: serif;
    font-style: italic;
    color: rgba(197,179,88,0.2);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    animation: vwWordDrift ease-in-out infinite;
  }
  @keyframes vwWordDrift {
    0%, 100% { transform: translateX(0px) translateY(0px); opacity: 0.15; }
    50%       { transform: translateX(12px) translateY(-8px); opacity: 0.35; }
  }

  /* Glow orbs (deep marine) */
  .vw-glow {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(70px);
    animation: vwGlowPulse ease-in-out infinite alternate;
  }
  @keyframes vwGlowPulse {
    0%   { opacity: 0.25; transform: scale(1); }
    100% { opacity: 0.45; transform: scale(1.1); }
  }

  /* Ink drip lines */
  .vw-drip {
    position: fixed;
    width: 2px;
    background: linear-gradient(180deg, transparent, rgba(30,58,95,0.7), rgba(5,15,40,0.9), transparent);
    pointer-events: none;
    z-index: 1;
    animation: vwDripFlow ease-in-out infinite;
    border-radius: 1px;
  }
  @keyframes vwDripFlow {
    0%   { transform: translateY(-30px) scaleY(0.5); opacity: 0; }
    20%  { opacity: 0.6; }
    80%  { opacity: 0.4; }
    100% { transform: translateY(60px) scaleY(1.5); opacity: 0; }
  }

  /* Content */
  .vw-content { position: relative; z-index: 10; }

  .vw-title {
    background: linear-gradient(90deg, #d4a853, #f5f5dc, #c5b358, #b8860b, #d4a853);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: vwTitleShimmer 6s linear infinite;
    filter: drop-shadow(0 0 25px rgba(212,168,83,0.5));
  }
  @keyframes vwTitleShimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  .vw-tag {
    background: rgba(212,168,83,0.12);
    border: 1px solid rgba(212,168,83,0.35);
    color: rgba(212,168,83,0.9);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .vw-card {
    background: rgba(3,8,20,0.82);
    border: 1px solid rgba(212,168,83,0.18);
    border-radius: 1rem;
    transition: border-color 0.2s, background 0.2s;
    backdrop-filter: blur(8px);
  }
  .vw-card:hover {
    border-color: rgba(212,168,83,0.45);
    background: rgba(5,12,28,0.9);
  }

  details.vw-faq {
    background: rgba(3,8,20,0.82);
    border: 1px solid rgba(212,168,83,0.15);
    border-radius: 0.75rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }
  details.vw-faq[open] {
    border-color: rgba(212,168,83,0.42);
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Vocabulary Wheel", url: "https://realwheelpicker.com/templates/vocabulary-wheel" },
  ]} />

  <div class="vw-page">
    <div class="vw-sky"></div>

    <!-- Deep marine glow orbs -->
    <div class="vw-glow" style="width:500px;height:400px;background:rgba(30,58,95,0.5);top:10%;left:-10%;animation-duration:9s;"></div>
    <div class="vw-glow" style="width:400px;height:350px;background:rgba(15,39,68,0.4);top:50%;right:-8%;animation-duration:11s;animation-delay:3s;"></div>
    <div class="vw-glow" style="width:350px;height:300px;background:rgba(44,74,138,0.3);bottom:10%;left:30%;animation-duration:8s;animation-delay:5s;"></div>

    <!-- 5 ink blots -->
    <div class="vw-inkblot" style="width:300px;height:200px;top:5%;left:-5%;animation-duration:7s;"></div>
    <div class="vw-inkblot" style="width:250px;height:180px;top:40%;right:-3%;animation-duration:9s;animation-delay:2s;"></div>
    <div class="vw-inkblot" style="width:200px;height:150px;bottom:20%;left:5%;animation-duration:8s;animation-delay:4s;"></div>
    <div class="vw-inkblot" style="width:350px;height:220px;bottom:5%;right:10%;animation-duration:10s;animation-delay:1s;"></div>
    <div class="vw-inkblot" style="width:180px;height:130px;top:25%;left:40%;animation-duration:6s;animation-delay:3s;"></div>

    <!-- Moving quill -->
    <div class="vw-quill" style="top:15%;right:15%;animation-duration:12s;">✒️</div>

    <!-- 30 floating alphabet letters -->
    {Array.from({ length: 30 }, (_, i) => {
      const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
      const l = letters[i % 26];
      const sizes = [0.9, 1.1, 1.4, 1.8, 2.2, 2.8, 3.5];
      const size = sizes[i % sizes.length];
      const rot = ((i * 23) % 40) - 20;
      return (
        <span class="vw-letter" style={`font-size:${size}rem;left:${(i * 3.2 + 1) % 97}%;top:${(i * 8.5 + 3) % 88}%;animation-duration:${5 + i % 6}s;animation-delay:${i * 0.3}s;--rot:${rot}deg;`}>{l}</span>
      );
    })}

    <!-- 15 floating vocabulary words -->
    {['vocabulary','lexicon','prose','syntax','diction','grammar','rhetoric','eloquence','semantics','etymology','syllable','morpheme','phoneme','dialect','idiom'].map((word, i) => (
      <span class="vw-word" style={`left:${(i * 6.5 + 2) % 90}%;top:${(i * 9 + 4) % 92}%;animation-duration:${6 + i * 0.7}s;animation-delay:${i * 0.45}s;font-size:${0.6 + (i % 3) * 0.1}rem;`}>{word}</span>
    ))}

    <!-- 8 ink drip lines -->
    {Array.from({ length: 8 }, (_, i) => (
      <div class="vw-drip" style={`height:${60 + i * 20}px;left:${10 + i * 11}%;top:${5 + (i % 4) * 22}%;animation-duration:${4 + i * 0.8}s;animation-delay:${i * 0.6}s;`}></div>
    ))}

    <div class="vw-content">
      <HeaderIsland client:load />
      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Vocabulary Wheel</span>
        </nav>
        <div class="text-center mb-8">
          <div class="text-5xl mb-3">✒️</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight vw-title mb-3">Vocabulary Wheel</h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">Spin for a random vocabulary word to define, use in a sentence, or explore. 12 advanced words pre-loaded — replace with your own study list for personalized practice.</p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="vw-tag">Word Practice</span>
            <span class="vw-tag">SAT Prep</span>
            <span class="vw-tag">Language Learning</span>
          </div>
        </div>
        <SimpleWheelIsland defaultParticipants={defaultParticipants} colors={themeColors} wheelShape="hexagon" hubTheme="amber" client:load />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="vw-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Better Vocabulary Through Random Practice</h2>
          <p class="text-white/60 leading-relaxed">Vocabulary growth stalls when practice becomes predictable. Studying a word list in order means you always know what's coming next, which reduces the retrieval challenge that makes learning stick. Random selection forces genuine recall — you don't know which word is coming, so you can't prepare, which means you're actually testing your memory rather than your pattern recognition.</p>
          <p class="text-white/60 leading-relaxed">The vocabulary wheel creates a game-like quality to word review. Spin, see the word, try to define it before looking it up, then check. This active recall approach, combined with the visual randomness of the spin, makes vocabulary practice significantly more effective than passive re-reading.</p>
          <p class="text-white/60 leading-relaxed">For classroom use, the wheel makes vocabulary review a group activity. Spin for a word, call on a student to define it or use it in a sentence. The randomness keeps everyone engaged because any student might be called next.</p>
        </div>

        <div class="vw-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Quick Definitions for the Pre-Loaded Words</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {[
              ["Ephemeral", "Lasting for only a brief time; short-lived"],
              ["Ubiquitous", "Present, appearing, or found everywhere"],
              ["Serendipity", "The occurrence of fortunate events by chance"],
              ["Tenacious", "Holding firmly to a purpose; persistent"],
              ["Pragmatic", "Dealing with things practically and realistically"],
              ["Enigmatic", "Mysterious and difficult to understand"],
            ].map(([word, def]) => (
              <div class="p-3 rounded-lg bg-amber-900/20 border border-amber-700/25">
                <p class="font-semibold text-amber-300 text-sm">{word}</p>
                <p class="text-white/55 text-xs mt-1">{def}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="vw-card p-6 space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Study Methods That Work</h2>
          <div class="space-y-3">
            <div class="p-4 rounded-lg bg-blue-900/20 border border-blue-700/25">
              <p class="font-semibold text-white text-sm mb-1">Active Recall</p>
              <p class="text-white/60 text-sm">Spin the wheel, see the word, attempt to define it without looking. Check after. This struggle is where learning happens.</p>
            </div>
            <div class="p-4 rounded-lg bg-indigo-900/20 border border-indigo-700/25">
              <p class="font-semibold text-white text-sm mb-1">Sentence Creation</p>
              <p class="text-white/60 text-sm">Write a sentence using the spun word in context. Own vocabulary is retained far better than memorized definitions.</p>
            </div>
            <div class="p-4 rounded-lg bg-slate-800/40 border border-slate-600/25">
              <p class="font-semibold text-white text-sm mb-1">Spaced Repetition</p>
              <p class="text-white/60 text-sm">Run 5-minute sessions daily. The random spin ensures natural spaced repetition without needing a flashcard app.</p>
            </div>
          </div>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="vw-faq group">
                <summary class="font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-2">
                  {question}
                  <span class="text-white/40 shrink-0 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <p class="text-white/60 text-sm leading-relaxed mt-3">{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-white">Related Tools</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {[
              { href: "/templates/writing-prompt-wheel", label: "Writing Prompt Spinner", desc: "Put your vocabulary to use — random story starters to practice new words." },
              { href: "/templates/math-problem-wheel", label: "Math Problem Spinner", desc: "Random math topic selector for balanced study sessions." },
              { href: "/classroom-picker", label: "Classroom Picker", desc: "Random student name picker for interactive classroom activities." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="vw-card flex items-start gap-3 p-4">
                  <span>
                    <span class="font-semibold text-white text-sm">{label}</span>
                    <span class="text-white/50 text-sm block mt-0.5">{desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      </main>

      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
