---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Vocabulary Wheel — Random Word Practice Spinner";
const description = "Spin the vocabulary wheel for a random word to define, use in a sentence, or explore. 12 advanced words pre-loaded. Great for SAT prep, writers, and word lovers.";
const canonical = "/templates/vocabulary-wheel";

const faqItems = [
  {
    question: "How do I use this for vocabulary study?",
    answer: "Spin the wheel to get a word, then try to define it without looking it up. Check your answer, then use the word in an original sentence. Repeat for 5-10 words per session. Active recall (guessing before checking) is far more effective than passive reading.",
  },
  {
    question: "Can I replace the pre-loaded words with my own list?",
    answer: "Yes — paste in your own vocabulary list, SAT words, foreign language vocabulary, or subject-specific terminology. The wheel works with any language and any word list.",
  },
  {
    question: "Is this good for ESL or language learning?",
    answer: "Excellent for language learning. Load the wheel with target language words you're studying, spin for the word, try to recall the meaning, then check. The visual randomness keeps review sessions engaging rather than monotonous.",
  },
];

const defaultParticipants = [
  { pseudo: "Ephemeral", weight: 1 },
  { pseudo: "Ubiquitous", weight: 1 },
  { pseudo: "Serendipity", weight: 1 },
  { pseudo: "Melancholy", weight: 1 },
  { pseudo: "Eloquent", weight: 1 },
  { pseudo: "Tenacious", weight: 1 },
  { pseudo: "Ambiguous", weight: 1 },
  { pseudo: "Resilient", weight: 1 },
  { pseudo: "Pragmatic", weight: 1 },
  { pseudo: "Verbose", weight: 1 },
  { pseudo: "Enigmatic", weight: 1 },
  { pseudo: "Pensive", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/vocabulary-wheel",
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Vocabulary Wheel", url: "https://realwheelpicker.com/templates/vocabulary-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Vocabulary Wheel</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Vocabulary Wheel — Random Word Practice Spinner
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Spin for a random vocabulary word to define, use in a sentence, or explore. 12 advanced words pre-loaded. Replace with your own study list for personalized practice.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- Wheel -->
      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <!-- Article Content -->
      <section class="space-y-8">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Better Vocabulary Through Random Practice</h2>
          <p class="text-muted-foreground leading-relaxed">
            Vocabulary growth stalls when practice becomes predictable. Studying a word list in order means you always know what's coming next, which reduces the retrieval challenge that makes learning stick. Random selection forces genuine recall — you don't know which word is coming, so you can't prepare, which means you're actually testing your memory rather than your pattern recognition.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The vocabulary wheel creates a game-like quality to word review. Spin, see the word, try to define it before looking it up, then check. This active recall approach, combined with the visual randomness of the spin, makes vocabulary practice significantly more effective than passive re-reading.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            For classroom use, the wheel makes vocabulary review a group activity. Spin for a word, call on a student to define it or use it in a sentence. The randomness keeps everyone engaged because any student might be called next.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Quick Definitions for the Pre-Loaded Words</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {[
              ["Ephemeral", "Lasting for only a brief time; short-lived"],
              ["Ubiquitous", "Present, appearing, or found everywhere"],
              ["Serendipity", "The occurrence of fortunate events by chance"],
              ["Tenacious", "Holding firmly to a purpose; persistent"],
              ["Pragmatic", "Dealing with things practically and realistically"],
              ["Enigmatic", "Mysterious and difficult to understand"],
            ].map(([word, def]) => (
              <div class="p-3 rounded-lg bg-primary/5 border border-primary/20">
                <p class="font-semibold text-foreground text-sm">{word}</p>
                <p class="text-muted-foreground text-xs mt-1">{def}</p>
              </div>
            ))}
          </div>
        </div>

      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/templates/writing-prompt-wheel", label: "Writing Prompt Spinner", desc: "Put your vocabulary to use — random story starters to practice new words." },
            { href: "/templates/math-problem-wheel", label: "Math Problem Spinner", desc: "Random math topic selector for balanced study sessions." },
            { href: "/classroom-picker", label: "Classroom Picker", desc: "Random student name picker for interactive classroom activities." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
