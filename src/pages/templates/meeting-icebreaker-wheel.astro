---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Meeting Icebreaker Spinner — Quick Team Questions";
const description = "Start meetings with a random icebreaker question. Pre-loaded with 8 professional prompts. Spin, ask, answer, move on. Under 2 minutes.";
const canonical = "/templates/meeting-icebreaker-wheel";

const faqItems = [
  {
    question: "How long should meeting icebreakers take?",
    answer: "Under 2 minutes for small teams, up to 5 minutes for larger groups. Keep it moving — one spin, one question, everyone answers quickly. The goal is warmth and presence, not a therapy session.",
  },
  {
    question: "Are these appropriate for all workplace cultures?",
    answer: "The defaults are intentionally neutral and professional. Customize them for your team's culture — a startup might want more creative prompts, while a corporate team might want strictly work-related questions.",
  },
  {
    question: "Can I use this for virtual meetings?",
    answer: "Works great for remote teams. Screen-share the wheel, spin live, and let everyone answer in the chat or unmute in order. It's even more valuable remotely where casual conversation doesn't happen naturally.",
  },
];

const defaultParticipants = [
  { pseudo: "Highlight of your week?", weight: 1 },
  { pseudo: "Learning something new?", weight: 1 },
  { pseudo: "Best meal lately?", weight: 1 },
  { pseudo: "Morning routine tip?", weight: 1 },
  { pseudo: "Podcast recommendation?", weight: 1 },
  { pseudo: "Unpopular work opinion?", weight: 1 },
  { pseudo: "Superpower you'd want?", weight: 1 },
  { pseudo: "Weekend plans?", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/meeting-icebreaker-wheel",
};

const themeColors = ['#1e3a5f','#14b8a6','#ffffff','#f59e0b','#0f2744','#0d9488','#f5f5f5','#d97706','#2dd4bf','#1e40af'];

const coffeePos = [
  { left: '5%', top: '15%', delay: '0s', duration: '3s' },
  { left: '20%', top: '65%', delay: '0.8s', duration: '3.5s' },
  { right: '8%', top: '25%', delay: '1.5s', duration: '2.8s' },
  { right: '22%', top: '55%', delay: '0.3s', duration: '3.2s' },
  { left: '45%', top: '5%', delay: '1.1s', duration: '3.8s' },
];

const connectionNodes = Array.from({length: 10}, (_, i) => ({
  left: `${10 + (i * 8.5) % 80}%`,
  top: `${15 + (i * 11.3) % 65}%`,
  delay: `${(i * 0.35).toFixed(1)}s`,
  duration: `${2.5 + (i % 3) * 0.5}s`,
  color: i % 2 === 0 ? '#14b8a6' : '#2dd4bf',
}));

const particles = Array.from({length: 20}, (_, i) => ({
  left: `${(i * 5.3) % 100}%`,
  delay: `${(i * 0.45).toFixed(2)}s`,
  duration: `${4 + (i % 4) * 1.1}s`,
  size: `${4 + (i % 3) * 2}px`,
  color: i % 3 === 0 ? '#14b8a6' : i % 3 === 1 ? '#2dd4bf' : '#0d9488',
}));

const steamLines = [
  { delay: '0s', xOffset: '0px' },
  { delay: '0.4s', xOffset: '4px' },
  { delay: '0.2s', xOffset: '-4px' },
];
---

<style>
  .mi-page {
    background: #050f1a;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }
  .mi-sky {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(ellipse at 20% 20%, rgba(20,184,166,0.1) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(30,58,95,0.3) 0%, transparent 50%);
  }
  .mi-halo-teal {
    position: fixed;
    top: -15%;
    left: -10%;
    width: 55vw;
    height: 55vw;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(20,184,166,0.14) 0%, transparent 65%);
    z-index: 1;
    pointer-events: none;
    animation: miHaloTeal 7s ease-in-out infinite;
  }
  @keyframes miHaloTeal {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }
  .mi-halo-amber {
    position: fixed;
    bottom: -10%;
    right: -10%;
    width: 50vw;
    height: 50vw;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245,158,11,0.1) 0%, transparent 65%);
    z-index: 1;
    pointer-events: none;
  }
  .mi-coffee-wrapper {
    position: fixed;
    z-index: 3;
    pointer-events: none;
    font-size: 2rem;
  }
  .mi-coffee-icon {
    animation: miCoffeeFloat var(--cfdur) var(--cfdelay) ease-in-out infinite;
    display: inline-block;
  }
  @keyframes miCoffeeFloat {
    0%, 100% { transform: translateY(0px) rotate(-5deg); }
    50% { transform: translateY(-10px) rotate(5deg); }
  }
  .mi-steam {
    position: absolute;
    top: -18px;
    width: 3px;
    height: 14px;
    border-radius: 2px;
    background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.6) 50%, rgba(255,255,255,0) 100%);
    animation: miSteamRise 1.5s var(--sfdelay) ease-out infinite;
  }
  @keyframes miSteamRise {
    0% { transform: translateY(0px) translateX(var(--sx)) scaleY(1); opacity: 0.7; }
    100% { transform: translateY(-18px) translateX(calc(var(--sx) * 1.5)) scaleY(0.5); opacity: 0; }
  }
  .mi-node {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    animation: miNodePulse var(--ndur) var(--ndelay) ease-in-out infinite;
  }
  @keyframes miNodePulse {
    0%, 100% { transform: scale(1); opacity: 0.6; box-shadow: 0 0 6px var(--ncol); }
    50% { transform: scale(1.3); opacity: 1; box-shadow: 0 0 16px var(--ncol); }
  }
  .mi-particle {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 3;
    animation: miParticleRise var(--mpdur) var(--mpdelay) ease-out infinite;
  }
  @keyframes miParticleRise {
    0% { transform: translateY(0px) scale(1); opacity: 0.8; }
    100% { transform: translateY(-60px) scale(0.3); opacity: 0; }
  }
  .mi-graph {
    position: fixed;
    right: 3%;
    top: 35%;
    width: 80px;
    height: 60px;
    z-index: 2;
    pointer-events: none;
    opacity: 0.12;
    animation: miGraphBob 4s ease-in-out infinite;
  }
  @keyframes miGraphBob {
    0%, 100% { transform: translateY(0px); opacity: 0.1; }
    50% { transform: translateY(-5px); opacity: 0.18; }
  }
  .mi-clock {
    position: fixed;
    left: 3%;
    bottom: 25%;
    font-size: 2.5rem;
    z-index: 2;
    pointer-events: none;
    opacity: 0.15;
    animation: miClockTick 2s steps(1) infinite;
  }
  @keyframes miClockTick {
    0% { opacity: 0.12; }
    50% { opacity: 0.2; }
  }
  .mi-content {
    position: relative;
    z-index: 10;
  }
  .mi-title {
    background: linear-gradient(135deg, #14b8a6 0%, #ffffff 40%, #f59e0b 70%, #2dd4bf 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: miShimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 25px rgba(20,184,166,0.4));
  }
  @keyframes miShimmer {
    0%, 100% { filter: drop-shadow(0 0 25px rgba(20,184,166,0.4)); }
    50% { filter: drop-shadow(0 0 40px rgba(245,158,11,0.4)); }
  }
  .mi-card {
    background: rgba(5,15,26,0.85);
    border: 1px solid rgba(20,184,166,0.22);
    border-radius: 1rem;
    padding: 1.5rem;
  }
  .mi-card h2 { color: #f0fdfa; }
  .mi-card p, .mi-card li { color: rgba(240,253,250,0.65); line-height: 1.7; }
  .mi-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    border: 1px solid rgba(20,184,166,0.3);
    background: rgba(20,184,166,0.1);
    color: #5eead4;
  }
  details.mi-faq {
    background: rgba(5,15,26,0.85);
    border: 1px solid rgba(20,184,166,0.18);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
  details.mi-faq summary {
    font-weight: 600;
    color: #f0fdfa;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  details.mi-faq summary::before { content: '☕'; font-size: 0.9rem; }
  details.mi-faq[open] summary::before { content: '💡'; }
  details.mi-faq p {
    margin-top: 0.75rem;
    color: rgba(240,253,250,0.65);
    font-size: 0.9rem;
    line-height: 1.7;
  }
  .mi-related-link {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(5,15,26,0.85);
    border: 1px solid rgba(20,184,166,0.18);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .mi-related-link:hover {
    border-color: rgba(20,184,166,0.45);
    box-shadow: 0 0 20px rgba(20,184,166,0.12);
  }
  .mi-connection-line {
    position: fixed;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(20,184,166,0.3), transparent);
    pointer-events: none;
    z-index: 2;
    animation: miLineFlash 4s ease-in-out infinite;
  }
  @keyframes miLineFlash {
    0%, 100% { opacity: 0; }
    40%, 60% { opacity: 1; }
  }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Meeting Icebreaker Spinner", url: "https://realwheelpicker.com/templates/meeting-icebreaker-wheel" },
  ]} />

  <div class="mi-page">
    <div class="mi-sky"></div>
    <div class="mi-halo-teal"></div>
    <div class="mi-halo-amber"></div>

    <div class="mi-graph" aria-hidden="true">
      <svg viewBox="0 0 80 60" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polyline points="5,50 20,35 35,42 50,20 65,28 75,10" stroke="#14b8a6" stroke-width="2" fill="none"/>
        <circle cx="20" cy="35" r="3" fill="#14b8a6"/>
        <circle cx="35" cy="42" r="3" fill="#2dd4bf"/>
        <circle cx="50" cy="20" r="3" fill="#14b8a6"/>
        <circle cx="65" cy="28" r="3" fill="#f59e0b"/>
      </svg>
    </div>
    <div class="mi-clock" aria-hidden="true">🕐</div>

    {coffeePos.map((c, i) => (
      <div class="mi-coffee-wrapper" style={`${c.left ? `left:${c.left};` : ''} ${c.right ? `right:${c.right};` : ''} top:${c.top};`}>
        <div class="mi-coffee-icon" style={`--cfdur:${c.duration}; --cfdelay:${c.delay};`}>
          ☕
          {steamLines.map((s, si) => (
            <div class="mi-steam" style={`left:${8 + si * 9}px; --sfdelay:${s.delay}; --sx:${s.xOffset};`}></div>
          ))}
        </div>
      </div>
    ))}

    {connectionNodes.map((n) => (
      <div
        class="mi-node"
        style={`left:${n.left}; top:${n.top}; width:8px; height:8px; background:${n.color}; --ndur:${n.duration}; --ndelay:${n.delay}; --ncol:${n.color};`}
      ></div>
    ))}

    {particles.map((p) => (
      <div
        class="mi-particle"
        style={`left:${p.left}; bottom:${20 + parseInt(p.delay) * 5}%; width:${p.size}; height:${p.size}; background:${p.color}; --mpdur:${p.duration}; --mpdelay:${p.delay}; box-shadow: 0 0 5px ${p.color};`}
      ></div>
    ))}

    <div class="mi-content">
      <HeaderIsland client:load />
      <div class="max-w-4xl mx-auto px-4 pt-4 pb-12">
        <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <a href="/templates" class="hover:text-white/60 transition-colors">Templates</a>
          <span>/</span>
          <span class="text-white/50">Meeting Icebreaker Spinner</span>
        </nav>
        <div class="text-center mb-8">
          <div class="text-5xl mb-3">☕</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight mi-title mb-3">
            Meeting Icebreaker Spinner — Quick Team Questions
          </h1>
          <p class="text-lg text-white/55 max-w-xl mx-auto mb-5">
            Start every meeting with a random question that actually gets people talking. No awkward silence, no boring introductions. Just spin and go.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="mi-tag">☕ Under 2 min</span>
            <span class="mi-tag">💼 Professional</span>
            <span class="mi-tag">🆓 Free</span>
            <span class="mi-tag">💻 Remote-friendly</span>
          </div>
        </div>
        <SimpleWheelIsland defaultParticipants={defaultParticipants} colors={themeColors} wheelShape="circle" hubTheme="teal" client:load />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <div class="mi-card space-y-4">
          <h2 class="text-xl md:text-2xl font-bold">Why Meeting Icebreakers Work (When Done Right)</h2>
          <p>Most meeting icebreakers fail because they're either too personal (making introverts uncomfortable) or too generic. The wheel solves both problems: the question is random and pre-prepared, and everyone answers the same thing, which levels the playing field.</p>
          <p>The act of spinning also creates a small shared moment before the meeting's actual content. Teams that start meetings with brief informal connection report higher engagement throughout the session. The wheel keeps it structured so it doesn't eat into meeting time.</p>
        </div>

        <div class="mi-card space-y-4">
          <h2 class="text-xl md:text-2xl font-bold">Customize for Your Team</h2>
          <ul class="space-y-3">
            <li class="flex gap-3"><span style="color:#14b8a6" class="font-bold">→</span><span><strong style="color:#f0fdfa">Remote teams:</strong> Add questions about home setup, time zone morning routines, or local weather.</span></li>
            <li class="flex gap-3"><span style="color:#f59e0b" class="font-bold">→</span><span><strong style="color:#f0fdfa">Weekly standups:</strong> Keep prompts quick — "one word for your week" or "energy level 1-10".</span></li>
            <li class="flex gap-3"><span style="color:#2dd4bf" class="font-bold">→</span><span><strong style="color:#f0fdfa">Monthly all-hands:</strong> More substantial — "biggest win this month" or "what you're excited about Q2".</span></li>
            <li class="flex gap-3"><span style="color:#1e40af" class="font-bold">→</span><span><strong style="color:#f0fdfa">New team members:</strong> Mix introductory questions with existing team questions to blend both.</span></li>
          </ul>
        </div>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#f0fdfa">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <details class="mi-faq">
                <summary>{question}</summary>
                <p>{answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#f0fdfa">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/templates/standup-order-wheel", label: "Standup Order Picker", desc: "Randomize who goes first in your daily standup." },
              { href: "/templates/sprint-retrospective-wheel", label: "Sprint Retro Wheel", desc: "Spin for retrospective discussion topics." },
              { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random team member for any task or activity." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="mi-related-link">
                  <span style="color:#14b8a6" class="font-bold text-sm mt-0.5">→</span>
                  <span>
                    <span class="font-semibold" style="color:#f0fdfa">{label}</span>
                    <span style="color:rgba(240,253,250,0.55)" class="text-sm"> — {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
