---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Movie Picker Wheel — What Should We Watch Tonight?";
const description = "Can't agree on a movie? Spin the wheel. Add your watchlist or use our genre suggestions. End the Netflix scroll in 3 seconds.";
const canonical = "/templates/movie-picker-wheel";

const faqItems = [
  {
    question: "Can I put actual movie titles on the wheel?",
    answer: "Yes. Replace the genre names with specific titles from your watchlist. This works great for deciding between 5-10 movies you all want to watch.",
  },
  {
    question: "What if nobody wants to watch what the wheel picks?",
    answer: "Allow one group veto — but the second spin is final, no exceptions.",
  },
  {
    question: "Can I use this for TV shows too?",
    answer: "Absolutely. Put your show watchlist on the wheel. Works for series, anime, docuseries, or any episodic content.",
  },
];

const defaultParticipants = [
  { pseudo: "Action", weight: 1 },
  { pseudo: "Comedy", weight: 1 },
  { pseudo: "Horror", weight: 1 },
  { pseudo: "Sci-Fi", weight: 1 },
  { pseudo: "Romance", weight: 1 },
  { pseudo: "Thriller", weight: 1 },
  { pseudo: "Documentary", weight: 1 },
  { pseudo: "Animation", weight: 1 },
  { pseudo: "Drama", weight: 1 },
  { pseudo: "Mystery", weight: 1 },
];

const myColors = ['#8b0000','#d4af37','#1a1a1a','#f5f5dc','#b22222','#c5b358','#2f2f2f','#ffd700'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/movie-picker-wheel",
};
---

<style>
  /* ===== CINEMA GLAMOUR THEME ===== */

  .cinema-page {
    min-height: 100vh;
    background: #0a0005;
    position: relative;
    overflow-x: hidden;
  }

  /* Fond noir cinéma profond */
  .cinema-bg {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, #1a0a0a 0%, #0a0005 50%, #050003 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Rideaux velours gauche */
  .cinema-curtain-left {
    position: fixed;
    top: 0;
    left: 0;
    width: 140px;
    height: 100vh;
    background: linear-gradient(90deg,
      #5a0000 0%,
      #8b0000 30%,
      #a00000 55%,
      #7a0000 75%,
      rgba(90,0,0,0.3) 100%
    );
    z-index: 3;
    pointer-events: none;
    animation: curtainSway 6s ease-in-out infinite alternate;
    transform-origin: top left;
    box-shadow: inset -20px 0 40px rgba(0,0,0,0.6);
  }
  /* Plis velours gauche */
  .cinema-curtain-left::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      rgba(0,0,0,0.25) 0px,
      transparent 8px,
      rgba(200,0,0,0.1) 16px,
      transparent 24px
    );
  }

  /* Rideaux velours droite */
  .cinema-curtain-right {
    position: fixed;
    top: 0;
    right: 0;
    width: 140px;
    height: 100vh;
    background: linear-gradient(270deg,
      #5a0000 0%,
      #8b0000 30%,
      #a00000 55%,
      #7a0000 75%,
      rgba(90,0,0,0.3) 100%
    );
    z-index: 3;
    pointer-events: none;
    animation: curtainSway 6s ease-in-out infinite alternate-reverse;
    transform-origin: top right;
    box-shadow: inset 20px 0 40px rgba(0,0,0,0.6);
  }
  .cinema-curtain-right::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      rgba(0,0,0,0.25) 0px,
      transparent 8px,
      rgba(200,0,0,0.1) 16px,
      transparent 24px
    );
  }

  @keyframes curtainSway {
    0%   { transform: scaleX(1) skewY(0deg); }
    100% { transform: scaleX(1.04) skewY(0.5deg); }
  }

  /* Spotlights de scène */
  .cinema-spotlight {
    position: fixed;
    top: -80px;
    width: 300px;
    height: 700px;
    background: linear-gradient(180deg,
      rgba(255,255,240,0.12) 0%,
      rgba(255,255,220,0.06) 40%,
      transparent 100%
    );
    transform-origin: top center;
    pointer-events: none;
    z-index: 2;
    animation: spotlightSweep ease-in-out infinite alternate;
    border-radius: 0 0 50% 50%;
    filter: blur(2px);
  }

  @keyframes spotlightSweep {
    0%   { transform: rotate(-18deg); opacity: 0.5; }
    100% { transform: rotate(18deg);  opacity: 0.9; }
  }

  /* Pellicule cinéma en bas */
  .cinema-film-strip {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 48px;
    background: #1a1a1a;
    z-index: 100;
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 0;
    overflow: hidden;
    border-top: 2px solid #333;
  }
  .cinema-film-strip::before,
  .cinema-film-strip::after {
    content: '';
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 0;
    right: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent 0px,
      transparent 20px,
      #000 20px,
      #000 28px,
      transparent 28px,
      transparent 48px
    );
  }
  .cinema-film-strip::after {
    top: auto;
    bottom: 6px;
  }
  .cinema-film-frame {
    flex-shrink: 0;
    width: 56px;
    height: 34px;
    background: #2a2a2a;
    border: 1px solid #444;
    margin: 0 6px;
    animation: filmAdvance 0.8s steps(1) infinite;
    border-radius: 2px;
  }
  @keyframes filmAdvance {
    0%   { opacity: 0.6; background: #1e1e1e; }
    50%  { opacity: 1;   background: #3a2a1a; }
    100% { opacity: 0.6; background: #1e1e1e; }
  }

  /* Étoiles scintillantes */
  .cinema-star {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    animation: starTwinkle ease-in-out infinite;
    font-size: 1.1rem;
  }
  @keyframes starTwinkle {
    0%, 100% { opacity: 0.2; transform: scale(0.8); }
    50%       { opacity: 1;   transform: scale(1.3); }
  }

  /* Popcorn tombant */
  .cinema-popcorn {
    position: fixed;
    pointer-events: none;
    z-index: 2;
    font-size: 1.4rem;
    opacity: 0;
    animation: popcornFall linear infinite;
  }
  @keyframes popcornFall {
    0%   { transform: translateY(-60px) rotate(0deg);   opacity: 0; }
    10%  { opacity: 0.7; }
    90%  { opacity: 0.5; }
    100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
  }

  /* Lueur ambiante dorée */
  .cinema-glow {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    filter: blur(80px);
    animation: glowPulse ease-in-out infinite alternate;
  }
  @keyframes glowPulse {
    0%   { opacity: 0.3; transform: scale(1); }
    100% { opacity: 0.6; transform: scale(1.2); }
  }

  /* Contenu */
  .cinema-content {
    position: relative;
    z-index: 10;
  }

  /* Cards sombres cinéma */
  .cinema-card {
    background: rgba(10, 2, 2, 0.82);
    border: 1px solid rgba(180, 30, 30, 0.35);
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 0 30px rgba(139,0,0,0.15), inset 0 1px 0 rgba(212,175,55,0.08);
    backdrop-filter: blur(12px);
  }

  .cinema-inner-card {
    background: rgba(212,175,55,0.05);
    border: 1px solid rgba(212,175,55,0.2);
    border-radius: 0.75rem;
    padding: 0.875rem;
  }

  .cinema-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    border: 1px solid;
  }

  .faq-card {
    background: rgba(10,2,2,0.78);
    border: 1px solid rgba(212,175,55,0.2);
    border-radius: 1rem;
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }

  .related-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(10,2,2,0.75);
    border: 1px solid rgba(180,30,30,0.3);
    border-radius: 1rem;
    text-decoration: none;
    transition: all 0.2s;
    backdrop-filter: blur(8px);
  }
  .related-card:hover {
    border-color: rgba(212,175,55,0.7);
    box-shadow: 0 0 20px rgba(212,175,55,0.15);
    transform: translateY(-2px);
  }

  h1 {
    color: #ffd700;
    text-shadow:
      0 0 20px rgba(212,175,55,0.6),
      0 0 40px rgba(139,0,0,0.5),
      2px 2px 4px rgba(0,0,0,0.9);
    font-style: italic;
  }
  h2 { color: #f5e6b0; }
  .body-text  { color: #d4c4a0; }
  .muted-text { color: #9a8860; }
  .bc-link { color: #9a8860; text-decoration: none; transition: color 0.2s; }
  .bc-link:hover { color: #ffd700; }
</style>

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Movie Picker Wheel", url: "https://realwheelpicker.com/templates/movie-picker-wheel" },
  ]} />

  <div class="cinema-page">
    <!-- Atmosphère fixe -->
    <div class="cinema-bg"></div>

    <!-- Rideaux velours -->
    <div class="cinema-curtain-left"></div>
    <div class="cinema-curtain-right"></div>

    <!-- Lueurs ambiantes -->
    <div class="cinema-glow" style="top:-100px; left:-100px; width:400px; height:400px; background:rgba(139,0,0,0.3); animation-duration:7s;"></div>
    <div class="cinema-glow" style="top:-80px; right:-80px; width:350px; height:350px; background:rgba(212,175,55,0.15); animation-duration:9s;"></div>
    <div class="cinema-glow" style="bottom:-100px; left:40%; width:500px; height:300px; background:rgba(100,0,0,0.25); animation-duration:8s;"></div>

    <!-- Spotlights de scène -->
    <div class="cinema-spotlight" style="left:15%; animation-duration:8s;"></div>
    <div class="cinema-spotlight" style="left:40%; animation-duration:11s; animation-delay:-3s;"></div>
    <div class="cinema-spotlight" style="right:15%; animation-duration:9s; animation-delay:-5s;"></div>

    <!-- Étoiles scintillantes -->
    {[
      {l:"20%",t:"8%",d:"1.2s"},{l:"35%",t:"5%",d:"2.1s"},{l:"50%",t:"10%",d:"0.8s"},
      {l:"65%",t:"6%",d:"3.0s"},{l:"78%",t:"9%",d:"1.7s"},{l:"12%",t:"18%",d:"2.5s"},
      {l:"88%",t:"15%",d:"0.5s"},{l:"42%",t:"20%",d:"1.9s"},{l:"58%",t:"14%",d:"2.8s"},
      {l:"25%",t:"25%",d:"1.4s"},{l:"72%",t:"22%",d:"3.3s"},{l:"5%",t:"30%",d:"2.0s"},
      {l:"93%",t:"28%",d:"0.9s"},{l:"48%",t:"3%",d:"1.6s"},{l:"82%",t:"32%",d:"2.4s"},
    ].map(({l,t,d}) => (
      <div class="cinema-star" style={`left:${l}; top:${t}; animation-duration:${d}; animation-delay:-${parseFloat(d)*0.5}s;`}>⭐</div>
    ))}

    <!-- Popcorn tombant -->
    {[
      {l:"8%",dur:"9s",del:"0s"},{l:"22%",dur:"12s",del:"-4s"},{l:"38%",dur:"10s",del:"-2s"},
      {l:"54%",dur:"14s",del:"-7s"},{l:"68%",dur:"11s",del:"-1s"},{l:"80%",dur:"13s",del:"-5s"},
      {l:"91%",dur:"10s",del:"-3s"},{l:"16%",dur:"15s",del:"-8s"},
    ].map(({l,dur,del}) => (
      <div class="cinema-popcorn" style={`left:${l}; animation-duration:${dur}; animation-delay:${del};`}>🍿</div>
    ))}

    <!-- Pellicule -->
    <div class="cinema-film-strip">
      {Array.from({length: 18}).map((_, i) => (
        <div class="cinema-film-frame" style={`animation-delay:${i * 0.08}s;`}></div>
      ))}
    </div>

    <div class="cinema-content">
      <HeaderIsland client:load />

      <div class="max-w-4xl mx-auto px-4 pt-6 pb-16">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="text-xs flex gap-1 mb-6 muted-text">
          <a href="/" class="bc-link">Home</a>
          <span>/</span>
          <a href="/templates" class="bc-link">Templates</a>
          <span>/</span>
          <span style="color:#f5e6b0;">Movie Picker Wheel</span>
        </nav>

        <!-- Hero -->
        <section class="text-center space-y-4 py-4 mb-6">
          <div class="text-5xl mb-2">🎬</div>
          <h1 class="text-3xl md:text-5xl font-black leading-tight">
            Movie Picker Wheel
          </h1>
          <p class="text-lg md:text-xl body-text max-w-2xl mx-auto">
            End the Netflix scroll in 3 seconds. Add your watchlist or spin the genre wheel and commit to the result.
          </p>
          <div class="flex flex-wrap justify-center gap-2 mt-3">
            <span class="cinema-tag" style="border-color:#8b0000; color:#fca5a5; background:rgba(139,0,0,0.15);">🎬 Cinéma</span>
            <span class="cinema-tag" style="border-color:#d4af37; color:#fde68a; background:rgba(212,175,55,0.1);">⭐ Glamour</span>
            <span class="cinema-tag" style="border-color:#c5b358; color:#fef9c3; background:rgba(197,179,88,0.1);">🆓 Free</span>
          </div>
        </section>

        <!-- Wheel -->
        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          colors={myColors}
          wheelShape="circle"
          hubTheme="crimson"
          client:load
        />
      </div>

      <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

        <section class="space-y-6">
          <div class="cinema-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">The Netflix Decision Problem</h2>
            <p class="body-text leading-relaxed">
              The average couple spends 17.8 minutes deciding what to watch before giving up and rewatching something familiar. The movie picker wheel solves this in 3 seconds. Spin, commit, watch.
            </p>
            <p class="body-text leading-relaxed">
              The problem is not laziness. It is that streaming platforms now offer tens of thousands of titles and no natural stopping point. The scroll is infinite. The wheel is not — it forces a decision and removes the browsing loop entirely.
            </p>
          </div>

          <div class="cinema-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">How to Use the Movie Wheel</h2>
            <div class="space-y-4">
              <div class="cinema-inner-card">
                <p class="font-semibold text-sm mb-1" style="color:#ffd700;">Option A — Genre mode</p>
                <p class="muted-text text-sm">Load the wheel with genres, spin to pick the category, then search that genre for something neither of you has seen. Two-minute browsing limit — first thing that looks good, that is the one.</p>
              </div>
              <div class="cinema-inner-card">
                <p class="font-semibold text-sm mb-1" style="color:#ffd700;">Option B — Title mode</p>
                <p class="muted-text text-sm">Both people add 3-5 movies they want to watch. Spin to pick. No veto allowed. Everyone had input; fate made the final call.</p>
              </div>
              <div class="cinema-inner-card">
                <p class="font-semibold text-sm mb-1" style="color:#ffd700;">Option C — Platform mode</p>
                <p class="muted-text text-sm">Load with Netflix, Hulu, Disney+, HBO, Prime. Spin to pick the platform, then browse for 2 minutes max and pick whatever looks good. Forces discovery over comfort zones.</p>
              </div>
            </div>
          </div>

          <div class="cinema-card space-y-4">
            <h2 class="text-xl md:text-2xl font-bold">For Movie Nights with Groups</h2>
            <p class="body-text leading-relaxed">
              Everyone submits one movie. Six people means six movies on the wheel. Spin. Whatever wins, that is the movie. No debate, no drama. The randomness removes the social pressure of choosing — nobody can be blamed for the pick because nobody chose it.
            </p>
            <p class="body-text leading-relaxed">
              The coin flip alternative for two-person households: Person A picks 3 movies they want to watch. Person B picks 3. Put all 6 on the wheel. Spin. Everyone had input, fate decides. Less arguing than direct negotiation, and it often leads to movies you would have never picked on your own — which are sometimes the best ones.
            </p>
          </div>
        </section>

        <!-- FAQ -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#f5e6b0;">Frequently Asked Questions</h2>
          <div class="space-y-3">
            {faqItems.map(({ question, answer }) => (
              <div class="faq-card">
                <p class="font-semibold mb-2" style="color:#ffd700;">{question}</p>
                <p class="muted-text text-sm leading-relaxed">{answer}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Related Tools -->
        <section class="space-y-4">
          <h2 class="text-xl md:text-2xl font-bold" style="color:#f5e6b0;">Related Tools</h2>
          <ul class="space-y-3">
            {[
              { href: "/", label: "Spin the Wheel", desc: "The main wheel picker — add any names or options and spin." },
              { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random name from your list without the wheel animation." },
              { href: "/giveaway-picker", label: "Giveaway Picker", desc: "Run transparent prize draws for contests and promotions." },
              { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
            ].map(({ href, label, desc }) => (
              <li>
                <a href={href} class="related-card">
                  <span style="color:#d4af37; font-weight:700; font-size:0.875rem; margin-top:2px;">→</span>
                  <span>
                    <span class="font-semibold" style="color:#f5e6b0;">{label}</span>
                    <span class="muted-text text-sm"> — {desc}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

      </main>
      <GlobalFooterIsland client:load />
    </div>
  </div>
</Layout>
