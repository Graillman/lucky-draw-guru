---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Movie Picker Wheel — What Should We Watch Tonight?";
const description = "Can't agree on a movie? Spin the wheel. Add your watchlist or use our genre suggestions. End the Netflix scroll in 3 seconds.";
const canonical = "/templates/movie-picker-wheel";

const faqItems = [
  {
    question: "Can I put actual movie titles on the wheel?",
    answer: "Yes. Replace the genre names with specific titles from your watchlist. This works great for deciding between 5-10 movies you all want to watch.",
  },
  {
    question: "What if nobody wants to watch what the wheel picks?",
    answer: "Allow one group veto — but the second spin is final, no exceptions.",
  },
  {
    question: "Can I use this for TV shows too?",
    answer: "Absolutely. Put your show watchlist on the wheel. Works for series, anime, docuseries, or any episodic content.",
  },
];

const defaultParticipants = [
  { pseudo: "Action", weight: 1 },
  { pseudo: "Comedy", weight: 1 },
  { pseudo: "Horror", weight: 1 },
  { pseudo: "Sci-Fi", weight: 1 },
  { pseudo: "Romance", weight: 1 },
  { pseudo: "Thriller", weight: 1 },
  { pseudo: "Documentary", weight: 1 },
  { pseudo: "Animation", weight: 1 },
  { pseudo: "Drama", weight: 1 },
  { pseudo: "Mystery", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://realwheelpicker.com/templates/movie-picker-wheel",
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Templates", url: "https://realwheelpicker.com/templates" },
    { name: "Movie Picker Wheel", url: "https://realwheelpicker.com/templates/movie-picker-wheel" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/templates" class="hover:text-primary transition-colors">Templates</a>
        <span>/</span>
        <span class="text-foreground">Movie Picker Wheel</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Movie Picker Wheel — What Should We Watch Tonight?
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          End the Netflix scroll in 3 seconds. Add your watchlist or spin the genre wheel and commit to the result.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- Wheel -->
      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <!-- Article Content -->
      <section class="space-y-8">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">The Netflix Decision Problem</h2>
          <p class="text-muted-foreground leading-relaxed">
            The average couple spends 17.8 minutes deciding what to watch before giving up and rewatching something familiar. The movie picker wheel solves this in 3 seconds. Spin, commit, watch.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The problem isn't laziness. It's that streaming platforms now offer tens of thousands of titles and no natural stopping point. The scroll is infinite. The wheel is not — it forces a decision and removes the browsing loop entirely.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Use the Movie Wheel</h2>
          <div class="space-y-4">
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Option A — Genre mode</p>
              <p class="text-muted-foreground text-sm">Load the wheel with genres, spin to pick the category, then search that genre for something neither of you has seen. Two-minute browsing limit — first thing that looks good, that's the one.</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Option B — Title mode</p>
              <p class="text-muted-foreground text-sm">Both people add 3-5 movies they want to watch. Spin to pick. No veto allowed. Everyone had input; fate made the final call.</p>
            </div>
            <div class="p-4 rounded-lg bg-primary/5 border border-primary/20">
              <p class="font-semibold text-foreground text-sm mb-1">Option C — Platform mode</p>
              <p class="text-muted-foreground text-sm">Load with Netflix, Hulu, Disney+, HBO, Prime. Spin to pick the platform, then browse for 2 minutes max and pick whatever looks good. Forces discovery over comfort zones.</p>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">For Movie Nights with Groups</h2>
          <p class="text-muted-foreground leading-relaxed">
            Everyone submits one movie. Six people means six movies on the wheel. Spin. Whatever wins, that's the movie. No debate, no drama. The randomness removes the social pressure of choosing — nobody can be blamed for the pick because nobody chose it.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            The coin flip alternative for two-person households: Person A picks 3 movies they want to watch. Person B picks 3. Put all 6 on the wheel. Spin. Everyone had input, fate decides. Less arguing than direct negotiation, and it often leads to movies you'd have never picked on your own — which are sometimes the best ones.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            This wheel also works for TV shows, anime series, documentary series, or any episodic content you've been meaning to start. The commitment problem is the same whether it's a 90-minute film or a 10-episode season. Spin, pick, watch.
          </p>
        </div>

      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/", label: "Spin the Wheel", desc: "The main wheel picker — add any names or options and spin." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Pick a random name from your list without the wheel animation." },
            { href: "/giveaway-picker", label: "Giveaway Picker", desc: "Run transparent prize draws for contests and promotions." },
            { href: "/templates", label: "All Templates", desc: "Browse all pre-loaded wheel templates for every occasion." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:load />
  </div>
</Layout>
