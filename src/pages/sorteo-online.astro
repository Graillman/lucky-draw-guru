---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import AdPlaceholder from '@/components/AdPlaceholder';
import { ArrowRight, Check } from 'lucide-react';

const title = "Sorteo Online Gratis — Ruleta para Sorteos | Real Wheel Picker";
const description = "Haz un sorteo online justo y transparente. Añade los participantes, gira la ruleta y elige al ganador al azar. Gratis, sin registro, aleatorio criptográfico.";
const canonical = "/sorteo-online";
const locale = "es_ES";
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Sorteo Online — Real Wheel Picker",
      "url": "https://realwheelpicker.com/sorteo-online",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "description": "Realiza sorteos online gratis con aleatoridad criptográfica. Añade participantes, gira la ruleta y elige al ganador.",
      "inLanguage": "es",
    },,
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Es este sorteo online realmente aleatorio y justo?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Real Wheel Picker usa window.crypto.getRandomValues(), el estándar criptográfico de los navegadores modernos. Es el mismo nivel de aleatoriedad que se usa en banca online. Ningún participante tiene más probabilidad que otro, y el resultado es imposible de predecir o manipular." },
        },
        {
          "@type": "Question",
          "name": "¿Cuántos participantes puedo añadir?",
          "acceptedAnswer": { "@type": "Answer", "text": "Puedes añadir tantos participantes como necesites. Haz clic en cualquier nombre para editarlo y añade más entradas. La ruleta se adapta automáticamente." },
        },
        {
          "@type": "Question",
          "name": "¿Puedo usar esto para un sorteo en Instagram o TikTok?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Copia los nombres de los comentarios, añádelos a la ruleta y graba la pantalla mientras giras. Es transparente y verificable para tu audiencia." },
        },
        {
          "@type": "Question",
          "name": "¿Es gratis?",
          "acceptedAnswer": { "@type": "Answer", "text": "Completamente gratis. No necesitas crear una cuenta, descargar nada ni pagar nada. La herramienta funciona directamente en tu navegador." },
        },
      ],
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Sorteo Online" },
      ],
    },
  ],
};

const defaultParticipants = [
  { pseudo: "Participante 1", weight: 1 },
  { pseudo: "Participante 2", weight: 1 },
  { pseudo: "Participante 3", weight: 1 },
  { pseudo: "Participante 4", weight: 1 },
];

const USOS = [
  "Sorteos en Instagram — comenta y gana",
  "Rifas para recaudar fondos",
  "Seleccionar ganadores en YouTube",
  "Sorteos en vivo en Twitch o TikTok",
  "Elegir turnos o tareas en clase",
  "Cualquier concurso online o presencial",
];
---

<Layout title={title} description={description} canonical={canonical} locale={locale} jsonLd={jsonLd}
  hreflangLinks={[
    { hreflang: 'en',       href: 'https://realwheelpicker.com/' },
    { hreflang: 'fr',       href: 'https://realwheelpicker.com/tirage-au-sort' },
    { hreflang: 'es',       href: 'https://realwheelpicker.com/sorteo-online' },
    { hreflang: 'pt',       href: 'https://realwheelpicker.com/sorteio-online' },
    { hreflang: 'it',       href: 'https://realwheelpicker.com/sorteggio-online' },
    { hreflang: 'de',       href: 'https://realwheelpicker.com/zufallsgenerator' },
    { hreflang: 'x-default', href: 'https://realwheelpicker.com/' },
  ]}
>
  <div class="relative min-h-screen overflow-hidden" style="background: var(--gradient-bg)">
    <div aria-hidden class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div class="aurora-orb aurora-orb-gold"></div>
      <div class="aurora-orb aurora-orb-purple"></div>
      <div class="aurora-orb aurora-orb-blue"></div>
    </div>
    <div class="relative z-10">
      <HeaderIsland client:load />
      <main class="max-w-5xl mx-auto px-4 py-8 space-y-10">

        <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span>/</span>
          <span class="text-foreground">Sorteo Online</span>
        </nav>

        <section class="text-center space-y-4 py-2">
          <h1 class="text-2xl md:text-4xl font-bold text-foreground leading-tight">
            Sorteo Online Gratis — Ruleta para Elegir al Ganador
          </h1>
          <p class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto">
            Haz sorteos justos y transparentes en segundos. Añade los participantes, gira la ruleta y elige al ganador con aleatoridad criptográfica. Sin registro, completamente gratis.
          </p>
        </section>

        <section class="bg-card border border-border rounded-xl p-5 text-sm text-muted-foreground leading-relaxed">
          <p>
            <strong class="text-foreground">Sorteo online:</strong> Añade los nombres de los participantes, haz clic en Girar la Ruleta y el sistema elige un ganador al azar usando <code>window.crypto.getRandomValues()</code> — el estándar criptográfico de los navegadores modernos. Cada participante tiene exactamente la misma probabilidad de ganar. Transparente, verificable, gratuito.
          </p>
        </section>

        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />

        <section class="space-y-4">
          <h2 class="text-xl font-bold text-foreground">Para qué sirve esta herramienta</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {USOS.map((uso, i) => (
              <li class="flex items-start gap-3 bg-card border border-border rounded-xl p-4">
                <Check className="w-5 h-5 text-primary mt-0.5 shrink-0" />
                <span class="text-sm text-muted-foreground">{uso}</span>
              </li>
            ))}
          </ul>
        </section>

        <AdPlaceholder position="after-use-cases" client:visible />

        <section class="bg-card border border-border rounded-xl p-6 space-y-3">
          <h2 class="text-xl font-bold text-foreground">¿Por qué usar una ruleta para sorteos?</h2>
          <p class="text-muted-foreground leading-relaxed">
            Una ruleta digital con aleatoridad criptográfica es el método más justo y transparente para hacer sorteos online. A diferencia de elegir "al azar" manualmente (donde el sesgo humano es inevitable) o usar métodos físicos como sacar papelitos (donde el orden importa), <code>window.crypto.getRandomValues()</code> garantiza que cada participante tiene exactamente la misma probabilidad de ser elegido.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Para sorteos en redes sociales, la transparencia es clave: graba la pantalla mientras giras la ruleta y muéstrasela a tu audiencia. El proceso es verificable y difícil de cuestionar.
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Más herramientas</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {[
              { label: "Giveaway Picker", href: "/giveaway-picker" },
              { label: "Random Name Picker", href: "/random-name-picker" },
              { label: "Raffle Picker", href: "/raffle-picker" },
            ].map((link) => (
              <a href={link.href}
                class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-md transition-all text-sm font-semibold text-foreground">
                {link.label}
              </a>
            ))}
          </div>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Preguntas frecuentes</h2>
          <div class="space-y-3">
            {[
              ["¿Es este sorteo online realmente aleatorio y justo?",
               "Sí. Usamos window.crypto.getRandomValues(), el estándar criptográfico de los navegadores modernos. Es el mismo nivel de aleatoriedad que se usa en banca online. Ningún participante tiene más probabilidad que otro."],
              ["¿Cuántos participantes puedo añadir?",
               "Tantos como necesites. Haz clic en cualquier nombre para editarlo y añade más entradas. La ruleta se adapta automáticamente."],
              ["¿Puedo usar esto para un sorteo en Instagram o TikTok?",
               "Sí. Copia los nombres de los comentarios, añádelos a la ruleta y graba la pantalla mientras giras. Es transparente y verificable para tu audiencia."],
              ["¿Es gratis?",
               "Completamente gratis. Sin registro, sin descargas, sin pagos. Funciona directamente en tu navegador."],
            ].map(([q, a], i) => (
              <div class="bg-card border border-border rounded-xl p-5">
                <p class="font-semibold text-foreground mb-2">{q}</p>
                <p class="text-muted-foreground">{a}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="text-center py-6">
          <a href="/" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition-opacity">
            Herramienta completa <ArrowRight className="w-4 h-4" />
          </a>
        </section>

        <AdPlaceholder position="bottom" client:visible />
      </main>
      <GlobalFooterIsland client:idle />
    </div>
  </div>
</Layout>
