---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import AdPlaceholder from '@/components/AdPlaceholder';
import FaqAccordionIsland from '@/components/FaqAccordionIsland';
import FaqPageHeaderIsland from '@/components/FaqPageHeaderIsland';

const title = "Random Picker FAQ — Common Questions Answered | Real Wheel Picker";
const description = "Answers to the most common questions about Real Wheel Picker: randomness, fairness, privacy, giveaway rules, classroom use, and more. Free, no signup required.";
const canonical = "/faq";

const faqItems = [
  {
    question: "Is this random picker actually fair, or is that just marketing?",
    answer: "It's verifiable. Every draw calls window.crypto.getRandomValues(), the browser API that backs TLS handshakes and password generators. You can open DevTools → Sources → find the spin function and read the line yourself. There's no server roundtrip, so we couldn't manipulate the result if we tried — the page wouldn't know which entry you'd want to win.",
  },
  {
    question: "How is crypto.getRandomValues() different from Math.random()?",
    answer: "Math.random() uses a deterministic pseudo-random algorithm seeded by a timestamp. Given the seed and the call sequence, the output is reproducible — which is fine for visual effects but bad for prize draws where someone with the timestamp could in principle reproduce your sequence. crypto.getRandomValues() pulls from a kernel-level CSPRNG that mixes hardware entropy (CPU jitter, mouse-movement timing, etc.) and is not reproducible. Same RNG that TLS uses.",
  },
  {
    question: "What do you store about me on your servers?",
    answer: "Nothing about your draws. The site has Google AdSense, which sets advertising cookies — that's the only third-party tracking. Your participant list lives in your browser's localStorage (you can wipe it via the trash icon or DevTools → Application → Local Storage). We don't have an API endpoint that accepts your list, which means we don't have an inbox of leaked rosters either.",
  },
  {
    question: "Can I use this for Instagram or YouTube giveaways?",
    answer: "Yes, and the platform-specific pages handle the awkward bits: Instagram's reply-thread paste, YouTube's Newest-first sort trap, TikTok's interleaved comments. The dedicated /instagram-giveaway-picker / /youtube-giveaway-picker / /tiktok-giveaway-picker pages all run the same crypto-RNG underneath but with platform-aware comment cleaning.",
  },
  {
    question: "What's the difference between equal-odds and weighted draws?",
    answer: "Equal-odds means every entry gets the same segment size (1/N each). Weighted means you assign per-entry weights (numbers) and the segment sizes scale to match — entry with weight 5 takes 5× the space of weight 1. Use the /weighted-random-picker for tickets-purchased, sub-tier, or donation-amount draws. The wheel shows the exact percentages live as you edit.",
  },
  {
    question: "Can I pick multiple winners in one draw?",
    answer: "Yes. Set the winners count above the wheel before spinning. The picker draws without replacement — first winner gets removed from the pool, second winner comes from the remaining N-1, and so on. The result panel shows them in draw order. Useful for 1st/2nd/3rd place sequences.",
  },
  {
    question: "Does it work on phones and tablets?",
    answer: "Yes. The canvas renders the same on mobile as on desktop, and the spin works via tap or swipe instead of click. The one caveat: the wheel sizes to viewport height, so on a tall narrow screen it'll be smaller than on a 16:9 monitor. If you need a larger wheel on mobile, the fullscreen icon (top-right) gives you the entire viewport.",
  },
  {
    question: "What's the catch? Why is it free?",
    answer: "The site runs Google AdSense — not paywalled tools, not feature locks. Ads sit in fixed slots that don't overlay the wheel. The tool is genuinely free with no usage caps. If you find that annoying, an uBlock-style blocker disables them and we don't paywall in response. The math doesn't change either way.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer },
  })),
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-4xl mx-auto px-4 py-8 space-y-8">

      <FaqPageHeaderIsland client:load />

      <FaqAccordionIsland client:load />

      <section class="bg-card border border-border rounded-xl p-6 md:p-8 space-y-4">
        <h2 class="text-xl font-bold text-foreground">Still have questions?</h2>
        <p class="text-muted-foreground leading-relaxed">
          The questions we get most often that aren't in the list above: how to embed the wheel in a website (see <a href="/embed" class="text-primary hover:underline">/embed</a>), how to verify a winner after the fact (screen-record the spin, the recording is the proof), what happens if a winner doesn't respond within X days (remove them in the result panel and re-spin from the remaining pool).
        </p>
        <p class="text-muted-foreground leading-relaxed">
          For anything not covered, the <a href="/contact" class="text-primary hover:underline">contact page</a> has the email. We answer questions about the maths in detail because we'd rather you understood how the tool works than took our word for it.
        </p>
      </section>

      <AdPlaceholder position="after-use-cases" client:visible />

      <section class="text-center py-8 space-y-6">
        <h2 class="text-2xl font-bold text-foreground">Ready to pick a winner?</h2>
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-xl font-semibold text-lg hover:opacity-90 transition-opacity"
        >
          Start Your Free Draw
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </section>

      <AdPlaceholder position="bottom" client:visible />
    </main>
    <GlobalFooterIsland client:idle />
  </div>
</Layout>
