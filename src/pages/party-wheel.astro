---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Party Wheel — Random Decision Maker for Games & Fun";
const description = "Spin the party wheel to pick dares, games, challenges, or random decisions. Add your own options, spin, and let the wheel decide. Free, instant, no signup.";

const defaultParticipants = [
  { pseudo: "😈 Dare",            weight: 1 },
  { pseudo: "💬 Truth",           weight: 1 },
  { pseudo: "🎤 Sing a Song",     weight: 1 },
  { pseudo: "💃 Dance Move",      weight: 1 },
  { pseudo: "🍺 Take a Sip",      weight: 1 },
  { pseudo: "🎲 Double Dare",     weight: 1 },
  { pseudo: "🃏 Wild Card",       weight: 1 },
  { pseudo: "😂 Tell a Joke",     weight: 1 },
  { pseudo: "🤫 Keep a Secret",   weight: 1 },
  { pseudo: "⏭️ Skip",            weight: 1 },
];

const faqItems = [
  {
    question: "What can I put on the party wheel?",
    answer: "Anything. Dares, truths, challenges, drinking rules, game choices, activity ideas, or player names. The wheel works for any party decision — just edit the entries.",
  },
  {
    question: "Can I save my party wheel for next time?",
    answer: "Your customized list is saved as long as you don't clear it. Click ✏️ Customize entries and your changes persist in the session.",
  },
  {
    question: "Does it work on a phone at a party?",
    answer: "Yes. The wheel is fully touch-optimized. Swipe or tap to spin on any smartphone or tablet. Pass the phone around the table.",
  },
  {
    question: "Can I add funny options or emojis?",
    answer: "Yes, the wheel displays emojis and any text. Already included by default — just edit to add your own.",
  },
  {
    question: "How many options can I add?",
    answer: "As many as you want. The wheel adjusts segment sizes automatically. For large lists the text gets smaller but stays readable.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "@id": "https://realwheelpicker.com/party-wheel#app",
  "name": "Party Wheel — Real Wheel Picker",
  "url": "https://realwheelpicker.com/party-wheel",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "publisher": { "@type": "Organization", "@id": "https://realwheelpicker.com/#organization", "name": "Real Wheel Picker", "url": "https://realwheelpicker.com" },
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<style>
  /* ─── Party dark background ─── */
  .party-hero {
    position: relative;
    overflow: hidden;
    background: #07000f;
    min-height: 100vh;
  }

  /* Animated spotlights */
  .spot {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    will-change: transform, opacity;
  }
  .spot-pink {
    width: 500px; height: 500px;
    top: -120px; left: -80px;
    background: radial-gradient(circle, rgba(255,0,110,0.35) 0%, transparent 70%);
    animation: spotDrift1 7s ease-in-out infinite alternate;
  }
  .spot-blue {
    width: 450px; height: 450px;
    top: -100px; right: -60px;
    background: radial-gradient(circle, rgba(58,134,255,0.3) 0%, transparent 70%);
    animation: spotDrift2 9s ease-in-out infinite alternate;
  }
  .spot-purple {
    width: 400px; height: 400px;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(131,56,236,0.25) 0%, transparent 70%);
    animation: spotDrift3 6s ease-in-out infinite alternate;
  }
  .spot-gold {
    width: 300px; height: 300px;
    top: 40%; right: 10%;
    background: radial-gradient(circle, rgba(255,215,0,0.2) 0%, transparent 70%);
    animation: spotDrift4 8s ease-in-out infinite alternate;
  }
  .spot-green {
    width: 280px; height: 280px;
    bottom: 10%; left: 5%;
    background: radial-gradient(circle, rgba(6,214,160,0.18) 0%, transparent 70%);
    animation: spotDrift5 11s ease-in-out infinite alternate;
  }

  @keyframes spotDrift1 {
    from { transform: translate(0, 0) scale(1); opacity: 0.7; }
    to   { transform: translate(60px, 40px) scale(1.15); opacity: 1; }
  }
  @keyframes spotDrift2 {
    from { transform: translate(0, 0) scale(1.1); opacity: 1; }
    to   { transform: translate(-50px, 60px) scale(0.9); opacity: 0.6; }
  }
  @keyframes spotDrift3 {
    from { transform: translateX(-50%) scale(1); opacity: 0.5; }
    to   { transform: translateX(-40%) scale(1.2); opacity: 0.9; }
  }
  @keyframes spotDrift4 {
    from { transform: translate(0, 0); opacity: 0.4; }
    to   { transform: translate(-30px, -50px); opacity: 0.8; }
  }
  @keyframes spotDrift5 {
    from { transform: translate(0, 0); opacity: 0.6; }
    to   { transform: translate(40px, -30px); opacity: 0.3; }
  }

  /* Floating party particles */
  .particle {
    position: absolute;
    border-radius: 2px;
    pointer-events: none;
    animation: fall linear infinite;
    opacity: 0.7;
  }
  @keyframes fall {
    0%   { transform: translateY(-20px) rotate(0deg); opacity: 0; }
    10%  { opacity: 0.8; }
    90%  { opacity: 0.6; }
    100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
  }

  /* Floor/ceiling scan lines effect */
  .scan-lines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(255,255,255,0.015) 3px,
      rgba(255,255,255,0.015) 4px
    );
    pointer-events: none;
  }

  /* Party title glow */
  .party-title {
    text-shadow: 0 0 40px rgba(255, 0, 110, 0.6), 0 0 80px rgba(58, 134, 255, 0.3);
  }
  .party-subtitle {
    color: rgba(255,255,255,0.55);
  }

  /* Tag pills */
  .party-tag {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7);
    border-radius: 9999px;
    padding: 4px 14px;
    font-size: 0.75rem;
    font-weight: 600;
    backdrop-filter: blur(4px);
  }
</style>

<Layout title={title} description={description} canonical="/party-wheel" jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Party Wheel", url: "https://realwheelpicker.com/party-wheel" },
  ]} />

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- PARTY HERO — dark club atmosphere                          -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div class="party-hero">
    <!-- Atmospheric spotlights -->
    <div class="spot spot-pink"></div>
    <div class="spot spot-blue"></div>
    <div class="spot spot-purple"></div>
    <div class="spot spot-gold"></div>
    <div class="spot spot-green"></div>
    <div class="scan-lines"></div>

    <!-- Falling confetti particles (CSS only) -->
    <div class="particle" style="width:6px;height:6px;background:#FF006E;left:8%;animation-duration:4.2s;animation-delay:0s;"></div>
    <div class="particle" style="width:4px;height:10px;background:#3A86FF;left:18%;animation-duration:5.1s;animation-delay:0.8s;"></div>
    <div class="particle" style="width:8px;height:5px;background:#FFD700;left:32%;animation-duration:3.8s;animation-delay:1.5s;"></div>
    <div class="particle" style="width:5px;height:5px;background:#06D6A0;left:47%;animation-duration:6.2s;animation-delay:0.3s;"></div>
    <div class="particle" style="width:7px;height:4px;background:#8338EC;left:63%;animation-duration:4.7s;animation-delay:2.1s;"></div>
    <div class="particle" style="width:4px;height:8px;background:#FF006E;left:75%;animation-duration:5.5s;animation-delay:0.6s;"></div>
    <div class="particle" style="width:6px;height:6px;background:#FFD700;left:88%;animation-duration:3.5s;animation-delay:1.9s;"></div>
    <div class="particle" style="width:5px;height:5px;background:#3A86FF;left:55%;animation-duration:4.9s;animation-delay:3.2s;"></div>
    <div class="particle" style="width:8px;height:3px;background:#06D6A0;left:25%;animation-duration:6.8s;animation-delay:1.1s;"></div>
    <div class="particle" style="width:4px;height:7px;background:#FF006E;left:92%;animation-duration:4.3s;animation-delay:2.7s;"></div>

    <HeaderIsland client:load />

    <div class="relative z-10 max-w-4xl mx-auto px-4 pt-4 pb-12">

      <nav aria-label="breadcrumb" class="text-xs text-white/30 flex gap-1 mb-6">
        <a href="/" class="hover:text-white/60 transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/50">Party Wheel</span>
      </nav>

      <!-- Party title -->
      <div class="text-center mb-2">
        <div class="text-4xl mb-2">🎉</div>
        <h1 class="text-4xl md:text-6xl font-black text-white leading-tight party-title mb-3">
          Party Wheel
        </h1>
        <p class="text-lg party-subtitle max-w-xl mx-auto mb-4">
          Add dares, truths, challenges — let the wheel decide who goes next.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-2">
          <span class="party-tag">🎮 Truth or Dare</span>
          <span class="party-tag">🎲 Party Games</span>
          <span class="party-tag">💃 Dance Dares</span>
          <span class="party-tag">📱 Mobile Ready</span>
        </div>
      </div>

      <!-- THE WHEEL — front and center in the party -->
      <div class="mt-6">
        <SimpleWheelIsland
          defaultParticipants={defaultParticipants}
          client:load
        />
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CONTENT BELOW                                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div style="background: var(--gradient-bg)">
    <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

      <!-- Party Wheel Ideas grid -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Party Wheel Ideas</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { emoji: "😈", title: "Truth or Dare", desc: "Add truths, dares, or player names and spin" },
            { emoji: "🎮", title: "Game Selector", desc: "Can't agree on what to play? Spin." },
            { emoji: "🍕", title: "Food Chooser", desc: "Pizza, tacos, burgers — let fate decide" },
            { emoji: "🎵", title: "Song Challenge", desc: "Spin for a song to sing, rap or hum" },
            { emoji: "💃", title: "Dance Dare", desc: "Random dance moves or TikTok challenges" },
            { emoji: "🎲", title: "Drinking Rules", desc: "Add game rules and spin for who drinks" },
          ].map((c) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center hover:scale-105 transition-all hover:border-primary/50">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-3 bg-primary/10 text-2xl">{c.emoji}</div>
              <h3 class="font-semibold text-foreground text-sm mb-1">{c.title}</h3>
              <p class="text-xs text-muted-foreground">{c.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- How it works -->
      <section class="p-6 rounded-xl border bg-card border-border space-y-3">
        <h2 class="text-lg font-bold text-foreground">How it works</h2>
        <p class="text-sm text-muted-foreground leading-relaxed">
          The party wheel comes pre-loaded with 10 fun options — Truth, Dare, Sing a Song, Dance Move and more. Click <strong class="text-foreground">✏️ Customize entries</strong> to add your own, remove ones you don't want, or build a completely custom list for your party. Pass your phone around, everyone watches the spin, nobody argues about what happens next.
        </p>
      </section>

      <!-- FAQs -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <details class="bg-card border border-border rounded-xl p-5 group">
              <summary class="font-semibold text-foreground cursor-pointer list-none flex items-center justify-between gap-2">
                {question}
                <span class="text-muted-foreground shrink-0 group-open:rotate-180 transition-transform">▾</span>
              </summary>
              <p class="text-muted-foreground text-sm leading-relaxed mt-3">{answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/spin-the-bottle", label: "Spin the Bottle", desc: "The classic party game, online." },
            { href: "/yes-no-wheel", label: "Yes or No Wheel", desc: "Quick yes/no decisions with a spin." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Select a random player or participant." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:idle />
  </div>
</Layout>
