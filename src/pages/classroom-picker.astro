---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Classroom Random Picker — Free Student Selector for Teachers";
const description = "Pick a random student in seconds. Add your class roster, spin the wheel, call on students fairly. No favoritism, more engagement. Free, no signup.";

const faqItems = [
  {
    question: "How do I add my class roster?",
    answer: "Type student names one per line, or paste directly from Google Classroom, Google Sheets, or any spreadsheet. The tool accepts one name per line.",
  },
  {
    question: "Can I avoid picking the same student twice?",
    answer: "Yes. Click 'Remove winner' after each spin. The student is removed from the wheel and won't be picked again until you reset the list for a new session.",
  },
  {
    question: "Can I save my class list for next time?",
    answer: "Your list is saved in your browser's local storage. It will still be there the next time you open the tool on the same device and browser.",
  },
  {
    question: "Does it work on a smartboard or projector?",
    answer: "Yes. The tool is fully responsive and works on any screen size. Open it in a browser tab and project it directly — students can watch the wheel spin in real time.",
  },
  {
    question: "Is the selection fair?",
    answer: "Yes. Each student has exactly the same probability of being selected on each spin. We use crypto.getRandomValues() — the same cryptographic standard used in banking.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Classroom Random Picker — Real Wheel Picker",
  "url": "https://realwheelpicker.com/classroom-picker",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<Layout
  title={title}
  description={description}
  canonical="/classroom-picker"
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Classroom Picker", url: "https://realwheelpicker.com/classroom-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Classroom Picker</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Classroom Random Picker — Call on Students Fairly
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Add your class roster, spin the wheel, and pick a student at random. More engagement, zero favoritism. Works on any device or smartboard.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Works on projectors</p>
      </section>

      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Why Use a Random Student Picker?</h2>
        <p class="text-muted-foreground leading-relaxed">
          Teachers who use random selection report higher attention in class — students stay focused because they know they could be called on at any moment. It also removes any perception of favoritism, which matters for classroom dynamics.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Add your roster once, spin as many times as you need. Remove each selected student to avoid repeats. Reset at the start of each session.
        </p>
      </section>

      <SEOPageIsland slug="classroom-picker" client:load />

      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Use the Classroom Picker</h2>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 1 — Add Your Class Roster</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Type student first names (or full names) one per line. Or paste directly from Google Classroom, a spreadsheet, or a text file. The list saves automatically in your browser.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 2 — Spin the Wheel</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Click spin or tap the wheel. All student names appear on the wheel segments. The wheel slows down and stops on a random name. Project this on your smartboard so students can watch live.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 3 — Remove and Continue</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Click 'Remove winner' to take the selected student off the wheel. Spin again to pick the next student. No one gets called on twice until you reset the list.
          </p>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/random-name-picker", label: "Random Name Picker", desc: "General purpose random name selector." },
            { href: "/team-generator", label: "Team Generator", desc: "Split students into random groups for activities." },
            { href: "/wheel-of-names", label: "Wheel of Names", desc: "The classic spinning wheel for any name list." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
