---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
---

<Layout
  title="Page Not Found — Real Wheel Picker"
  description="The page you're looking for doesn't exist. Go back to the homepage and spin the wheel!"
  canonical="/404"
>
  <div style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-2xl mx-auto px-4 py-20 text-center space-y-6">
      <div class="text-8xl font-bold text-primary/20">404</div>
      <h1 class="text-3xl font-bold text-foreground">Page not found</h1>
      <p class="text-muted-foreground text-lg">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition-opacity"
      >
        Back to Home
      </a>
    </main>
    <GlobalFooterIsland client:idle />
  </div>
</Layout>
