---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Secret Santa Picker — Free Random Gift Assignment";
const description = "Randomly assign Secret Santa gift pairs in seconds. Add participant names, spin the wheel, reveal each person's gift recipient one by one. Free, no signup.";

const faqItems = [
  {
    question: "How does Secret Santa assignment work?",
    answer: "Add all participant names to the wheel. Each person spins in turn to find out who they're buying a gift for. The selected name is removed after each spin so no one gets assigned the same recipient.",
  },
  {
    question: "What if someone draws their own name?",
    answer: "Remove them from the wheel before they spin, or use the 'remove winner' feature to respin if needed. For fully automated assignment without anyone seeing the full list, use a dedicated Secret Santa app — this tool is best for in-person reveals.",
  },
  {
    question: "Can I use this for online groups?",
    answer: "Yes. Share your screen during a video call and each person spins in turn. The visual spin adds excitement to remote holiday celebrations.",
  },
  {
    question: "How many people can participate?",
    answer: "As many as you want. The wheel handles large groups smoothly.",
  },
  {
    question: "Is the assignment random?",
    answer: "Yes. Each spin uses crypto.getRandomValues() — the same cryptographic standard used in banking. Every name has an equal chance of being selected.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "@id": "https://realwheelpicker.com/secret-santa-picker#app",
  "name": "Secret Santa Picker — Real Wheel Picker",
  "url": "https://realwheelpicker.com/secret-santa-picker",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "publisher": { "@type": "Organization", "@id": "https://realwheelpicker.com/#organization", "name": "Real Wheel Picker", "url": "https://realwheelpicker.com" },
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "ratingCount": "2340", "bestRating": "5", "worstRating": "1" }
};
---

<Layout
  title={title}
  description={description}
  canonical="/secret-santa-picker"
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Secret Santa Picker", url: "https://realwheelpicker.com/secret-santa-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Secret Santa Picker</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Secret Santa Picker — Assign Gift Recipients Randomly
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Add all participant names, spin the wheel one by one, and assign Secret Santa pairs in a fun and fair way. Works in person or on a video call.
        </p>
        <p class="text-sm text-muted-foreground">Free • No signup • Perfect for Christmas & holiday parties</p>
      </section>

      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Run Secret Santa With the Wheel</h2>
        <p class="text-muted-foreground leading-relaxed">
          Add everyone's name to the wheel. The first person spins to find out who they're buying for — that name is removed. The second person spins from the remaining names, and so on. Each person gets a unique recipient, and the wheel handles all the randomness.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          For remote teams or families: share your screen during a video call. Everyone watches the spin live, making the assignment feel like an event rather than a chore.
        </p>
      </section>

      <SEOPageIsland slug="secret-santa-picker" client:load />

      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Step-by-Step Secret Santa Guide</h2>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">In Person</h3>
          <ol class="space-y-2 text-sm text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span><span>Add all participant names to the wheel</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span><span>Each person spins in turn — the result is their Secret Santa recipient</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span><span>Click 'Remove winner' so the same name isn't drawn twice</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">4.</span><span>Continue until everyone has been assigned a recipient</span></li>
          </ol>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Online / Video Call</h3>
          <ol class="space-y-2 text-sm text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span><span>One person opens the tool and shares their screen</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span><span>Each participant calls out when it's their turn to spin</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span><span>The host clicks spin on their behalf</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">4.</span><span>Everyone sees the result live — no secrets until gift day</span></li>
          </ol>
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/wheel-of-names", label: "Wheel of Names", desc: "Pick a random name from any list." },
            { href: "/random-name-picker", label: "Random Name Picker", desc: "Simple one-click random name selector." },
            { href: "/giveaway-picker", label: "Giveaway Picker", desc: "Run fair prize draws and contests." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
