---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';

const title = "Terms of Service — Real Wheel Picker";
const description = "Read the terms of service for Real Wheel Picker. Understand the rules of use for our free online spinning wheel and random picker tools. Free to use, no account required.";
const canonical = "/terms-of-service";

const lastUpdated = new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://realwheelpicker.com/terms-of-service",
  "name": "Terms of Service — Real Wheel Picker",
  "url": "https://realwheelpicker.com/terms-of-service",
  "description": "Terms of service for Real Wheel Picker. Free to use, no account required.",
  "dateModified": "2026-03-01",
  "isPartOf": { "@id": "https://realwheelpicker.com/#website" },
  "publisher": { "@id": "https://realwheelpicker.com/#organization" },
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-3xl mx-auto px-4 py-12">
      <article class="bg-card border border-border rounded-xl p-6 md:p-10 prose prose-sm max-w-none text-muted-foreground space-y-6">
        <h1 class="text-3xl font-bold text-foreground">Terms of Service</h1>
        <p class="text-sm">Last updated: {lastUpdated}</p>

        <h2 class="text-xl font-bold text-foreground">1. Acceptance of Terms</h2>
        <p>By accessing and using Random Picker ("the Service"), you agree to be bound by these Terms of Service. If you do not agree with any part of these terms, you should not use our Service.</p>

        <h2 class="text-xl font-bold text-foreground">2. Description of Service</h2>
        <p>Random Picker is a free online tool that provides random selection and decision-making functionalities, including but not limited to: spinning wheels, name pickers, team generators, number generators, giveaway pickers, and party game wheels. The Service operates entirely in your web browser and does not require account registration.</p>

        <h2 class="text-xl font-bold text-foreground">3. Use of the Service</h2>
        <p>You agree to use the Service only for lawful purposes and in a manner that does not infringe upon the rights of others. Specifically, you agree not to:</p>
        <ul class="list-disc pl-5 space-y-1">
          <li>Use the Service for any illegal gambling or betting activities</li>
          <li>Misrepresent the results of draws or selections</li>
          <li>Attempt to manipulate or interfere with the random generation algorithms</li>
          <li>Use the Service to make decisions that could cause harm to others</li>
          <li>Scrape, copy, or redistribute the Service's code or content without permission</li>
        </ul>

        <h2 class="text-xl font-bold text-foreground">4. Disclaimer of Warranties</h2>
        <p>The Service is provided "as is" and "as available" without warranties of any kind, either express or implied. We do not guarantee that:</p>
        <ul class="list-disc pl-5 space-y-1">
          <li>The Service will be uninterrupted or error-free</li>
          <li>Results will meet your specific requirements or expectations</li>
          <li>Any defects in the Service will be corrected</li>
        </ul>
        <p>While our random selection algorithms use cryptographically secure methods, we make no guarantees about the suitability of results for any specific purpose, including but not limited to legal proceedings, financial decisions, or contractual obligations.</p>

        <h2 class="text-xl font-bold text-foreground">5. Limitation of Liability</h2>
        <p>To the fullest extent permitted by applicable law, Random Picker and its creators shall not be liable for any indirect, incidental, special, consequential, or punitive damages, or any loss of profits or revenues, whether incurred directly or indirectly, or any loss of data, use, goodwill, or other intangible losses resulting from your use of the Service.</p>

        <h2 class="text-xl font-bold text-foreground">6. User Responsibility</h2>
        <p>You are solely responsible for how you use the results generated by our Service. This includes but is not limited to:</p>
        <ul class="list-disc pl-5 space-y-1">
          <li>Ensuring compliance with local laws and regulations regarding contests, giveaways, and random selections</li>
          <li>Verifying that your use of the tool complies with platform-specific rules (e.g., Instagram, TikTok, YouTube contest guidelines)</li>
          <li>Taking responsibility for any decisions made based on the Service's results</li>
        </ul>

        <h2 class="text-xl font-bold text-foreground">7. Intellectual Property</h2>
        <p>All content, design, code, and functionality of Random Picker are the intellectual property of its creators and are protected by applicable copyright and intellectual property laws. You may not reproduce, distribute, or create derivative works without explicit permission.</p>

        <h2 class="text-xl font-bold text-foreground">8. Advertising</h2>
        <p>The Service is supported by advertising through Google AdSense. By using the Service, you acknowledge that advertisements will be displayed. We are not responsible for the content of third-party advertisements.</p>

        <h2 class="text-xl font-bold text-foreground">9. Modifications to Terms</h2>
        <p>We reserve the right to modify these Terms of Service at any time. Changes will be posted on this page with an updated date. Your continued use of the Service after changes are posted constitutes acceptance of the modified terms.</p>

        <h2 class="text-xl font-bold text-foreground">10. Governing Law</h2>
        <p>These Terms shall be governed by and construed in accordance with applicable laws, without regard to conflict of law principles.</p>

        <h2 class="text-xl font-bold text-foreground">11. Contact</h2>
        <p>For any questions regarding these Terms of Service, please reach out through our <a href="/contact" class="text-primary hover:underline">Contact page</a>.</p>
      </article>
    </main>
    <GlobalFooterIsland client:idle />
  </div>
</Layout>
