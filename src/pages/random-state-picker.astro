---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Random US State Picker — Spin to Pick a Random State";
const description = "Spin the wheel to pick a random US state. All 50 states included. Customize the list for any region. Free, cryptographically random, instant result.";
const canonical = "/random-state-picker";

const faqItems = [
  {
    question: "Does this include all 50 US states?",
    answer: "Yes. The default wheel includes all 50 states. You can remove states you don't need — for example, spin only the continental 48, or restrict to a specific region like the Southeast or the Pacific Coast.",
  },
  {
    question: "How is the state selected?",
    answer: "The wheel uses crypto.getRandomValues() — cryptographic randomness sourced from your device's hardware. Each spin is independent and genuinely random. Every state on the wheel has equal probability.",
  },
  {
    question: "Can I add only certain states?",
    answer: "Yes. Click the × next to any state to remove it, or click any label to edit it. You can set up a wheel for only West Coast states, only swing states, or your own custom regional list.",
  },
  {
    question: "What's a good use for a random state picker?",
    answer: "Road trip planning (spin to pick your next destination), US geography education, trivia games, travel bucket list challenges, virtual field trips, and deciding which state's cuisine to cook this weekend.",
  },
  {
    question: "Can I use this for a geography quiz?",
    answer: "Absolutely. Spin to pick a state, then quiz yourself or students on the capital, abbreviation, population, famous landmarks, or bordering states. Remove each state after you've covered it to go through all 50 systematically.",
  },
];

const defaultParticipants = [
  { pseudo: "Alabama", weight: 1 },
  { pseudo: "Alaska", weight: 1 },
  { pseudo: "Arizona", weight: 1 },
  { pseudo: "Arkansas", weight: 1 },
  { pseudo: "California", weight: 1 },
  { pseudo: "Colorado", weight: 1 },
  { pseudo: "Connecticut", weight: 1 },
  { pseudo: "Delaware", weight: 1 },
  { pseudo: "Florida", weight: 1 },
  { pseudo: "Georgia", weight: 1 },
  { pseudo: "Hawaii", weight: 1 },
  { pseudo: "Idaho", weight: 1 },
  { pseudo: "Illinois", weight: 1 },
  { pseudo: "Indiana", weight: 1 },
  { pseudo: "Iowa", weight: 1 },
  { pseudo: "Kansas", weight: 1 },
  { pseudo: "Kentucky", weight: 1 },
  { pseudo: "Louisiana", weight: 1 },
  { pseudo: "Maine", weight: 1 },
  { pseudo: "Maryland", weight: 1 },
  { pseudo: "Massachusetts", weight: 1 },
  { pseudo: "Michigan", weight: 1 },
  { pseudo: "Minnesota", weight: 1 },
  { pseudo: "Mississippi", weight: 1 },
  { pseudo: "Missouri", weight: 1 },
  { pseudo: "Montana", weight: 1 },
  { pseudo: "Nebraska", weight: 1 },
  { pseudo: "Nevada", weight: 1 },
  { pseudo: "New Hampshire", weight: 1 },
  { pseudo: "New Jersey", weight: 1 },
  { pseudo: "New Mexico", weight: 1 },
  { pseudo: "New York", weight: 1 },
  { pseudo: "North Carolina", weight: 1 },
  { pseudo: "North Dakota", weight: 1 },
  { pseudo: "Ohio", weight: 1 },
  { pseudo: "Oklahoma", weight: 1 },
  { pseudo: "Oregon", weight: 1 },
  { pseudo: "Pennsylvania", weight: 1 },
  { pseudo: "Rhode Island", weight: 1 },
  { pseudo: "South Carolina", weight: 1 },
  { pseudo: "South Dakota", weight: 1 },
  { pseudo: "Tennessee", weight: 1 },
  { pseudo: "Texas", weight: 1 },
  { pseudo: "Utah", weight: 1 },
  { pseudo: "Vermont", weight: 1 },
  { pseudo: "Virginia", weight: 1 },
  { pseudo: "Washington", weight: 1 },
  { pseudo: "West Virginia", weight: 1 },
  { pseudo: "Wisconsin", weight: 1 },
  { pseudo: "Wyoming", weight: 1 },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Random US State Picker — Real Wheel Picker",
      "url": "https://realwheelpicker.com/random-state-picker",
      "description": description,
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "publisher": { "@type": "Organization", "name": "Real Wheel Picker", "url": "https://realwheelpicker.com" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Random State Picker" },
      ],
    },
  ],
};
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Random State Picker", url: "https://realwheelpicker.com/random-state-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Random State Picker</span>
      </nav>

      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Random US State Picker — Spin to Pick a State
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Spin the wheel and land on a random US state. All 50 states included by default. Customize the list to any region. Cryptographically random — every state has equal odds.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • All 50 states</p>
      </section>

      <section class="flex flex-col items-center">
        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />
      </section>

      <section class="space-y-6">

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">What to Do With a Random State</h2>
          <div class="grid sm:grid-cols-2 gap-3 text-sm">
            {[
              { use: "Road trip planning", example: "Spin to decide your next US destination. Research the state capital, national parks, and must-see landmarks." },
              { use: "Geography education", example: "Spin and quiz yourself or your class on the state capital, abbreviation, population, and famous facts." },
              { use: "State cuisine night", example: "Cook a traditional dish from the random state — explore regional American food one spin at a time." },
              { use: "Trivia game host", example: "Use the wheel to randomly pick which state's trivia questions you answer next in a US geography game." },
              { use: "Travel bucket list", example: "Spin to add random states to your road trip bucket list — challenge yourself to visit all 50 someday." },
              { use: "History research", example: "Write a one-page summary of the randomly picked state's most important historical event or figure." },
            ].map((item) => (
              <div class="p-3 bg-primary/5 border border-primary/20 rounded-lg">
                <p class="font-semibold text-foreground text-sm mb-0.5">{item.use}</p>
                <p class="text-xs text-muted-foreground">{item.example}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Customize for Any Region</h2>
          <p class="text-muted-foreground leading-relaxed">
            Remove states you don't need by clicking the × next to them. Click any state name to rename it. You can build regional wheels for:
          </p>
          <ul class="space-y-2 text-sm text-muted-foreground">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> The 48 continental states (remove Alaska and Hawaii)</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> Southeast states (Alabama, Georgia, Florida, Tennessee…)</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> Pacific Coast only (California, Oregon, Washington)</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> Midwest states for a regional geography lesson</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span> Swing states for a political science class exercise</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-4">
          <h2 class="text-xl md:text-2xl font-bold text-foreground">US State Quick Facts</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
            {[
              { label: "Total states", value: "50" },
              { label: "Largest by area", value: "Alaska" },
              { label: "Smallest by area", value: "Rhode Island" },
              { label: "Most populous", value: "California" },
              { label: "Least populous", value: "Wyoming" },
              { label: "Newest state", value: "Hawaii (1959)" },
              { label: "Oldest state", value: "Delaware (1787)" },
              { label: "Most landlocked", value: "Kansas (center)" },
              { label: "Longest coastline", value: "Alaska" },
            ].map((fact) => (
              <div class="p-3 bg-card border border-border rounded-lg">
                <p class="text-xs text-muted-foreground">{fact.label}</p>
                <p class="font-semibold text-foreground text-sm">{fact.value}</p>
              </div>
            ))}
          </div>
        </div>

      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/random-country-picker", label: "Random Country Picker", desc: "Spin to pick a random country from around the world." },
            { href: "/decision-wheel", label: "Decision Wheel", desc: "Custom options for any decision — places, activities, or cities." },
            { href: "/random-number-picker", label: "Random Number Picker", desc: "Pick any random number from a custom range." },
            { href: "/", label: "Spin the Wheel", desc: "The main wheel — add any custom options and spin." },
          ].map(({ href, label, desc }) => (
            <li>
              <a href={href} class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all">
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>
    <GlobalFooterIsland client:idle />
  </div>
</Layout>
