---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import AdPlaceholder from '@/components/AdPlaceholder';
import { ArrowRight } from 'lucide-react';

const title = "Generador de Nombres Aleatorio Online — Rueda de Nombres | Real Wheel Picker";
const description = "Genera un nombre aleatorio girando la rueda. Añade todos los nombres, gira y obtén uno al azar. Gratis, sin registro, aleatorio criptográfico.";
const canonical = "/generador-de-nombres";
const locale = "es_ES";
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Generador de Nombres — Real Wheel Picker",
      "url": "https://realwheelpicker.com/generador-de-nombres",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "inLanguage": "es",
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Generador de Nombres" },
      ],
    },
  ],
};

const defaultParticipants = [
  { pseudo: "Carlos", weight: 1 },
  { pseudo: "María", weight: 1 },
  { pseudo: "Alejandro", weight: 1 },
  { pseudo: "Sofía", weight: 1 },
  { pseudo: "Diego", weight: 1 },
  { pseudo: "Valentina", weight: 1 },
];
---

<Layout title={title} description={description} canonical={canonical} locale={locale} jsonLd={jsonLd}>
  <div class="relative min-h-screen overflow-hidden" style="background: var(--gradient-bg)">
    <div aria-hidden class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div class="aurora-orb aurora-orb-gold"></div>
      <div class="aurora-orb aurora-orb-purple"></div>
      <div class="aurora-orb aurora-orb-blue"></div>
    </div>
    <div class="relative z-10">
      <HeaderIsland client:load />
      <main class="max-w-5xl mx-auto px-4 py-8 space-y-10">

        <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span>/</span>
          <span class="text-foreground">Generador de Nombres</span>
        </nav>

        <section class="text-center space-y-4 py-2">
          <h1 class="text-2xl md:text-4xl font-bold text-foreground leading-tight">
            Generador de Nombres Aleatorio — Rueda de Nombres Online
          </h1>
          <p class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto">
            Añade los nombres, gira la rueda y elige uno al azar de forma justa e imparcial. Ideal para profesores, sorteos y actividades de grupo.
          </p>
        </section>

        <section class="bg-card border border-border rounded-xl p-5 text-sm text-muted-foreground leading-relaxed">
          <p>
            <strong class="text-foreground">Generador de nombres:</strong> Introduce los nombres en la rueda, haz clic en Girar y el sistema elige uno aleatoriamente con <code>window.crypto.getRandomValues()</code>. Cada nombre tiene exactamente la misma probabilidad de ser seleccionado.
          </p>
        </section>

        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Para qué usar el generador de nombres</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              ["Aula", "Seleccionar alumnos para responder, presentar o dirigir actividades."],
              ["Sorteos", "Elegir ganadores de forma transparente."],
              ["Juegos en grupo", "Decidir quién empieza o quién realiza la tarea."],
              ["Equipos", "Asignar responsabilidades de forma aleatoria y justa."],
            ].map(([title, desc], i) => (
              <div class="bg-card border border-border rounded-xl p-4">
                <p class="font-semibold text-foreground mb-1">{title}</p>
                <p class="text-sm text-muted-foreground">{desc}</p>
              </div>
            ))}
          </div>
        </section>

        <AdPlaceholder position="after-use-cases" client:visible />

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Más herramientas</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {[
              { label: "Sorteo Online", href: "/sorteo-online" },
              { label: "Rueda de la Suerte", href: "/rueda-de-la-suerte" },
              { label: "Classroom Picker", href: "/classroom-picker" },
            ].map((link) => (
              <a href={link.href}
                class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-md transition-all text-sm font-semibold text-foreground">
                {link.label}
              </a>
            ))}
          </div>
        </section>

        <section class="text-center py-6">
          <a href="/" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition-opacity">
            Herramienta completa <ArrowRight className="w-4 h-4" />
          </a>
        </section>

        <AdPlaceholder position="bottom" client:visible />
      </main>
      <GlobalFooterIsland client:idle />
    </div>
  </div>
</Layout>
