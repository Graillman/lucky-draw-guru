---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import AdPlaceholder from '@/components/AdPlaceholder';

const title = "About Real Wheel Picker — Fair Online Random Picker";
const description = "Learn about Real Wheel Picker, our mission to make random decisions simple and fair, and how our cryptographically secure algorithm works.";
const canonical = "/about";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": "https://realwheelpicker.com/about",
  "name": "About Real Wheel Picker",
  "description": "The most trusted random picker for fair, transparent draws worldwide",
  "url": "https://realwheelpicker.com/about",
  "isPartOf": { "@id": "https://realwheelpicker.com/#website" },
  "about": { "@id": "https://realwheelpicker.com/#organization" },
  "publisher": { "@id": "https://realwheelpicker.com/#organization" },
};

const values = [
  {
    icon: "shield",
    title: "Complete Privacy",
    text: "Zero data collection. No cookies. No tracking. Your participant lists never leave your browser. We can't see who's in your draws - and that's by design.",
  },
  {
    icon: "zap",
    title: "True Randomness",
    text: "We use the Web Crypto API for cryptographically secure random numbers - the same standard used by financial institutions. No pseudo-random shortcuts.",
  },
  {
    icon: "globe",
    title: "Global Accessibility",
    text: "Available in multiple languages, works on any device, no registration required. From classrooms in Tokyo to streamers in São Paulo - everyone gets the same fair tool.",
  },
  {
    icon: "heart",
    title: "Forever Free",
    text: "No premium tiers, no feature locks, no \"free trial\" gimmicks. We're supported by non-intrusive ads that never interrupt your experience.",
  },
];

const users = [
  { title: "Content Creators", desc: "Streamers, YouTubers, and influencers running transparent giveaways" },
  { title: "Educators", desc: "Teachers and trainers picking students fairly for activities" },
  { title: "Businesses", desc: "Teams making unbiased decisions and running internal contests" },
];

const stats = [
  { val: "0 bytes", label: "Data we store about you" },
  { val: "100%", label: "Client-Side Processing" },
  { val: "Free", label: "Always, no account needed" },
  { val: "CSPRNG", label: "Cryptographic randomness" },
];
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-4xl mx-auto px-4 py-8 space-y-8">

      <!-- Hero -->
      <section class="text-center space-y-4 py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground">About Real Wheel Picker</h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">A no-account random picker built on the same RNG as your bank's TLS handshake. Free, browser-only, no data leaves your device.</p>
        <p class="text-sm text-muted-foreground">Independent · Made in France · MIT-licensed core</p>
      </section>

      <!-- Origin Story -->
      <section class="bg-card border border-border rounded-xl p-6 md:p-8 space-y-4">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary" aria-hidden="true"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Why We Built This</h2>
        </div>
        <p class="text-muted-foreground leading-relaxed">Real Wheel Picker started from a simple frustration: every existing random picker tool was either riddled with ads that broke the experience, required you to create an account just to use a spinning wheel, or — worse — used <code class="text-xs bg-muted px-1 py-0.5 rounded">Math.random()</code>, JavaScript's built-in pseudo-random function that produces predictable sequences.</p>
        <p class="text-muted-foreground leading-relaxed">That last point matters more than it sounds. <code class="text-xs bg-muted px-1 py-0.5 rounded">Math.random()</code> uses a deterministic algorithm seeded by a timestamp. A skilled developer can reproduce any sequence it generates. For a classroom activity or a casual team standup, this probably doesn't matter. But for a YouTube giveaway with thousands of participants, or a company raffle with real prizes, the integrity of the draw is everything — and pseudo-random isn't good enough.</p>
        <p class="text-muted-foreground leading-relaxed">So we built Real Wheel Picker on <strong class="text-foreground">the Web Crypto API</strong> (<code class="text-xs bg-muted px-1 py-0.5 rounded">crypto.getRandomValues()</code>), the same cryptographic standard used by password managers and banking applications. The randomness comes from hardware entropy — electrical noise inside your device — which is fundamentally impossible to predict or reproduce. That's the foundation every tool on this site is built on.</p>
      </section>

      <!-- Who We Are -->
      <section class="bg-card border border-border rounded-xl p-6 md:p-8 space-y-4">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h2 class="text-xl md:text-2xl font-bold text-foreground">Who We Are</h2>
        </div>
        <p class="text-muted-foreground leading-relaxed">We're an independent web development project based in France. Real Wheel Picker is built and maintained by a small team of developers who got tired of tools that treat users as data sources rather than people trying to get something done.</p>
        <p class="text-muted-foreground leading-relaxed">The entire site runs on modern open-web standards: <strong class="text-foreground">Astro</strong> for static rendering (your wheel loads instantly, no waiting for JavaScript), <strong class="text-foreground">TypeScript</strong> throughout for reliability, <strong class="text-foreground">React</strong> for the interactive components, and <strong class="text-foreground">Tailwind CSS</strong> for the interface. All your data — participant names, draw history, wheel configurations — stays in your browser's local storage. It never reaches our servers, because we don't have servers that accept it.</p>
        <p class="text-muted-foreground leading-relaxed">The site is supported by advertising through Google AdSense, which is how we keep every tool completely free. We deliberately chose non-intrusive ad placements that don't interrupt the actual draw experience. Our rule: ads should fund the product, not become the product.</p>
      </section>

      <!-- How the randomness works -->
      <section class="bg-card border border-border rounded-xl p-6 md:p-8 space-y-4">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h2 class="text-xl md:text-2xl font-bold text-foreground">How the Randomness Works</h2>
        </div>
        <p class="text-muted-foreground leading-relaxed">Every pick on Real Wheel Picker calls <code class="text-xs bg-muted px-1 py-0.5 rounded">window.crypto.getRandomValues()</code>, a browser API defined in the <a href="https://www.w3.org/TR/WebCryptoAPI/" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">W3C Web Cryptography specification</a>. The browser collects entropy from multiple hardware sources — CPU timing variations, mouse movements, disk I/O interrupts — and feeds it into a cryptographically secure pseudorandom number generator (CSPRNG).</p>
        <p class="text-muted-foreground leading-relaxed">The result: each draw is statistically independent. Winning one draw has zero influence on who wins the next. There is no "hot streak" and no way for the operator to predict the outcome before it happens — not even us.</p>
        <p class="text-muted-foreground leading-relaxed">For weighted draws (where some entries have higher odds), we use the Fisher-Yates shuffle algorithm seeded by the crypto API, which guarantees uniform distribution — every entry's probability exactly matches its configured weight, with no rounding artifacts or clustering.</p>
      </section>

      <!-- Values -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">Our Core Values</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {values.map((v) => (
            <div class="bg-card border border-border rounded-xl p-6 space-y-3">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                {v.icon === "shield" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                )}
                {v.icon === "zap" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                )}
                {v.icon === "globe" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                )}
                {v.icon === "heart" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                )}
              </div>
              <h3 class="font-semibold text-foreground">{v.title}</h3>
              <p class="text-sm text-muted-foreground">{v.text}</p>
            </div>
          ))}
        </div>
      </section>

      <AdPlaceholder position="after-use-cases" client:visible />

      <!-- Stats -->
      <section class="bg-primary/5 border border-primary/20 rounded-xl p-6 md:p-8">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center mb-6">Trusted Worldwide</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          {stats.map((s) => (
            <div>
              <div class="text-2xl md:text-3xl font-bold text-primary">{s.val}</div>
              <div class="text-sm text-muted-foreground">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Who Uses -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">Who Uses Real Wheel Picker?</h2>
        <div class="grid md:grid-cols-3 gap-4">
          {users.map((u) => (
            <div class="bg-card border border-border rounded-xl p-5 text-center space-y-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mx-auto" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <h3 class="font-semibold text-foreground">{u.title}</h3>
              <p class="text-xs text-muted-foreground">{u.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">Common Questions</h2>
        <div class="space-y-3">
          {[
            {
              q: "Is the random pick really fair?",
              a: "Yes. Every draw uses the Web Crypto API, which draws entropy from hardware sources inside your device. The outcome cannot be predicted, replayed, or influenced by any external factor — including us. We have no server-side involvement in the draw at all."
            },
            {
              q: "Do you store my participant names?",
              a: "No. Participant names are processed entirely in your browser using JavaScript. If you use the save feature, the data is written to your browser's localStorage — a storage area on your device that we cannot read. Closing your browser or clearing site data removes everything."
            },
            {
              q: "Why is it free?",
              a: "The site is funded by Google AdSense advertising. We believe randomization tools should be a public utility, not a subscription product. Every feature — weighted draws, multiple wheels, the giveaway picker, team generator — is permanently free."
            },
            {
              q: "Can I use this for a real giveaway with legal requirements?",
              a: "Real Wheel Picker is a tool, not a legal service. For giveaways with legal or platform-specific requirements (Instagram, YouTube, etc.), you are responsible for ensuring your draw complies with those rules. We recommend reading the platform's contest guidelines and your local regulations before running a public giveaway."
            },
            {
              q: "How is this different from other wheel spinners?",
              a: "Three things: (1) cryptographic randomness instead of Math.random(), (2) zero data collection — no login, no tracking, nothing stored on our servers, (3) all tools are free with no feature tiers. Most competitors lock weighted draws or CSV import behind a paid plan."
            },
          ].map((item) => (
            <details class="bg-card border border-border rounded-xl p-5 group">
              <summary class="font-semibold text-foreground cursor-pointer flex items-center justify-between gap-3 list-none">
                {item.q}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted-foreground transition-transform group-open:rotate-180" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="mt-3 text-sm text-muted-foreground leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Contact -->
      <section class="bg-card border border-border rounded-xl p-6 md:p-8 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Get in Touch</h2>
        <p class="text-muted-foreground leading-relaxed">Have questions about how our randomness algorithm works? Want to report a bug, suggest a feature, or discuss a partnership? We read every message and respond to most within a few business days.</p>
        <p class="text-muted-foreground leading-relaxed">
          <a href="/contact" class="text-primary hover:underline font-medium">Visit our contact page</a> to reach out directly. We're a small team, but we take user feedback seriously — many of the features on this site came from user suggestions.
        </p>
      </section>

      <!-- CTA -->
      <section class="text-center py-8 space-y-6">
        <h2 class="text-2xl font-bold text-foreground">Ready to run a fair draw?</h2>
        <a href="/" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-xl font-semibold text-lg hover:opacity-90 transition-opacity">
          Start Your Free Draw
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </section>

      <AdPlaceholder position="bottom" client:visible />
    </main>
    <GlobalFooterIsland client:idle />
  </div>
</Layout>
