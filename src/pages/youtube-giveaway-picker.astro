---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "YouTube Giveaway Picker — Free Random Winner Selector | Real Wheel Picker";
const description = "Pick random winners from YouTube comments and subscribers. Record the wheel spin for your next upload. Cryptographically fair, no signup.";

const faqItems = [
  {
    question: "How do I export YouTube comments?",
    answer: "Use browser extensions like YT Comment Export, web tools like Exportcomments.com, or Google Takeout. For smaller videos (under 200 comments), copying manually works too.",
  },
  {
    question: "Can I use this during a YouTube Live stream?",
    answer: "Yes. Open RealWheelPicker in a browser tab, paste the names from chat, and spin live. Your audience watches the draw in real-time. Use OBS or Streamlabs to show the wheel as an overlay.",
  },
  {
    question: "Should I require subscribers to enter?",
    answer: "You can ask, but there's no reliable way to verify subscriber status for each commenter. Most creators use the honor system and spot-check the winner before announcing.",
  },
  {
    question: "Can I include YouTube Shorts comments?",
    answer: "Yes. Shorts comments work the same way. Export or copy them and paste into the picker. Shorts giveaways tend to get higher entry counts due to the format's wider reach.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "YouTube Giveaway Picker — Real Wheel Picker",
  "url": "https://realwheelpicker.com/youtube-giveaway-picker",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<Layout
  title={title}
  description={description}
  canonical="/youtube-giveaway-picker"
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "YouTube Giveaway Picker", url: "https://realwheelpicker.com/youtube-giveaway-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">YouTube Giveaway Picker</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          YouTube Giveaway Picker — Draw Winners on Camera
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Export YouTube comments, spin the wheel on screen, and include the draw in your next upload.
        </p>
        <p class="text-sm text-muted-foreground">Free • No account • Instant result</p>
      </section>

      <!-- How it works -->
      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How Does the YouTube Giveaway Picker Work?</h2>
        <p class="text-muted-foreground leading-relaxed">
          Export the comments from your YouTube video, paste the commenter names into the wheel, and spin to pick a random winner. The selection is cryptographically random and fully transparent — ideal for screen-recording and showing in your next video.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          YouTube audiences are skeptical by default. They've seen too many fake giveaways. The visual wheel spin gives them proof the draw was legitimate, and screen-recording the process lets you include it directly in your announcement video.
        </p>
      </section>

      <!-- Interactive tool -->
      <SEOPageIsland slug="youtube-giveaway-picker" client:load />

      <!-- Step-by-step guide -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Run a YouTube Giveaway</h2>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 1: Announce the Giveaway</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Create a dedicated video or add a segment to your regular upload. Show the prize on camera. State rules clearly: 'Subscribe, like this video, and leave a comment to enter.' Set a deadline. Pin a comment with the full rules.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 2: Export YouTube Comments</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Use YT Comment Export (browser extension), Exportcomments.com (web-based), or Google Takeout. Extract unique commenter display names. Remove your own replies and obvious spam.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 3: Draw on Camera</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Open RealWheelPicker with the name list loaded. Start recording. Show the loaded wheel so viewers can see all names. Spin and react to the result. Include this clip in your next upload or as a Community post.</p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Step 4: Notify the Winner</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">Reply to their comment: 'You won! Check your DMs'. Send a message through YouTube messaging. Set a claim deadline of 72 hours. If no response, draw again on camera and document it.</p>
        </div>
      </section>

      <!-- Use Cases -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">YouTube Giveaway Use Cases</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { emoji: "🎥", title: "Subscriber Milestones", desc: "Celebrate growth with a giveaway" },
            { emoji: "🎁", title: "Comment Giveaways", desc: "Pick winners from video comments" },
            { emoji: "👥", title: "Member Rewards", desc: "Draw prizes for channel members" },
            { emoji: "🏆", title: "Live Stream Draws", desc: "Pick winners during YouTube Live" },
            { emoji: "✨", title: "Channel Growth", desc: "Boost engagement with contests" },
            { emoji: "📱", title: "YouTube Shorts", desc: "Draw from Shorts comment entries" },
          ].map((c) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center hover:scale-105 transition-all hover:border-primary/50">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-3 bg-primary/10 text-2xl">{c.emoji}</div>
              <h3 class="font-semibold text-foreground text-sm mb-1">{c.title}</h3>
              <p class="text-xs text-muted-foreground">{c.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- SEO bottom -->
      <section class="py-8 px-6 rounded-xl border bg-primary/5 border-primary/20 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Free YouTube Giveaway Picker — Draw Winners on Camera</h2>
        <p class="text-muted-foreground leading-relaxed">
          Our YouTube giveaway picker selects random winners from your comment section with cryptographic fairness. Record the wheel spin, include it in your next upload, and give your audience visual proof the draw was real. For live stream giveaways, open the picker alongside OBS.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          For giveaways on other platforms, see our <a href="/instagram-giveaway-picker" class="text-primary hover:underline">Instagram (/instagram-giveaway-picker)</a> and <a href="/tiktok-giveaway-picker" class="text-primary hover:underline">TikTok (/tiktok-giveaway-picker)</a> pickers.
        </p>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/instagram-giveaway-picker", label: "Instagram Giveaway Picker", desc: "Pick random winners from Instagram comments and post the draw to your Story." },
            { href: "/tiktok-giveaway-picker", label: "TikTok Giveaway Picker", desc: "Export TikTok comments and turn the wheel spin into your next viral video." },
            { href: "/twitch-giveaway-picker", label: "Twitch Giveaway Picker", desc: "Draw winners live from Twitch chat with cryptographic fairness." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
