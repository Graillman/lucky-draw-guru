---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import AdPlaceholder from '@/components/AdPlaceholder';
import { ArrowRight, Check } from 'lucide-react';

const title = "Şans Çarkı Online — Ücretsiz Rastgele Çark | Real Wheel Picker";
const description = "Şans çarkını döndür ve anında rastgele bir sonuç al. Seçeneklerini ekle, çevir ve şansa bırak. Ücretsiz, kayıt gerekmez, kriptografik rastgelelik.";
const canonical = "/sans-carki";
const locale = "tr_TR";
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Şans Çarkı Online — Real Wheel Picker",
      "url": "https://realwheelpicker.com/sans-carki",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "description": "Ücretsiz online şans çarkı. window.crypto.getRandomValues() ile anında adil rastgele sonuç.",
      "inLanguage": "tr",
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Şans çarkı gerçekten rastgele mi?",
          "acceptedAnswer": { "@type": "Answer", "text": "Evet. Real Wheel Picker, modern tarayıcıların kriptografik standardı olan window.crypto.getRandomValues() kullanır. Her seçeneğin seçilme olasılığı tam olarak eşittir." },
        },
        {
          "@type": "Question",
          "name": "Çarka kendi seçeneklerimi ekleyebilir miyim?",
          "acceptedAnswer": { "@type": "Answer", "text": "Evet. Herhangi bir etiketin üzerine tıklayarak düzenleyebilirsin. İstediğin kadar seçenek ekleyebilirsin, çark otomatik olarak uyum sağlar." },
        },
      ],
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Şans Çarkı" },
      ],
    },
  ],
};

const defaultParticipants = [
  { pseudo: "Seçenek 1", weight: 1 },
  { pseudo: "Seçenek 2", weight: 1 },
  { pseudo: "Seçenek 3", weight: 1 },
  { pseudo: "Seçenek 4", weight: 1 },
  { pseudo: "Seçenek 5", weight: 1 },
  { pseudo: "Seçenek 6", weight: 1 },
];

const USOS = [
  "Karar vermek — ne yiyeceğini, nereye gideceğini seç",
  "Sosyal medya çekilişleri — Instagram, TikTok, YouTube",
  "Sınıf aktiviteleri — öğrenci seçimi ve görev dağılımı",
  "Parti oyunları — kim başlar, kim görev yapar",
  "Takım kararları — rastgele ve adil atamalar",
  "Her türlü rastgele seçim için",
];
---

<Layout title={title} description={description} canonical={canonical} locale={locale} jsonLd={jsonLd}>
  <div class="relative min-h-screen overflow-hidden" style="background: var(--gradient-bg)">
    <div aria-hidden class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div class="aurora-orb aurora-orb-gold"></div>
      <div class="aurora-orb aurora-orb-purple"></div>
      <div class="aurora-orb aurora-orb-blue"></div>
    </div>
    <div class="relative z-10">
      <HeaderIsland client:load />
      <main class="max-w-5xl mx-auto px-4 py-8 space-y-10">

        <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
          <a href="/" class="hover:text-primary transition-colors">Ana Sayfa</a>
          <span>/</span>
          <span class="text-foreground">Şans Çarkı</span>
        </nav>

        <section class="text-center space-y-4 py-2">
          <h1 class="text-2xl md:text-4xl font-bold text-foreground leading-tight">
            Şans Çarkı Online — Ücretsiz Rastgele Çark Çevir
          </h1>
          <p class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto">
            Karar veremiyorsun? Seçeneklerini ekle, çarkı çevir ve şans karar versin. Ücretsiz, kayıt gerekmez, kriptografik olarak adil.
          </p>
        </section>

        <section class="bg-card border border-border rounded-xl p-5 text-sm text-muted-foreground leading-relaxed">
          <p>
            <strong class="text-foreground">Şans çarkı online:</strong> Seçeneklerini yaz, Çevir düğmesine tıkla ve sonuç <code>window.crypto.getRandomValues()</code> ile belirlenir — her seçenek tam olarak eşit olasılığa sahiptir. Sıfır önyargı, sıfır manipülasyon.
          </p>
        </section>

        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />

        <section class="space-y-4">
          <h2 class="text-xl font-bold text-foreground">Şans çarkı kullanım alanları</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {USOS.map((uso, i) => (
              <li class="flex items-start gap-3 bg-card border border-border rounded-xl p-4">
                <Check className="w-5 h-5 text-primary mt-0.5 shrink-0" />
                <span class="text-sm text-muted-foreground">{uso}</span>
              </li>
            ))}
          </ul>
        </section>

        <AdPlaceholder position="after-use-cases" client:visible />

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Sık sorulan sorular</h2>
          <div class="space-y-3">
            {[
              ["Şans çarkı gerçekten rastgele mi?", "Evet. Tarayıcıların kriptografik standardı olan window.crypto.getRandomValues() kullanıyoruz. Her seçenek tam olarak eşit olasılığa sahip."],
              ["Kendi seçeneklerimi ekleyebilir miyim?", "Evet. Herhangi bir etikete tıklayarak düzenleyebilirsin. İstediğin kadar seçenek ekle."],
              ["Ücretsiz mi?", "Tamamen ücretsiz. Kayıt yok, indirme yok, ödeme yok."],
            ].map(([q, a], i) => (
              <div class="bg-card border border-border rounded-xl p-5">
                <p class="font-semibold text-foreground mb-2">{q}</p>
                <p class="text-muted-foreground">{a}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Diğer araçlar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {[
              { label: "Coin Flip", href: "/coin-flip" },
              { label: "Yes or No Wheel", href: "/yes-or-no-wheel" },
              { label: "Random Decision Maker", href: "/random-decision-maker" },
            ].map((link) => (
              <a href={link.href}
                class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-md transition-all text-sm font-semibold text-foreground">
                {link.label}
              </a>
            ))}
          </div>
        </section>

        <section class="text-center py-6">
          <a href="/" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition-opacity">
            Tam araç <ArrowRight className="w-4 h-4" />
          </a>
        </section>

        <AdPlaceholder position="bottom" client:visible />
      </main>
      <GlobalFooterIsland client:idle />
    </div>
  </div>
</Layout>
