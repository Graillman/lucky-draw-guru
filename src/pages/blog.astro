---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import AdPlaceholder from '@/components/AdPlaceholder';
import BlogHeaderIsland from '@/components/BlogHeaderIsland';

const title = "Blog — Spin the Wheel Guides, Giveaway Tips & Random Picker Tutorials";
const description = "In-depth guides on running giveaways, using random pickers in classrooms, splitting teams fairly, and getting the most from every spin wheel tool.";
const canonical = "/blog";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Real Wheel Picker Blog",
  "description": "Guides on giveaways, random pickers, classroom tools, and team generators.",
  "url": "https://realwheelpicker.com/blog",
  "publisher": { "@type": "Organization", "name": "Real Wheel Picker", "url": "https://realwheelpicker.com" },
};

const posts = [
  { slug: "/blog/how-to-run-instagram-giveaway", title: "How to Run a Fair Instagram Giveaway: Complete 2026 Guide", excerpt: "Step-by-step guide to running a legitimate Instagram giveaway. Learn how to pick a random winner from comments fairly, avoid cheating, and grow your audience.", tag: "Giveaways", readTime: "8 min", date: "Jan 15, 2025" },
  { slug: "/blog/online-giveaway-guide", title: "How to Run a Fair Online Giveaway: Complete Guide for 2026", excerpt: "Everything you need to know to run a legitimate, transparent online giveaway across any platform — with rules, legal requirements, and proven strategies.", tag: "Giveaways", readTime: "12 min", date: "Mar 1, 2025" },
  { slug: "/blog/classroom-random-picker", title: "10 Ways to Use a Random Name Picker in the Classroom", excerpt: "Discover how teachers use random name pickers to improve participation, reduce bias, and create fairer, more engaging learning environments.", tag: "Education", readTime: "7 min", date: "Jan 20, 2025" },
  { slug: "/blog/spin-wheel-team-generator", title: "How to Split Teams Randomly: The Fair Group Generator Guide", excerpt: "Whether it's a gym class, hackathon, or office event — learn how to split groups fairly and why random selection beats every alternative.", tag: "Teams", readTime: "6 min", date: "Feb 1, 2025" },
  { slug: "/blog/weighted-random-picker", title: "Weighted Random Picker: What It Is and When to Use It", excerpt: "Learn what a weighted random picker is, how probability weights work, and 8 real use cases from tiered raffles to sports drafts.", tag: "Tools", readTime: "6 min", date: "Feb 10, 2025" },
  { slug: "/blog/spin-wheel-ideas", title: "50 Creative Spin the Wheel Ideas for Parties, Classes & Events", excerpt: "50 proven spin wheel ideas organized by category — parties, classrooms, work events, social media, and personal life. Copy-paste ready templates.", tag: "Ideas", readTime: "10 min", date: "Feb 15, 2025" },
  { slug: "/blog/tiktok-giveaway-guide", title: "How to Pick a Winner on TikTok: Complete Giveaway Guide 2026", excerpt: "Step-by-step guide to running a fair TikTok giveaway or live draw. Learn how to collect entries, pick a random winner, and stay compliant with TikTok's rules.", tag: "Giveaways", readTime: "8 min", date: "Jul 1, 2025" },
  { slug: "/blog/discord-giveaway-guide", title: "How to Pick a Winner on Discord: Complete Giveaway Guide 2026", excerpt: "Run a fair, transparent Discord giveaway with or without a bot. Step-by-step guide to collecting entries, picking a random winner, and building community trust.", tag: "Giveaways", readTime: "7 min", date: "Aug 1, 2025" },
  { slug: "/blog/youtube-giveaway-guide", title: "How to Pick a Winner on YouTube: Complete Giveaway Guide 2026", excerpt: "Run a fair YouTube giveaway from start to finish. Collect entries from comments, verify eligibility, pick a random winner on camera, and comply with YouTube policies.", tag: "Giveaways", readTime: "7 min", date: "Sep 1, 2025" },
  { slug: "/blog/twitter-giveaway-guide", title: "How to Pick a Winner on Twitter / X: Complete Giveaway Guide 2026", excerpt: "Step-by-step guide to running a fair Twitter or X giveaway. Learn how to collect entries from replies, pick a random winner, and stay compliant with X's rules.", tag: "Giveaways", readTime: "8 min", date: "Oct 1, 2025" },
  { slug: "/blog/facebook-giveaway-guide", title: "How to Pick a Winner on Facebook: Complete Giveaway Guide 2026", excerpt: "Run a fair Facebook giveaway from start to finish. Collect entries from comments, pick a random winner on video, and comply with Facebook's promotion policies.", tag: "Giveaways", readTime: "8 min", date: "Nov 1, 2025" },
  { slug: "/blog/twitch-giveaway-guide", title: "How to Pick a Winner on Twitch: Complete Streamer Guide 2026", excerpt: "Run a fair Twitch giveaway live on stream. Learn how to collect entries from chat, pick a random winner on camera, and follow Twitch's guidelines.", tag: "Giveaways", readTime: "9 min", date: "Dec 1, 2025" },
  { slug: "/blog/reddit-giveaway-guide", title: "How to Pick a Winner on Reddit: Complete Giveaway Guide 2026", excerpt: "Run a fair Reddit giveaway and pick a random winner from post comments. Includes subreddit rules, best practices, and free tools.", tag: "Giveaways", readTime: "9 min", date: "Jan 1, 2026" },
  { slug: "/blog/linkedin-giveaway-guide", title: "How to Pick a Winner on LinkedIn: Complete Giveaway Guide 2026", excerpt: "Run a professional LinkedIn giveaway and pick a random winner from post comments. B2B strategies, LinkedIn rules, and free tools.", tag: "Giveaways", readTime: "8 min", date: "Feb 1, 2026" },
  { slug: "/blog/snapchat-giveaway-guide", title: "How to Pick a Winner on Snapchat: Giveaway Guide 2026", excerpt: "Step-by-step guide to running a fair Snapchat giveaway. Collect entries from Stories and DMs, pick a random winner on camera, and stay compliant.", tag: "Giveaways", readTime: "7 min", date: "Mar 2, 2026" },
  { slug: "/blog/secret-santa-guide", title: "How to Run a Secret Santa Online: Complete 2026 Guide", excerpt: "Organize a Secret Santa gift exchange for offices, families, or friend groups. Pick names randomly, prevent self-assignment, and keep everything a surprise.", tag: "Ideas", readTime: "7 min", date: "Mar 2, 2026" },
  { slug: "/blog/best-random-picker-tools", title: "Best Free Random Picker Tools in 2026: Full Comparison", excerpt: "Unbiased comparison of the top spinning wheel tools: Real Wheel Picker vs Wheel of Names vs Picker Wheel vs Random.org. Features, randomness, and verdict.", tag: "Tools", readTime: "9 min", date: "Mar 2, 2026" },
];

const featured = posts[0];
const rest = posts.slice(1);
---

<Layout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <div style="background: var(--gradient-bg)">
    <HeaderIsland client:load />
    <main class="max-w-4xl mx-auto px-4 py-10 space-y-10">

      <BlogHeaderIsland featured={featured} rest={rest} client:load />

      <AdPlaceholder position="after-winners" client:visible />
      <AdPlaceholder position="bottom" client:visible />
    </main>
    <GlobalFooterIsland client:idle />
  </div>
</Layout>
