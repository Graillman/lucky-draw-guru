---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SimpleWheelIsland from '@/components/SimpleWheelIsland';
import AdPlaceholder from '@/components/AdPlaceholder';
import { ArrowRight, Check } from 'lucide-react';

const title = "Roue des noms en ligne gratuite — Choisir un prénom au hasard | Real Wheel Picker";
const description = "Roue des noms gratuite : entrez des prénoms, faites tourner la roue et obtenez un nom aléatoire. Idéal pour les enseignants, animateurs et organisateurs de concours.";
const canonical = "/roue-des-noms";
const locale = "fr_FR";
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Roue des noms — Real Wheel Picker",
      "url": "https://realwheelpicker.com/roue-des-noms",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "isAccessibleForFree": true,
      "inLanguage": "fr",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Comment utiliser la roue des noms en classe ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Entrez la liste des prénoms de vos élèves, projetez la roue sur le tableau interactif ou le vidéoprojecteur, puis cliquez sur 'Lancer'. Le mode plein écran est parfait pour les présentations en classe.",
          },
        },
        {
          "@type": "Question",
          "name": "La roue des noms est-elle gratuite ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Oui, entièrement gratuite, sans inscription, sans limite de participants. Ajoutez autant de noms que vous voulez.",
          },
        },
      ],
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://realwheelpicker.com/" },
        { "@type": "ListItem", "position": 2, "name": "Roue des noms" },
      ],
    },
  ],
};

const defaultParticipants = [
  { pseudo: "Léa", weight: 1 },
  { pseudo: "Lucas", weight: 1 },
  { pseudo: "Manon", weight: 1 },
  { pseudo: "Noah", weight: 1 },
  { pseudo: "Inès", weight: 1 },
  { pseudo: "Théo", weight: 1 },
  { pseudo: "Chloé", weight: 1 },
  { pseudo: "Ethan", weight: 1 },
  { pseudo: "Camille", weight: 1 },
  { pseudo: "Jules", weight: 1 },
];

const USES = [
  "Appeler un élève au hasard en classe",
  "Désigner un volontaire dans un groupe",
  "Choisir qui commence un jeu ou une activité",
  "Organiser un Secret Santa entre amis ou collègues",
  "Sélectionner un participant pour un concours",
  "Décider de l'ordre de passage pour des présentations",
];
---

<Layout title={title} description={description} canonical={canonical} locale={locale} jsonLd={jsonLd}>
  <div class="relative min-h-screen overflow-hidden" style="background: var(--gradient-bg)">
    <div aria-hidden class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div class="aurora-orb aurora-orb-gold"></div>
      <div class="aurora-orb aurora-orb-purple"></div>
      <div class="aurora-orb aurora-orb-blue"></div>
    </div>
    <div class="relative z-10">
      <HeaderIsland client:load />
      <main class="max-w-5xl mx-auto px-4 py-8 space-y-10">

        {/* Breadcrumb */}
        <nav aria-label="fil d'Ariane" class="text-xs text-muted-foreground flex gap-1">
          <a href="/" class="hover:text-primary transition-colors">Accueil</a>
          <span>/</span>
          <span class="text-foreground">Roue des noms</span>
        </nav>

        {/* Hero */}
        <section class="text-center space-y-4 py-2">
          <h1 class="text-2xl md:text-4xl font-bold text-foreground leading-tight">
            Roue des noms en ligne — Gratuite et instantanée
          </h1>
          <p class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto">
            Entrez des prénoms, faites tourner la roue et laissez le hasard choisir.
            Parfait pour les enseignants, les animateurs, les organisateurs de concours. Gratuit, sans inscription.
          </p>
        </section>

        <SimpleWheelIsland defaultParticipants={defaultParticipants} client:load />

        {/* Cas d'usage */}
        <section class="space-y-4">
          <h2 class="text-xl font-bold text-foreground">Pourquoi utiliser une roue des noms ?</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {USES.map((use, i) => (
              <li class="flex items-start gap-3 bg-card border border-border rounded-xl p-4">
                <Check className="w-5 h-5 text-primary mt-0.5 shrink-0" />
                <span class="text-sm text-muted-foreground">{use}</span>
              </li>
            ))}
          </ul>
        </section>

        <AdPlaceholder position="after-use-cases" client:visible />

        {/* SEO text */}
        <section class="bg-card border border-border rounded-xl p-6 space-y-3">
          <h2 class="text-xl font-bold text-foreground">La roue des noms : l'outil des enseignants et animateurs</h2>
          <p class="text-muted-foreground leading-relaxed">
            La roue des noms est devenue un incontournable dans les classes, les animations et les concours en ligne. En visualisant la sélection aléatoire — regarder la roue tourner, ralentir, s'arrêter — vous créez un moment de suspense partagé qui renforce l'engagement et la confiance dans le résultat.
          </p>
          <p class="text-muted-foreground leading-relaxed">
            Real Wheel Picker propose une <strong>roue des noms en ligne gratuite</strong> sans limite de participants. Le mode plein écran est idéal pour les présentations sur vidéoprojecteur. La fonction « retirer le gagnant et relancer » permet de faire des tirages en cascade sans qu'un participant ne soit tiré deux fois — pratique pour les sondages en classe ou les tours de parole.
          </p>
        </section>

        {/* Liens internes français */}
        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Outils similaires en français</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {[
              { label: "Tirage au sort en ligne", href: "/tirage-au-sort" },
              { label: "Tirage aléatoire", href: "/tirage-aleatoire" },
              { label: "Roue de la fortune", href: "/wheel/food" },
            ].map((link) => (
              <a
                href={link.href}
                class="p-4 bg-card border border-border rounded-xl text-center hover:border-primary/50 hover:shadow-md transition-all text-sm font-semibold text-foreground"
              >
                {link.label}
              </a>
            ))}
          </div>
        </section>

        {/* FAQ */}
        <section class="space-y-3">
          <h2 class="text-xl font-bold text-foreground">Questions fréquentes</h2>
          <div class="space-y-3">
            {[
              ["Comment utiliser la roue des noms en classe ?",
               "Entrez la liste des prénoms, activez le mode plein écran et projetez la roue. Cliquez pour lancer et votre classe verra le résultat en direct."],
              ["Puis-je ajouter autant de noms que je veux ?",
               "Oui, sans limite. La roue s'adapte automatiquement : les segments se réduisent et le texte se redimensionne. Pour les grandes listes, vous pouvez aussi assigner des poids différents à chaque participant."],
              ["La roue des noms est-elle utilisable sur mobile ?",
               "Oui, entièrement responsive. Fonctionne sur iPhone, Android, tablette et ordinateur sans application à télécharger."],
            ].map(([q, a], i) => (
              <div class="bg-card border border-border rounded-xl p-5">
                <p class="font-semibold text-foreground mb-2">{q}</p>
                <p class="text-muted-foreground">{a}</p>
              </div>
            ))}
          </div>
        </section>

        {/* CTA */}
        <section class="text-center py-6 space-y-4">
          <p class="text-muted-foreground">Accédez au mode concours, aux tirages pondérés et aux multi-gagnants.</p>
          <a
            href="/"
            class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition-opacity"
          >
            Toutes les fonctionnalités <ArrowRight className="w-4 h-4" />
          </a>
        </section>

        <AdPlaceholder position="bottom" client:visible />
      </main>
      <GlobalFooterIsland client:idle />
    </div>
  </div>
</Layout>
