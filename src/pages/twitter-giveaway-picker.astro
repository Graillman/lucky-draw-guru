---
import Layout from '@/layouts/Layout.astro';
import HeaderIsland from '@/components/HeaderIsland';
import GlobalFooterIsland from '@/components/GlobalFooterIsland';
import SEOPageIsland from '@/components/SEOPageIsland';
import SchemaFAQ from '@/components/SchemaFAQ.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';

const title = "Twitter / X Giveaway Picker — Free RT to Win Selector | Real Wheel Picker";
const description = "Pick winners from Twitter/X retweets, replies, and quote tweets. Screen-record the wheel spin as proof. Cryptographically fair, no signup.";

const faqItems = [
  {
    question: "How do I export people who retweeted my tweet?",
    answer: "Twitter/X doesn't provide a native export. Use third-party tools like Phantombuster, or manually copy handles from the retweet list. For very large giveaways, the Twitter API v2 retweet lookup endpoint is the most reliable method.",
  },
  {
    question: "Should I require follow + RT or just RT?",
    answer: "Follow + RT is standard. Requiring both ensures the winner is actually part of your audience. RT-only giveaways tend to attract giveaway account farms.",
  },
  {
    question: "How do I avoid bot entries?",
    answer: "Look for accounts with no profile picture, no bio, very few tweets, or handles with long random number strings. Remove these before drawing. A quick scroll through the RT list usually reveals the obvious bots.",
  },
  {
    question: "Can I use this for Twitter/X Spaces giveaways?",
    answer: "Yes. During a Space, note or export listener names. After the Space, paste them into the picker and draw. You can also spin live by screen-sharing during the Space.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Twitter / X Giveaway Picker — Real Wheel Picker",
  "url": "https://realwheelpicker.com/twitter-giveaway-picker",
  "description": description,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<Layout
  title={title}
  description={description}
  canonical="/twitter-giveaway-picker"
  jsonLd={jsonLd}
>
  <SchemaFAQ items={faqItems} />
  <SchemaBreadcrumb items={[
    { name: "Home", url: "https://realwheelpicker.com" },
    { name: "Twitter/X Giveaway Picker", url: "https://realwheelpicker.com/twitter-giveaway-picker" },
  ]} />

  <div class="min-h-screen" style="background: var(--gradient-bg)">
    <HeaderIsland client:load />

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10 md:space-y-14">

      <!-- Breadcrumb -->
      <nav aria-label="breadcrumb" class="text-xs text-muted-foreground flex gap-1">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>/</span>
        <span class="text-foreground">Twitter/X Giveaway Picker</span>
      </nav>

      <!-- Hero -->
      <section class="text-center space-y-4 py-2 md:py-6">
        <h1 class="text-3xl md:text-5xl font-bold text-foreground leading-tight">
          Twitter / X Giveaway Picker — Fair RT to Win Draws
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Collect entries from retweets, replies, or quote tweets. Screen-record the wheel spin as verifiable proof of fairness.
        </p>
        <p class="text-sm text-muted-foreground">Free • No signup • Cryptographic fairness</p>
      </section>

      <!-- How it works -->
      <section class="p-6 rounded-xl border bg-primary/5 border-primary/30 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How Does the Twitter/X Giveaway Picker Work?</h2>
        <p class="text-muted-foreground leading-relaxed">
          Collect your giveaway entries from Twitter/X — retweets, replies, or quote tweets — paste the handles into the wheel, and spin to select a random winner. Cryptographic randomness ensures the draw is fair and impossible to manipulate.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Twitter/X giveaways ('RT to win' style) have been a staple of social media marketing for over a decade. The challenge has always been trust: nobody can see how the winner was selected. Our visual wheel fixes that — record the spin, post the clip, and let your followers see the draw happen.
        </p>
      </section>

      <!-- Interactive tool -->
      <SEOPageIsland slug="twitter-giveaway-picker" client:load />

      <!-- Step-by-step guide -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">How to Run a Twitter/X Giveaway</h2>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Setting Up the Giveaway</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Post your giveaway tweet with: clear prize description, entry method (Follow + RT or Reply with something), deadline (date, time, timezone), winner announcement date.
          </p>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Effective formats: 'RT + Follow to win [prize]. Winner drawn [date].' — simple, high participation.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Collecting Entries</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            For retweets: Twitter/X doesn't let you easily export who retweeted. Use Phantombuster or manually click the RT count and scroll through. For replies: scroll through the reply thread and copy handles.
          </p>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Clean the list: remove duplicates and obvious bot accounts.
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-card border-border space-y-3">
          <h3 class="text-lg font-bold text-foreground">Drawing and Announcing</h3>
          <ol class="space-y-2 text-sm text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span><span>Paste handles into RealWheelPicker</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span><span>Screen-record the wheel spin</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span><span>Post the recording as a reply to your original giveaway tweet</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">4.</span><span>Tag the winner: 'Congrats @winner! DM me to claim your prize.'</span></li>
            <li class="flex gap-3"><span class="text-primary font-bold">5.</span><span>DM them directly as backup</span></li>
          </ol>
        </div>
      </section>

      <!-- Use Cases -->
      <section class="space-y-6">
        <h2 class="text-xl md:text-2xl font-bold text-foreground text-center">Twitter/X Giveaway Use Cases</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {[
            { emoji: "🎁", title: "Retweet Giveaways", desc: "Pick winners from RT participants" },
            { emoji: "👥", title: "Reply Contests", desc: "Select from reply-to-enter participants" },
            { emoji: "🎥", title: "Quote Tweet Draws", desc: "Draw from quote tweet entrants" },
            { emoji: "🏆", title: "Follower Rewards", desc: "Reward your follower community" },
            { emoji: "✨", title: "Brand Campaigns", desc: "Transparent promotional draws" },
            { emoji: "📡", title: "Twitter Spaces", desc: "Live draws during Spaces sessions" },
          ].map((c) => (
            <div class="p-4 rounded-xl bg-card border border-border text-center hover:scale-105 transition-all hover:border-primary/50">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-3 bg-primary/10 text-2xl">{c.emoji}</div>
              <h3 class="font-semibold text-foreground text-sm mb-1">{c.title}</h3>
              <p class="text-xs text-muted-foreground">{c.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(({ question, answer }) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <p class="font-semibold text-foreground mb-2">{question}</p>
              <p class="text-muted-foreground text-sm leading-relaxed">{answer}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- SEO bottom -->
      <section class="py-8 px-6 rounded-xl border bg-primary/5 border-primary/20 space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Free Twitter/X Giveaway Picker — Fair RT to Win Draws</h2>
        <p class="text-muted-foreground leading-relaxed">
          Our Twitter giveaway picker selects random winners from your retweets, replies, or quote tweets. Screen-record the visual wheel spin and share it as proof of a fair draw.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          Works for RT to win campaigns, reply-to-enter contests, and Twitter Spaces giveaways. For other platforms, see our <a href="/instagram-giveaway-picker" class="text-primary hover:underline">Instagram</a> and <a href="/facebook-giveaway-picker" class="text-primary hover:underline">Facebook</a> pickers.
        </p>
      </section>

      <!-- Related Tools -->
      <section class="space-y-4">
        <h2 class="text-xl md:text-2xl font-bold text-foreground">Related Tools</h2>
        <ul class="space-y-3">
          {[
            { href: "/instagram-giveaway-picker", label: "Instagram Giveaway Picker", desc: "Pick winners from Instagram post comments and story mentions." },
            { href: "/facebook-giveaway-picker", label: "Facebook Giveaway Picker", desc: "Draw random winners from Facebook post comments and group members." },
            { href: "/giveaway-picker", label: "Giveaway Picker", desc: "Universal giveaway picker for any platform or contest." },
          ].map(({ href, label, desc }) => (
            <li>
              <a
                href={href}
                class="flex items-start gap-3 p-4 bg-card border border-border rounded-xl hover:border-primary/50 hover:shadow-md transition-all"
              >
                <span class="text-primary font-bold text-sm mt-0.5">→</span>
                <span>
                  <span class="font-semibold text-foreground">{label}</span>
                  <span class="text-muted-foreground text-sm"> — {desc}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </main>

    <GlobalFooterIsland client:idle />
  </div>
</Layout>
