---
interface HowToStep {
  name: string;
  text: string;
}

interface Props {
  name: string;
  description: string;
  steps: HowToStep[];
}

const { name, description, steps } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": name,
  "description": description,
  "step": steps.map((step, index) => ({
    "@type": "HowToStep",
    "position": index + 1,
    "name": step.name,
    "text": step.text
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
